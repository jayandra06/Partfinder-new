<UserControl
    x:Class="PartFinder.Views.Components.KpiCard"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:viewModels="using:PartFinder.ViewModels">

    <UserControl.Resources>
        <!-- Entrance animation -->
        <Storyboard x:Key="EntranceSb">
            <DoubleAnimation Storyboard.TargetName="RootBorder" Storyboard.TargetProperty="Opacity"
                             From="0" To="1" Duration="0:0:0.35">
                <DoubleAnimation.EasingFunction><ExponentialEase EasingMode="EaseOut" Exponent="4"/></DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="SlideTransform" Storyboard.TargetProperty="Y"
                             From="14" To="0" Duration="0:0:0.35">
                <DoubleAnimation.EasingFunction><ExponentialEase EasingMode="EaseOut" Exponent="4"/></DoubleAnimation.EasingFunction>
            </DoubleAnimation>

            <!-- Icon floating animation (perpetual gentle bob) -->
            <DoubleAnimation Storyboard.TargetName="IconFloatTransform" Storyboard.TargetProperty="Y"
                             From="0" To="-3.5" Duration="0:0:2"
                             BeginTime="0:0:0.5"
                             AutoReverse="True" RepeatBehavior="Forever">
                <DoubleAnimation.EasingFunction><SineEase EasingMode="EaseInOut"/></DoubleAnimation.EasingFunction>
            </DoubleAnimation>

            <!-- Accent bar shimmer: opacity pulse -->
            <DoubleAnimation Storyboard.TargetName="AccentBar" Storyboard.TargetProperty="Opacity"
                             From="0.5" To="1" Duration="0:0:2.5"
                             BeginTime="0:0:0.6"
                             AutoReverse="True" RepeatBehavior="Forever">
                <DoubleAnimation.EasingFunction><SineEase EasingMode="EaseInOut"/></DoubleAnimation.EasingFunction>
            </DoubleAnimation>

            <!-- Accent bar shimmer: width pulse -->
            <DoubleAnimation Storyboard.TargetName="AccentBar" Storyboard.TargetProperty="Width"
                             From="32" To="56" Duration="0:0:3"
                             BeginTime="0:0:0.6"
                             AutoReverse="True" RepeatBehavior="Forever">
                <DoubleAnimation.EasingFunction><SineEase EasingMode="EaseInOut"/></DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>
        <!-- Warning pulse -->
        <Storyboard x:Key="PulseSb" RepeatBehavior="Forever" AutoReverse="True">
            <DoubleAnimation Storyboard.TargetName="AlertGlow" Storyboard.TargetProperty="Opacity"
                             From="0" To="0.18" Duration="0:0:1.2">
                <DoubleAnimation.EasingFunction><SineEase EasingMode="EaseInOut"/></DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>
    </UserControl.Resources>

    <Border x:Name="RootBorder"
            Background="{StaticResource CardBackgroundBrush}"
            BorderBrush="{StaticResource BorderDefaultBrush}"
            BorderThickness="1"
            CornerRadius="12"
            Padding="16,14"
            Margin="0,0,10,0"
            Opacity="0"
            Translation="0,0,16">

        <Border.Shadow>
            <ThemeShadow/>
        </Border.Shadow>

        <Border.RenderTransform>
            <TranslateTransform x:Name="SlideTransform" Y="14"/>
        </Border.RenderTransform>

        <!-- Outer Grid: stacks alert glow behind content -->
        <Grid>
            <!-- Alert glow overlay (sits behind content, animated opacity) -->
            <Border x:Name="AlertGlow"
                    CornerRadius="12"
                    Opacity="0"
                    IsHitTestVisible="False"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Stretch">
                <Border.Background>
                    <SolidColorBrush x:Name="AlertGlowBrush" Color="#FFB781"/>
                </Border.Background>
            </Border>

            <!-- Glassmorphism top-edge highlight -->
            <Border CornerRadius="12,12,0,0" Height="1" VerticalAlignment="Top"
                    IsHitTestVisible="False" Opacity="0.07"
                    Background="White" Margin="1,0,1,0"/>

            <!-- Card content -->
            <Grid RowSpacing="6">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="4"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Label -->
                <TextBlock Grid.Row="0"
                           Text="{x:Bind Label, Mode=OneWay}"
                           FontSize="10"
                           Foreground="{StaticResource TextTertiaryBrush}"
                           CharacterSpacing="60"
                           FontWeight="SemiBold"/>

                <!-- Icon circle -->
                <Border x:Name="IconCircle"
                        Grid.Row="0" Grid.Column="1"
                        Grid.RowSpan="2"
                        Width="36" Height="36"
                        CornerRadius="18"
                        VerticalAlignment="Top">
                    <Border.RenderTransform>
                        <TranslateTransform x:Name="IconFloatTransform"/>
                    </Border.RenderTransform>
                    <FontIcon x:Name="CardIcon"
                              FontSize="15"
                              Foreground="{StaticResource AccentPrimaryBrush}"/>
                </Border>

                <!-- Value -->
                <TextBlock Grid.Row="1"
                           Text="{x:Bind Value, Mode=OneWay}"
                           FontSize="26"
                           FontWeight="Bold"
                           Foreground="{StaticResource TextPrimaryBrush}"/>

                <!-- Delta badge -->
                <Border x:Name="DeltaBadge"
                        Grid.Row="2"
                        HorizontalAlignment="Left"
                        CornerRadius="6"
                        Padding="7,3"
                        Background="#102ABD8F">
                    <TextBlock x:Name="DeltaText"
                               Text="{x:Bind Delta, Mode=OneWay}"
                               FontSize="10"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource SuccessBrush}"/>
                </Border>

                <!-- Bottom accent bar -->
                <Border x:Name="AccentBar"
                        Grid.Row="3" Grid.ColumnSpan="2"
                        Height="3" CornerRadius="2"
                        HorizontalAlignment="Left" Width="32"
                        Background="{StaticResource AccentPrimaryBrush}"
                        Margin="0,2,0,0"/>
            </Grid>
        </Grid>
    </Border>
</UserControl>
