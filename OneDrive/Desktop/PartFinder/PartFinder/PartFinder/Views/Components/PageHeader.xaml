<UserControl
    x:Class="PartFinder.Views.Components.PageHeader"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="0,0,0,16">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>
        <StackPanel>
            <TextBlock Text="{x:Bind Title, Mode=OneWay}" Style="{ThemeResource AppTitleTextStyle}" />
            <TextBlock Text="{x:Bind Subtitle, Mode=OneWay}" Foreground="{ThemeResource AppSubtleTextBrush}" />
        </StackPanel>
        <ContentPresenter Grid.Column="1" Content="{x:Bind Actions, Mode=OneWay}" />
    </Grid>
</UserControl>
