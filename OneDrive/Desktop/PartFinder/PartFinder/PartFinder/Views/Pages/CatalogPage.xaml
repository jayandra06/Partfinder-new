<Page
    x:Class="PartFinder.Views.Pages.CatalogPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Background="{StaticResource PageBackgroundBrush}">
        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <StackPanel Padding="24,20,24,32" Spacing="18" HorizontalAlignment="Stretch">
                <StackPanel.ChildrenTransitions>
                    <TransitionCollection>
                        <EntranceThemeTransition IsStaggeringEnabled="True" FromVerticalOffset="50" />
                    </TransitionCollection>
                </StackPanel.ChildrenTransitions>

                <!-- HEADER -->
                <Grid ColumnSpacing="12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Spacing="2">
                        <TextBlock Text="CATALOG" FontSize="10" Foreground="{StaticResource AccentPrimaryBrush}" CharacterSpacing="100" FontWeight="SemiBold" />
                        <TextBlock Text="Parts Catalog" FontSize="32" FontWeight="Light" CharacterSpacing="20" />
                        <TextBlock Text="Browse, search, and compare parts with advanced filtering and specifications." FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" />
                    </StackPanel>
                    <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                        <Button Style="{StaticResource OutlinedButtonStyle}" FontSize="12" Click="OnCompareClick">
                            <StackPanel Orientation="Horizontal" Spacing="5">
                                <FontIcon Glyph="&#xE71E;" FontSize="13" />
                                <TextBlock Text="Compare" FontSize="12" />
                            </StackPanel>
                        </Button>
                        <Button Style="{StaticResource PrimaryButtonStyle}" FontSize="12" Click="OnAddPartClick">
                            <StackPanel Orientation="Horizontal" Spacing="5">
                                <FontIcon Glyph="&#xE710;" FontSize="13" />
                                <TextBlock Text="Add Part" FontSize="12" />
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Grid>

                <!-- ADVANCED SEARCH -->
                <Border Background="{StaticResource CardBackgroundBrush}" BorderBrush="{StaticResource BorderDefaultBrush}" BorderThickness="1" CornerRadius="4" Padding="16,14" Translation="0,0,32">
                            <Border.Shadow><ThemeShadow/></Border.Shadow>
                            <StackPanel Spacing="12">
        <TextBlock Text="Advanced Search &amp; Filters" FontSize="13" FontWeight="SemiBold" />

                        <!-- Search Bar -->
                        <Border Background="{StaticResource ElevatedCardBackgroundBrush}" CornerRadius="8" Padding="10,0" BorderBrush="{StaticResource BorderDefaultBrush}" BorderThickness="1">
                            <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                <FontIcon Glyph="&#xE721;" FontSize="13" Foreground="{StaticResource TextTertiaryBrush}" />
                                <TextBox BorderThickness="0" Background="Transparent" PlaceholderText="Search by part name, ID, or specifications..." FontSize="12" VerticalAlignment="Center" HorizontalAlignment="Stretch" />
                            </StackPanel>
                        </Border>

                        <!-- Filter Grid -->
                        <Grid ColumnSpacing="10" RowSpacing="10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <ComboBox FontSize="11" PlaceholderText="Category" HorizontalAlignment="Stretch">
                                <ComboBoxItem Content="Engine Parts" />
                                <ComboBoxItem Content="Fuel Systems" />
                                <ComboBoxItem Content="Valve Systems" />
                                <ComboBoxItem Content="Cooling" />
                                <ComboBoxItem Content="Electrical" />
                            </ComboBox>
                            <ComboBox Grid.Column="1" FontSize="11" PlaceholderText="Supplier" HorizontalAlignment="Stretch">
                                <ComboBoxItem Content="Global Parts Inc" />
                                <ComboBoxItem Content="Premium Motors" />
                                <ComboBoxItem Content="Tech Components" />
                            </ComboBox>
                            <ComboBox Grid.Column="2" FontSize="11" PlaceholderText="Condition" HorizontalAlignment="Stretch">
                                <ComboBoxItem Content="New" />
                                <ComboBoxItem Content="Refurbished" />
                                <ComboBoxItem Content="Used" />
                            </ComboBox>
                            <ComboBox Grid.Column="3" FontSize="11" PlaceholderText="Availability" HorizontalAlignment="Stretch">
                                <ComboBoxItem Content="In Stock" />
                                <ComboBoxItem Content="Low Stock" />
                                <ComboBoxItem Content="Out of Stock" />
                            </ComboBox>
                        </Grid>

                        <!-- Price Range & More Filters -->
                        <Grid ColumnSpacing="10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <StackPanel Spacing="4">
                                <TextBlock Text="Price Range" FontSize="10" Foreground="{StaticResource TextTertiaryBrush}" />
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <TextBox PlaceholderText="Min" FontSize="11" MinWidth="80" />
                                    <TextBlock Text="-" VerticalAlignment="Center" />
                                    <TextBox PlaceholderText="Max" FontSize="11" MinWidth="80" />
                                </StackPanel>
                            </StackPanel>

                            <StackPanel Grid.Column="1" Spacing="4">
                                <TextBlock Text="Stock Status" FontSize="10" Foreground="{StaticResource TextTertiaryBrush}" />
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <CheckBox Content="In Stock" FontSize="11" />
                                    <CheckBox Content="Low Stock" FontSize="11" />
                                </StackPanel>
                            </StackPanel>

                            <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="6" VerticalAlignment="Bottom">
                                <Button Style="{StaticResource PrimaryButtonStyle}" Padding="12,8" FontSize="11">Search</Button>
                                <Button Style="{StaticResource OutlinedButtonStyle}" Padding="12,8" FontSize="11">Reset</Button>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- RESULTS SUMMARY -->
                <Grid ColumnSpacing="12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Showing 1,248 parts" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center" />
                    <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
                        <ComboBox MinWidth="120" FontSize="11" PlaceholderText="Sort by" />
                        <Button Style="{StaticResource GhostButtonStyle}" Padding="8,4" FontSize="11">
                            <FontIcon Glyph="&#xE71E;" FontSize="13" />
                        </Button>
                    </StackPanel>
                </Grid>

                <!-- PARTS GRID -->
                <Grid ColumnSpacing="14" RowSpacing="14">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <!-- Part Card 1 -->
                    <Border Grid.Column="0" Background="{StaticResource CardBackgroundBrush}" BorderBrush="{StaticResource BorderDefaultBrush}" BorderThickness="1" CornerRadius="4" Padding="14" Translation="0,0,32">
                            <Border.Shadow><ThemeShadow/></Border.Shadow>
                            <StackPanel Spacing="10">
                            <Border Height="140" Background="{StaticResource ElevatedCardBackgroundBrush}" CornerRadius="8">
                                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="4">
                                    <FontIcon Glyph="&#xE946;" FontSize="32" Foreground="{StaticResource AccentPrimaryBrush}" HorizontalAlignment="Center" />
                                    <TextBlock Text="Part Image" FontSize="10" Foreground="{StaticResource TextTertiaryBrush}" HorizontalAlignment="Center" />
                                </StackPanel>
                            </Border>

                            <StackPanel Spacing="2">
                                <TextBlock Text="Turbocharger Assembly" FontSize="12" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                                <TextBlock Text="TRB-2024-001" FontSize="10" Foreground="{StaticResource TextTertiaryBrush}" />
                            </StackPanel>

                            <StackPanel Spacing="4">
                                <Grid ColumnSpacing="8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="$1,250.00" FontSize="13" FontWeight="SemiBold" />
                                    <Border CornerRadius="4" Padding="4,2" Background="#102ABD8F">
                                        <TextBlock Text="In Stock" FontSize="9" Foreground="{StaticResource SuccessBrush}" FontWeight="SemiBold" />
                                    </Border>
                                </Grid>

                                <TextBlock Text="156 units available" FontSize="10" Foreground="{StaticResource TextSecondaryBrush}" />
                            </StackPanel>

                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <Button Style="{StaticResource OutlinedButtonStyle}" Width="80" FontSize="11" Padding="8,6" Click="OnViewPartClick">
                                    <StackPanel Orientation="Horizontal" Spacing="4" HorizontalAlignment="Center">
                                        <FontIcon Glyph="&#xE70F;" FontSize="11" />
                                        <TextBlock Text="View" FontSize="11" />
                                    </StackPanel>
                                </Button>
                                <Button Style="{StaticResource PrimaryButtonStyle}" Width="80" FontSize="11" Padding="8,6" Click="OnAddPartClick">
                                    <StackPanel Orientation="Horizontal" Spacing="4" HorizontalAlignment="Center">
                                        <FontIcon Glyph="&#xE710;" FontSize="11" />
                                        <TextBlock Text="Add" FontSize="11" />
                                    </StackPanel>
                                </Button>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- Part Card 2 -->
                    <Border Grid.Column="1" Background="{StaticResource CardBackgroundBrush}" BorderBrush="{StaticResource BorderDefaultBrush}" BorderThickness="1" CornerRadius="4" Padding="14" Translation="0,0,32">
                            <Border.Shadow><ThemeShadow/></Border.Shadow>
                            <StackPanel Spacing="10">
                            <Border Height="140" Background="{StaticResource ElevatedCardBackgroundBrush}" CornerRadius="8">
                                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="4">
                                    <FontIcon Glyph="&#xE946;" FontSize="32" Foreground="{StaticResource WarningBrush}" HorizontalAlignment="Center" />
                                    <TextBlock Text="Part Image" FontSize="10" Foreground="{StaticResource TextTertiaryBrush}" HorizontalAlignment="Center" />
                                </StackPanel>
                            </Border>

                            <StackPanel Spacing="2">
                                <TextBlock Text="Fuel Injector" FontSize="12" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                                <TextBlock Text="FUL-2024-045" FontSize="10" Foreground="{StaticResource TextTertiaryBrush}" />
                            </StackPanel>

                            <StackPanel Spacing="4">
                                <Grid ColumnSpacing="8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="$450.00" FontSize="13" FontWeight="SemiBold" />
                                    <Border CornerRadius="4" Padding="4,2" Background="#10FEBC2E">
                                        <TextBlock Text="Low Stock" FontSize="9" Foreground="{StaticResource WarningBrush}" FontWeight="SemiBold" />
                                    </Border>
                                </Grid>

                                <TextBlock Text="23 units available" FontSize="10" Foreground="{StaticResource TextSecondaryBrush}" />
                            </StackPanel>

                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <Button Style="{StaticResource OutlinedButtonStyle}" Width="80" FontSize="11" Padding="8,6" Click="OnViewPartClick">
                                    <StackPanel Orientation="Horizontal" Spacing="4" HorizontalAlignment="Center">
                                        <FontIcon Glyph="&#xE70F;" FontSize="11" />
                                        <TextBlock Text="View" FontSize="11" />
                                    </StackPanel>
                                </Button>
                                <Button Style="{StaticResource PrimaryButtonStyle}" Width="80" FontSize="11" Padding="8,6" Click="OnAddPartClick">
                                    <StackPanel Orientation="Horizontal" Spacing="4" HorizontalAlignment="Center">
                                        <FontIcon Glyph="&#xE710;" FontSize="11" />
                                        <TextBlock Text="Add" FontSize="11" />
                                    </StackPanel>
                                </Button>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- Part Card 3 -->
                    <Border Grid.Column="2" Background="{StaticResource CardBackgroundBrush}" BorderBrush="{StaticResource BorderDefaultBrush}" BorderThickness="1" CornerRadius="4" Padding="14" Translation="0,0,32">
                            <Border.Shadow><ThemeShadow/></Border.Shadow>
                            <StackPanel Spacing="10">
                            <Border Height="140" Background="{StaticResource ElevatedCardBackgroundBrush}" CornerRadius="8">
                                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="4">
                                    <FontIcon Glyph="&#xE946;" FontSize="32" Foreground="{StaticResource DangerBrush}" HorizontalAlignment="Center" />
                                    <TextBlock Text="Part Image" FontSize="10" Foreground="{StaticResource TextTertiaryBrush}" HorizontalAlignment="Center" />
                                </StackPanel>
                            </Border>

                            <StackPanel Spacing="2">
                                <TextBlock Text="Valve Assembly" FontSize="12" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                                <TextBlock Text="VAL-2024-089" FontSize="10" Foreground="{StaticResource TextTertiaryBrush}" />
                            </StackPanel>

                            <StackPanel Spacing="4">
                                <Grid ColumnSpacing="8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="$320.00" FontSize="13" FontWeight="SemiBold" />
                                    <Border CornerRadius="4" Padding="4,2" Background="#10FF5F57">
                                        <TextBlock Text="Out of Stock" FontSize="9" Foreground="{StaticResource DangerBrush}" FontWeight="SemiBold" />
                                    </Border>
                                </Grid>

                                <TextBlock Text="0 units available" FontSize="10" Foreground="{StaticResource TextSecondaryBrush}" />
                            </StackPanel>

                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <Button Style="{StaticResource OutlinedButtonStyle}" Width="80" FontSize="11" Padding="8,6" Click="OnViewPartClick">
                                    <StackPanel Orientation="Horizontal" Spacing="4" HorizontalAlignment="Center">
                                        <FontIcon Glyph="&#xE70F;" FontSize="11" />
                                        <TextBlock Text="View" FontSize="11" />
                                    </StackPanel>
                                </Button>
                                <Button Style="{StaticResource PrimaryButtonStyle}" Width="80" FontSize="11" Padding="8,6" IsEnabled="False">
                                    <StackPanel Orientation="Horizontal" Spacing="4" HorizontalAlignment="Center">
                                        <FontIcon Glyph="&#xE710;" FontSize="11" />
                                        <TextBlock Text="Add" FontSize="11" />
                                    </StackPanel>
                                </Button>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </Grid>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>



