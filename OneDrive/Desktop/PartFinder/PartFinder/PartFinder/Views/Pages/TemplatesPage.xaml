п»ї<Page
    x:Class="PartFinder.Views.Pages.TemplatesPage"
    x:Name="TemplatesPageRoot"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:components="using:PartFinder.Views.Components"
    xmlns:converters="using:PartFinder.Converters"
    xmlns:viewmodels="using:PartFinder.ViewModels"
    xmlns:models="using:PartFinder.Models">
    <Page.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter" />
        <converters:InvertedBoolToVisibilityConverter x:Key="InvertedBoolToVisibilityConverter" />
    </Page.Resources>

    <Grid Padding="20" ColumnSpacing="16" Background="{StaticResource PageBackgroundBrush}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="240" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- ГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђ -->
        <!-- LEFT SIDEBAR Гўв‚¬вЂќ Template Manager                        -->
        <!-- ГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђ -->
        <Border
            Background="{StaticResource NavBackgroundBrush}"
            BorderBrush="{StaticResource BorderDefaultBrush}"
            BorderThickness="1"
            CornerRadius="4"
            Padding="12">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- Manager badge -->
                <Border
                    Grid.Row="0"
                    Margin="0,0,0,10"
                    Padding="10"
                    CornerRadius="8"
                    Background="{StaticResource CardBackgroundBrush}"
                    BorderBrush="{StaticResource BorderDefaultBrush}"
                    BorderThickness="1" Translation="0,0,32">
                            <Border.Shadow><ThemeShadow/></Border.Shadow>
                            <StackPanel Orientation="Horizontal" Spacing="8">
                        <Border Width="28" Height="28" CornerRadius="8" Background="{StaticResource AccentPrimaryBrush}">
                            <FontIcon Glyph="&#xE8A5;" FontSize="13" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <StackPanel Spacing="0">
                            <TextBlock Text="Template Manager" FontSize="12" FontWeight="SemiBold" />
                            <TextBlock Text="V2.4.0 HIGH-DENSITY" FontSize="9" Foreground="{StaticResource TextTertiaryBrush}" CharacterSpacing="60" />
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- New Template button -->
                <Button
                    Grid.Row="1"
                    Style="{StaticResource OutlinedButtonStyle}"
                    HorizontalAlignment="Stretch"
                    FontSize="12"
                    Command="{Binding StartNewCustomTemplateCommand}"
                    Content="ГўЕ вЂў  New Setup"
                    IsEnabled="{Binding CanAddAnotherTemplate}"
                    Visibility="{Binding CanAddAnotherTemplate, Converter={StaticResource BoolToVisibilityConverter}}" />

                <!-- Import CSV -->
                <Button
                    Grid.Row="2"
                    Margin="0,4,0,10"
                    Style="{StaticResource GhostButtonStyle}"
                    HorizontalAlignment="Stretch"
                    FontSize="11"
                    Content="Import CSV"
                    Click="OnImportCsvClick"
                    IsEnabled="{Binding ShowTemplatePreviewPanel}" />

                <!-- Active Templates label + list -->
                <StackPanel Grid.Row="3" Spacing="6">
                    <TextBlock Text="ACTIVE TEMPLATES" FontSize="9" Foreground="{StaticResource TextTertiaryBrush}" CharacterSpacing="80" FontWeight="SemiBold" Margin="2,0,0,0" />

                    <ListView
                        MinHeight="140"
                        ItemsSource="{Binding Templates}"
                        SelectedItem="{Binding SelectedTemplate, Mode=TwoWay}"
                        Visibility="{Binding ShowTemplateList, Converter={StaticResource BoolToVisibilityConverter}}"
                        SelectionMode="Single">
                        <ListView.ItemContainerStyle>
                            <Style TargetType="ListViewItem">
                                <Setter Property="Padding" Value="0" />
                                <Setter Property="Margin" Value="0,1" />
                                <Setter Property="MinHeight" Value="0" />
                                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                            </Style>
                        </ListView.ItemContainerStyle>
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Border Padding="10,8" CornerRadius="6">
                                    <StackPanel Spacing="1">
                                        <TextBlock Text="{Binding Name}" FontSize="12" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                                        <TextBlock Text="Updated recently" FontSize="10" Foreground="{StaticResource TextTertiaryBrush}" />
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>

                    <!-- Support links -->
                    <StackPanel Margin="2,8,0,0" Spacing="3">
                        <TextBlock Text="Support" FontSize="10" Foreground="{StaticResource TextTertiaryBrush}" />
                        <TextBlock Text="Logs" FontSize="10" Foreground="{StaticResource TextTertiaryBrush}" />
                    </StackPanel>
                </StackPanel>

                <!-- Import status -->
                <StackPanel x:Name="ImportStatusPanel" Grid.Row="4" Spacing="4" Visibility="Collapsed" Margin="0,10,0,0">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <ProgressRing x:Name="ImportProgressRing" Width="14" Height="14" IsActive="True" />
                        <TextBlock x:Name="ImportStatusText" Text="Import in progress..." FontSize="11" />
                    </StackPanel>
                    <TextBlock
                        x:Name="ImportStatusDetailText"
                        Foreground="{StaticResource TextSecondaryBrush}"
                        FontSize="10"
                        TextWrapping="WrapWholeWords" />
                </StackPanel>

                <!-- New Template bottom CTA -->
                <Border Grid.Row="5" Margin="0,8,0,0">
                    <Button
                        Style="{StaticResource OutlinedButtonStyle}"
                        HorizontalAlignment="Stretch"
                        FontSize="11"
                        Content="ГўЕ Еѕ  New Template"
                        Command="{Binding StartNewCustomTemplateCommand}"
                        IsEnabled="{Binding CanAddAnotherTemplate}" />
                </Border>
            </Grid>
        </Border>

        <!-- ГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђ -->
        <!-- RIGHT CONTENT AREA                                     -->
        <!-- ГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђ -->
        <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto" Background="{StaticResource PageBackgroundBrush}">
            <StackPanel Spacing="0" Padding="20,16,20,24" HorizontalAlignment="Stretch">

                <!-- ГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђ -->
                <!-- HEADER                                     -->
                <!-- ГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђ -->
                <StackPanel Spacing="2" Margin="0,0,0,14">
                    <TextBlock Text="TEMPLATES" FontSize="10" Foreground="{StaticResource AccentPrimaryBrush}" CharacterSpacing="100" FontWeight="SemiBold" />
                    <TextBlock Text="Schema Builder" FontSize="32" FontWeight="Light" CharacterSpacing="20" />
                    <TextBlock Text="Design and manage data schemas for your parts. Define columns, data types, and validation rules to structure your inventory." FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" TextWrapping="WrapWholeWords" />
                </StackPanel>

                <!-- ГўвЂќв‚¬ГўвЂќв‚¬ DB Missing Banner ГўвЂќв‚¬ГўвЂќв‚¬ -->
                <Border
                    Margin="0,0,0,14"
                    Padding="10,8"
                    CornerRadius="8"
                    Background="#2A1A1A"
                    BorderBrush="{StaticResource DangerBrush}"
                    BorderThickness="1"
                    Visibility="{Binding ShowDbMissingBanner, Converter={StaticResource BoolToVisibilityConverter}}">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon Glyph="&#xE7BA;" FontSize="13" Foreground="{StaticResource DangerBrush}" VerticalAlignment="Center" />
                        <TextBlock
                            Text="No tenant database configured. Complete setup with a valid organization and database connection."
                            FontSize="12"
                            Foreground="{StaticResource DangerBrush}"
                            TextWrapping="WrapWholeWords"
                            VerticalAlignment="Center" />
                    </StackPanel>
                </Border>

                <!-- ГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђ -->
                <!-- TEMPLATE EDITOR (New/Edit Template)        -->
                <!-- ГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђ -->
                <Grid Visibility="{Binding ShowTemplateEditor, Converter={StaticResource BoolToVisibilityConverter}}" ColumnSpacing="16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1.2*" />
                        <ColumnDefinition Width="1*" />
                    </Grid.ColumnDefinitions>

                    <!-- Left: Schema editor -->
                    <Border Grid.Column="0" Background="{StaticResource ElevatedCardBackgroundBrush}" BorderBrush="{StaticResource BorderDefaultBrush}" BorderThickness="1" CornerRadius="4" Padding="16">
                        <StackPanel Spacing="14">
                            <!-- Template name input -->
                            <TextBox
                                Style="{StaticResource StandardTextBoxStyle}"
                                IsReadOnly="{Binding IsTemplateNameReadOnly}"
                                PlaceholderText="Template name..."
                                FontSize="18"
                                FontWeight="SemiBold"
                                Background="Transparent"
                                BorderThickness="0"
                                Text="{Binding NewTemplateName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                            <!-- Column headers -->
                            <Grid ColumnSpacing="8" Margin="0,4,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="1.7*" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="COLUMN NAME" FontSize="9" Foreground="{StaticResource TextTertiaryBrush}" CharacterSpacing="80" FontWeight="SemiBold" VerticalAlignment="Center" />
                                <TextBlock Grid.Column="1" Text="TYPE" FontSize="9" Foreground="{StaticResource TextTertiaryBrush}" CharacterSpacing="80" FontWeight="SemiBold" VerticalAlignment="Center" />
                            </Grid>

                            <!-- Column rows -->
                            <ItemsControl ItemsSource="{Binding ColumnLabels}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="0,1,0,1" ColumnSpacing="8" MinHeight="36">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="1.7*" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <TextBox
                                                Grid.Column="0"
                                                FontSize="12"
                                                PlaceholderText="Column name"
                                                Text="{Binding Label, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                            <ComboBox
                                                Grid.Column="1"
                                                FontSize="11"
                                                DisplayMemberPath="Label"
                                                ItemsSource="{Binding DataContext.FieldTypeOptions, ElementName=TemplatesPageRoot}"
                                                SelectedValue="{Binding FieldType, Mode=TwoWay}"
                                                SelectedValuePath="Value" />
                                            <Button
                                                Grid.Column="2"
                                                Style="{StaticResource GhostButtonStyle}"
                                                Click="OnRemoveColumnClick"
                                                Content="ГѓвЂ”"
                                                FontSize="14"
                                                Padding="6,2" />
                                            <Button
                                                Grid.Column="3"
                                                Style="{StaticResource OutlinedButtonStyle}"
                                                Width="24"
                                                Height="24"
                                                Click="OnInsertDraftColumnClick"
                                                Opacity="0.35"
                                                PointerEntered="OnAffordancePointerEntered"
                                                PointerExited="OnAffordancePointerExited"
                                                Content="+"
                                                FontSize="12"
                                                Padding="0"
                                                ToolTipService.ToolTip="Insert a column below this one" />
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <!-- Add column (dashed style) -->
                            <Border
                                Padding="8,6"
                                CornerRadius="8"
                                BorderBrush="{StaticResource BorderDefaultBrush}"
                                BorderThickness="1"
                                HorizontalAlignment="Stretch">
                                <Button
                                    Style="{StaticResource GhostButtonStyle}"
                                    HorizontalAlignment="Center"
                                    Command="{Binding AddColumnCommand}"
                                    FontSize="12">
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                        <TextBlock Text="+" FontSize="14" VerticalAlignment="Center" />
                                        <TextBlock Text="Add column" FontSize="12" VerticalAlignment="Center" />
                                    </StackPanel>
                                </Button>
                            </Border>

                            <!-- Action buttons -->
                            <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,8,0,0">
                                <Button Style="{StaticResource GhostButtonStyle}" Command="{Binding CancelCreateCommand}" Content="Cancel" FontSize="12" />
                                <Button Style="{StaticResource PrimaryButtonStyle}" Command="{Binding SaveTemplateCommand}" Content="Save Template" FontSize="12" />
                            </StackPanel>
                            <TextBlock
                                Foreground="{StaticResource DangerBrush}"
                                Text="{Binding FormError}"
                                FontSize="12"
                                TextWrapping="WrapWholeWords" />
                        </StackPanel>
                    </Border>

                    <!-- Right: Live Preview + Tip -->
                    <StackPanel Grid.Column="1" Spacing="14">
                        <!-- Live Preview -->
                        <Border Background="{StaticResource ElevatedCardBackgroundBrush}" BorderBrush="{StaticResource BorderDefaultBrush}" BorderThickness="1" CornerRadius="4" Padding="16">
                            <StackPanel Spacing="10">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Spacing="2">
                                        <TextBlock Text="Live Preview" FontSize="14" FontWeight="SemiBold" />
                                        <TextBlock Text="Real-time schema visualization for industrial parts" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" />
                                    </StackPanel>
                                    <!-- Traffic light dots -->
                                    <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="4" VerticalAlignment="Top">
                                        <Ellipse Width="8" Height="8" Fill="#FF5F57" />
                                        <Ellipse Width="8" Height="8" Fill="#FEBC2E" />
                                        <Ellipse Width="8" Height="8" Fill="#28C840" />
                                    </StackPanel>
                                </Grid>

                                <!-- Preview table header -->
                                <Border Background="{StaticResource AccentPrimaryBrush}" CornerRadius="6,6,0,0" Padding="10,8">
                                    <ItemsControl ItemsSource="{Binding ColumnLabels}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <StackPanel Orientation="Horizontal" Spacing="16" />
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding Label}" FontSize="10" FontWeight="SemiBold" Foreground="White" CharacterSpacing="40" MinWidth="80" />
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </Border>

                                <!-- Preview placeholder rows -->
                                <Border Background="{StaticResource CardBackgroundBrush}" CornerRadius="0,0,6,6" Padding="10,8" MinHeight="40" BorderBrush="{StaticResource BorderDefaultBrush}" BorderThickness="1,0,1,1" Translation="0,0,32">
                                    <ItemsControl ItemsSource="{Binding ColumnLabels}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <StackPanel Orientation="Horizontal" Spacing="16" />
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="..." FontSize="11" Foreground="{StaticResource TextTertiaryBrush}" MinWidth="80" />
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </Border>

                                <!-- Schema drafting mode empty state -->
                                <StackPanel Spacing="6" HorizontalAlignment="Center" Margin="0,20,0,20">
                                    <Border Width="40" Height="40" CornerRadius="8" Background="{StaticResource GridHeaderBackgroundBrush}" HorizontalAlignment="Center">
                                        <FontIcon Glyph="&#xE8A5;" FontSize="18" Foreground="{StaticResource TextSecondaryBrush}" />
                                    </Border>
                                    <TextBlock
                                        Text="Schema Drafting Mode"
                                        FontSize="13"
                                        FontWeight="SemiBold"
                                        HorizontalAlignment="Center" />
                                    <TextBlock
                                        Text="Fields defined on the left will automatically populate this preview. Ensure structural alignment before saving."
                                        FontSize="11"
                                        Foreground="{StaticResource TextTertiaryBrush}"
                                        TextWrapping="WrapWholeWords"
                                        HorizontalAlignment="Center"
                                        TextAlignment="Center"
                                        MaxWidth="280" />
                                </StackPanel>

                                <!-- Preview status bar -->
                                <Border Background="{StaticResource GridHeaderBackgroundBrush}" CornerRadius="6" Padding="10,6">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Orientation="Horizontal" Spacing="14">
                                            <TextBlock FontSize="9" Foreground="{StaticResource TextTertiaryBrush}" CharacterSpacing="60">
                                                <Run Text="COLUMNS: " /><Run Text="{Binding ColumnLabels.Count}" />
                                            </TextBlock>
                                            <TextBlock Text="DATATYPE: MIXED" FontSize="9" Foreground="{StaticResource TextTertiaryBrush}" CharacterSpacing="60" />
                                        </StackPanel>
                                        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="4">
                                            <Ellipse Width="6" Height="6" Fill="{StaticResource SuccessBrush}" VerticalAlignment="Center" />
                                            <TextBlock Text="PREVIEW ACTIVE" FontSize="9" Foreground="{StaticResource TextTertiaryBrush}" CharacterSpacing="60" />
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </StackPanel>
                        </Border>

                        <!-- Optimization Tip -->
                        <Border Background="{StaticResource ElevatedCardBackgroundBrush}" BorderBrush="{StaticResource BorderDefaultBrush}" BorderThickness="1" CornerRadius="4" Padding="14">
                            <StackPanel Orientation="Horizontal" Spacing="12">
                                <Border Width="48" Height="48" CornerRadius="8" Background="{StaticResource GridHeaderBackgroundBrush}">
                                    <FontIcon Glyph="&#xE946;" FontSize="20" Foreground="{StaticResource TextSecondaryBrush}" />
                                </Border>
                                <StackPanel Spacing="2" VerticalAlignment="Center">
                                    <TextBlock Text="Optimization Tip" FontSize="13" FontWeight="SemiBold" />
                                    <TextBlock
                                        Text="Using 'Number' types for quantities enables automatic inventory alerts and trend visualization in the main dashboard."
                                        FontSize="11"
                                        Foreground="{StaticResource TextSecondaryBrush}"
                                        TextWrapping="WrapWholeWords"
                                        MaxWidth="320" />
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Grid>

                <!-- ГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђ -->
                <!-- TEMPLATE PREVIEW (Selected Template View)  -->
                <!-- ГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђ -->
                <StackPanel Visibility="{Binding ShowTemplatePreviewPanel, Converter={StaticResource BoolToVisibilityConverter}}" Spacing="14">

                    <!-- Configuration Mode header -->
                    <StackPanel Spacing="2">
                        <TextBlock Text="CONFIGURATION MODE" FontSize="10" Foreground="{StaticResource AccentPrimaryBrush}" CharacterSpacing="80" FontWeight="SemiBold" />
                        <TextBlock Text="Select and edit your template schema Гўв‚¬вЂќ columns, types and cell actions." FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" />
                    </StackPanel>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="{Binding SelectedTemplate.Name}" FontSize="22" FontWeight="SemiBold" />
                        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
                            <Button Style="{StaticResource GhostButtonStyle}" Content="Discard" FontSize="12" />
                            <Button Style="{StaticResource PrimaryButtonStyle}" Command="{Binding BeginEditSelectedTemplateCommand}" Content="Save Changes" FontSize="12" />
                        </StackPanel>
                    </Grid>

                    <!-- Data Schema Columns section -->
                    <StackPanel Spacing="8">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <FontIcon Glyph="&#xE80A;" FontSize="13" Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center" />
                                <TextBlock Text="Data Schema Columns" FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center" />
                            </StackPanel>
                            <Border Grid.Column="2" Style="{StaticResource GrayBadgeStyle}" Padding="6,2">
                                <TextBlock FontSize="9" Foreground="{StaticResource TextSecondaryBrush}" CharacterSpacing="60">
                                    <Run Text="{Binding SelectedTemplate.Fields.Count}" /><Run Text=" FIELDS DEFINED" />
                                </TextBlock>
                            </Border>
                        </Grid>

                        <!-- Schema chip row -->
                        <ScrollViewer HorizontalScrollBarVisibility="Auto" HorizontalScrollMode="Enabled">
                            <StackPanel
                                x:Name="TemplateChipRowPanel"
                                Orientation="Horizontal"
                                Spacing="0" />
                        </ScrollViewer>
                    </StackPanel>

                    <!-- Cell Actions section -->
                    <Border Background="{StaticResource ElevatedCardBackgroundBrush}" BorderBrush="{StaticResource BorderDefaultBrush}" BorderThickness="1" CornerRadius="4" Padding="14" Visibility="{Binding ShowContextActionsEditor, Converter={StaticResource BoolToVisibilityConverter}}">
                        <StackPanel Spacing="10">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <TextBlock Text="ГўЕЎВЎ" FontSize="14" VerticalAlignment="Center" />
                                <TextBlock Text="Cell Actions" FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center" />
                            </StackPanel>
                            <TextBlock
                                Foreground="{StaticResource TextSecondaryBrush}"
                                FontSize="11"
                                Text="Define right-click actions for specific cell types in Explorer."
                                TextWrapping="WrapWholeWords" />

                            <!-- Action cards grid -->
                            <ListView
                                MaxHeight="200"
                                SelectedItem="{Binding SelectedContextAction, Mode=TwoWay}"
                                ItemsSource="{Binding ContextActionRows}"
                                SelectionMode="Single">
                                <ListView.ItemContainerStyle>
                                    <Style TargetType="ListViewItem">
                                        <Setter Property="Padding" Value="0" />
                                        <Setter Property="Margin" Value="0,0,8,8" />
                                        <Setter Property="MinHeight" Value="0" />
                                    </Style>
                                </ListView.ItemContainerStyle>
                                <ListView.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <ItemsWrapGrid Orientation="Horizontal" ItemWidth="200" />
                                    </ItemsPanelTemplate>
                                </ListView.ItemsPanel>
                                <ListView.ItemTemplate>
                                    <DataTemplate x:DataType="viewmodels:ContextActionListRow">
                                        <Border Background="{StaticResource CardBackgroundBrush}" BorderBrush="{StaticResource BorderDefaultBrush}" BorderThickness="1" CornerRadius="8" Padding="12" Translation="0,0,32">
                            <Border.Shadow><ThemeShadow/></Border.Shadow>
                            <StackPanel Spacing="6">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto" />
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>
                                                    <Border Width="28" Height="28" CornerRadius="6" Background="{StaticResource GridHeaderBackgroundBrush}">
                                                        <FontIcon Glyph="&#xE8A5;" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" />
                                                    </Border>
                                                    <FontIcon Grid.Column="2" Glyph="&#xE74D;" FontSize="12" Foreground="{StaticResource TextTertiaryBrush}" />
                                                </Grid>
                                                <TextBlock Text="{x:Bind Action.MenuLabel}" FontSize="12" FontWeight="SemiBold" />
                                                <TextBlock FontSize="10" Foreground="{StaticResource TextSecondaryBrush}" TextTrimming="CharacterEllipsis">
                                                    <Run Text="ГўвЂ вЂ™ " /><Run Text="{x:Bind TargetTemplateName}" />
                                                </TextBlock>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>

                            <!-- Add cell action (dashed) -->
                            <Border
                                Padding="14,10"
                                CornerRadius="8"
                                BorderBrush="{StaticResource BorderDefaultBrush}"
                                BorderThickness="1"
                                HorizontalAlignment="Left">
                                <Button Style="{StaticResource GhostButtonStyle}" Click="OnAddContextActionClick" FontSize="12">
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                        <FontIcon Glyph="&#xE710;" FontSize="12" />
                                        <TextBlock Text="ADD CELL ACTION" FontSize="10" CharacterSpacing="60" VerticalAlignment="Center" />
                                    </StackPanel>
                                </Button>
                            </Border>

                            <Button Style="{StaticResource GhostButtonStyle}" Command="{Binding DeleteContextActionCommand}" Content="Remove selected" FontSize="11" HorizontalAlignment="Left" />
                        </StackPanel>
                    </Border>

                    <!-- Template Usage Analysis + Help -->
                    <Grid ColumnSpacing="14">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2*" />
                            <ColumnDefinition Width="1*" />
                        </Grid.ColumnDefinitions>

                        <!-- Usage Analysis -->
                        <Border Grid.Column="0" Background="{StaticResource ElevatedCardBackgroundBrush}" BorderBrush="{StaticResource BorderDefaultBrush}" BorderThickness="1" CornerRadius="4" Padding="14">
                            <StackPanel Spacing="10">
                                <TextBlock Text="Template Usage Analysis" FontSize="14" FontWeight="SemiBold" />
                                <Grid ColumnSpacing="10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.Column="0" Background="{StaticResource CardBackgroundBrush}" BorderBrush="{StaticResource BorderDefaultBrush}" BorderThickness="1" CornerRadius="8" Padding="10,8" Translation="0,0,32">
                            <Border.Shadow><ThemeShadow/></Border.Shadow>
                            <StackPanel Spacing="2">
                                            <TextBlock Text="ACTIVE PROJECTS" FontSize="8" Foreground="{StaticResource TextTertiaryBrush}" CharacterSpacing="60" />
                                            <TextBlock Text="14" FontSize="18" FontWeight="SemiBold" />
                                        </StackPanel>
                                    </Border>
                                    <Border Grid.Column="1" Background="{StaticResource CardBackgroundBrush}" BorderBrush="{StaticResource BorderDefaultBrush}" BorderThickness="1" CornerRadius="8" Padding="10,8" Translation="0,0,32">
                            <Border.Shadow><ThemeShadow/></Border.Shadow>
                            <StackPanel Spacing="2">
                                            <TextBlock Text="DATA DENSITY" FontSize="8" Foreground="{StaticResource TextTertiaryBrush}" CharacterSpacing="60" />
                                            <TextBlock Text="82%" FontSize="18" FontWeight="SemiBold" />
                                        </StackPanel>
                                    </Border>
                                    <Border Grid.Column="2" Background="{StaticResource CardBackgroundBrush}" BorderBrush="{StaticResource BorderDefaultBrush}" BorderThickness="1" CornerRadius="8" Padding="10,8" Translation="0,0,32">
                            <Border.Shadow><ThemeShadow/></Border.Shadow>
                            <StackPanel Spacing="2">
                                            <TextBlock Text="INTEGRITY SCORE" FontSize="8" Foreground="{StaticResource TextTertiaryBrush}" CharacterSpacing="60" />
                                            <TextBlock Text="9.8" FontSize="18" FontWeight="SemiBold" />
                                        </StackPanel>
                                    </Border>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- Template Integrity panel -->
                        <Border Grid.Column="1" Background="{StaticResource ElevatedCardBackgroundBrush}" BorderBrush="{StaticResource BorderDefaultBrush}" BorderThickness="1" CornerRadius="4" Padding="14">
                            <StackPanel Spacing="8">
                                <TextBlock Text="TEMPLATE INTEGRITY" FontSize="10" Foreground="{StaticResource TextSecondaryBrush}" CharacterSpacing="60" FontWeight="SemiBold" />
                                <StackPanel Spacing="4">
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                        <Ellipse Width="6" Height="6" Fill="{StaticResource SuccessBrush}" VerticalAlignment="Center" />
                                        <TextBlock Text="Schema validation passed" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" />
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                        <Ellipse Width="6" Height="6" Fill="{StaticResource SuccessBrush}" VerticalAlignment="Center" />
                                        <TextBlock Text="Actions compatible with Fluent UI" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" />
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                        <Ellipse Width="6" Height="6" Fill="{StaticResource WarningBrush}" VerticalAlignment="Center" />
                                        <TextBlock Text="Review linked templates" FontSize="11" Foreground="{StaticResource WarningBrush}" />
                                    </StackPanel>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </Grid>
                </StackPanel>

                <!-- ГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђ -->
                <!-- SELECT TEMPLATE PROMPT                     -->
                <!-- ГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђ -->
                <StackPanel Visibility="{Binding ShowSelectTemplatePromptPanel, Converter={StaticResource BoolToVisibilityConverter}}">
                    <components:PageHeader Subtitle="Select a template on the left to preview its columns." Title="Templates" />
                </StackPanel>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>



