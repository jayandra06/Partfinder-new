<Page
    x:Class="PartFinder.Views.Pages.AnalyticsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:lvc="using:LiveChartsCore.SkiaSharpView.WinUI">

    <Grid Background="{StaticResource PageBackgroundBrush}">
        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <StackPanel Padding="24,20,24,32" Spacing="18" HorizontalAlignment="Stretch">
                <StackPanel.ChildrenTransitions>
                    <TransitionCollection>
                        <EntranceThemeTransition IsStaggeringEnabled="True" FromVerticalOffset="50" />
                    </TransitionCollection>
                </StackPanel.ChildrenTransitions>

                <!-- â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â• -->
                <!-- HEADER                                         -->
                <!-- â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â• -->
                <Grid ColumnSpacing="12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Spacing="2">
                        <TextBlock Text="ANALYTICS" FontSize="10" Foreground="{StaticResource AccentPrimaryBrush}" CharacterSpacing="100" FontWeight="SemiBold" />
                        <TextBlock Text="Reports &amp; Analytics" FontSize="32" FontWeight="Light" CharacterSpacing="20" />
                        <TextBlock Text="Deep insights into inventory trends, performance metrics, and data completeness across your organization." FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" />
                    </StackPanel>
                    <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                        <Button x:Name="RefreshButton" Style="{StaticResource GhostButtonStyle}" FontSize="12" Click="OnRefreshClick">
                            <StackPanel Orientation="Horizontal" Spacing="5">
                                <FontIcon x:Name="RefreshIcon" Glyph="&#xE72C;" FontSize="13" />
                                <TextBlock Text="Refresh" FontSize="12" />
                            </StackPanel>
                        </Button>
                        <Button Style="{StaticResource OutlinedButtonStyle}" FontSize="12" Click="OnExportClick">
                            <StackPanel Orientation="Horizontal" Spacing="5">
                                <FontIcon Glyph="&#xE74E;" FontSize="13" />
                                <TextBlock Text="Export Report" FontSize="12" />
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Grid>

                <!-- â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â• -->
                <!-- KPI CARDS ROW                                  -->
                <!-- â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â• -->
                <Grid ColumnSpacing="14">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <!-- Parts Added This Month -->
                    <Border Grid.Column="0" Background="{StaticResource CardBackgroundBrush}" BorderBrush="{StaticResource BorderDefaultBrush}" BorderThickness="1" CornerRadius="4" Padding="16,14" Translation="0,0,32">
                            <Border.Shadow><ThemeShadow/></Border.Shadow>
                            <StackPanel Spacing="8">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Spacing="2">
                                    <TextBlock Text="PARTS ADDED" FontSize="9" Foreground="{StaticResource TextTertiaryBrush}" CharacterSpacing="60" FontWeight="SemiBold" />
                                    <TextBlock Text="247" FontSize="32" FontWeight="Light" CharacterSpacing="20" />
                                </StackPanel>
                                <Border Grid.Column="1" Width="44" Height="44" CornerRadius="4" Background="#101F7AE0" VerticalAlignment="Top">
                                    <FontIcon Glyph="&#xE710;" FontSize="18" Foreground="{StaticResource AccentPrimaryBrush}" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                </Border>
                            </Grid>
                            <TextBlock Text="â†‘ 18% this month" FontSize="10" Foreground="{StaticResource SuccessBrush}" />
                        </StackPanel>
                    </Border>

                    <!-- Avg Stock Level -->
                    <Border Grid.Column="1" Background="{StaticResource CardBackgroundBrush}" BorderBrush="{StaticResource BorderDefaultBrush}" BorderThickness="1" CornerRadius="4" Padding="16,14" Translation="0,0,32">
                            <Border.Shadow><ThemeShadow/></Border.Shadow>
                            <StackPanel Spacing="8">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Spacing="2">
                                    <TextBlock Text="AVG STOCK LEVEL" FontSize="9" Foreground="{StaticResource TextTertiaryBrush}" CharacterSpacing="60" FontWeight="SemiBold" />
                                    <TextBlock Text="84 units" FontSize="32" FontWeight="Light" CharacterSpacing="20" />
                                </StackPanel>
                                <Border Grid.Column="1" Width="44" Height="44" CornerRadius="4" Background="#102ABD8F" VerticalAlignment="Top">
                                    <FontIcon Glyph="&#xE80A;" FontSize="18" Foreground="{StaticResource SuccessBrush}" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                </Border>
                            </Grid>
                            <TextBlock Text="Across all categories" FontSize="10" Foreground="{StaticResource TextSecondaryBrush}" />
                        </StackPanel>
                    </Border>

                    <!-- Top Category -->
                    <Border Grid.Column="2" Background="{StaticResource CardBackgroundBrush}" BorderBrush="{StaticResource BorderDefaultBrush}" BorderThickness="1" CornerRadius="4" Padding="16,14" Translation="0,0,32">
                            <Border.Shadow><ThemeShadow/></Border.Shadow>
                            <StackPanel Spacing="8">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Spacing="2">
                                    <TextBlock Text="TOP CATEGORY" FontSize="9" Foreground="{StaticResource TextTertiaryBrush}" CharacterSpacing="60" FontWeight="SemiBold" />
                                    <TextBlock Text="Engine" FontSize="32" FontWeight="Light" CharacterSpacing="20" />
                                </StackPanel>
                                <Border Grid.Column="1" Width="44" Height="44" CornerRadius="4" Background="#10FEBC2E" VerticalAlignment="Top">
                                    <FontIcon Glyph="&#xE9D9;" FontSize="18" Foreground="{StaticResource WarningBrush}" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                </Border>
                            </Grid>
                            <TextBlock Text="42% of total inventory" FontSize="10" Foreground="{StaticResource TextSecondaryBrush}" />
                        </StackPanel>
                    </Border>

                    <!-- Data Completeness -->
                    <Border Grid.Column="3" Background="{StaticResource CardBackgroundBrush}" BorderBrush="{StaticResource BorderDefaultBrush}" BorderThickness="1" CornerRadius="4" Padding="16,14" Translation="0,0,32">
                            <Border.Shadow><ThemeShadow/></Border.Shadow>
                            <StackPanel Spacing="8">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Spacing="2">
                                    <TextBlock Text="DATA COMPLETENESS" FontSize="9" Foreground="{StaticResource TextTertiaryBrush}" CharacterSpacing="60" FontWeight="SemiBold" />
                                    <TextBlock Text="96.4%" FontSize="32" FontWeight="Light" CharacterSpacing="20" />
                                </StackPanel>
                                <Border Grid.Column="1" Width="44" Height="44" CornerRadius="4" Background="#108B5CF6" VerticalAlignment="Top">
                                    <FontIcon Glyph="&#xE9D5;" FontSize="18" Foreground="#8B5CF6" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                </Border>
                            </Grid>
                            <TextBlock Text="â†‘ 2.1% improvement" FontSize="10" Foreground="{StaticResource SuccessBrush}" />
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â• -->
                <!-- ROW 1: Monthly Parts Trend (full width)        -->
                <!-- â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â• -->
                <Border Background="{StaticResource CardBackgroundBrush}" BorderBrush="{StaticResource BorderDefaultBrush}" BorderThickness="1" CornerRadius="4" Padding="18,14" Translation="0,0,32">
                            <Border.Shadow><ThemeShadow/></Border.Shadow>
                            <StackPanel Spacing="12">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Spacing="2">
                                <TextBlock Text="Monthly Parts Trend" FontSize="15" FontWeight="SemiBold" />
                                <TextBlock Text="Parts added per month over the last 12 months" FontSize="11" Foreground="{StaticResource TextTertiaryBrush}" />
                            </StackPanel>
                            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                <Border CornerRadius="6" Padding="8,3" Background="#101F7AE0">
                                    <TextBlock Text="LAST 12 MONTHS" FontSize="8" Foreground="{StaticResource AccentPrimaryBrush}" CharacterSpacing="60" FontWeight="SemiBold" />
                                </Border>
                            </StackPanel>
                        </Grid>
                        <lvc:CartesianChart
                            x:Name="MonthlyTrendChart"
                            Height="280"
                            AnimationsSpeed="00:00:00.6" />
                        <!-- Legend -->
                        <StackPanel Orientation="Horizontal" Spacing="16">
                            <StackPanel Orientation="Horizontal" Spacing="5">
                                <Border Width="16" Height="3" CornerRadius="2" Background="#1F7AE0" VerticalAlignment="Center" />
                                <TextBlock Text="Parts Added" FontSize="10" Foreground="{StaticResource TextTertiaryBrush}" />
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Spacing="5">
                                <Border Width="16" Height="3" CornerRadius="2" Background="#2ABD8F" VerticalAlignment="Center" />
                                <TextBlock Text="Parts Removed" FontSize="10" Foreground="{StaticResource TextTertiaryBrush}" />
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Spacing="5">
                                <Border Width="16" Height="1" CornerRadius="1" Background="#64647880" VerticalAlignment="Center" />
                                <TextBlock Text="Average" FontSize="10" Foreground="{StaticResource TextTertiaryBrush}" />
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â• -->
                <!-- ROW 2: Category Distribution + Stock Movement  -->
                <!-- â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â• -->
                <Grid ColumnSpacing="16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="1.4*" />
                    </Grid.ColumnDefinitions>

                    <!-- Category Distribution Pie -->
                    <Border Grid.Column="0" Background="{StaticResource CardBackgroundBrush}" BorderBrush="{StaticResource BorderDefaultBrush}" BorderThickness="1" CornerRadius="4" Padding="18,14" Translation="0,0,32">
                            <Border.Shadow><ThemeShadow/></Border.Shadow>
                            <StackPanel Spacing="12">
                            <StackPanel Spacing="2">
                                <TextBlock Text="Category Distribution" FontSize="15" FontWeight="SemiBold" />
                                <TextBlock Text="Parts breakdown by category" FontSize="11" Foreground="{StaticResource TextTertiaryBrush}" />
                            </StackPanel>
                            <lvc:PieChart
                                x:Name="CategoryPieChart"
                                Height="220"
                                AnimationsSpeed="00:00:00.8"
                                InitialRotation="-90" />
                            <StackPanel Spacing="5">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <Ellipse Width="8" Height="8" Fill="#1F7AE0" VerticalAlignment="Center" />
                                    <TextBlock Text="Engine" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" />
                                    <TextBlock Text="42%" FontSize="11" FontWeight="SemiBold" />
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <Ellipse Width="8" Height="8" Fill="#2ABD8F" VerticalAlignment="Center" />
                                    <TextBlock Text="Fuel Systems" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" />
                                    <TextBlock Text="24%" FontSize="11" FontWeight="SemiBold" />
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <Ellipse Width="8" Height="8" Fill="#FEBC2E" VerticalAlignment="Center" />
                                    <TextBlock Text="Valve Systems" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" />
                                    <TextBlock Text="18%" FontSize="11" FontWeight="SemiBold" />
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <Ellipse Width="8" Height="8" Fill="#8B5CF6" VerticalAlignment="Center" />
                                    <TextBlock Text="Cooling" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" />
                                    <TextBlock Text="10%" FontSize="11" FontWeight="SemiBold" />
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <Ellipse Width="8" Height="8" Fill="#FF5F57" VerticalAlignment="Center" />
                                    <TextBlock Text="Electrical" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" />
                                    <TextBlock Text="6%" FontSize="11" FontWeight="SemiBold" />
                                </StackPanel>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- Stock Movement Bar Chart -->
                    <Border Grid.Column="1" Background="{StaticResource CardBackgroundBrush}" BorderBrush="{StaticResource BorderDefaultBrush}" BorderThickness="1" CornerRadius="4" Padding="18,14" Translation="0,0,32">
                            <Border.Shadow><ThemeShadow/></Border.Shadow>
                            <StackPanel Spacing="12">
                            <StackPanel Spacing="2">
                                <TextBlock Text="Stock Movement" FontSize="15" FontWeight="SemiBold" />
                                <TextBlock Text="Weekly inbound vs outbound stock flow" FontSize="11" Foreground="{StaticResource TextTertiaryBrush}" />
                            </StackPanel>
                            <lvc:CartesianChart
                                x:Name="StockMovementChart"
                                Height="280"
                                AnimationsSpeed="00:00:00.6" />
                            <StackPanel Orientation="Horizontal" Spacing="16">
                                <StackPanel Orientation="Horizontal" Spacing="5">
                                    <Border Width="12" Height="12" CornerRadius="2" Background="#1F7AE0" VerticalAlignment="Center" />
                                    <TextBlock Text="Inbound" FontSize="10" Foreground="{StaticResource TextTertiaryBrush}" />
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Spacing="5">
                                    <Border Width="12" Height="12" CornerRadius="2" Background="#FF5F57" VerticalAlignment="Center" />
                                    <TextBlock Text="Outbound" FontSize="10" Foreground="{StaticResource TextTertiaryBrush}" />
                                </StackPanel>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â• -->
                <!-- ROW 3: Top Performing Templates Table          -->
                <!-- â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â• -->
                <Border Background="{StaticResource CardBackgroundBrush}" BorderBrush="{StaticResource BorderDefaultBrush}" BorderThickness="1" CornerRadius="4" Padding="0" Translation="0,0,32">
                            <Border.Shadow><ThemeShadow/></Border.Shadow>
                            <StackPanel>
                        <!-- Table Title -->
                        <Grid Padding="18,14,18,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Spacing="2">
                                <TextBlock Text="Top Performing Templates" FontSize="15" FontWeight="SemiBold" />
                                <TextBlock Text="Templates ranked by parts count and activity" FontSize="11" Foreground="{StaticResource TextTertiaryBrush}" />
                            </StackPanel>
                            <Border Grid.Column="1" CornerRadius="6" Padding="8,3" Background="#102ABD8F" VerticalAlignment="Center">
                                <TextBlock Text="TOP 5" FontSize="8" Foreground="{StaticResource SuccessBrush}" CharacterSpacing="60" FontWeight="SemiBold" />
                            </Border>
                        </Grid>

                        <!-- Table Header -->
                        <Grid Padding="18,8" Background="{StaticResource GridHeaderBackgroundBrush}" ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="2*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="#" FontSize="9" Foreground="{StaticResource TextTertiaryBrush}" CharacterSpacing="60" FontWeight="SemiBold" MinWidth="24" />
                            <TextBlock Grid.Column="1" Text="TEMPLATE" FontSize="9" Foreground="{StaticResource TextTertiaryBrush}" CharacterSpacing="60" FontWeight="SemiBold" />
                            <TextBlock Grid.Column="2" Text="PARTS COUNT" FontSize="9" Foreground="{StaticResource TextTertiaryBrush}" CharacterSpacing="60" FontWeight="SemiBold" />
                            <TextBlock Grid.Column="3" Text="LAST UPDATED" FontSize="9" Foreground="{StaticResource TextTertiaryBrush}" CharacterSpacing="60" FontWeight="SemiBold" />
                            <TextBlock Grid.Column="4" Text="STATUS" FontSize="9" Foreground="{StaticResource TextTertiaryBrush}" CharacterSpacing="60" FontWeight="SemiBold" />
                        </Grid>

                        <!-- Row 1 -->
                        <Grid Padding="18,12" ColumnSpacing="12" BorderBrush="{StaticResource BorderDefaultBrush}" BorderThickness="0,1,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="2*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Border Width="24" Height="24" CornerRadius="6" Background="#101F7AE0">
                                <TextBlock Text="1" FontSize="10" FontWeight="Bold" Foreground="{StaticResource AccentPrimaryBrush}" HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                            <StackPanel Grid.Column="1" Spacing="2" VerticalAlignment="Center">
                                <TextBlock Text="Turbocharger Assembly" FontSize="12" FontWeight="SemiBold" />
                                <TextBlock Text="Marine engine components" FontSize="10" Foreground="{StaticResource TextTertiaryBrush}" />
                            </StackPanel>
                            <TextBlock Grid.Column="2" Text="1,248" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center" />
                            <TextBlock Grid.Column="3" Text="2 hours ago" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center" />
                            <Border Grid.Column="4" CornerRadius="6" Padding="8,4" Background="#102ABD8F" HorizontalAlignment="Left" VerticalAlignment="Center">
                                <TextBlock Text="Active" FontSize="9" Foreground="{StaticResource SuccessBrush}" FontWeight="SemiBold" />
                            </Border>
                        </Grid>

                        <!-- Row 2 -->
                        <Grid Padding="18,12" ColumnSpacing="12" BorderBrush="{StaticResource BorderDefaultBrush}" BorderThickness="0,1,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="2*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Border Width="24" Height="24" CornerRadius="6" Background="#102ABD8F">
                                <TextBlock Text="2" FontSize="10" FontWeight="Bold" Foreground="{StaticResource SuccessBrush}" HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                            <StackPanel Grid.Column="1" Spacing="2" VerticalAlignment="Center">
                                <TextBlock Text="Fuel Injector System" FontSize="12" FontWeight="SemiBold" />
                                <TextBlock Text="Precision fuel delivery" FontSize="10" Foreground="{StaticResource TextTertiaryBrush}" />
                            </StackPanel>
                            <TextBlock Grid.Column="2" Text="892" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center" />
                            <TextBlock Grid.Column="3" Text="Yesterday" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center" />
                            <Border Grid.Column="4" CornerRadius="6" Padding="8,4" Background="#102ABD8F" HorizontalAlignment="Left" VerticalAlignment="Center">
                                <TextBlock Text="Active" FontSize="9" Foreground="{StaticResource SuccessBrush}" FontWeight="SemiBold" />
                            </Border>
                        </Grid>

                        <!-- Row 3 -->
                        <Grid Padding="18,12" ColumnSpacing="12" BorderBrush="{StaticResource BorderDefaultBrush}" BorderThickness="0,1,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="2*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Border Width="24" Height="24" CornerRadius="6" Background="#10FEBC2E">
                                <TextBlock Text="3" FontSize="10" FontWeight="Bold" Foreground="{StaticResource WarningBrush}" HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                            <StackPanel Grid.Column="1" Spacing="2" VerticalAlignment="Center">
                                <TextBlock Text="Valve Assembly" FontSize="12" FontWeight="SemiBold" />
                                <TextBlock Text="Precision valve control" FontSize="10" Foreground="{StaticResource TextTertiaryBrush}" />
                            </StackPanel>
                            <TextBlock Grid.Column="2" Text="634" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center" />
                            <TextBlock Grid.Column="3" Text="3 days ago" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center" />
                            <Border Grid.Column="4" CornerRadius="6" Padding="8,4" Background="#10FEBC2E" HorizontalAlignment="Left" VerticalAlignment="Center">
                                <TextBlock Text="Review" FontSize="9" Foreground="{StaticResource WarningBrush}" FontWeight="SemiBold" />
                            </Border>
                        </Grid>

                        <!-- Row 4 -->
                        <Grid Padding="18,12" ColumnSpacing="12" BorderBrush="{StaticResource BorderDefaultBrush}" BorderThickness="0,1,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="2*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Border Width="24" Height="24" CornerRadius="6" Background="#108B5CF6">
                                <TextBlock Text="4" FontSize="10" FontWeight="Bold" Foreground="#8B5CF6" HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                            <StackPanel Grid.Column="1" Spacing="2" VerticalAlignment="Center">
                                <TextBlock Text="Cooling System Parts" FontSize="12" FontWeight="SemiBold" />
                                <TextBlock Text="Heat management components" FontSize="10" Foreground="{StaticResource TextTertiaryBrush}" />
                            </StackPanel>
                            <TextBlock Grid.Column="2" Text="421" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center" />
                            <TextBlock Grid.Column="3" Text="1 week ago" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center" />
                            <Border Grid.Column="4" CornerRadius="6" Padding="8,4" Background="#102ABD8F" HorizontalAlignment="Left" VerticalAlignment="Center">
                                <TextBlock Text="Active" FontSize="9" Foreground="{StaticResource SuccessBrush}" FontWeight="SemiBold" />
                            </Border>
                        </Grid>

                        <!-- Row 5 -->
                        <Grid Padding="18,12" ColumnSpacing="12" BorderBrush="{StaticResource BorderDefaultBrush}" BorderThickness="0,1,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="2*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Border Width="24" Height="24" CornerRadius="6" Background="#10647880">
                                <TextBlock Text="5" FontSize="10" FontWeight="Bold" Foreground="{StaticResource TextSecondaryBrush}" HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                            <StackPanel Grid.Column="1" Spacing="2" VerticalAlignment="Center">
                                <TextBlock Text="Electrical Components" FontSize="12" FontWeight="SemiBold" />
                                <TextBlock Text="Wiring and sensors" FontSize="10" Foreground="{StaticResource TextTertiaryBrush}" />
                            </StackPanel>
                            <TextBlock Grid.Column="2" Text="318" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center" />
                            <TextBlock Grid.Column="3" Text="2 weeks ago" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center" />
                            <Border Grid.Column="4" CornerRadius="6" Padding="8,4" Background="#10647880" HorizontalAlignment="Left" VerticalAlignment="Center">
                                <TextBlock Text="Inactive" FontSize="9" Foreground="{StaticResource TextTertiaryBrush}" FontWeight="SemiBold" />
                            </Border>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â• -->
                <!-- ROW 4: Donut Health Gauge + Supplier Spend     -->
                <!-- â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â• -->
                <Grid ColumnSpacing="16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="1.6*" />
                    </Grid.ColumnDefinitions>

                    <!-- Inventory Health Donut -->
                    <Border Grid.Column="0" Background="{StaticResource CardBackgroundBrush}" BorderBrush="{StaticResource BorderDefaultBrush}" BorderThickness="1" CornerRadius="4" Padding="18,14" Translation="0,0,32">
                            <Border.Shadow><ThemeShadow/></Border.Shadow>
                            <StackPanel Spacing="12">
                            <StackPanel Spacing="2">
                                <TextBlock Text="Inventory Health" FontSize="15" FontWeight="SemiBold" />
                                <TextBlock Text="Stock status breakdown across all parts" FontSize="11" Foreground="{StaticResource TextTertiaryBrush}" />
                            </StackPanel>
                            <Grid>
                                <lvc:PieChart
                                    x:Name="HealthDonutChart"
                                    Height="200"
                                    AnimationsSpeed="00:00:01.0"
                                    InitialRotation="-90" />
                                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="0">
                                    <TextBlock Text="94.2%" FontSize="22" FontWeight="Bold" HorizontalAlignment="Center" />
                                    <TextBlock Text="Healthy" FontSize="10" Foreground="{StaticResource TextTertiaryBrush}" HorizontalAlignment="Center" />
                                </StackPanel>
                            </Grid>
                            <StackPanel Spacing="6">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <Ellipse Width="8" Height="8" Fill="#2ABD8F" VerticalAlignment="Center" />
                                    <TextBlock Text="In Stock" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" />
                                    <TextBlock Text="1,206" FontSize="11" FontWeight="SemiBold" />
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <Ellipse Width="8" Height="8" Fill="#FEBC2E" VerticalAlignment="Center" />
                                    <TextBlock Text="Low Stock" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" />
                                    <TextBlock Text="34" FontSize="11" FontWeight="SemiBold" />
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <Ellipse Width="8" Height="8" Fill="#FF5F57" VerticalAlignment="Center" />
                                    <TextBlock Text="Out of Stock" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" />
                                    <TextBlock Text="8" FontSize="11" FontWeight="SemiBold" />
                                </StackPanel>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- Supplier Spend Bar Chart -->
                    <Border Grid.Column="1" Background="{StaticResource CardBackgroundBrush}" BorderBrush="{StaticResource BorderDefaultBrush}" BorderThickness="1" CornerRadius="4" Padding="18,14" Translation="0,0,32">
                            <Border.Shadow><ThemeShadow/></Border.Shadow>
                            <StackPanel Spacing="12">
                            <StackPanel Spacing="2">
                                <TextBlock Text="Supplier Spend Analysis" FontSize="15" FontWeight="SemiBold" />
                                <TextBlock Text="YTD procurement spend per supplier" FontSize="11" Foreground="{StaticResource TextTertiaryBrush}" />
                            </StackPanel>
                            <lvc:CartesianChart
                                x:Name="SupplierSpendChart"
                                Height="240"
                                AnimationsSpeed="00:00:00.8" />
                            <StackPanel Orientation="Horizontal" Spacing="16">
                                <StackPanel Orientation="Horizontal" Spacing="5">
                                    <Border Width="12" Height="12" CornerRadius="2" Background="#1F7AE0" VerticalAlignment="Center" />
                                    <TextBlock Text="Spend ($M)" FontSize="10" Foreground="{StaticResource TextTertiaryBrush}" />
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Spacing="5">
                                    <Border Width="12" Height="12" CornerRadius="2" Background="#2ABD8F" VerticalAlignment="Center" />
                                    <TextBlock Text="Orders" FontSize="10" Foreground="{StaticResource TextTertiaryBrush}" />
                                </StackPanel>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </Grid>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>



