<Page
    x:Class="PartFinder.Views.Pages.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converters="using:PartFinder.Converters">

    <Page.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter" />

        <!-- ========================================== -->
        <!-- LUXURY MINIMAL DESIGN SYSTEM FOR SETTINGS   -->
        <!-- ========================================== -->
        
        <Style x:Key="SectionTitleStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="28" />
            <Setter Property="FontWeight" Value="Light" />
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
            <Setter Property="CharacterSpacing" Value="20" />
            <Setter Property="Margin" Value="0,0,0,8" />
        </Style>

        <Style x:Key="SectionDescriptionStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}" />
            <Setter Property="LineHeight" Value="20" />
            <Setter Property="Margin" Value="0,0,0,32" />
        </Style>

        <Style x:Key="SettingRowBorderStyle" TargetType="Border">
            <Setter Property="BorderBrush" Value="{StaticResource BorderDefaultBrush}" />
            <Setter Property="BorderThickness" Value="0,0,0,1" />
            <Setter Property="Padding" Value="0,20,0,20" />
        </Style>

        <Style x:Key="SettingLabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
            <Setter Property="Margin" Value="0,0,0,4" />
        </Style>

        <Style x:Key="SettingHintStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Foreground" Value="{StaticResource TextTertiaryBrush}" />
            <Setter Property="TextWrapping" Value="WrapWholeWords" />
        </Style>

        <Style x:Key="NavButtonStyle" TargetType="Button">
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="16,12" />
            <Setter Property="CornerRadius" Value="6" />
        </Style>
    </Page.Resources>

    <Grid Background="{StaticResource PageBackgroundBrush}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="260" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- TOAST POPUP (Preserved x:Names) -->
        <Border
            x:Name="ToastPopup"
            Grid.ColumnSpan="2"
            HorizontalAlignment="Right"
            VerticalAlignment="Bottom"
            Margin="0,0,32,32"
            Padding="20,16"
            CornerRadius="8"
            Background="{StaticResource ElevatedCardBackgroundBrush}"
            BorderBrush="{StaticResource BorderDefaultBrush}"
            BorderThickness="1"
            Opacity="0"
            IsHitTestVisible="False"
            Canvas.ZIndex="99">
            <Border.Shadow><ThemeShadow/></Border.Shadow>
            <StackPanel Orientation="Horizontal" Spacing="16">
                <Border Width="32" Height="32" CornerRadius="16" Background="#102ABD8F" BorderBrush="#302ABD8F" BorderThickness="1">
                    <FontIcon Glyph="&#xE73E;" FontSize="14" Foreground="{StaticResource SuccessBrush}" />
                </Border>
                <StackPanel Spacing="2" VerticalAlignment="Center">
                    <TextBlock x:Name="ToastTitle" Text="Saved successfully" FontSize="13" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}" />
                    <TextBlock x:Name="ToastMessage" Text="Your changes have been applied." FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" />
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- LEFT SIDEBAR: Editorial Navigation -->
        <Border Grid.Column="0" Background="{StaticResource CardBackgroundBrush}" BorderBrush="{StaticResource BorderDefaultBrush}" BorderThickness="0,0,1,0" Padding="24,32" Translation="0,0,32">
            <Grid RowSpacing="32">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Spacing="4">
                    <TextBlock Text="PREFERENCES" FontSize="10" Foreground="{StaticResource TextTertiaryBrush}" CharacterSpacing="100" FontWeight="Bold" />
                    <TextBlock Text="Settings" FontSize="22" FontWeight="SemiBold" />
                </StackPanel>

                <StackPanel Grid.Row="1" Spacing="4">
                    <!-- Profile -->
                    <Border x:Name="NavProfileItem" CornerRadius="6" Background="{StaticResource NavItemSelectedBrush}">
                        <Button Style="{StaticResource NavButtonStyle}" Click="OnNavProfileClick">
                            <StackPanel Orientation="Horizontal" Spacing="12">
                                <FontIcon Glyph="&#xE77B;" FontSize="14" Foreground="{StaticResource AccentPrimaryBrush}" />
                                <TextBlock Text="Profile" FontSize="13" FontWeight="Medium" Foreground="{StaticResource TextPrimaryBrush}" />
                            </StackPanel>
                        </Button>
                    </Border>

                    <!-- Security & 2FA -->
                    <Border x:Name="NavSecurityItem" CornerRadius="6" Background="Transparent">
                        <Button Style="{StaticResource NavButtonStyle}" Click="OnNavSecurityClick">
                            <StackPanel Orientation="Horizontal" Spacing="12">
                                <FontIcon Glyph="&#xE72E;" FontSize="14" Foreground="{StaticResource TextSecondaryBrush}" />
                                <TextBlock Text="Security &amp; 2FA" FontSize="13" Foreground="{StaticResource TextSecondaryBrush}" />
                            </StackPanel>
                        </Button>
                    </Border>

                    <!-- Change Password -->
                    <Border x:Name="NavPasswordItem" CornerRadius="6" Background="Transparent">
                        <Button Style="{StaticResource NavButtonStyle}" Click="OnNavPasswordClick">
                            <StackPanel Orientation="Horizontal" Spacing="12">
                                <FontIcon Glyph="&#xE8D7;" FontSize="14" Foreground="{StaticResource TextSecondaryBrush}" />
                                <TextBlock Text="Password" FontSize="13" Foreground="{StaticResource TextSecondaryBrush}" />
                            </StackPanel>
                        </Button>
                    </Border>

                    <!-- App Lock -->
                    <Border x:Name="NavAppLockItem" CornerRadius="6" Background="Transparent">
                        <Button Style="{StaticResource NavButtonStyle}" Click="OnNavAppLockClick">
                            <StackPanel Orientation="Horizontal" Spacing="12">
                                <FontIcon Glyph="&#xE72E;" FontSize="14" Foreground="{StaticResource TextSecondaryBrush}" />
                                <TextBlock Text="App Lock" FontSize="13" Foreground="{StaticResource TextSecondaryBrush}" />
                            </StackPanel>
                        </Button>
                    </Border>

                    <!-- Hidden bindings -->
                    <Border x:Name="NavTwoFactorItem" Visibility="Collapsed" />
                    <Border x:Name="NavAppearanceItem" Visibility="Collapsed" />
                    <Border x:Name="NavNotificationsItem" Visibility="Collapsed" />
                </StackPanel>

                <!-- Org info Minimal -->
                <Border Grid.Row="2" Background="Transparent" BorderBrush="{StaticResource BorderDefaultBrush}" BorderThickness="0,1,0,0" Padding="0,24,0,0">
                    <StackPanel Spacing="4">
                        <TextBlock Text="ORGANIZATION" FontSize="10" Foreground="{StaticResource TextTertiaryBrush}" CharacterSpacing="50" FontWeight="SemiBold" />
                        <TextBlock Text="Fleet Ops" FontSize="14" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}" />
                        <TextBlock Text="Enterprise Tier" FontSize="11" Foreground="{StaticResource AccentPrimaryBrush}" />
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <!-- RIGHT CONTENT AREA -->
        <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <!-- Constrain width for readability, but allow it to stretch nicely -->
            <StackPanel HorizontalAlignment="Stretch" Padding="64,48,64,80" MaxWidth="1000">

                <!-- â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â• -->
                <!-- PROFILE SECTION                                    -->
                <!-- â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â• -->
                <StackPanel x:Name="ProfileSection" Visibility="Visible">
                    <TextBlock Text="PROFILE &amp; IDENTITY" Style="{StaticResource SectionTitleStyle}" />
                    <TextBlock Text="Manage your identity, personal information, and how you appear to others within the organization. Changes are reflected across the entire workspace." Style="{StaticResource SectionDescriptionStyle}" />

                    <!-- Avatar Row -->
                    <Border Style="{StaticResource SettingRowBorderStyle}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="2*" />
                                <ColumnDefinition Width="3*" />
                            </Grid.ColumnDefinitions>
                            
                            <StackPanel Spacing="8">
                                <TextBlock Text="Avatar &amp; Role" Style="{StaticResource SettingLabelStyle}" />
                                <TextBlock Text="Your profile picture and system privileges." Style="{StaticResource SettingHintStyle}" />
                            </StackPanel>

                            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="24">
                                <Border Width="72" Height="72" CornerRadius="36" Background="{StaticResource AccentPrimaryBrush}">
                                    <TextBlock Text="JD" FontSize="20" FontWeight="SemiBold" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                </Border>
                                <StackPanel VerticalAlignment="Center" Spacing="8">
                                    <StackPanel Orientation="Horizontal" Spacing="12">
                                        <Button Style="{StaticResource GhostButtonStyle}" Content="Change photo" />
                                        <Button Style="{StaticResource GhostButtonStyle}" Content="Use email profile" Click="OnUseEmailProfileClick" />
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <Border Background="#101F7AE0" BorderBrush="#301F7AE0" BorderThickness="1" CornerRadius="4" Padding="8,2">
                                            <TextBlock Text="Administrator" FontSize="10" FontWeight="SemiBold" Foreground="{StaticResource AccentPrimaryBrush}" />
                                        </Border>
                                        <Border Background="#102ABD8F" BorderBrush="#302ABD8F" BorderThickness="1" CornerRadius="4" Padding="8,2">
                                            <TextBlock Text="Verified User" FontSize="10" FontWeight="SemiBold" Foreground="{StaticResource SuccessBrush}" />
                                        </Border>
                                    </StackPanel>
                                </StackPanel>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- Personal Info Row -->
                    <Border Style="{StaticResource SettingRowBorderStyle}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="2*" />
                                <ColumnDefinition Width="3*" />
                            </Grid.ColumnDefinitions>
                            
                            <StackPanel Spacing="8">
                                <TextBlock Text="Personal Details" Style="{StaticResource SettingLabelStyle}" />
                                <TextBlock Text="Core identification details used for auditing and communication." Style="{StaticResource SettingHintStyle}" />
                            </StackPanel>

                            <Grid Grid.Column="1" RowSpacing="20" ColumnSpacing="16">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Row="0" Grid.Column="0" Spacing="6">
                                    <TextBlock Text="Display Name" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" />
                                    <TextBox Style="{StaticResource StandardTextBoxStyle}" Text="{Binding ProfileName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                </StackPanel>

                                <StackPanel Grid.Row="0" Grid.Column="1" Spacing="6">
                                    <TextBlock Text="Email Address (Read-only)" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" />
                                    <TextBox Style="{StaticResource StandardTextBoxStyle}" IsReadOnly="True" Text="{Binding SessionEmailDisplay}" />
                                </StackPanel>

                                <StackPanel Grid.Row="1" Grid.Column="0" Spacing="6">
                                    <TextBlock Text="Designation" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" />
                                    <TextBox Style="{StaticResource StandardTextBoxStyle}" PlaceholderText="e.g. Lead Engineer" />
                                </StackPanel>

                                <StackPanel Grid.Row="1" Grid.Column="1" Spacing="6">
                                    <TextBlock Text="Department" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" />
                                    <TextBox Style="{StaticResource StandardTextBoxStyle}" PlaceholderText="e.g. Operations" />
                                </StackPanel>
                            </Grid>
                        </Grid>
                    </Border>

                    <!-- Bio Row -->
                    <Border Style="{StaticResource SettingRowBorderStyle}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="2*" />
                                <ColumnDefinition Width="3*" />
                            </Grid.ColumnDefinitions>
                            
                            <StackPanel Spacing="8">
                                <TextBlock Text="Professional Bio" Style="{StaticResource SettingLabelStyle}" />
                                <TextBlock Text="A brief description of your responsibilities. Visible to other workspace members." Style="{StaticResource SettingHintStyle}" />
                            </StackPanel>

                            <StackPanel Grid.Column="1" Spacing="20">
                                <TextBox Style="{StaticResource StandardTextBoxStyle}" AcceptsReturn="True" TextWrapping="Wrap" MinHeight="100" />
                                
                                <Grid ColumnSpacing="24">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <ToggleSwitch Grid.Column="0" Header="Public Explorer Visibility" IsOn="True" />
                                    <ToggleSwitch Grid.Column="1" Header="Show Online Status" IsOn="True" />
                                </Grid>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="12" Margin="0,32,0,0">
                        <TextBlock Text="{Binding ProfileMessage}" Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center" Margin="0,0,16,0" />
                        <Button Style="{StaticResource GhostButtonStyle}" Content="Discard" />
                        <Button Style="{StaticResource PrimaryButtonStyle}" Content="Save Changes" Command="{Binding SaveProfileCommand}" Padding="24,8" />
                    </StackPanel>
                </StackPanel>

                <!-- â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â• -->
                <!-- SECURITY SECTION                                   -->
                <!-- â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â• -->
                <StackPanel x:Name="SecuritySection" Visibility="Collapsed">
                    <TextBlock Text="SECURITY &amp; 2FA" Style="{StaticResource SectionTitleStyle}" />
                    <TextBlock Text="Secure your account with two-factor authentication and manage active sessions across all devices." Style="{StaticResource SectionDescriptionStyle}" />

                    <!-- 2FA Status Row -->
                    <Border Style="{StaticResource SettingRowBorderStyle}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="2*" />
                                <ColumnDefinition Width="3*" />
                            </Grid.ColumnDefinitions>
                            
                            <StackPanel Spacing="8">
                                <TextBlock Text="Two-Factor Authentication" Style="{StaticResource SettingLabelStyle}" />
                                <TextBlock Text="Add an extra layer of security to your account." Style="{StaticResource SettingHintStyle}" />
                            </StackPanel>

                            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="16" VerticalAlignment="Center">
                                <ToggleSwitch IsOn="{Binding TwoFactorEnabled}" IsEnabled="False" Margin="0" />
                                <Border Background="#102ABD8F" BorderBrush="#302ABD8F" BorderThickness="1" CornerRadius="4" Padding="8,4" Visibility="{Binding TwoFactorEnabled, Converter={StaticResource BoolToVisibilityConverter}}">
                                    <TextBlock Text="PROTECTED" FontSize="11" FontWeight="Bold" Foreground="{StaticResource SuccessBrush}" CharacterSpacing="50" />
                                </Border>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- 2FA Setup Flow -->
                    <Border Style="{StaticResource SettingRowBorderStyle}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="2*" />
                                <ColumnDefinition Width="3*" />
                            </Grid.ColumnDefinitions>
                            
                            <StackPanel Spacing="8">
                                <TextBlock Text="Authenticator Setup" Style="{StaticResource SettingLabelStyle}" />
                                <TextBlock Text="Use an app like Google Authenticator or Authy to scan the QR code." Style="{StaticResource SettingHintStyle}" />
                            </StackPanel>

                            <StackPanel Grid.Column="1" Spacing="24">
                                <!-- QR and Key -->
                                <Grid ColumnSpacing="24">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    
                                    <Border Width="160" Height="160" Background="White" CornerRadius="8" Padding="12">
                                        <Image Source="{Binding TwoFactorQrImage}" Stretch="Uniform" />
                                    </Border>
                                    
                                    <StackPanel Grid.Column="1" Spacing="16" VerticalAlignment="Center">
                                        <StackPanel Spacing="6">
                                            <TextBlock Text="Manual Entry Key" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource TextSecondaryBrush}" />
                                            <Grid ColumnSpacing="8">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <TextBox Style="{StaticResource StandardTextBoxStyle}" IsReadOnly="True" Text="{Binding TwoFactorSecretDisplay}" FontFamily="Consolas" />
                                                <Button Grid.Column="1" Style="{StaticResource GhostButtonStyle}" Width="36" Height="36" Padding="0" Click="OnCopyTwoFactorKeyClick">
                                                    <FontIcon Glyph="&#xE8C8;" FontSize="14" />
                                                </Button>
                                            </Grid>
                                        </StackPanel>
                                        
                                        <StackPanel Spacing="6">
                                            <TextBlock Text="Verification Code" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource TextSecondaryBrush}" />
                                            <TextBox Style="{StaticResource StandardTextBoxStyle}" MaxLength="6" PlaceholderText="000000" Text="{Binding TwoFactorConfirmCode, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" FontFamily="Consolas" FontSize="18" CharacterSpacing="10" />
                                        </StackPanel>
                                    </StackPanel>
                                </Grid>

                                <!-- Actions -->
                                <Grid>
                                    <TextBlock Text="{Binding TwoFactorMessage}" Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center" />
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="12">
                                        <Button Style="{StaticResource OutlinedButtonStyle}" Content="Disable 2FA" Click="OnDisableTwoFactorClick" Foreground="{StaticResource DangerBrush}" />
                                        <Button Style="{StaticResource GhostButtonStyle}" Content="Generate Key" Command="{Binding StartTwoFactorSetupCommand}" IsEnabled="{Binding IsStartTwoFactorEnabled}" />
                                        <Button Style="{StaticResource PrimaryButtonStyle}" Content="Verify &amp; Save" Command="{Binding ConfirmTwoFactorSetupCommand}" />
                                    </StackPanel>
                                </Grid>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- Active Sessions Row -->
                    <Border Style="{StaticResource SettingRowBorderStyle}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="2*" />
                                <ColumnDefinition Width="3*" />
                            </Grid.ColumnDefinitions>
                            
                            <StackPanel Spacing="8">
                                <TextBlock Text="Active Sessions" Style="{StaticResource SettingLabelStyle}" />
                                <TextBlock Text="Devices currently logged into your account. Revoke any you don't recognize." Style="{StaticResource SettingHintStyle}" />
                            </StackPanel>

                            <StackPanel Grid.Column="1" Spacing="12">
                                <!-- Session 1 -->
                                <Border Background="{StaticResource CardBackgroundBrush}" BorderBrush="{StaticResource BorderDefaultBrush}" BorderThickness="1" CornerRadius="6" Padding="16,12" Translation="0,0,32">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Spacing="2">
                                            <StackPanel Orientation="Horizontal" Spacing="8">
                                                <TextBlock Text="Windows Desktop" FontSize="14" FontWeight="SemiBold" />
                                                <Border Background="#102ABD8F" Padding="6,2" CornerRadius="4">
                                                    <TextBlock Text="THIS DEVICE" FontSize="9" FontWeight="Bold" Foreground="{StaticResource SuccessBrush}" />
                                                </Border>
                                            </StackPanel>
                                            <TextBlock Text="Delhi, IN â€¢ Active now" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" />
                                        </StackPanel>
                                    </Grid>
                                </Border>
                                
                                <!-- Session 2 -->
                                <Border Background="{StaticResource CardBackgroundBrush}" BorderBrush="{StaticResource BorderDefaultBrush}" BorderThickness="1" CornerRadius="6" Padding="16,12" Translation="0,0,32">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Spacing="2">
                                            <TextBlock Text="MacBook Pro 16&quot;" FontSize="14" FontWeight="SemiBold" />
                                            <TextBlock Text="Mumbai, IN â€¢ Last active 4 hours ago" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" />
                                        </StackPanel>
                                        <Button Grid.Column="1" Style="{StaticResource GhostButtonStyle}" Content="Revoke" Foreground="{StaticResource DangerBrush}" VerticalAlignment="Center" />
                                    </Grid>
                                </Border>
                            </StackPanel>
                        </Grid>
                    </Border>
                </StackPanel>

                <!-- â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â• -->
                <!-- PASSWORD SECTION                                   -->
                <!-- â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â• -->
                <StackPanel x:Name="PasswordSection" Visibility="Collapsed">
                    <TextBlock Text="PASSWORD MANAGEMENT" Style="{StaticResource SectionTitleStyle}" />
                    <TextBlock Text="Update your account password. We recommend using a strong password manager." Style="{StaticResource SectionDescriptionStyle}" />

                    <!-- Password Fields -->
                    <Border Style="{StaticResource SettingRowBorderStyle}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="2*" />
                                <ColumnDefinition Width="3*" />
                            </Grid.ColumnDefinitions>
                            
                            <StackPanel Spacing="8">
                                <TextBlock Text="Change Password" Style="{StaticResource SettingLabelStyle}" />
                                <TextBlock Text="Ensure your new password is at least 8 characters long and contains a mix of letters, numbers, and symbols." Style="{StaticResource SettingHintStyle}" />
                            </StackPanel>

                            <StackPanel Grid.Column="1" Spacing="20">
                                <StackPanel Spacing="6">
                                    <TextBlock Text="Current Password" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" />
                                    <PasswordBox Password="{Binding ChangeCurrentPassword, Mode=TwoWay}" />
                                </StackPanel>

                                <StackPanel Spacing="6">
                                    <TextBlock Text="New Password" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" />
                                    <PasswordBox Password="{Binding ChangeNewPassword, Mode=TwoWay}" />
                                    
                                    <!-- Strength Indicator -->
                                    <Grid ColumnSpacing="8" Margin="0,4,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Rectangle Grid.Column="0" Height="2" Fill="{StaticResource AccentPrimaryBrush}" />
                                        <Rectangle Grid.Column="1" Height="2" Fill="{StaticResource AccentPrimaryBrush}" />
                                        <Rectangle Grid.Column="2" Height="2" Fill="{StaticResource BorderDefaultBrush}" />
                                        <Rectangle Grid.Column="3" Height="2" Fill="{StaticResource BorderDefaultBrush}" />
                                    </Grid>
                                    <TextBlock Text="Moderate strength" FontSize="10" Foreground="{StaticResource TextTertiaryBrush}" HorizontalAlignment="Right" />
                                </StackPanel>

                                <StackPanel Spacing="6">
                                    <TextBlock Text="Confirm New Password" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" />
                                    <PasswordBox Password="{Binding ChangeConfirmPassword, Mode=TwoWay}" />
                                </StackPanel>

                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="12">
                                    <TextBlock Text="{Binding ChangePasswordMessage}" Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center" />
                                    <Button Style="{StaticResource PrimaryButtonStyle}" Content="Update Password" Command="{Binding ChangePasswordCommand}" Padding="24,8" />
                                </StackPanel>
                            </StackPanel>
                        </Grid>
                    </Border>
                </StackPanel>

                <!-- â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â• -->
                <!-- APP LOCK SECTION                                   -->
                <!-- â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â• -->
                <StackPanel x:Name="AppLockSection" Visibility="Collapsed">
                    <TextBlock Text="APPLICATION LOCK" Style="{StaticResource SectionTitleStyle}" />
                    <TextBlock Text="Protect your local session with a 6-digit PIN. This is required whenever the app is left idle." Style="{StaticResource SectionDescriptionStyle}" />

                    <Border Style="{StaticResource SettingRowBorderStyle}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="2*" />
                                <ColumnDefinition Width="3*" />
                            </Grid.ColumnDefinitions>
                            
                            <StackPanel Spacing="8">
                                <TextBlock Text="PIN Configuration" Style="{StaticResource SettingLabelStyle}" />
                                <TextBlock Text="Manage your application lock settings." Style="{StaticResource SettingHintStyle}" />
                            </StackPanel>

                            <StackPanel Grid.Column="1" Spacing="24">
                                <!-- Status Overview -->
                                <Border Background="{StaticResource CardBackgroundBrush}" BorderBrush="{StaticResource BorderDefaultBrush}" BorderThickness="1" CornerRadius="6" Padding="20" Translation="0,0,32">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Spacing="4">
                                            <TextBlock Text="{Binding PasscodeStatusText}" FontSize="16" FontWeight="SemiBold" />
                                            <TextBlock Text="{Binding PasscodePrimaryActionText}" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" />
                                        </StackPanel>
                                        <Button Grid.Column="1" Style="{StaticResource OutlinedButtonStyle}" Content="{Binding PasscodePrimaryActionText}" Click="OnOpenAppLockEditorClick" VerticalAlignment="Center" />
                                    </Grid>
                                </Border>

                                <!-- Editor Panel -->
                                <Border Background="{StaticResource ElevatedCardBackgroundBrush}" BorderBrush="{StaticResource BorderDefaultBrush}" BorderThickness="1" CornerRadius="6" Padding="24" Visibility="{Binding ShowAppLockEditor, Converter={StaticResource BoolToVisibilityConverter}}">
                                    <StackPanel Spacing="20">
                                        <TextBlock Text="Update PIN" FontSize="16" FontWeight="SemiBold" />
                                        
                                        <StackPanel Spacing="6" Visibility="{Binding ShowPasscodeCurrentField, Converter={StaticResource BoolToVisibilityConverter}}">
                                            <TextBlock Text="Current PIN" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" />
                                            <PasswordBox x:Name="PasscodeCurrentBox" PasswordChanged="OnPasscodeFieldChanged" MaxLength="6" />
                                        </StackPanel>
                                        
                                        <Grid ColumnSpacing="16">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0" Spacing="6">
                                                <TextBlock Text="New PIN" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" />
                                                <PasswordBox x:Name="PasscodeNewBox" PasswordChanged="OnPasscodeFieldChanged" MaxLength="6" />
                                            </StackPanel>
                                            <StackPanel Grid.Column="1" Spacing="6">
                                                <TextBlock Text="Confirm PIN" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" />
                                                <PasswordBox x:Name="PasscodeConfirmBox" PasswordChanged="OnPasscodeFieldChanged" MaxLength="6" />
                                            </StackPanel>
                                        </Grid>

                                        <StackPanel Spacing="6" Visibility="{Binding ShowPasscodeRemoveTotpField, Converter={StaticResource BoolToVisibilityConverter}}">
                                            <TextBlock Text="Authenticator Code (For removal)" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" />
                                            <TextBox Style="{StaticResource StandardTextBoxStyle}" MaxLength="6" Text="{Binding PasscodeRemoveTotpCode, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" FontFamily="Consolas" />
                                        </StackPanel>

                                        <Grid>
                                            <TextBlock Text="{Binding PasscodeMessage}" Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center" />
                                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="12">
                                                <Button Style="{StaticResource GhostButtonStyle}" Content="Cancel" Click="OnCloseAppLockEditorClick" />
                                                <Button Style="{StaticResource OutlinedButtonStyle}" Content="Remove PIN" Foreground="{StaticResource DangerBrush}" Click="OnRemovePasscodeClick" Visibility="{Binding PasscodeIsConfigured, Converter={StaticResource BoolToVisibilityConverter}}" />
                                                <Button Style="{StaticResource PrimaryButtonStyle}" Content="Save PIN" Click="OnSavePasscodeClick" />
                                            </StackPanel>
                                        </Grid>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </Grid>
                    </Border>
                </StackPanel>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>



