пїњ<Page
    x:Class="PartFinder.Views.Pages.SuppliersPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Background="{StaticResource PageBackgroundBrush}">
        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <StackPanel Padding="24,20,24,32" Spacing="18" HorizontalAlignment="Stretch">
                <StackPanel.ChildrenTransitions>
                    <TransitionCollection>
                        <EntranceThemeTransition IsStaggeringEnabled="True" FromVerticalOffset="50" />
                    </TransitionCollection>
                </StackPanel.ChildrenTransitions>

                <!-- HEADER -->
                <Grid ColumnSpacing="12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Spacing="2">
                        <TextBlock Text="SUPPLIERS" FontSize="10" Foreground="{StaticResource AccentPrimaryBrush}" CharacterSpacing="100" FontWeight="SemiBold" />
                        <TextBlock Text="Supplier Management" FontSize="32" FontWeight="Light" CharacterSpacing="20" />
                        <TextBlock Text="Manage suppliers, track performance, lead times, and quality ratings." FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" />
                    </StackPanel>
                    <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                        <Button Style="{StaticResource OutlinedButtonStyle}" FontSize="12" Click="OnAddSupplierClick">
                            <StackPanel Orientation="Horizontal" Spacing="5">
                                <FontIcon Glyph="&#xE8FA;" FontSize="13" />
                                <TextBlock Text="Add Supplier" FontSize="12" />
                            </StackPanel>
                        </Button>
                        <Button Style="{StaticResource PrimaryButtonStyle}" FontSize="12" Click="OnExportListClick">
                            <StackPanel Orientation="Horizontal" Spacing="5">
                                <FontIcon Glyph="&#xE74E;" FontSize="13" />
                                <TextBlock Text="Export List" FontSize="12" />
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Grid>

                <!-- METRICS -->
                <Grid ColumnSpacing="14">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Background="{StaticResource CardBackgroundBrush}" BorderBrush="{StaticResource BorderDefaultBrush}" BorderThickness="1" CornerRadius="4" Padding="16,14" Translation="0,0,32">
                            <Border.Shadow><ThemeShadow/></Border.Shadow>
                            <StackPanel Spacing="8">
                            <StackPanel Spacing="2">
                                <TextBlock Text="ACTIVE SUPPLIERS" FontSize="9" Foreground="{StaticResource TextTertiaryBrush}" CharacterSpacing="60" FontWeight="SemiBold" />
                                <TextBlock Text="24" FontSize="32" FontWeight="Light" CharacterSpacing="20" />
                            </StackPanel>
                            <TextBlock Text="Verified &amp; active" FontSize="10" Foreground="{StaticResource SuccessBrush}" />
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="1" Background="{StaticResource CardBackgroundBrush}" BorderBrush="{StaticResource BorderDefaultBrush}" BorderThickness="1" CornerRadius="4" Padding="16,14" Translation="0,0,32">
                            <Border.Shadow><ThemeShadow/></Border.Shadow>
                            <StackPanel Spacing="8">
                            <StackPanel Spacing="2">
                                <TextBlock Text="AVG RATING" FontSize="9" Foreground="{StaticResource TextTertiaryBrush}" CharacterSpacing="60" FontWeight="SemiBold" />
                                <TextBlock Text="4.6/5.0" FontSize="32" FontWeight="Light" CharacterSpacing="20" />
                            </StackPanel>
                            <TextBlock Text="Quality &amp; reliability" FontSize="10" Foreground="{StaticResource SuccessBrush}" />
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="2" Background="{StaticResource CardBackgroundBrush}" BorderBrush="{StaticResource BorderDefaultBrush}" BorderThickness="1" CornerRadius="4" Padding="16,14" Translation="0,0,32">
                            <Border.Shadow><ThemeShadow/></Border.Shadow>
                            <StackPanel Spacing="8">
                            <StackPanel Spacing="2">
                                <TextBlock Text="ON-TIME DELIVERY" FontSize="9" Foreground="{StaticResource TextTertiaryBrush}" CharacterSpacing="60" FontWeight="SemiBold" />
                                <TextBlock Text="94.2%" FontSize="32" FontWeight="Light" CharacterSpacing="20" />
                            </StackPanel>
                            <TextBlock Text="Average performance" FontSize="10" Foreground="{StaticResource SuccessBrush}" />
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="3" Background="{StaticResource CardBackgroundBrush}" BorderBrush="{StaticResource BorderDefaultBrush}" BorderThickness="1" CornerRadius="4" Padding="16,14" Translation="0,0,32">
                            <Border.Shadow><ThemeShadow/></Border.Shadow>
                            <StackPanel Spacing="8">
                            <StackPanel Spacing="2">
                                <TextBlock Text="TOTAL SPEND" FontSize="9" Foreground="{StaticResource TextTertiaryBrush}" CharacterSpacing="60" FontWeight="SemiBold" />
                                <TextBlock Text="$8.2M" FontSize="32" FontWeight="Light" CharacterSpacing="20" />
                            </StackPanel>
                            <TextBlock Text="YTD procurement" FontSize="10" Foreground="{StaticResource SuccessBrush}" />
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- SEARCH & FILTER -->
                <Border Background="{StaticResource CardBackgroundBrush}" BorderBrush="{StaticResource BorderDefaultBrush}" BorderThickness="1" CornerRadius="4" Padding="14,10" Translation="0,0,32">
                            <Border.Shadow><ThemeShadow/></Border.Shadow>
                            <Grid ColumnSpacing="10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon Glyph="&#xE721;" FontSize="12" Foreground="{StaticResource TextTertiaryBrush}" VerticalAlignment="Center" />
                            <TextBox BorderThickness="0" Background="Transparent" PlaceholderText="Search suppliers..." FontSize="12" MinWidth="240" VerticalAlignment="Center" />
                        </StackPanel>

                        <ComboBox Grid.Column="1" MinWidth="140" FontSize="11" PlaceholderText="Category" />
                        <ComboBox Grid.Column="2" MinWidth="140" FontSize="11" PlaceholderText="Rating" />
                    </Grid>
                </Border>

                <!-- SUPPLIERS TABLE -->
                <Border Background="{StaticResource CardBackgroundBrush}" BorderBrush="{StaticResource BorderDefaultBrush}" BorderThickness="1" CornerRadius="4" Padding="0" Translation="0,0,32">
                            <Border.Shadow><ThemeShadow/></Border.Shadow>
                            <StackPanel>
                        <!-- Header -->
                        <Grid Padding="14,10" Background="{StaticResource GridHeaderBackgroundBrush}" ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="2*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="SUPPLIER NAME" FontSize="9" Foreground="{StaticResource TextTertiaryBrush}" CharacterSpacing="60" FontWeight="SemiBold" />
                            <TextBlock Grid.Column="1" Text="CATEGORY" FontSize="9" Foreground="{StaticResource TextTertiaryBrush}" CharacterSpacing="60" FontWeight="SemiBold" />
                            <TextBlock Grid.Column="2" Text="RATING" FontSize="9" Foreground="{StaticResource TextTertiaryBrush}" CharacterSpacing="60" FontWeight="SemiBold" />
                            <TextBlock Grid.Column="3" Text="LEAD TIME" FontSize="9" Foreground="{StaticResource TextTertiaryBrush}" CharacterSpacing="60" FontWeight="SemiBold" />
                            <TextBlock Grid.Column="4" Text="YTD SPEND" FontSize="9" Foreground="{StaticResource TextTertiaryBrush}" CharacterSpacing="60" FontWeight="SemiBold" />
                            <TextBlock Grid.Column="5" Text="ACTION" FontSize="9" Foreground="{StaticResource TextTertiaryBrush}" CharacterSpacing="60" FontWeight="SemiBold" MinWidth="60" />
                        </Grid>

                        <!-- Row 1 -->
                        <Border Padding="14,10" BorderBrush="{StaticResource BorderDefaultBrush}" BorderThickness="0,0,0,1">
                            <Grid ColumnSpacing="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="2*" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <StackPanel Spacing="2" VerticalAlignment="Center">
                                    <TextBlock Text="Global Parts Inc" FontSize="12" FontWeight="SemiBold" />
                                    <TextBlock Text="contact@globalparts.com" FontSize="10" Foreground="{StaticResource TextTertiaryBrush}" />
                                </StackPanel>

                                <TextBlock Grid.Column="1" Text="Engine Parts" FontSize="11" VerticalAlignment="Center" />
                                <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
                                    <TextBlock Text="4.8" FontSize="11" FontWeight="SemiBold" />
                                    <TextBlock Text="√ҐЋЬвА¶√ҐЋЬвА¶√ҐЋЬвА¶√ҐЋЬвА¶√ҐЋЬвА¶" FontSize="10" Foreground="{StaticResource WarningBrush}" />
                                </StackPanel>
                                <TextBlock Grid.Column="3" Text="8-12 days" FontSize="11" VerticalAlignment="Center" />
                                <TextBlock Grid.Column="4" Text="$2.4M" FontSize="11" FontWeight="SemiBold" VerticalAlignment="Center" />

                                <Button Grid.Column="5" Style="{StaticResource GhostButtonStyle}" Padding="8,4" FontSize="11" Click="OnViewSupplierClick">
                                    <StackPanel Orientation="Horizontal" Spacing="4">
                                        <FontIcon Glyph="&#xE70F;" FontSize="11" />
                                        <TextBlock Text="View" FontSize="11" />
                                    </StackPanel>
                                </Button>
                            </Grid>
                        </Border>

                        <!-- Row 2 -->
                        <Border Padding="14,10" BorderBrush="{StaticResource BorderDefaultBrush}" BorderThickness="0,0,0,1">
                            <Grid ColumnSpacing="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="2*" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <StackPanel Spacing="2" VerticalAlignment="Center">
                                    <TextBlock Text="Premium Motors" FontSize="12" FontWeight="SemiBold" />
                                    <TextBlock Text="sales@premiummotors.com" FontSize="10" Foreground="{StaticResource TextTertiaryBrush}" />
                                </StackPanel>

                                <TextBlock Grid.Column="1" Text="Fuel Systems" FontSize="11" VerticalAlignment="Center" />
                                <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
                                    <TextBlock Text="4.5" FontSize="11" FontWeight="SemiBold" />
                                    <TextBlock Text="√ҐЋЬвА¶√ҐЋЬвА¶√ҐЋЬвА¶√ҐЋЬвА¶√ҐЋЬвА†" FontSize="10" Foreground="{StaticResource WarningBrush}" />
                                </StackPanel>
                                <TextBlock Grid.Column="3" Text="10-14 days" FontSize="11" VerticalAlignment="Center" />
                                <TextBlock Grid.Column="4" Text="$1.8M" FontSize="11" FontWeight="SemiBold" VerticalAlignment="Center" />

                                <Button Grid.Column="5" Style="{StaticResource GhostButtonStyle}" Padding="8,4" FontSize="11" Click="OnViewSupplierClick">
                                    <StackPanel Orientation="Horizontal" Spacing="4">
                                        <FontIcon Glyph="&#xE70F;" FontSize="11" />
                                        <TextBlock Text="View" FontSize="11" />
                                    </StackPanel>
                                </Button>
                            </Grid>
                        </Border>

                        <!-- Row 3 -->
                        <Border Padding="14,10">
                            <Grid ColumnSpacing="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="2*" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <StackPanel Spacing="2" VerticalAlignment="Center">
                                    <TextBlock Text="Tech Components Ltd" FontSize="12" FontWeight="SemiBold" />
                                    <TextBlock Text="info@techcomponents.com" FontSize="10" Foreground="{StaticResource TextTertiaryBrush}" />
                                </StackPanel>

                                <TextBlock Grid.Column="1" Text="Electronics" FontSize="11" VerticalAlignment="Center" />
                                <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
                                    <TextBlock Text="4.3" FontSize="11" FontWeight="SemiBold" />
                                    <TextBlock Text="√ҐЋЬвА¶√ҐЋЬвА¶√ҐЋЬвА¶√ҐЋЬвА¶√ҐЋЬвА†" FontSize="10" Foreground="{StaticResource WarningBrush}" />
                                </StackPanel>
                                <TextBlock Grid.Column="3" Text="5-8 days" FontSize="11" VerticalAlignment="Center" />
                                <TextBlock Grid.Column="4" Text="$1.2M" FontSize="11" FontWeight="SemiBold" VerticalAlignment="Center" />

                                <Button Grid.Column="5" Style="{StaticResource GhostButtonStyle}" Padding="8,4" FontSize="11" Click="OnViewSupplierClick">
                                    <StackPanel Orientation="Horizontal" Spacing="4">
                                        <FontIcon Glyph="&#xE70F;" FontSize="11" />
                                        <TextBlock Text="View" FontSize="11" />
                                    </StackPanel>
                                </Button>
                            </Grid>
                        </Border>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>



