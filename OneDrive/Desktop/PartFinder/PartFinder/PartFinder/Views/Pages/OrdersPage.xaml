<Page
    x:Class="PartFinder.Views.Pages.OrdersPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Background="{StaticResource PageBackgroundBrush}">
        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <StackPanel Padding="24,20,24,32" Spacing="18" HorizontalAlignment="Stretch">
                <StackPanel.ChildrenTransitions>
                    <TransitionCollection>
                        <EntranceThemeTransition IsStaggeringEnabled="True" FromVerticalOffset="50" />
                    </TransitionCollection>
                </StackPanel.ChildrenTransitions>

                <!-- HEADER -->
                <Grid ColumnSpacing="12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Spacing="2">
                        <TextBlock Text="PROCUREMENT" FontSize="10" Foreground="{StaticResource AccentPrimaryBrush}" CharacterSpacing="100" FontWeight="SemiBold" />
                        <TextBlock Text="Orders &amp; Procurement" FontSize="32" FontWeight="Light" CharacterSpacing="20" />
                        <TextBlock Text="Manage purchase orders, track deliveries, and monitor procurement spend across all suppliers." FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" />
                    </StackPanel>
                    <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                        <Button Style="{StaticResource GhostButtonStyle}" FontSize="12" Click="OnExportOrdersClick">
                            <StackPanel Orientation="Horizontal" Spacing="5">
                                <FontIcon Glyph="&#xE74E;" FontSize="13" />
                                <TextBlock Text="Export" FontSize="12" />
                            </StackPanel>
                        </Button>
                        <Button Style="{StaticResource PrimaryButtonStyle}" FontSize="12" Click="OnNewOrderClick">
                            <StackPanel Orientation="Horizontal" Spacing="5">
                                <FontIcon Glyph="&#xE710;" FontSize="13" />
                                <TextBlock Text="New Order" FontSize="12" />
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Grid>

                <!-- KPI CARDS -->
                <Grid ColumnSpacing="14">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Background="{StaticResource CardBackgroundBrush}" BorderBrush="{StaticResource BorderDefaultBrush}" BorderThickness="1" CornerRadius="4" Padding="16,14" Translation="0,0,32">
                            <Border.Shadow><ThemeShadow/></Border.Shadow>
                            <StackPanel Spacing="8">
                            <Grid>
                                <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                                <StackPanel Spacing="2">
                                    <TextBlock Text="OPEN ORDERS" FontSize="9" Foreground="{StaticResource TextTertiaryBrush}" CharacterSpacing="60" FontWeight="SemiBold" />
                                    <TextBlock Text="18" FontSize="28" FontWeight="Bold" />
                                </StackPanel>
                                <Border Grid.Column="1" Width="44" Height="44" CornerRadius="4" Background="#101F7AE0" VerticalAlignment="Top">
                                    <FontIcon Glyph="&#xE8B5;" FontSize="20" Foreground="{StaticResource AccentPrimaryBrush}" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                </Border>
                            </Grid>
                            <TextBlock Text="Awaiting delivery" FontSize="10" Foreground="{StaticResource TextSecondaryBrush}" />
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="1" Background="{StaticResource CardBackgroundBrush}" BorderBrush="{StaticResource BorderDefaultBrush}" BorderThickness="1" CornerRadius="4" Padding="16,14" Translation="0,0,32">
                            <Border.Shadow><ThemeShadow/></Border.Shadow>
                            <StackPanel Spacing="8">
                            <Grid>
                                <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                                <StackPanel Spacing="2">
                                    <TextBlock Text="IN TRANSIT" FontSize="9" Foreground="{StaticResource TextTertiaryBrush}" CharacterSpacing="60" FontWeight="SemiBold" />
                                    <TextBlock Text="7" FontSize="28" FontWeight="Bold" Foreground="{StaticResource WarningBrush}" />
                                </StackPanel>
                                <Border Grid.Column="1" Width="44" Height="44" CornerRadius="4" Background="#10FEBC2E" VerticalAlignment="Top">
                                    <FontIcon Glyph="&#xE7C0;" FontSize="20" Foreground="{StaticResource WarningBrush}" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                </Border>
                            </Grid>
                            <TextBlock Text="Shipped, en route" FontSize="10" Foreground="{StaticResource WarningBrush}" />
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="2" Background="{StaticResource CardBackgroundBrush}" BorderBrush="{StaticResource BorderDefaultBrush}" BorderThickness="1" CornerRadius="4" Padding="16,14" Translation="0,0,32">
                            <Border.Shadow><ThemeShadow/></Border.Shadow>
                            <StackPanel Spacing="8">
                            <Grid>
                                <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                                <StackPanel Spacing="2">
                                    <TextBlock Text="DELIVERED (MTD)" FontSize="9" Foreground="{StaticResource TextTertiaryBrush}" CharacterSpacing="60" FontWeight="SemiBold" />
                                    <TextBlock Text="43" FontSize="28" FontWeight="Bold" Foreground="{StaticResource SuccessBrush}" />
                                </StackPanel>
                                <Border Grid.Column="1" Width="44" Height="44" CornerRadius="4" Background="#102ABD8F" VerticalAlignment="Top">
                                    <FontIcon Glyph="&#xE73E;" FontSize="20" Foreground="{StaticResource SuccessBrush}" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                </Border>
                            </Grid>
                            <TextBlock Text="This month" FontSize="10" Foreground="{StaticResource SuccessBrush}" />
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="3" Background="{StaticResource CardBackgroundBrush}" BorderBrush="{StaticResource BorderDefaultBrush}" BorderThickness="1" CornerRadius="4" Padding="16,14" Translation="0,0,32">
                            <Border.Shadow><ThemeShadow/></Border.Shadow>
                            <StackPanel Spacing="8">
                            <Grid>
                                <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                                <StackPanel Spacing="2">
                                    <TextBlock Text="TOTAL SPEND (MTD)" FontSize="9" Foreground="{StaticResource TextTertiaryBrush}" CharacterSpacing="60" FontWeight="SemiBold" />
                                    <TextBlock Text="$342K" FontSize="28" FontWeight="Bold" />
                                </StackPanel>
                                <Border Grid.Column="1" Width="44" Height="44" CornerRadius="4" Background="#108B5CF6" VerticalAlignment="Top">
                                    <FontIcon Glyph="&#xE8B5;" FontSize="20" Foreground="#8B5CF6" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                </Border>
                            </Grid>
                            <TextBlock Text="Month to date" FontSize="10" Foreground="{StaticResource TextSecondaryBrush}" />
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- FILTER BAR -->
                <Border Background="{StaticResource CardBackgroundBrush}" BorderBrush="{StaticResource BorderDefaultBrush}" BorderThickness="1" CornerRadius="4" Padding="14,10" Translation="0,0,32">
                            <Border.Shadow><ThemeShadow/></Border.Shadow>
                            <Grid ColumnSpacing="10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon Glyph="&#xE721;" FontSize="12" Foreground="{StaticResource TextTertiaryBrush}" VerticalAlignment="Center" />
                            <TextBox BorderThickness="0" Background="Transparent" PlaceholderText="Search orders by ID or supplier..." FontSize="12" MinWidth="240" VerticalAlignment="Center" />
                        </StackPanel>
                        <ComboBox Grid.Column="1" MinWidth="130" FontSize="11" PlaceholderText="Status" HorizontalAlignment="Stretch">
                            <ComboBoxItem Content="All Status" />
                            <ComboBoxItem Content="Pending" />
                            <ComboBoxItem Content="In Transit" />
                            <ComboBoxItem Content="Delivered" />
                            <ComboBoxItem Content="Cancelled" />
                        </ComboBox>
                        <ComboBox Grid.Column="2" MinWidth="130" FontSize="11" PlaceholderText="Supplier" HorizontalAlignment="Stretch">
                            <ComboBoxItem Content="All Suppliers" />
                            <ComboBoxItem Content="Global Parts Inc" />
                            <ComboBoxItem Content="Premium Motors" />
                            <ComboBoxItem Content="Tech Components" />
                        </ComboBox>
                        <Button Grid.Column="3" Style="{StaticResource GhostButtonStyle}" Content="Clear" FontSize="11" />
                    </Grid>
                </Border>

                <!-- ORDERS TABLE -->
                <Border Background="{StaticResource CardBackgroundBrush}" BorderBrush="{StaticResource BorderDefaultBrush}" BorderThickness="1" CornerRadius="4" Padding="0" Translation="0,0,32">
                            <Border.Shadow><ThemeShadow/></Border.Shadow>
                            <StackPanel>
                        <Grid Padding="14,10" Background="{StaticResource GridHeaderBackgroundBrush}" ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="1.5*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="ORDER ID" FontSize="9" Foreground="{StaticResource TextTertiaryBrush}" CharacterSpacing="60" FontWeight="SemiBold" />
                            <TextBlock Grid.Column="1" Text="SUPPLIER" FontSize="9" Foreground="{StaticResource TextTertiaryBrush}" CharacterSpacing="60" FontWeight="SemiBold" />
                            <TextBlock Grid.Column="2" Text="PARTS" FontSize="9" Foreground="{StaticResource TextTertiaryBrush}" CharacterSpacing="60" FontWeight="SemiBold" />
                            <TextBlock Grid.Column="3" Text="AMOUNT" FontSize="9" Foreground="{StaticResource TextTertiaryBrush}" CharacterSpacing="60" FontWeight="SemiBold" />
                            <TextBlock Grid.Column="4" Text="ORDER DATE" FontSize="9" Foreground="{StaticResource TextTertiaryBrush}" CharacterSpacing="60" FontWeight="SemiBold" />
                            <TextBlock Grid.Column="5" Text="STATUS" FontSize="9" Foreground="{StaticResource TextTertiaryBrush}" CharacterSpacing="60" FontWeight="SemiBold" />
                            <TextBlock Grid.Column="6" Text="ACTION" FontSize="9" Foreground="{StaticResource TextTertiaryBrush}" CharacterSpacing="60" FontWeight="SemiBold" MinWidth="60" />
                        </Grid>

                        <!-- Order rows -->
                        <Grid Padding="14,12" ColumnSpacing="12" BorderBrush="{StaticResource BorderDefaultBrush}" BorderThickness="0,1,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="1.5*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="PO-2024-0142" FontSize="11" FontWeight="SemiBold" VerticalAlignment="Center" />
                            <TextBlock Grid.Column="1" Text="Global Parts Inc" FontSize="11" VerticalAlignment="Center" />
                            <TextBlock Grid.Column="2" Text="Turbocharger Ã—50" FontSize="11" VerticalAlignment="Center" />
                            <TextBlock Grid.Column="3" Text="$62,500" FontSize="11" FontWeight="SemiBold" VerticalAlignment="Center" />
                            <TextBlock Grid.Column="4" Text="Apr 20, 2026" FontSize="11" VerticalAlignment="Center" />
                            <Border Grid.Column="5" CornerRadius="6" Padding="8,4" Background="#10FEBC2E" VerticalAlignment="Center" HorizontalAlignment="Left">
                                <TextBlock Text="In Transit" FontSize="9" Foreground="{StaticResource WarningBrush}" FontWeight="SemiBold" />
                            </Border>
                            <Button Grid.Column="6" Style="{StaticResource GhostButtonStyle}" Padding="8,4" FontSize="11" Click="OnViewOrderClick">
                                <StackPanel Orientation="Horizontal" Spacing="4">
                                    <FontIcon Glyph="&#xE70F;" FontSize="11" />
                                    <TextBlock Text="View" FontSize="11" />
                                </StackPanel>
                            </Button>
                        </Grid>

                        <Grid Padding="14,12" ColumnSpacing="12" BorderBrush="{StaticResource BorderDefaultBrush}" BorderThickness="0,1,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="1.5*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="PO-2024-0141" FontSize="11" FontWeight="SemiBold" VerticalAlignment="Center" />
                            <TextBlock Grid.Column="1" Text="Premium Motors" FontSize="11" VerticalAlignment="Center" />
                            <TextBlock Grid.Column="2" Text="Fuel Injector Ã—100" FontSize="11" VerticalAlignment="Center" />
                            <TextBlock Grid.Column="3" Text="$45,000" FontSize="11" FontWeight="SemiBold" VerticalAlignment="Center" />
                            <TextBlock Grid.Column="4" Text="Apr 18, 2026" FontSize="11" VerticalAlignment="Center" />
                            <Border Grid.Column="5" CornerRadius="6" Padding="8,4" Background="#101F7AE0" VerticalAlignment="Center" HorizontalAlignment="Left">
                                <TextBlock Text="Pending" FontSize="9" Foreground="{StaticResource AccentPrimaryBrush}" FontWeight="SemiBold" />
                            </Border>
                            <Button Grid.Column="6" Style="{StaticResource GhostButtonStyle}" Padding="8,4" FontSize="11" Click="OnViewOrderClick">
                                <StackPanel Orientation="Horizontal" Spacing="4">
                                    <FontIcon Glyph="&#xE70F;" FontSize="11" />
                                    <TextBlock Text="View" FontSize="11" />
                                </StackPanel>
                            </Button>
                        </Grid>

                        <Grid Padding="14,12" ColumnSpacing="12" BorderBrush="{StaticResource BorderDefaultBrush}" BorderThickness="0,1,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="1.5*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="PO-2024-0138" FontSize="11" FontWeight="SemiBold" VerticalAlignment="Center" />
                            <TextBlock Grid.Column="1" Text="Tech Components" FontSize="11" VerticalAlignment="Center" />
                            <TextBlock Grid.Column="2" Text="Valve Assembly Ã—200" FontSize="11" VerticalAlignment="Center" />
                            <TextBlock Grid.Column="3" Text="$64,000" FontSize="11" FontWeight="SemiBold" VerticalAlignment="Center" />
                            <TextBlock Grid.Column="4" Text="Apr 15, 2026" FontSize="11" VerticalAlignment="Center" />
                            <Border Grid.Column="5" CornerRadius="6" Padding="8,4" Background="#102ABD8F" VerticalAlignment="Center" HorizontalAlignment="Left">
                                <TextBlock Text="Delivered" FontSize="9" Foreground="{StaticResource SuccessBrush}" FontWeight="SemiBold" />
                            </Border>
                            <Button Grid.Column="6" Style="{StaticResource GhostButtonStyle}" Padding="8,4" FontSize="11" Click="OnViewOrderClick">
                                <StackPanel Orientation="Horizontal" Spacing="4">
                                    <FontIcon Glyph="&#xE70F;" FontSize="11" />
                                    <TextBlock Text="View" FontSize="11" />
                                </StackPanel>
                            </Button>
                        </Grid>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>



