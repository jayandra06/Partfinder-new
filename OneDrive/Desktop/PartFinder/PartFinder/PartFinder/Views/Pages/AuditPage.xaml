<Page
    x:Class="PartFinder.Views.Pages.AuditPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Background="{StaticResource PageBackgroundBrush}">
        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <StackPanel Padding="24,20,24,32" Spacing="18" HorizontalAlignment="Stretch">
                <StackPanel.ChildrenTransitions>
                    <TransitionCollection>
                        <EntranceThemeTransition IsStaggeringEnabled="True" FromVerticalOffset="50" />
                    </TransitionCollection>
                </StackPanel.ChildrenTransitions>

                <!-- HEADER -->
                <Grid ColumnSpacing="12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Spacing="2">
                        <TextBlock Text="AUDIT" FontSize="10" Foreground="{StaticResource AccentPrimaryBrush}" CharacterSpacing="100" FontWeight="SemiBold" />
                        <TextBlock Text="Audit &amp; History" FontSize="32" FontWeight="Light" CharacterSpacing="20" />
                        <TextBlock Text="Complete audit trail of all inventory changes, user actions, and system events for compliance and traceability." FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" />
                    </StackPanel>
                    <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                        <Button Style="{StaticResource GhostButtonStyle}" FontSize="12" Click="OnFilterClick">
                            <StackPanel Orientation="Horizontal" Spacing="5">
                                <FontIcon Glyph="&#xE71C;" FontSize="13" />
                                <TextBlock Text="Filter" FontSize="12" />
                            </StackPanel>
                        </Button>
                        <Button Style="{StaticResource OutlinedButtonStyle}" FontSize="12" Click="OnExportAuditClick">
                            <StackPanel Orientation="Horizontal" Spacing="5">
                                <FontIcon Glyph="&#xE74E;" FontSize="13" />
                                <TextBlock Text="Export Log" FontSize="12" />
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Grid>

                <!-- KPI CARDS -->
                <Grid ColumnSpacing="14">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Background="{StaticResource CardBackgroundBrush}" BorderBrush="{StaticResource BorderDefaultBrush}" BorderThickness="1" CornerRadius="4" Padding="16,14" Translation="0,0,32">
                            <Border.Shadow><ThemeShadow/></Border.Shadow>
                            <StackPanel Spacing="8">
                            <Grid>
                                <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                                <StackPanel Spacing="2">
                                    <TextBlock Text="EVENTS TODAY" FontSize="9" Foreground="{StaticResource TextTertiaryBrush}" CharacterSpacing="60" FontWeight="SemiBold" />
                                    <TextBlock Text="284" FontSize="28" FontWeight="Bold" />
                                </StackPanel>
                                <Border Grid.Column="1" Width="44" Height="44" CornerRadius="4" Background="#101F7AE0" VerticalAlignment="Top">
                                    <FontIcon Glyph="&#xE823;" FontSize="20" Foreground="{StaticResource AccentPrimaryBrush}" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                </Border>
                            </Grid>
                            <TextBlock Text="All system events" FontSize="10" Foreground="{StaticResource TextSecondaryBrush}" />
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="1" Background="{StaticResource CardBackgroundBrush}" BorderBrush="{StaticResource BorderDefaultBrush}" BorderThickness="1" CornerRadius="4" Padding="16,14" Translation="0,0,32">
                            <Border.Shadow><ThemeShadow/></Border.Shadow>
                            <StackPanel Spacing="8">
                            <Grid>
                                <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                                <StackPanel Spacing="2">
                                    <TextBlock Text="STOCK CHANGES" FontSize="9" Foreground="{StaticResource TextTertiaryBrush}" CharacterSpacing="60" FontWeight="SemiBold" />
                                    <TextBlock Text="142" FontSize="28" FontWeight="Bold" Foreground="{StaticResource SuccessBrush}" />
                                </StackPanel>
                                <Border Grid.Column="1" Width="44" Height="44" CornerRadius="4" Background="#102ABD8F" VerticalAlignment="Top">
                                    <FontIcon Glyph="&#xE80A;" FontSize="20" Foreground="{StaticResource SuccessBrush}" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                </Border>
                            </Grid>
                            <TextBlock Text="Inventory updates" FontSize="10" Foreground="{StaticResource SuccessBrush}" />
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="2" Background="{StaticResource CardBackgroundBrush}" BorderBrush="{StaticResource BorderDefaultBrush}" BorderThickness="1" CornerRadius="4" Padding="16,14" Translation="0,0,32">
                            <Border.Shadow><ThemeShadow/></Border.Shadow>
                            <StackPanel Spacing="8">
                            <Grid>
                                <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                                <StackPanel Spacing="2">
                                    <TextBlock Text="USER ACTIONS" FontSize="9" Foreground="{StaticResource TextTertiaryBrush}" CharacterSpacing="60" FontWeight="SemiBold" />
                                    <TextBlock Text="97" FontSize="28" FontWeight="Bold" Foreground="{StaticResource WarningBrush}" />
                                </StackPanel>
                                <Border Grid.Column="1" Width="44" Height="44" CornerRadius="4" Background="#10FEBC2E" VerticalAlignment="Top">
                                    <FontIcon Glyph="&#xE77B;" FontSize="20" Foreground="{StaticResource WarningBrush}" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                </Border>
                            </Grid>
                            <TextBlock Text="Login, edits, exports" FontSize="10" Foreground="{StaticResource WarningBrush}" />
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="3" Background="{StaticResource CardBackgroundBrush}" BorderBrush="{StaticResource BorderDefaultBrush}" BorderThickness="1" CornerRadius="4" Padding="16,14" Translation="0,0,32">
                            <Border.Shadow><ThemeShadow/></Border.Shadow>
                            <StackPanel Spacing="8">
                            <Grid>
                                <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                                <StackPanel Spacing="2">
                                    <TextBlock Text="SYSTEM EVENTS" FontSize="9" Foreground="{StaticResource TextTertiaryBrush}" CharacterSpacing="60" FontWeight="SemiBold" />
                                    <TextBlock Text="45" FontSize="28" FontWeight="Bold" />
                                </StackPanel>
                                <Border Grid.Column="1" Width="44" Height="44" CornerRadius="4" Background="#108B5CF6" VerticalAlignment="Top">
                                    <FontIcon Glyph="&#xE9D9;" FontSize="20" Foreground="#8B5CF6" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                </Border>
                            </Grid>
                            <TextBlock Text="Sync, imports, exports" FontSize="10" Foreground="{StaticResource TextSecondaryBrush}" />
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- SEARCH & DATE FILTER -->
                <Border Background="{StaticResource CardBackgroundBrush}" BorderBrush="{StaticResource BorderDefaultBrush}" BorderThickness="1" CornerRadius="4" Padding="14,10" Translation="0,0,32">
                            <Border.Shadow><ThemeShadow/></Border.Shadow>
                            <Grid ColumnSpacing="10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon Glyph="&#xE721;" FontSize="12" Foreground="{StaticResource TextTertiaryBrush}" VerticalAlignment="Center" />
                            <TextBox BorderThickness="0" Background="Transparent" PlaceholderText="Search by user, action, or part..." FontSize="12" MinWidth="240" VerticalAlignment="Center" />
                        </StackPanel>
                        <ComboBox Grid.Column="1" MinWidth="130" FontSize="11" PlaceholderText="Event Type" HorizontalAlignment="Stretch">
                            <ComboBoxItem Content="All Events" />
                            <ComboBoxItem Content="Stock Changes" />
                            <ComboBoxItem Content="User Actions" />
                            <ComboBoxItem Content="System Events" />
                            <ComboBoxItem Content="Alerts" />
                        </ComboBox>
                        <ComboBox Grid.Column="2" MinWidth="130" FontSize="11" PlaceholderText="User" HorizontalAlignment="Stretch">
                            <ComboBoxItem Content="All Users" />
                            <ComboBoxItem Content="Sahil Ibrahim" />
                            <ComboBoxItem Content="Admin" />
                            <ComboBoxItem Content="System" />
                        </ComboBox>
                        <ComboBox Grid.Column="3" MinWidth="130" FontSize="11" PlaceholderText="Date Range" HorizontalAlignment="Stretch">
                            <ComboBoxItem Content="Today" />
                            <ComboBoxItem Content="Last 7 days" />
                            <ComboBoxItem Content="Last 30 days" />
                            <ComboBoxItem Content="All time" />
                        </ComboBox>
                    </Grid>
                </Border>

                <!-- AUDIT LOG TABLE -->
                <Border Background="{StaticResource CardBackgroundBrush}" BorderBrush="{StaticResource BorderDefaultBrush}" BorderThickness="1" CornerRadius="4" Padding="0" Translation="0,0,32">
                            <Border.Shadow><ThemeShadow/></Border.Shadow>
                            <StackPanel>
                        <Grid Padding="14,10" Background="{StaticResource GridHeaderBackgroundBrush}" ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="1.5*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="TYPE" FontSize="9" Foreground="{StaticResource TextTertiaryBrush}" CharacterSpacing="60" FontWeight="SemiBold" MinWidth="80" />
                            <TextBlock Grid.Column="1" Text="ACTION" FontSize="9" Foreground="{StaticResource TextTertiaryBrush}" CharacterSpacing="60" FontWeight="SemiBold" />
                            <TextBlock Grid.Column="2" Text="DETAILS" FontSize="9" Foreground="{StaticResource TextTertiaryBrush}" CharacterSpacing="60" FontWeight="SemiBold" />
                            <TextBlock Grid.Column="3" Text="USER" FontSize="9" Foreground="{StaticResource TextTertiaryBrush}" CharacterSpacing="60" FontWeight="SemiBold" />
                            <TextBlock Grid.Column="4" Text="TIMESTAMP" FontSize="9" Foreground="{StaticResource TextTertiaryBrush}" CharacterSpacing="60" FontWeight="SemiBold" />
                            <TextBlock Grid.Column="5" Text="INFO" FontSize="9" Foreground="{StaticResource TextTertiaryBrush}" CharacterSpacing="60" FontWeight="SemiBold" MinWidth="50" />
                        </Grid>

                        <!-- Row 1 - Stock Change -->
                        <Grid Padding="14,12" ColumnSpacing="12" BorderBrush="{StaticResource BorderDefaultBrush}" BorderThickness="0,1,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="1.5*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <Border CornerRadius="6" Padding="6,3" Background="#102ABD8F" VerticalAlignment="Center" MinWidth="80">
                                <TextBlock Text="STOCK" FontSize="9" Foreground="{StaticResource SuccessBrush}" FontWeight="SemiBold" HorizontalAlignment="Center" />
                            </Border>
                            <TextBlock Grid.Column="1" Text="Stock Added" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center" />
                            <TextBlock Grid.Column="2" Text="Turbocharger Assembly +50 units" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center" />
                            <TextBlock Grid.Column="3" Text="Sahil Ibrahim" FontSize="11" VerticalAlignment="Center" />
                            <TextBlock Grid.Column="4" Text="Today 14:32" FontSize="11" Foreground="{StaticResource TextTertiaryBrush}" VerticalAlignment="Center" />
                            <Button Grid.Column="5" Style="{StaticResource GhostButtonStyle}" Padding="6,4" FontSize="11" Click="OnViewDetailClick">
                                <FontIcon Glyph="&#xE946;" FontSize="12" />
                            </Button>
                        </Grid>

                        <!-- Row 2 - User Action -->
                        <Grid Padding="14,12" ColumnSpacing="12" BorderBrush="{StaticResource BorderDefaultBrush}" BorderThickness="0,1,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="1.5*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <Border CornerRadius="6" Padding="6,3" Background="#10FEBC2E" VerticalAlignment="Center" MinWidth="80">
                                <TextBlock Text="USER" FontSize="9" Foreground="{StaticResource WarningBrush}" FontWeight="SemiBold" HorizontalAlignment="Center" />
                            </Border>
                            <TextBlock Grid.Column="1" Text="Template Edited" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center" />
                            <TextBlock Grid.Column="2" Text="Fuel Injector template â€” 2 fields modified" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center" />
                            <TextBlock Grid.Column="3" Text="Admin" FontSize="11" VerticalAlignment="Center" />
                            <TextBlock Grid.Column="4" Text="Today 13:15" FontSize="11" Foreground="{StaticResource TextTertiaryBrush}" VerticalAlignment="Center" />
                            <Button Grid.Column="5" Style="{StaticResource GhostButtonStyle}" Padding="6,4" FontSize="11" Click="OnViewDetailClick">
                                <FontIcon Glyph="&#xE946;" FontSize="12" />
                            </Button>
                        </Grid>

                        <!-- Row 3 - System Event -->
                        <Grid Padding="14,12" ColumnSpacing="12" BorderBrush="{StaticResource BorderDefaultBrush}" BorderThickness="0,1,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="1.5*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <Border CornerRadius="6" Padding="6,3" Background="#108B5CF6" VerticalAlignment="Center" MinWidth="80">
                                <TextBlock Text="SYSTEM" FontSize="9" Foreground="#8B5CF6" FontWeight="SemiBold" HorizontalAlignment="Center" />
                            </Border>
                            <TextBlock Grid.Column="1" Text="DB Sync Completed" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center" />
                            <TextBlock Grid.Column="2" Text="1,248 records synced successfully" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center" />
                            <TextBlock Grid.Column="3" Text="System" FontSize="11" VerticalAlignment="Center" />
                            <TextBlock Grid.Column="4" Text="Today 12:00" FontSize="11" Foreground="{StaticResource TextTertiaryBrush}" VerticalAlignment="Center" />
                            <Button Grid.Column="5" Style="{StaticResource GhostButtonStyle}" Padding="6,4" FontSize="11" Click="OnViewDetailClick">
                                <FontIcon Glyph="&#xE946;" FontSize="12" />
                            </Button>
                        </Grid>

                        <!-- Row 4 - Critical -->
                        <Grid Padding="14,12" ColumnSpacing="12" BorderBrush="{StaticResource BorderDefaultBrush}" BorderThickness="0,1,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="1.5*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <Border CornerRadius="6" Padding="6,3" Background="#10FF5F57" VerticalAlignment="Center" MinWidth="80">
                                <TextBlock Text="ALERT" FontSize="9" Foreground="{StaticResource DangerBrush}" FontWeight="SemiBold" HorizontalAlignment="Center" />
                            </Border>
                            <TextBlock Grid.Column="1" Text="Out of Stock" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center" />
                            <TextBlock Grid.Column="2" Text="Valve Assembly reached 0 units" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center" />
                            <TextBlock Grid.Column="3" Text="System" FontSize="11" VerticalAlignment="Center" />
                            <TextBlock Grid.Column="4" Text="Today 10:47" FontSize="11" Foreground="{StaticResource TextTertiaryBrush}" VerticalAlignment="Center" />
                            <Button Grid.Column="5" Style="{StaticResource GhostButtonStyle}" Padding="6,4" FontSize="11" Click="OnViewDetailClick">
                                <FontIcon Glyph="&#xE946;" FontSize="12" />
                            </Button>
                        </Grid>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>



