<Page
    x:Class="PartFinder.Views.Pages.DashboardPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:components="using:PartFinder.Views.Components"
    xmlns:converters="using:PartFinder.Converters"
    xmlns:lvc="using:LiveChartsCore.SkiaSharpView.WinUI"
    xmlns:viewModels="using:PartFinder.ViewModels">

    <Page.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>

        <!-- Card hover style with glassmorphism elevation -->
        <Style x:Key="HoverCardStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource CardBackgroundBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderDefaultBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="12"/>
        </Style>

        <!-- Quick action button style -->
        <Style x:Key="ActionRowStyle" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource ElevatedCardBackgroundBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderDefaultBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="10,9"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
        </Style>
    </Page.Resources>

    <ScrollViewer Background="{StaticResource PageBackgroundBrush}" HorizontalScrollBarVisibility="Disabled">
        <StackPanel x:Name="RootStack" Padding="24,20,24,36" Spacing="16" HorizontalAlignment="Stretch">

            <!-- â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â• -->
            <!-- HEADER                                                         -->
            <!-- â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â• -->
            <Grid x:Name="HeaderGrid" Opacity="0">
                <Grid.RenderTransform><TranslateTransform x:Name="HeaderSlide" Y="-10"/></Grid.RenderTransform>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Spacing="3">
                    <TextBlock Text="OVERVIEW" FontSize="10" Foreground="{StaticResource TextTertiaryBrush}"
                               CharacterSpacing="80" FontWeight="SemiBold"/>
                    <TextBlock Text="Inventory Dashboard" FontSize="26" FontWeight="Bold">
                        <TextBlock.Foreground>
                            <LinearGradientBrush StartPoint="0,0.5" EndPoint="1,0.5">
                                <GradientStop Color="#4DA8FF" Offset="0"/>
                                <GradientStop Color="#1F7AE0" Offset="0.4"/>
                                <GradientStop Color="#8B5CF6" Offset="1"/>
                            </LinearGradientBrush>
                        </TextBlock.Foreground>
                    </TextBlock>
                    <TextBlock Text="Real-time overview of your parts inventory, templates, and system health."
                               FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"/>
                </StackPanel>

                <!-- Status badge with animated pulse dot + outer glow -->
                <Grid Grid.Column="1" VerticalAlignment="Center">
                    <!-- Outer pulsing glow halo -->
                    <Border CornerRadius="24" Margin="-6,-4"
                            Background="#082ABD8F" Opacity="0.5"
                            IsHitTestVisible="False"/>
                    <!-- Badge -->
                    <Border CornerRadius="20"
                            Padding="12,7" Background="#102ABD8F" BorderBrush="#302ABD8F" BorderThickness="1">
                        <StackPanel Orientation="Horizontal" Spacing="7">
                            <Grid Width="10" Height="10" VerticalAlignment="Center">
                                <!-- Outer pulse ring -->
                                <Ellipse x:Name="PulseRing" Width="10" Height="10"
                                         Fill="Transparent"
                                         Stroke="{StaticResource SuccessBrush}" StrokeThickness="1.5"
                                         Opacity="0"/>
                                <!-- Solid dot -->
                                <Ellipse Width="6" Height="6" Fill="{StaticResource SuccessBrush}"
                                         HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Grid>
                            <TextBlock Text="SYSTEM ONLINE" FontSize="9" Foreground="{StaticResource SuccessBrush}"
                                       CharacterSpacing="60" FontWeight="SemiBold" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </Grid>

            <!-- â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â• -->
            <!-- LOW STOCK ALERT BANNER (visible only when HasLowStock = true)  -->
            <!-- â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â• -->
            <Border x:Name="LowStockBanner"
                    CornerRadius="12" Padding="16,12"
                    Background="#0DFFB781"
                    BorderThickness="1"
                    Opacity="0"
                    Visibility="{Binding HasLowStock, Converter={StaticResource BoolToVisibilityConverter}}">
                <Border.BorderBrush>
                    <SolidColorBrush x:Name="BannerBorderBrush" Color="#40FFB781"/>
                </Border.BorderBrush>

                <Grid ColumnSpacing="12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Warning icon with glow -->
                    <Border Grid.Column="0" Width="40" Height="40" CornerRadius="20"
                            Background="#1AFFB781" VerticalAlignment="Center">
                        <FontIcon x:Name="BannerIcon" Glyph="&#xE7BA;" FontSize="18"
                                  Foreground="#FFB781" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>

                    <!-- Text + items -->
                    <StackPanel Grid.Column="1" Spacing="6" VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <TextBlock Text="LOW STOCK ALERT" FontSize="11" FontWeight="Bold"
                                       Foreground="#FFB781" CharacterSpacing="40"/>
                            <Border CornerRadius="4" Padding="5,1" Background="#20FFB781">
                                <TextBlock Text="{Binding LowStockItems.Count}" FontSize="9"
                                           FontWeight="Bold" Foreground="#FFB781"/>
                            </Border>
                        </StackPanel>

                        <!-- Low stock items as chips -->
                        <ItemsControl ItemsSource="{Binding LowStockItems}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Orientation="Horizontal" Spacing="6"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="viewModels:LowStockItem">
                                    <Border CornerRadius="6" Padding="8,4" BorderThickness="1">
                                        <Border.Background>
                                            <SolidColorBrush Color="#15FFB781"/>
                                        </Border.Background>
                                        <Border.BorderBrush>
                                            <SolidColorBrush Color="#30FFB781"/>
                                        </Border.BorderBrush>
                                        <StackPanel Orientation="Horizontal" Spacing="5">
                                            <TextBlock Text="{x:Bind Name}" FontSize="10"
                                                       Foreground="#FFB781" FontWeight="SemiBold"/>
                                            <Border CornerRadius="3" Padding="4,1">
                                                <Border.Background>
                                                    <SolidColorBrush Color="#25FFB4AB"/>
                                                </Border.Background>
                                                <TextBlock Text="{x:Bind StatusText}" FontSize="8"
                                                           Foreground="#FFB4AB" FontWeight="Bold"
                                                           CharacterSpacing="30"/>
                                            </Border>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>

                    <!-- View Parts button -->
                    <Button Grid.Column="2" VerticalAlignment="Center"
                            Content="View Parts â†’"
                            FontSize="11" FontWeight="SemiBold"
                            Foreground="#FFB781"
                            Background="#15FFB781"
                            BorderBrush="#30FFB781"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="12,6"/>
                </Grid>
            </Border>

            <!-- â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â• -->
            <!-- KPI CARDS ROW                                                  -->
            <!-- â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â• -->
            <ItemsControl x:Name="KpiRow" ItemsSource="{Binding Kpis}" Opacity="0">
                <ItemsControl.RenderTransform><TranslateTransform x:Name="KpiSlide" Y="10"/></ItemsControl.RenderTransform>
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <ItemsWrapGrid Orientation="Horizontal" ItemWidth="270"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="viewModels:KpiItem">
                        <components:KpiCard
                            Label="{x:Bind Label}"
                            Value="{x:Bind Value, Mode=OneWay}"
                            Delta="{x:Bind Delta, Mode=OneWay}"
                            IconGlyph="{x:Bind Icon}"
                            AccentHex="{x:Bind AccentHex}"
                            AlertLevel="{x:Bind AlertLevel, Mode=OneWay}"/>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <!-- â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â• -->
            <!-- ROW 1: Trend Chart + Distribution Donut                        -->
            <!-- â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â• -->
            <Grid x:Name="Row1" ColumnSpacing="14" Opacity="0">
                <Grid.RenderTransform><TranslateTransform x:Name="Row1Slide" Y="12"/></Grid.RenderTransform>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2.2*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Parts Trend Chart -->
                <Border Grid.Column="0" Style="{StaticResource HoverCardStyle}" Padding="18,16">
                    <Border.Shadow><ThemeShadow/></Border.Shadow>
                    <StackPanel Spacing="12">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Spacing="2">
                                <TextBlock Text="Parts Trend" FontSize="15" FontWeight="SemiBold"/>
                                <TextBlock Text="Parts created over time with average baseline"
                                           FontSize="11" Foreground="{StaticResource TextTertiaryBrush}"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                                <Border CornerRadius="6" Padding="8,3" Background="#101F7AE0">
                                    <TextBlock Text="LAST 30 DAYS" FontSize="8" Foreground="{StaticResource AccentPrimaryBrush}"
                                               CharacterSpacing="60" FontWeight="SemiBold"/>
                                </Border>
                                <Border CornerRadius="6" Padding="8,3" Background="#10FFFFFF">
                                    <StackPanel Orientation="Horizontal" Spacing="4">
                                        <Ellipse Width="5" Height="5" Fill="{StaticResource SuccessBrush}" VerticalAlignment="Center"/>
                                        <TextBlock Text="LIVE" FontSize="8" Foreground="{StaticResource TextTertiaryBrush}"
                                                   CharacterSpacing="60" FontWeight="SemiBold"/>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </Grid>

                        <Grid>
                            <lvc:CartesianChart
                                Height="240"
                                Series="{Binding TrendSeries}"
                                AnimationsSpeed="00:00:00.8"
                                EasingFunction="{x:Null}"/>
                            <ProgressRing Width="24" Height="24"
                                          HorizontalAlignment="Center" VerticalAlignment="Center"
                                          IsActive="{Binding IsLoading}"/>
                        </Grid>

                        <!-- Legend -->
                        <StackPanel Orientation="Horizontal" Spacing="18">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <Border Width="18" Height="3" CornerRadius="2" Background="#1F7AE0" VerticalAlignment="Center"/>
                                <TextBlock Text="Trend" FontSize="10" Foreground="{StaticResource TextTertiaryBrush}"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <Border Width="18" Height="1" CornerRadius="1" Background="#64647880" VerticalAlignment="Center"/>
                                <TextBlock Text="Average" FontSize="10" Foreground="{StaticResource TextTertiaryBrush}"/>
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Template Distribution Donut -->
                <Border Grid.Column="1" Style="{StaticResource HoverCardStyle}" Padding="18,16">
                    <Border.Shadow><ThemeShadow/></Border.Shadow>
                    <StackPanel Spacing="10">
                        <TextBlock Text="Template Distribution" FontSize="15" FontWeight="SemiBold"/>
                        <TextBlock Text="Parts per schema category" FontSize="11"
                                   Foreground="{StaticResource TextTertiaryBrush}"/>
                        <lvc:PieChart
                            Height="190"
                            Series="{Binding DistributionSeries}"
                            AnimationsSpeed="00:00:00.9"
                            InitialRotation="-90"/>
                        <!-- Legend -->
                        <StackPanel Spacing="5">
                            <StackPanel Orientation="Horizontal" Spacing="7">
                                <Border Width="10" Height="10" CornerRadius="5" Background="#1F7AE0" VerticalAlignment="Center"/>
                                <TextBlock Text="Turbocharger" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                                <TextBlock Text="42%" FontSize="11" FontWeight="Bold" VerticalAlignment="Center"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Spacing="7">
                                <Border Width="10" Height="10" CornerRadius="5" Background="#2ABD8F" VerticalAlignment="Center"/>
                                <TextBlock Text="Fuel Injector" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                                <TextBlock Text="28%" FontSize="11" FontWeight="Bold" VerticalAlignment="Center"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Spacing="7">
                                <Border Width="10" Height="10" CornerRadius="5" Background="#FEBC2E" VerticalAlignment="Center"/>
                                <TextBlock Text="Valve Assembly" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                                <TextBlock Text="18%" FontSize="11" FontWeight="Bold" VerticalAlignment="Center"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Spacing="7">
                                <Border Width="10" Height="10" CornerRadius="5" Background="#8B5CF6" VerticalAlignment="Center"/>
                                <TextBlock Text="Shaft Log" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                                <TextBlock Text="12%" FontSize="11" FontWeight="Bold" VerticalAlignment="Center"/>
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â• -->
            <!-- ROW 2: Stock Level Bar Chart + Health Gauge                    -->
            <!-- â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â• -->
            <Grid x:Name="Row2" ColumnSpacing="14" Opacity="0">
                <Grid.RenderTransform><TranslateTransform x:Name="Row2Slide" Y="12"/></Grid.RenderTransform>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.6*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Stock Level Bar Chart (NEW) -->
                <Border Grid.Column="0" Style="{StaticResource HoverCardStyle}" Padding="18,16">
                    <Border.Shadow><ThemeShadow/></Border.Shadow>
                    <StackPanel Spacing="12">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Spacing="2">
                                <TextBlock Text="Critical Stock Levels" FontSize="15" FontWeight="SemiBold"/>
                                <TextBlock Text="Current quantity for low-stock parts"
                                           FontSize="11" Foreground="{StaticResource TextTertiaryBrush}"/>
                            </StackPanel>
                            <Border Grid.Column="1" CornerRadius="6" Padding="8,3" Background="#10FFB781" VerticalAlignment="Top">
                                <StackPanel Orientation="Horizontal" Spacing="4">
                                    <FontIcon Glyph="&#xE7BA;" FontSize="8" Foreground="#FFB781"/>
                                    <TextBlock Text="NEEDS ATTENTION" FontSize="8" Foreground="#FFB781"
                                               CharacterSpacing="40" FontWeight="SemiBold"/>
                                </StackPanel>
                            </Border>
                        </Grid>

                        <lvc:CartesianChart
                            Height="200"
                            Series="{Binding StockLevelSeries}"
                            AnimationsSpeed="00:00:00.9"
                            EasingFunction="{x:Null}"/>

                        <!-- Min stock threshold note -->
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <Border Width="14" Height="3" CornerRadius="2" Background="#FFB781" VerticalAlignment="Center"/>
                            <TextBlock Text="Current qty â€” below minimum threshold" FontSize="10"
                                       Foreground="{StaticResource TextTertiaryBrush}"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- System Health Gauge -->
                <Border Grid.Column="1" Style="{StaticResource HoverCardStyle}" Padding="18,16">
                    <Border.Shadow><ThemeShadow/></Border.Shadow>
                    <StackPanel Spacing="10">
                        <TextBlock Text="System Health" FontSize="15" FontWeight="SemiBold"/>
                        <TextBlock Text="Import pipeline reliability" FontSize="11"
                                   Foreground="{StaticResource TextTertiaryBrush}"/>
                        <Grid>
                            <lvc:PieChart
                                Height="170"
                                Series="{Binding HealthGaugeSeries}"
                                AnimationsSpeed="00:00:01.1"
                                InitialRotation="225"
                                MaxAngle="270"/>
                            <!-- Center overlay -->
                            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="1">
                                <TextBlock Text="{Binding HealthLabel}" FontSize="22" FontWeight="Bold"
                                           HorizontalAlignment="Center" Foreground="{StaticResource TextPrimaryBrush}"/>
                                <TextBlock Text="Success" FontSize="10" Foreground="{StaticResource TextTertiaryBrush}"
                                           HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Grid>
                        <!-- Health indicators -->
                        <StackPanel Spacing="5">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <Ellipse Width="7" Height="7" Fill="{StaticResource SuccessBrush}" VerticalAlignment="Center"/>
                                <TextBlock Text="Schema validation" FontSize="10" Foreground="{StaticResource TextSecondaryBrush}"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <Ellipse Width="7" Height="7" Fill="{StaticResource SuccessBrush}" VerticalAlignment="Center"/>
                                <TextBlock Text="API connectivity" FontSize="10" Foreground="{StaticResource TextSecondaryBrush}"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <Ellipse Width="7" Height="7" Fill="{StaticResource SuccessBrush}" VerticalAlignment="Center"/>
                                <TextBlock Text="Database sync" FontSize="10" Foreground="{StaticResource TextSecondaryBrush}"/>
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â• -->
            <!-- ROW 3: Activity Feed + Quick Actions                           -->
            <!-- â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â• -->
            <Grid x:Name="Row3" ColumnSpacing="14" Opacity="0">
                <Grid.RenderTransform><TranslateTransform x:Name="Row3Slide" Y="12"/></Grid.RenderTransform>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.6*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Recent Activity with icons -->
                <Border Grid.Column="0" Style="{StaticResource HoverCardStyle}" Padding="18,16">
                    <Border.Shadow><ThemeShadow/></Border.Shadow>
                    <StackPanel Spacing="10">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Spacing="2">
                                <TextBlock Text="Recent Activity" FontSize="15" FontWeight="SemiBold"/>
                                <TextBlock Text="Latest operations and system events" FontSize="11"
                                           Foreground="{StaticResource TextTertiaryBrush}"/>
                            </StackPanel>
                            <Border Grid.Column="1" CornerRadius="6" Padding="8,3" Background="#10FFFFFF" VerticalAlignment="Top">
                                <StackPanel Orientation="Horizontal" Spacing="4">
                                    <Ellipse Width="5" Height="5" Fill="{StaticResource SuccessBrush}" VerticalAlignment="Center"/>
                                    <TextBlock Text="AUTO-REFRESH 60S" FontSize="8" Foreground="{StaticResource TextTertiaryBrush}"
                                               CharacterSpacing="40" FontWeight="SemiBold"/>
                                </StackPanel>
                            </Border>
                        </Grid>

                        <Border Background="{StaticResource ElevatedCardBackgroundBrush}"
                                CornerRadius="10" Padding="10"
                                BorderBrush="{StaticResource BorderDefaultBrush}" BorderThickness="1"
                                MinHeight="200">
                            <ItemsControl ItemsSource="{Binding RecentActivity}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="viewModels:ActivityItem">
                                        <Border Padding="8,7" Margin="0,0,0,2" CornerRadius="6">
                                            <StackPanel Orientation="Horizontal" Spacing="10">
                                                <!-- Colored icon per event type -->
                                                <Border Width="26" Height="26" CornerRadius="13"
                                                        VerticalAlignment="Center">
                                                    <Border.Background>
                                                        <SolidColorBrush Color="#15FFFFFF"/>
                                                    </Border.Background>
                                                    <FontIcon Glyph="{x:Bind Glyph}" FontSize="11"
                                                              Foreground="{x:Bind IconBrush}"
                                                              HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                                <TextBlock Text="{x:Bind Text}" FontSize="11"
                                                           Foreground="{StaticResource TextSecondaryBrush}"
                                                           TextTrimming="CharacterEllipsis"
                                                           VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </Border>
                    </StackPanel>
                </Border>

                <!-- Quick Actions (animated buttons) -->
                <Border Grid.Column="1" Style="{StaticResource HoverCardStyle}" Padding="18,16">
                    <Border.Shadow><ThemeShadow/></Border.Shadow>
                    <StackPanel Spacing="12">
                        <TextBlock Text="Quick Actions" FontSize="15" FontWeight="SemiBold"/>
                        <TextBlock Text="Common workflows at a glance" FontSize="11"
                                   Foreground="{StaticResource TextTertiaryBrush}"/>
                        <StackPanel Spacing="7">

                            <Button Style="{StaticResource ActionRowStyle}">
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <Border Width="32" Height="32" CornerRadius="8" Background="#151F7AE0">
                                        <FontIcon Glyph="&#xE710;" FontSize="14" Foreground="{StaticResource AccentPrimaryBrush}"/>
                                    </Border>
                                    <StackPanel Spacing="1" VerticalAlignment="Center">
                                        <TextBlock Text="New Template" FontSize="12" FontWeight="SemiBold"/>
                                        <TextBlock Text="Create schema" FontSize="9" Foreground="{StaticResource TextTertiaryBrush}"/>
                                    </StackPanel>
                                    <FontIcon Glyph="&#xE76C;" FontSize="10" Foreground="{StaticResource TextTertiaryBrush}"
                                              HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,0,0"/>
                                </StackPanel>
                            </Button>

                            <Button Style="{StaticResource ActionRowStyle}">
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <Border Width="32" Height="32" CornerRadius="8" Background="#152ABD8F">
                                        <FontIcon Glyph="&#xE8B5;" FontSize="14" Foreground="{StaticResource SuccessBrush}"/>
                                    </Border>
                                    <StackPanel Spacing="1" VerticalAlignment="Center">
                                        <TextBlock Text="Import Data" FontSize="12" FontWeight="SemiBold"/>
                                        <TextBlock Text="CSV or Excel" FontSize="9" Foreground="{StaticResource TextTertiaryBrush}"/>
                                    </StackPanel>
                                </StackPanel>
                            </Button>

                            <Button Style="{StaticResource ActionRowStyle}">
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <Border Width="32" Height="32" CornerRadius="8" Background="#15FEBC2E">
                                        <FontIcon Glyph="&#xE8FA;" FontSize="14" Foreground="{StaticResource WarningBrush}"/>
                                    </Border>
                                    <StackPanel Spacing="1" VerticalAlignment="Center">
                                        <TextBlock Text="Invite Member" FontSize="12" FontWeight="SemiBold"/>
                                        <TextBlock Text="Team access" FontSize="9" Foreground="{StaticResource TextTertiaryBrush}"/>
                                    </StackPanel>
                                </StackPanel>
                            </Button>

                            <Button Style="{StaticResource ActionRowStyle}">
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <Border Width="32" Height="32" CornerRadius="8" Background="#158B5CF6">
                                        <FontIcon Glyph="&#xEDE1;" FontSize="14" Foreground="#8B5CF6"/>
                                    </Border>
                                    <StackPanel Spacing="1" VerticalAlignment="Center">
                                        <TextBlock Text="Export Report" FontSize="12" FontWeight="SemiBold"/>
                                        <TextBlock Text="Excel download" FontSize="9" Foreground="{StaticResource TextTertiaryBrush}"/>
                                    </StackPanel>
                                </StackPanel>
                            </Button>

                            <Button Style="{StaticResource ActionRowStyle}">
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <Border Width="32" Height="32" CornerRadius="8" Background="#15FFB4AB">
                                        <FontIcon Glyph="&#xE9D9;" FontSize="14" Foreground="{StaticResource DangerBrush}"/>
                                    </Border>
                                    <StackPanel Spacing="1" VerticalAlignment="Center">
                                        <TextBlock Text="Scan QR Code" FontSize="12" FontWeight="SemiBold"/>
                                        <TextBlock Text="Find part instantly" FontSize="9" Foreground="{StaticResource TextTertiaryBrush}"/>
                                    </StackPanel>
                                </StackPanel>
                            </Button>

                        </StackPanel>
                    </StackPanel>
                </Border>
            </Grid>

        </StackPanel>
    </ScrollViewer>
</Page>



