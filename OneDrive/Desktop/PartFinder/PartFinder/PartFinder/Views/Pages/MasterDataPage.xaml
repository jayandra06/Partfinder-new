<Page
    x:Class="PartFinder.Views.Pages.MasterDataPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:components="using:PartFinder.Views.Components"
    xmlns:converters="using:PartFinder.Converters">
    <Page.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter" />
        <converters:InvertedBoolToVisibilityConverter x:Key="InvertedBoolToVisibilityConverter" />
        <converters:StringToVisibilityConverter x:Key="StringToVisibilityConverter" />
    </Page.Resources>

    <Grid x:Name="RootGrid" Padding="20" Background="{StaticResource PageBackgroundBrush}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="320" />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Grid.Column="0" Spacing="2" Margin="0,0,0,10">
            <TextBlock Text="MASTER DATA" FontSize="10" Foreground="{StaticResource AccentPrimaryBrush}" CharacterSpacing="100" FontWeight="SemiBold" />
            <TextBlock Text="Reference Data Manager" FontSize="22" FontWeight="SemiBold" />
            <TextBlock Text="Manage shared reference data used across all templates. Select a template, review rows and switch to edit mode to make changes." FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" TextWrapping="WrapWholeWords" />
        </StackPanel>

        <!-- Controls bar -->
        <Border Grid.Row="1" Grid.Column="0" Margin="0,0,0,0" Padding="14,10" CornerRadius="4" Background="{StaticResource CardBackgroundBrush}" BorderBrush="{StaticResource BorderDefaultBrush}" BorderThickness="1" Translation="0,0,32">
                            <Border.Shadow><ThemeShadow/></Border.Shadow>
                            <Grid RowSpacing="8" ColumnSpacing="10">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <ComboBox
                    Grid.Row="0"
                    MinWidth="260"
                    HorizontalAlignment="Left"
                    FontSize="12"
                    DisplayMemberPath="Name"
                    ItemsSource="{Binding DataTemplates}"
                    PlaceholderText="Choose templateâ€¦"
                    SelectedItem="{Binding SelectedDataTemplate, Mode=TwoWay}"
                    Visibility="{Binding ShowTemplatePicker, Converter={StaticResource BoolToVisibilityConverter}}" />

                <Button
                    Grid.Row="0"
                    Grid.Column="1"
                    Style="{StaticResource OutlinedButtonStyle}"
                    FontSize="12"
                    Visibility="{Binding IsEditMode, Converter={StaticResource InvertedBoolToVisibilityConverter}}"
                    Click="OnToggleEditModeClicked">
                    <StackPanel Orientation="Horizontal" Spacing="5">
                        <FontIcon Glyph="&#xE70F;" FontSize="12" />
                        <TextBlock Text="Edit" FontSize="12" />
                    </StackPanel>
                </Button>

                <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="8">
                    <Button
                        Click="OnSaveGridClicked"
                        Style="{StaticResource PrimaryButtonStyle}"
                        Content="Save"
                        FontSize="12"
                        Visibility="{Binding IsEditMode, Converter={StaticResource BoolToVisibilityConverter}}" />
                    <Button
                        Click="OnCancelEditClicked"
                        Style="{StaticResource OutlinedButtonStyle}"
                        Content="Cancel"
                        FontSize="12"
                        Visibility="{Binding IsEditMode, Converter={StaticResource BoolToVisibilityConverter}}" />
                    <TextBlock
                        VerticalAlignment="Center"
                        FontSize="11"
                        Foreground="{StaticResource TextSecondaryBrush}"
                        Text="Loading..."
                        Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibilityConverter}}" />
                </StackPanel>

                <StackPanel Grid.Row="1" Grid.Column="1" Orientation="Horizontal" Spacing="6">
                    <Button Style="{StaticResource OutlinedButtonStyle}" Click="OnExportTemplateClicked" FontSize="11">
                        <StackPanel Orientation="Horizontal" Spacing="5">
                            <FontIcon Glyph="&#xEDE1;" FontSize="11" />
                            <TextBlock Text="Export Excel" FontSize="11" />
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource OutlinedButtonStyle}" Click="OnImportExcelClicked" FontSize="11">
                        <StackPanel Orientation="Horizontal" Spacing="5">
                            <FontIcon Glyph="&#xE8B5;" FontSize="11" />
                            <TextBlock Text="Import Excel" FontSize="11" />
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Status messages -->
        <StackPanel Grid.Row="2" Grid.Column="0" Margin="0,6,0,6" Spacing="4">
            <TextBlock
                Foreground="{StaticResource TextSecondaryBrush}"
                Text="{Binding StatusMessage}"
                FontSize="11"
                TextWrapping="Wrap"
                Visibility="{Binding StatusMessage, Converter={StaticResource StringToVisibilityConverter}}" />
            <TextBlock
                Foreground="{StaticResource TextSecondaryBrush}"
                FontSize="11"
                Text="Create and save a Master Data template under Templates to see columns here."
                TextWrapping="Wrap"
                Visibility="{Binding ShowNoTemplateHint, Converter={StaticResource BoolToVisibilityConverter}}" />
            <TextBlock
                Foreground="{StaticResource TextSecondaryBrush}"
                FontSize="11"
                Text="No tenant database is configured. Complete setup with a valid organization and database connection."
                TextWrapping="Wrap"
                Visibility="{Binding ShowNoDatabaseHint, Converter={StaticResource BoolToVisibilityConverter}}" />
        </StackPanel>

        <!-- Spreadsheet host -->
        <ContentControl
            x:Name="SpreadsheetHost"
            Grid.Row="3"
            Grid.Column="0"
            Margin="0,6,0,0"
            HorizontalContentAlignment="Stretch"
            VerticalContentAlignment="Stretch" />

        <!-- Action overlay -->
        <Rectangle
            x:Name="ActionResultsOverlay"
            Grid.Column="0"
            Grid.RowSpan="5"
            Fill="Black"
            Opacity="0.3"
            Visibility="Collapsed"
            Tapped="OnActionOverlayTapped" />

        <!-- Action results slide panel -->
        <Border
            x:Name="ActionResultsPanel"
            Grid.Column="1"
            Grid.RowSpan="5"
            Width="320"
            Padding="14"
            Visibility="Collapsed"
            CornerRadius="4"
            Background="{StaticResource ElevatedCardBackgroundBrush}"
            BorderBrush="{StaticResource BorderDefaultBrush}"
            BorderThickness="1">
            <Border.RenderTransform>
                <TranslateTransform x:Name="ActionResultsTransform" X="320" />
            </Border.RenderTransform>
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock
                    x:Name="ActionTitleText"
                    Grid.Row="0"
                    Grid.Column="0"
                    FontSize="14"
                    FontWeight="SemiBold" />
                <Button
                    Grid.Row="0"
                    Grid.Column="1"
                    Style="{StaticResource GhostButtonStyle}"
                    Content="âœ•"
                    FontSize="12"
                    Click="OnCloseActionPanelClick" />

                <TextBlock
                    x:Name="ActionCountText"
                    Grid.Row="1"
                    Grid.ColumnSpan="2"
                    Margin="0,4,0,10"
                    FontSize="11"
                    Foreground="{StaticResource TextSecondaryBrush}" />

                <ListView x:Name="ActionRowsListView" Grid.Row="2">
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <Border
                                Margin="0,0,0,6"
                                Padding="10"
                                Background="{StaticResource CardBackgroundBrush}"
                                BorderBrush="{StaticResource BorderDefaultBrush}"
                                BorderThickness="1"
                                CornerRadius="8" Translation="0,0,32">
                            <Border.Shadow><ThemeShadow/></Border.Shadow>
                            <StackPanel Spacing="3">
                                    <TextBlock
                                        Text="{Binding Title}"
                                        FontSize="12"
                                        FontWeight="SemiBold"
                                        TextWrapping="WrapWholeWords" />
                                    <ItemsControl ItemsSource="{Binding Lines}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding}" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" TextWrapping="WrapWholeWords" />
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </Grid>
        </Border>
    </Grid>
</Page>



