<Page
    x:Class="PartFinder.Views.Pages.AlertsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Background="{StaticResource PageBackgroundBrush}">
        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <StackPanel Padding="24,20,24,32" Spacing="18" HorizontalAlignment="Stretch">
                <StackPanel.ChildrenTransitions>
                    <TransitionCollection>
                        <EntranceThemeTransition IsStaggeringEnabled="True" FromVerticalOffset="50" />
                    </TransitionCollection>
                </StackPanel.ChildrenTransitions>

                <!-- HEADER -->
                <Grid ColumnSpacing="12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Spacing="2">
                        <TextBlock Text="ALERTS" FontSize="10" Foreground="{StaticResource AccentPrimaryBrush}" CharacterSpacing="100" FontWeight="SemiBold" />
                        <TextBlock Text="Alerts &amp; Notifications" FontSize="32" FontWeight="Light" CharacterSpacing="20" />
                        <TextBlock Text="Real-time alerts for low stock, critical issues, and system events across your inventory." FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" />
                    </StackPanel>
                    <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                        <Button x:Name="MarkAllReadBtn" Style="{StaticResource GhostButtonStyle}" FontSize="12" Click="OnMarkAllReadClick">
                            <StackPanel Orientation="Horizontal" Spacing="5">
                                <FontIcon Glyph="&#xE73E;" FontSize="13" />
                                <TextBlock Text="Mark All Read" FontSize="12" />
                            </StackPanel>
                        </Button>
                        <Button Style="{StaticResource OutlinedButtonStyle}" FontSize="12" Click="OnConfigureAlertsClick">
                            <StackPanel Orientation="Horizontal" Spacing="5">
                                <FontIcon Glyph="&#xE713;" FontSize="13" />
                                <TextBlock Text="Configure" FontSize="12" />
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Grid>

                <!-- KPI CARDS -->
                <Grid ColumnSpacing="14">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Background="{StaticResource CardBackgroundBrush}" BorderBrush="{StaticResource DangerBrush}" BorderThickness="1" CornerRadius="4" Padding="16,14" Translation="0,0,32">
                            <Border.Shadow><ThemeShadow/></Border.Shadow>
                            <StackPanel Spacing="8">
                            <Grid>
                                <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                                <StackPanel Spacing="2">
                                    <TextBlock Text="CRITICAL" FontSize="9" Foreground="{StaticResource TextTertiaryBrush}" CharacterSpacing="60" FontWeight="SemiBold" />
                                    <TextBlock Text="8" FontSize="28" FontWeight="Bold" Foreground="{StaticResource DangerBrush}" />
                                </StackPanel>
                                <Border Grid.Column="1" Width="44" Height="44" CornerRadius="4" Background="#10FF5F57" VerticalAlignment="Top">
                                    <FontIcon Glyph="&#xE7BA;" FontSize="20" Foreground="{StaticResource DangerBrush}" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                </Border>
                            </Grid>
                            <TextBlock Text="Needs immediate action" FontSize="10" Foreground="{StaticResource DangerBrush}" />
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="1" Background="{StaticResource CardBackgroundBrush}" BorderBrush="{StaticResource BorderDefaultBrush}" BorderThickness="1" CornerRadius="4" Padding="16,14" Translation="0,0,32">
                            <Border.Shadow><ThemeShadow/></Border.Shadow>
                            <StackPanel Spacing="8">
                            <Grid>
                                <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                                <StackPanel Spacing="2">
                                    <TextBlock Text="WARNINGS" FontSize="9" Foreground="{StaticResource TextTertiaryBrush}" CharacterSpacing="60" FontWeight="SemiBold" />
                                    <TextBlock Text="34" FontSize="28" FontWeight="Bold" Foreground="{StaticResource WarningBrush}" />
                                </StackPanel>
                                <Border Grid.Column="1" Width="44" Height="44" CornerRadius="4" Background="#10FEBC2E" VerticalAlignment="Top">
                                    <FontIcon Glyph="&#xE7BA;" FontSize="20" Foreground="{StaticResource WarningBrush}" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                </Border>
                            </Grid>
                            <TextBlock Text="Low stock items" FontSize="10" Foreground="{StaticResource WarningBrush}" />
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="2" Background="{StaticResource CardBackgroundBrush}" BorderBrush="{StaticResource BorderDefaultBrush}" BorderThickness="1" CornerRadius="4" Padding="16,14" Translation="0,0,32">
                            <Border.Shadow><ThemeShadow/></Border.Shadow>
                            <StackPanel Spacing="8">
                            <Grid>
                                <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                                <StackPanel Spacing="2">
                                    <TextBlock Text="INFO" FontSize="9" Foreground="{StaticResource TextTertiaryBrush}" CharacterSpacing="60" FontWeight="SemiBold" />
                                    <TextBlock Text="12" FontSize="28" FontWeight="Bold" Foreground="{StaticResource InfoBrush}" />
                                </StackPanel>
                                <Border Grid.Column="1" Width="44" Height="44" CornerRadius="4" Background="#10A4C9FF" VerticalAlignment="Top">
                                    <FontIcon Glyph="&#xE946;" FontSize="20" Foreground="{StaticResource InfoBrush}" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                </Border>
                            </Grid>
                            <TextBlock Text="System notifications" FontSize="10" Foreground="{StaticResource TextSecondaryBrush}" />
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="3" Background="{StaticResource CardBackgroundBrush}" BorderBrush="{StaticResource BorderDefaultBrush}" BorderThickness="1" CornerRadius="4" Padding="16,14" Translation="0,0,32">
                            <Border.Shadow><ThemeShadow/></Border.Shadow>
                            <StackPanel Spacing="8">
                            <Grid>
                                <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                                <StackPanel Spacing="2">
                                    <TextBlock Text="RESOLVED TODAY" FontSize="9" Foreground="{StaticResource TextTertiaryBrush}" CharacterSpacing="60" FontWeight="SemiBold" />
                                    <TextBlock Text="27" FontSize="28" FontWeight="Bold" Foreground="{StaticResource SuccessBrush}" />
                                </StackPanel>
                                <Border Grid.Column="1" Width="44" Height="44" CornerRadius="4" Background="#102ABD8F" VerticalAlignment="Top">
                                    <FontIcon Glyph="&#xE73E;" FontSize="20" Foreground="{StaticResource SuccessBrush}" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                </Border>
                            </Grid>
                            <TextBlock Text="Cleared alerts" FontSize="10" Foreground="{StaticResource SuccessBrush}" />
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- FILTER TABS -->
                <Border Background="{StaticResource CardBackgroundBrush}" BorderBrush="{StaticResource BorderDefaultBrush}" BorderThickness="1" CornerRadius="4" Padding="14,10" Translation="0,0,32">
                            <Border.Shadow><ThemeShadow/></Border.Shadow>
                            <Grid ColumnSpacing="10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <Button Style="{StaticResource PrimaryButtonStyle}" Padding="12,6" FontSize="11" Content="All (54)" />
                        <Button Grid.Column="1" Style="{StaticResource GhostButtonStyle}" Padding="12,6" FontSize="11" Content="Critical (8)" />
                        <Button Grid.Column="2" Style="{StaticResource GhostButtonStyle}" Padding="12,6" FontSize="11" Content="Warnings (34)" />
                        <Button Grid.Column="3" Style="{StaticResource GhostButtonStyle}" Padding="12,6" FontSize="11" Content="Info (12)" />
                        <StackPanel Grid.Column="5" Orientation="Horizontal" Spacing="8">
                            <FontIcon Glyph="&#xE721;" FontSize="12" Foreground="{StaticResource TextTertiaryBrush}" VerticalAlignment="Center" />
                            <TextBox BorderThickness="0" Background="Transparent" PlaceholderText="Search alerts..." FontSize="12" MinWidth="180" VerticalAlignment="Center" />
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- CRITICAL ALERTS -->
                <StackPanel Spacing="8">
                    <TextBlock Text="CRITICAL ALERTS" FontSize="10" Foreground="{StaticResource DangerBrush}" CharacterSpacing="80" FontWeight="SemiBold" />

                    <Border Background="{StaticResource CardBackgroundBrush}" BorderBrush="{StaticResource DangerBrush}" BorderThickness="1" CornerRadius="4" Padding="16,14" Translation="0,0,32">
                            <Border.Shadow><ThemeShadow/></Border.Shadow>
                            <Grid ColumnSpacing="14">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="Auto" /><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                            <Border Width="40" Height="40" CornerRadius="4" Background="#20FF5F57">
                                <FontIcon Glyph="&#xE7BA;" FontSize="18" Foreground="{StaticResource DangerBrush}" HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                            <StackPanel Grid.Column="1" Spacing="4" VerticalAlignment="Center">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <TextBlock Text="Valve Assembly â€” Out of Stock" FontSize="13" FontWeight="SemiBold" />
                                    <Border CornerRadius="4" Padding="6,2" Background="#20FF5F57">
                                        <TextBlock Text="CRITICAL" FontSize="9" Foreground="{StaticResource DangerBrush}" FontWeight="Bold" CharacterSpacing="40" />
                                    </Border>
                                </StackPanel>
                                <TextBlock Text="VAL-2024-089 has reached 0 units. Immediate reorder required to prevent production delays." FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" TextWrapping="WrapWholeWords" />
                                <TextBlock Text="2 minutes ago" FontSize="10" Foreground="{StaticResource TextTertiaryBrush}" />
                            </StackPanel>
                            <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                                <Button Style="{StaticResource PrimaryButtonStyle}" Padding="10,6" FontSize="11" Click="OnResolveAlertClick">Resolve</Button>
                                <Button Style="{StaticResource GhostButtonStyle}" Padding="8,6" FontSize="11" Click="OnDismissAlertClick">Dismiss</Button>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <Border Background="{StaticResource CardBackgroundBrush}" BorderBrush="{StaticResource DangerBrush}" BorderThickness="1" CornerRadius="4" Padding="16,14" Translation="0,0,32">
                            <Border.Shadow><ThemeShadow/></Border.Shadow>
                            <Grid ColumnSpacing="14">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="Auto" /><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                            <Border Width="40" Height="40" CornerRadius="4" Background="#20FF5F57">
                                <FontIcon Glyph="&#xE8D7;" FontSize="18" Foreground="{StaticResource DangerBrush}" HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                            <StackPanel Grid.Column="1" Spacing="4" VerticalAlignment="Center">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <TextBlock Text="Database Sync Failed" FontSize="13" FontWeight="SemiBold" />
                                    <Border CornerRadius="4" Padding="6,2" Background="#20FF5F57">
                                        <TextBlock Text="CRITICAL" FontSize="9" Foreground="{StaticResource DangerBrush}" FontWeight="Bold" CharacterSpacing="40" />
                                    </Border>
                                </StackPanel>
                                <TextBlock Text="Last sync failed at 14:32. Data may be out of date. Check connection settings." FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" TextWrapping="WrapWholeWords" />
                                <TextBlock Text="18 minutes ago" FontSize="10" Foreground="{StaticResource TextTertiaryBrush}" />
                            </StackPanel>
                            <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                                <Button Style="{StaticResource PrimaryButtonStyle}" Padding="10,6" FontSize="11" Click="OnResolveAlertClick">Resolve</Button>
                                <Button Style="{StaticResource GhostButtonStyle}" Padding="8,6" FontSize="11" Click="OnDismissAlertClick">Dismiss</Button>
                            </StackPanel>
                        </Grid>
                    </Border>
                </StackPanel>

                <!-- WARNING ALERTS -->
                <StackPanel Spacing="8">
                    <TextBlock Text="WARNINGS" FontSize="10" Foreground="{StaticResource WarningBrush}" CharacterSpacing="80" FontWeight="SemiBold" />

                    <Border Background="{StaticResource CardBackgroundBrush}" BorderBrush="{StaticResource BorderDefaultBrush}" BorderThickness="1" CornerRadius="4" Padding="16,14" Translation="0,0,32">
                            <Border.Shadow><ThemeShadow/></Border.Shadow>
                            <Grid ColumnSpacing="14">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="Auto" /><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                            <Border Width="40" Height="40" CornerRadius="4" Background="#20FEBC2E">
                                <FontIcon Glyph="&#xE7BA;" FontSize="18" Foreground="{StaticResource WarningBrush}" HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                            <StackPanel Grid.Column="1" Spacing="4" VerticalAlignment="Center">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <TextBlock Text="Fuel Injector â€” Low Stock" FontSize="13" FontWeight="SemiBold" />
                                    <Border CornerRadius="4" Padding="6,2" Background="#20FEBC2E">
                                        <TextBlock Text="WARNING" FontSize="9" Foreground="{StaticResource WarningBrush}" FontWeight="Bold" CharacterSpacing="40" />
                                    </Border>
                                </StackPanel>
                                <TextBlock Text="FUL-2024-045 has only 23 units remaining. Reorder threshold is 50 units." FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" TextWrapping="WrapWholeWords" />
                                <TextBlock Text="1 hour ago" FontSize="10" Foreground="{StaticResource TextTertiaryBrush}" />
                            </StackPanel>
                            <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                                <Button Style="{StaticResource OutlinedButtonStyle}" Padding="10,6" FontSize="11" Click="OnReorderClick">Reorder</Button>
                                <Button Style="{StaticResource GhostButtonStyle}" Padding="8,6" FontSize="11" Click="OnDismissAlertClick">Dismiss</Button>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <Border Background="{StaticResource CardBackgroundBrush}" BorderBrush="{StaticResource BorderDefaultBrush}" BorderThickness="1" CornerRadius="4" Padding="16,14" Translation="0,0,32">
                            <Border.Shadow><ThemeShadow/></Border.Shadow>
                            <Grid ColumnSpacing="14">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="Auto" /><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                            <Border Width="40" Height="40" CornerRadius="4" Background="#20FEBC2E">
                                <FontIcon Glyph="&#xE8B5;" FontSize="18" Foreground="{StaticResource WarningBrush}" HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                            <StackPanel Grid.Column="1" Spacing="4" VerticalAlignment="Center">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <TextBlock Text="Pending Import â€” 3 Templates" FontSize="13" FontWeight="SemiBold" />
                                    <Border CornerRadius="4" Padding="6,2" Background="#20FEBC2E">
                                        <TextBlock Text="WARNING" FontSize="9" Foreground="{StaticResource WarningBrush}" FontWeight="Bold" CharacterSpacing="40" />
                                    </Border>
                                </StackPanel>
                                <TextBlock Text="3 CSV imports are pending review. Approve or reject to keep data current." FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" TextWrapping="WrapWholeWords" />
                                <TextBlock Text="3 hours ago" FontSize="10" Foreground="{StaticResource TextTertiaryBrush}" />
                            </StackPanel>
                            <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                                <Button Style="{StaticResource OutlinedButtonStyle}" Padding="10,6" FontSize="11" Click="OnResolveAlertClick">Review</Button>
                                <Button Style="{StaticResource GhostButtonStyle}" Padding="8,6" FontSize="11" Click="OnDismissAlertClick">Dismiss</Button>
                            </StackPanel>
                        </Grid>
                    </Border>
                </StackPanel>

                <!-- INFO ALERTS -->
                <StackPanel Spacing="8">
                    <TextBlock Text="INFORMATION" FontSize="10" Foreground="{StaticResource InfoBrush}" CharacterSpacing="80" FontWeight="SemiBold" />

                    <Border Background="{StaticResource CardBackgroundBrush}" BorderBrush="{StaticResource BorderDefaultBrush}" BorderThickness="1" CornerRadius="4" Padding="16,14" Translation="0,0,32">
                            <Border.Shadow><ThemeShadow/></Border.Shadow>
                            <Grid ColumnSpacing="14">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="Auto" /><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                            <Border Width="40" Height="40" CornerRadius="4" Background="#10A4C9FF">
                                <FontIcon Glyph="&#xE946;" FontSize="18" Foreground="{StaticResource InfoBrush}" HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                            <StackPanel Grid.Column="1" Spacing="4" VerticalAlignment="Center">
                                <TextBlock Text="New User Joined â€” Sahil Ibrahim" FontSize="13" FontWeight="SemiBold" />
                                <TextBlock Text="A new team member has accepted their invitation and joined the organization." FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" TextWrapping="WrapWholeWords" />
                                <TextBlock Text="5 hours ago" FontSize="10" Foreground="{StaticResource TextTertiaryBrush}" />
                            </StackPanel>
                            <Button Grid.Column="2" Style="{StaticResource GhostButtonStyle}" Padding="8,6" FontSize="11" VerticalAlignment="Center" Click="OnDismissAlertClick">Dismiss</Button>
                        </Grid>
                    </Border>
                </StackPanel>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>



