# Copy to .env and fill in real values. Do not commit .env.

# Option A — SRV (short). On some networks Node.js fails with querySrv ECONNREFUSED;
# then use Option B from Atlas: Connect -> Drivers -> use the "standard" connection string.
# MONGODB_URI=mongodb+srv://USER:PASS@cluster0.xxxxx.mongodb.net/partfinder?retryWrites=true&w=majority&appName=Cluster0

# Option B — Standard (three host:27017 + replicaSet + tls). Paste from Atlas if Option A fails.
MONGODB_URI=

JWT_SECRET=replace-with-a-long-random-secret

PORT=3000

CORS_ORIGIN=http://localhost:5173

# Optional: npm run seed:admin
# SEED_ADMIN_EMAIL=
# SEED_ADMIN_PASSWORD=
# Shared secret for PartFinder (WinUI) -> POST /api/admin/debug/logs/ingest (header X-Debug-Log-Ingest-Key)
# Match appsettings.json DebugLog:IngestKey for desktop logs on the admin Debug page.
# DEBUG_LOG_INGEST_KEY=
