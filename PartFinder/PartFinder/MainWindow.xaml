<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="PartFinder.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:components="using:PartFinder.Views.Components"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="PartFinder">

    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <Grid x:Name="RootGrid" Background="{ThemeResource AppBackgroundBrush}">
        <components:ShellLayout x:Name="ShellRoot" Visibility="Collapsed" />

        <Border
            x:Name="SubscriptionBlockedRoot"
            Width="520"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            Padding="24"
            Visibility="Collapsed"
            Style="{ThemeResource AppCardBorderStyle}">
            <StackPanel Spacing="14">
                <TextBlock Text="Subscription / license inactive" Style="{ThemeResource AppTitleTextStyle}" />
                <TextBlock
                    x:Name="SubscriptionBlockedMessage"
                    TextWrapping="WrapWholeWords"
                    Foreground="{ThemeResource AppSubtleTextBrush}" />
                <TextBlock
                    Text="Your organization code is checked against PartFinder Platform. If the subscription has expired or the org was disabled, this app cannot run."
                    TextWrapping="WrapWholeWords"
                    Foreground="{ThemeResource AppSubtleTextBrush}" />
                <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right">
                    <Button Content="Exit" Click="OnSubscriptionBlockedExitClicked" />
                    <Button Content="Re-enter organization code" Click="OnSubscriptionBlockedResetSetupClicked" />
                </StackPanel>
            </StackPanel>
        </Border>

        <Border
            x:Name="MaintenanceBlockedRoot"
            Width="520"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            Padding="24"
            Visibility="Collapsed"
            Style="{ThemeResource AppCardBorderStyle}">
            <StackPanel Spacing="14">
                <TextBlock Text="Under maintenance" Style="{ThemeResource AppTitleTextStyle}" />
                <TextBlock
                    x:Name="MaintenanceLiveByText"
                    TextWrapping="WrapWholeWords"
                    Foreground="{ThemeResource AppSubtleTextBrush}" />
                <TextBlock
                    x:Name="MaintenanceCountdownText"
                    TextWrapping="WrapWholeWords"
                    Foreground="{ThemeResource AppSubtleTextBrush}" />
                <TextBlock
                    Text="The PartFinder platform is in a scheduled maintenance window. The app will reconnect automatically when the window ends, if your internet connection is available."
                    TextWrapping="WrapWholeWords"
                    Foreground="{ThemeResource AppSubtleTextBrush}" />
                <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right">
                    <Button Content="Exit" Click="OnSubscriptionBlockedExitClicked" />
                    <Button Content="Re-enter organization code" Click="OnMaintenanceBlockedResetSetupClicked" />
                </StackPanel>
            </StackPanel>
        </Border>

        <Border x:Name="SetupRoot" Width="640" HorizontalAlignment="Center" VerticalAlignment="Center" Style="{ThemeResource AppCardBorderStyle}">
            <StackPanel Spacing="16">
                <TextBlock Text="PartFinder Setup" Style="{ThemeResource AppTitleTextStyle}" />
                <TextBlock x:Name="StepTitle" Style="{ThemeResource AppSectionTextStyle}" />
                <TextBlock x:Name="ProgressText" Foreground="{ThemeResource AppSubtleTextBrush}" />

                <StackPanel x:Name="Step1Panel" Spacing="10">
                    <TextBlock Text="Organization Code" />
                    <TextBox
                        x:Name="OrgCodeBox"
                        MaxLength="6"
                        PlaceholderText="6-digit code (e.g. from admin)"
                        InputScope="Number" />
                    <StackPanel
                        x:Name="LicenseSummaryPanel"
                        Spacing="4"
                        Visibility="Collapsed"
                        Padding="10">
                        <TextBlock x:Name="LicenseSummaryTitle" Style="{ThemeResource AppSectionTextStyle}" Text="License" />
                        <TextBlock x:Name="LicenseOrgNameText" TextWrapping="WrapWholeWords" />
                        <TextBlock x:Name="LicenseCodeText" TextWrapping="WrapWholeWords" />
                        <TextBlock x:Name="LicenseStatusText" TextWrapping="WrapWholeWords" />
                        <TextBlock x:Name="LicenseExpiryText" TextWrapping="WrapWholeWords" />
                        <TextBlock x:Name="LicenseLimitsText" TextWrapping="WrapWholeWords" />
                    </StackPanel>
                    <TextBlock
                        Text="For invited admins/users: enter your invited email and temporary password. If setup is already completed on another PC, use your current admin password."
                        TextWrapping="WrapWholeWords"
                        Foreground="{ThemeResource AppSubtleTextBrush}" />
                    <TextBox x:Name="InviteLoginEmailBox" PlaceholderText="Invited Email ID" />
                    <PasswordBox x:Name="InviteLoginPasswordBox" />
                </StackPanel>

                <StackPanel x:Name="Step2Panel" Spacing="10" Visibility="Collapsed">
                    <TextBlock Text="Choose Database Mode" />
                    <RadioButtons x:Name="DatabaseModeButtons" SelectedIndex="0" SelectionChanged="OnDatabaseModeChanged">
                        <x:String>Default</x:String>
                        <x:String>Custom</x:String>
                    </RadioButtons>
                    <StackPanel x:Name="CustomDbPanel" Spacing="8" Visibility="Collapsed">
                        <TextBlock Text="MongoDB URI" />
                        <TextBox x:Name="MongoUriBox" PlaceholderText="Paste MongoDB URI" />
                        <Button x:Name="TestConnectionButton" Content="Test Connection" Click="OnTestConnectionClicked" />
                        <TextBlock x:Name="ConnectionSuccessText" Visibility="Collapsed" Foreground="LimeGreen" Text="DB connection successful." />
                    </StackPanel>
                </StackPanel>

                <StackPanel x:Name="Step3Panel" Spacing="10" Visibility="Collapsed">
                    <TextBlock Text="Change Temporary Password" />
                    <TextBlock x:Name="Step3EmailText" Foreground="{ThemeResource AppSubtleTextBrush}" />
                    <PasswordBox x:Name="CurrentPasswordBox" PlaceholderText="Current temporary password" />
                    <PasswordBox x:Name="NewPasswordBox" PlaceholderText="New password" PasswordChanged="OnAdminPasswordChanged" />
                    <PasswordBox x:Name="ConfirmPasswordBox" PlaceholderText="Confirm new password" />
                    <TextBlock x:Name="PasswordHintText" Foreground="{ThemeResource AppSubtleTextBrush}" Text="New password must be at least 8 characters and include upper, lower, and a number." />
                </StackPanel>

                <StackPanel x:Name="Step4Panel" Spacing="10" Visibility="Collapsed">
                    <TextBlock Text="Congratulations!" Style="{ThemeResource AppSectionTextStyle}" />
                    <TextBlock Text="PartFinder is successfully setup." />
                    <Button Content="Let's Go" Click="OnLetsGoClicked" />
                </StackPanel>

                <TextBlock x:Name="ValidationText" Foreground="IndianRed" />

                <StackPanel x:Name="NavigationRow" Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8">
                    <Button x:Name="BackButton" Content="Back" Click="OnBackClicked" />
                    <Button x:Name="NextButton" Content="Next" Click="OnNextClicked" />
                </StackPanel>
            </StackPanel>
        </Border>
    </Grid>
</Window>
