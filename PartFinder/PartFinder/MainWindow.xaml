<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="PartFinder.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:components="using:PartFinder.Views.Components"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="PartFinder">

    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    

    <Grid x:Name="RootGrid" Background="#0A0E15">
        <Grid.Resources>
        <!-- ===== FADE-IN STORYBOARD FOR SETUP ROOT ===== -->
        <Storyboard x:Key="SetupFadeIn">
            <DoubleAnimation
                Storyboard.TargetName="SetupRoot"
                Storyboard.TargetProperty="Opacity"
                From="0" To="1" Duration="0:0:0.5" />
        </Storyboard>

        <!-- Step panel slide-up + fade-in -->
        <Storyboard x:Key="StepPanelEntrance">
            <DoubleAnimation
                Storyboard.TargetName="FormContentArea"
                Storyboard.TargetProperty="Opacity"
                From="0" To="1" Duration="0:0:0.35" />
            <DoubleAnimation
                Storyboard.TargetName="FormSlideTransform"
                Storyboard.TargetProperty="Y"
                From="18" To="0" Duration="0:0:0.35">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseOut" />
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>

        <!-- ===== INPUT STYLE ===== -->
        <Style x:Key="DarkInputStyle" TargetType="TextBox">
            <Setter Property="Background" Value="#0B1320" />
            <Setter Property="Foreground" Value="#EAF2FF" />
            <Setter Property="BorderBrush" Value="#2A3D58" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Padding" Value="12,10" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="PlaceholderForeground" Value="#7B8DA8" />
            <Setter Property="MinHeight" Value="44" />
        </Style>

        <Style x:Key="DarkPasswordStyle" TargetType="PasswordBox">
            <Setter Property="Background" Value="#0B1320" />
            <Setter Property="Foreground" Value="#EAF2FF" />
            <Setter Property="BorderBrush" Value="#2A3D58" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Padding" Value="12,10" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="MinHeight" Value="44" />
        </Style>

        <!-- ===== PRIMARY BUTTON STYLE ===== -->
        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#1F7AE0" />
            <Setter Property="Foreground" Value="#FFFFFF" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="CornerRadius" Value="10" />
            <Setter Property="Padding" Value="20,12" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="MinHeight" Value="46" />
        </Style>

        <!-- ===== GHOST BUTTON STYLE ===== -->
        <Style x:Key="GhostButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="#AAB8CA" />
            <Setter Property="BorderBrush" Value="#2A3D58" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="10" />
            <Setter Property="Padding" Value="20,12" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="MinHeight" Value="46" />
        </Style>

        <!-- ===== LABEL STYLE ===== -->
        <Style x:Key="FieldLabelStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#AAB8CA" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Margin" Value="0,0,0,6" />
            <Setter Property="CharacterSpacing" Value="50" />
        </Style>

        <!-- ===== BLOCKED CARD STYLE ===== -->
        <Style x:Key="BlockedCardStyle" TargetType="Border">
            <Setter Property="Background" Value="#111A26" />
            <Setter Property="BorderBrush" Value="#2A3D58" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="16" />
            <Setter Property="Padding" Value="40" />
        </Style>
    </Grid.Resources>
        <!-- Shell (main app, shown after setup) -->
        <components:ShellLayout x:Name="ShellRoot" Visibility="Collapsed" />

        <!-- ===================================================== -->
        <!-- SUBSCRIPTION BLOCKED SCREEN                           -->
        <!-- ===================================================== -->
        <Border
            x:Name="SubscriptionBlockedRoot"
            Width="520"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            Visibility="Collapsed"
            Style="{StaticResource BlockedCardStyle}">
            <StackPanel Spacing="0">
                <!-- Icon -->
                <Border
                    Width="64" Height="64"
                    CornerRadius="32"
                    Background="#2A1A0E"
                    HorizontalAlignment="Left"
                    Margin="0,0,0,20">
                    <FontIcon
                        Glyph="&#xE7BA;"
                        FontSize="28"
                        Foreground="#FFB781"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center" />
                </Border>

                <TextBlock
                    Text="Subscription Inactive"
                    FontSize="22"
                    FontWeight="Bold"
                    Foreground="#EAF2FF"
                    Margin="0,0,0,8" />

                <TextBlock
                    x:Name="SubscriptionBlockedMessage"
                    TextWrapping="WrapWholeWords"
                    Foreground="#AAB8CA"
                    FontSize="14"
                    LineHeight="22"
                    Margin="0,0,0,8" />

                <TextBlock
                    Text="Your organization code is checked against PartFinder Platform. If the subscription has expired or the org was disabled, this app cannot run."
                    TextWrapping="WrapWholeWords"
                    Foreground="#7B8DA8"
                    FontSize="13"
                    LineHeight="20"
                    Margin="0,0,0,28" />

                <!-- Divider -->
                <Border Height="1" Background="#2A3D58" Margin="0,0,0,24" />

                <StackPanel Orientation="Horizontal" Spacing="12" HorizontalAlignment="Right">
                    <Button
                        Content="Exit"
                        Click="OnSubscriptionBlockedExitClicked"
                        Style="{StaticResource GhostButtonStyle}"
                        Width="120" />
                    <Button
                        Content="Re-enter Organization Code"
                        Click="OnSubscriptionBlockedResetSetupClicked"
                        Style="{StaticResource PrimaryButtonStyle}"
                        Width="220" />
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- ===================================================== -->
        <!-- MAINTENANCE BLOCKED SCREEN                            -->
        <!-- ===================================================== -->
        <Border
            x:Name="MaintenanceBlockedRoot"
            Width="520"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            Visibility="Collapsed"
            Style="{StaticResource BlockedCardStyle}">
            <StackPanel Spacing="0">
                <!-- Icon -->
                <Border
                    Width="64" Height="64"
                    CornerRadius="32"
                    Background="#0E1E2A"
                    HorizontalAlignment="Left"
                    Margin="0,0,0,20">
                    <FontIcon
                        Glyph="&#xE90F;"
                        FontSize="28"
                        Foreground="#A4C9FF"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center" />
                </Border>

                <TextBlock
                    Text="Under Maintenance"
                    FontSize="22"
                    FontWeight="Bold"
                    Foreground="#EAF2FF"
                    Margin="0,0,0,8" />

                <TextBlock
                    x:Name="MaintenanceLiveByText"
                    TextWrapping="WrapWholeWords"
                    Foreground="#AAB8CA"
                    FontSize="14"
                    LineHeight="22"
                    Margin="0,0,0,4" />

                <TextBlock
                    x:Name="MaintenanceCountdownText"
                    TextWrapping="WrapWholeWords"
                    Foreground="#1F7AE0"
                    FontSize="14"
                    FontWeight="SemiBold"
                    Margin="0,0,0,8" />

                <TextBlock
                    Text="The PartFinder platform is in a scheduled maintenance window. The app will reconnect automatically when the window ends, if your internet connection is available."
                    TextWrapping="WrapWholeWords"
                    Foreground="#7B8DA8"
                    FontSize="13"
                    LineHeight="20"
                    Margin="0,0,0,28" />

                <!-- Divider -->
                <Border Height="1" Background="#2A3D58" Margin="0,0,0,24" />

                <StackPanel Orientation="Horizontal" Spacing="12" HorizontalAlignment="Right">
                    <Button
                        Content="Exit"
                        Click="OnSubscriptionBlockedExitClicked"
                        Style="{StaticResource GhostButtonStyle}"
                        Width="120" />
                    <Button
                        Content="Re-enter Organization Code"
                        Click="OnMaintenanceBlockedResetSetupClicked"
                        Style="{StaticResource PrimaryButtonStyle}"
                        Width="220" />
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- ===================================================== -->
        <!-- SETUP ROOT - FULL SCREEN TWO-COLUMN LAYOUT            -->
        <!-- ===================================================== -->
        <Border
            x:Name="SetupRoot"
            HorizontalAlignment="Stretch"
            VerticalAlignment="Stretch"
            Opacity="0">
            <Border.Triggers>
                <EventTrigger RoutedEvent="Border.Loaded">
                    <BeginStoryboard>
                        <Storyboard>
                            <DoubleAnimation
                                Storyboard.TargetName="SetupRoot"
                                Storyboard.TargetProperty="Opacity"
                                From="0" To="1" Duration="0:0:0.55">
                                <DoubleAnimation.EasingFunction>
                                    <CubicEase EasingMode="EaseOut" />
                                </DoubleAnimation.EasingFunction>
                            </DoubleAnimation>
                        </Storyboard>
                    </BeginStoryboard>
                </EventTrigger>
            </Border.Triggers>

            <Grid>
                <Grid.ColumnDefinitions>
                    <!-- Left branding panel: 40% -->
                    <ColumnDefinition Width="2*" />
                    <!-- Right form panel: 60% -->
                    <ColumnDefinition Width="3*" />
                </Grid.ColumnDefinitions>

                <!-- ============================================= -->
                <!-- LEFT PANEL - Dark branded sidebar             -->
                <!-- ============================================= -->
                <Grid Grid.Column="0" Background="#0B111B">
                    <!-- Decorative background rings -->
                    <Canvas HorizontalAlignment="Stretch" VerticalAlignment="Stretch" IsHitTestVisible="False">
                        <!-- Large outer ring -->
                        <Ellipse
                            Canvas.Left="-120" Canvas.Top="-120"
                            Width="520" Height="520"
                            Stroke="#1A2A3E"
                            StrokeThickness="1.5"
                            Fill="Transparent"
                            Opacity="0.5" />
                        <!-- Medium ring -->
                        <Ellipse
                            Canvas.Left="-60" Canvas.Top="-60"
                            Width="360" Height="360"
                            Stroke="#1F3050"
                            StrokeThickness="1"
                            Fill="Transparent"
                            Opacity="0.4" />
                        <!-- Bottom decorative ring -->
                        <Ellipse
                            Canvas.Left="-80" Canvas.Top="520"
                            Width="400" Height="400"
                            Stroke="#1A2A3E"
                            StrokeThickness="1.5"
                            Fill="Transparent"
                            Opacity="0.35" />
                        <!-- Accent glow dot top-right -->
                        <Ellipse
                            Canvas.Left="180" Canvas.Top="60"
                            Width="8" Height="8"
                            Fill="#1F7AE0"
                            Opacity="0.6" />
                        <Ellipse
                            Canvas.Left="220" Canvas.Top="120"
                            Width="4" Height="4"
                            Fill="#2ABD8F"
                            Opacity="0.5" />
                        <Ellipse
                            Canvas.Left="160" Canvas.Top="160"
                            Width="6" Height="6"
                            Fill="#1F7AE0"
                            Opacity="0.3" />
                    </Canvas>

                    <!-- Gradient overlay -->
                    <Border HorizontalAlignment="Stretch" VerticalAlignment="Stretch" IsHitTestVisible="False">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                <GradientStop Color="#0D1520" Offset="0" />
                                <GradientStop Color="#0B111B" Offset="0.5" />
                                <GradientStop Color="#080E16" Offset="1" />
                            </LinearGradientBrush>
                        </Border.Background>
                    </Border>

                    <!-- Left panel content -->
                    <Grid Margin="40,48,40,40">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <!-- Logo + Brand -->
                        <StackPanel Grid.Row="0" Spacing="0">
                            <!-- Logo circle -->
                            <Border
                                Width="56" Height="56"
                                CornerRadius="16"
                                HorizontalAlignment="Left"
                                Margin="0,0,0,20">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Color="#1F7AE0" Offset="0" />
                                        <GradientStop Color="#155DAF" Offset="1" />
                                    </LinearGradientBrush>
                                </Border.Background>
                                <FontIcon
                                    Glyph="&#xE946;"
                                    FontSize="26"
                                    Foreground="#FFFFFF"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center" />
                            </Border>

                            <TextBlock
                                Text="PartFinder"
                                FontSize="28"
                                FontWeight="Bold"
                                Foreground="#EAF2FF"
                                Margin="0,0,0,6" />

                            <TextBlock
                                Text="Inventory Management Platform"
                                FontSize="13"
                                Foreground="#7B8DA8"
                                Margin="0,0,0,48" />

                            <!-- Thin separator -->
                            <Border Height="1" Margin="0,0,0,40">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                        <GradientStop Color="#2A3D58" Offset="0" />
                                        <GradientStop Color="Transparent" Offset="1" />
                                    </LinearGradientBrush>
                                </Border.Background>
                            </Border>
                        </StackPanel>

                        <!-- Step progress indicators -->
                        <StackPanel Grid.Row="1" Spacing="0" VerticalAlignment="Top">
                            <!-- Step 1 -->
                            <Grid Margin="0,0,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <!-- Circle indicator -->
                                <Border
                                    x:Name="Step1Circle"
                                    Grid.Column="0" Grid.Row="0"
                                    Width="32" Height="32"
                                    CornerRadius="16"
                                    Background="#1F7AE0"
                                    Margin="0,0,16,0">
                                    <TextBlock
                                        x:Name="Step1CircleText"
                                        Text="1"
                                        FontSize="13"
                                        FontWeight="Bold"
                                        Foreground="#FFFFFF"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center" />
                                </Border>

                                <!-- Step label -->
                                <StackPanel x:Name="Step1Label" Grid.Column="1" Grid.Row="0" VerticalAlignment="Center" Spacing="2">
                                    <TextBlock
                                        Text="Organization"
                                        FontSize="14"
                                        FontWeight="SemiBold"
                                        Foreground="#EAF2FF" />
                                    <TextBlock
                                        Text="License &amp; credentials"
                                        FontSize="12"
                                        Foreground="#7B8DA8" />
                                </StackPanel>

                                <!-- Connector line -->
                                <Border
                                    x:Name="Step1Connector"
                                    Grid.Column="0" Grid.Row="1"
                                    Width="2" Height="32"
                                    Background="#2A3D58"
                                    HorizontalAlignment="Center"
                                    Margin="0,4,16,4" />
                            </Grid>

                            <!-- Step 2 -->
                            <Grid Margin="0,0,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <Border
                                    x:Name="Step2Circle"
                                    Grid.Column="0" Grid.Row="0"
                                    Width="32" Height="32"
                                    CornerRadius="16"
                                    Background="#172334"
                                    BorderBrush="#2A3D58"
                                    BorderThickness="1.5"
                                    Margin="0,0,16,0"
                                    Opacity="0.7">
                                    <TextBlock
                                        x:Name="Step2CircleText"
                                        Text="2"
                                        FontSize="13"
                                        FontWeight="Bold"
                                        Foreground="#7B8DA8"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center" />
                                </Border>

                                <StackPanel x:Name="Step2Label" Grid.Column="1" Grid.Row="0" VerticalAlignment="Center" Spacing="2" Opacity="0.6">
                                    <TextBlock
                                        Text="Database"
                                        FontSize="14"
                                        FontWeight="SemiBold"
                                        Foreground="#EAF2FF" />
                                    <TextBlock
                                        Text="Storage configuration"
                                        FontSize="12"
                                        Foreground="#7B8DA8" />
                                </StackPanel>

                                <Border
                                    x:Name="Step2Connector"
                                    Grid.Column="0" Grid.Row="1"
                                    Width="2" Height="32"
                                    Background="#2A3D58"
                                    HorizontalAlignment="Center"
                                    Margin="0,4,16,4"
                                    Opacity="0.5" />
                            </Grid>

                            <!-- Step 3 -->
                            <Grid Margin="0,0,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <Border
                                    x:Name="Step3Circle"
                                    Grid.Column="0" Grid.Row="0"
                                    Width="32" Height="32"
                                    CornerRadius="16"
                                    Background="#172334"
                                    BorderBrush="#2A3D58"
                                    BorderThickness="1.5"
                                    Margin="0,0,16,0"
                                    Opacity="0.5">
                                    <TextBlock
                                        x:Name="Step3CircleText"
                                        Text="3"
                                        FontSize="13"
                                        FontWeight="Bold"
                                        Foreground="#7B8DA8"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center" />
                                </Border>

                                <StackPanel x:Name="Step3Label" Grid.Column="1" Grid.Row="0" VerticalAlignment="Center" Spacing="2" Opacity="0.45">
                                    <TextBlock
                                        Text="Security"
                                        FontSize="14"
                                        FontWeight="SemiBold"
                                        Foreground="#EAF2FF" />
                                    <TextBlock
                                        Text="Admin password"
                                        FontSize="12"
                                        Foreground="#7B8DA8" />
                                </StackPanel>

                                <Border
                                    x:Name="Step3Connector"
                                    Grid.Column="0" Grid.Row="1"
                                    Width="2" Height="32"
                                    Background="#2A3D58"
                                    HorizontalAlignment="Center"
                                    Margin="0,4,16,4"
                                    Opacity="0.35" />
                            </Grid>

                            <!-- Step 4 -->
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <Border
                                    x:Name="Step4Circle"
                                    Grid.Column="0"
                                    Width="32" Height="32"
                                    CornerRadius="16"
                                    Background="#172334"
                                    BorderBrush="#2A3D58"
                                    BorderThickness="1.5"
                                    Margin="0,0,16,0"
                                    Opacity="0.4">
                                    <TextBlock
                                        x:Name="Step4CircleText"
                                        Text="4"
                                        FontSize="13"
                                        FontWeight="Bold"
                                        Foreground="#7B8DA8"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center" />
                                </Border>

                                <StackPanel x:Name="Step4Label" Grid.Column="1" VerticalAlignment="Center" Spacing="2" Opacity="0.35">
                                    <TextBlock
                                        Text="Ready"
                                        FontSize="14"
                                        FontWeight="SemiBold"
                                        Foreground="#EAF2FF" />
                                    <TextBlock
                                        Text="Launch PartFinder"
                                        FontSize="12"
                                        Foreground="#7B8DA8" />
                                </StackPanel>
                            </Grid>
                        </StackPanel>

                        <!-- Bottom tagline -->
                        <StackPanel Grid.Row="2" Orientation="Horizontal" Spacing="10" VerticalAlignment="Bottom">
                            <FontIcon
                                Glyph="&#xEA18;"
                                FontSize="14"
                                Foreground="#7B8DA8"
                                VerticalAlignment="Center" />
                            <TextBlock
                                Text="Enterprise-grade parts management"
                                FontSize="12"
                                Foreground="#7B8DA8"
                                VerticalAlignment="Center" />
                        </StackPanel>
                    </Grid>
                </Grid>

                <!-- ============================================= -->
                <!-- RIGHT PANEL - Form area                       -->
                <!-- ============================================= -->
                <Border Grid.Column="1" Background="#111A26">
                    <!-- Subtle top border accent -->
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="3" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <!-- Top accent line -->
                        <Border Grid.Row="0">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                    <GradientStop Color="Transparent" Offset="0" />
                                    <GradientStop Color="#1F7AE0" Offset="0.4" />
                                    <GradientStop Color="#2ABD8F" Offset="0.7" />
                                    <GradientStop Color="Transparent" Offset="1" />
                                </LinearGradientBrush>
                            </Border.Background>
                        </Border>

                        <!-- Scrollable form content -->
                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                            <Grid x:Name="FormContentArea" Margin="64,52,64,52">
                                <Grid.RenderTransform>
                                    <TranslateTransform x:Name="FormSlideTransform" Y="0" />
                                </Grid.RenderTransform>

                                <StackPanel Spacing="0" MaxWidth="520">

                                    <!-- Step title + progress -->
                                    <TextBlock
                                        x:Name="StepTitle"
                                        FontSize="26"
                                        FontWeight="Bold"
                                        Foreground="#EAF2FF"
                                        Margin="0,0,0,8" />

                                    <TextBlock
                                        x:Name="ProgressText"
                                        FontSize="13"
                                        Foreground="#7B8DA8"
                                        Margin="0,0,0,36" />

                                    <!-- ========================= -->
                                    <!-- STEP 1: Organization      -->
                                    <!-- ========================= -->
                                    <StackPanel x:Name="Step1Panel" Spacing="0">

                                        <!-- Org Code field -->
                                        <TextBlock Text="ORGANIZATION CODE" Style="{StaticResource FieldLabelStyle}" />
                                        <TextBox
                                            x:Name="OrgCodeBox"
                                            MaxLength="6"
                                            PlaceholderText="6-digit code"
                                            InputScope="Number"
                                            Style="{StaticResource DarkInputStyle}"
                                            Margin="0,0,0,20" />

                                        <!-- License summary card (shown when org code is validated) -->
                                        <StackPanel
                                            x:Name="LicenseSummaryPanel"
                                            Spacing="0"
                                            Visibility="Collapsed"
                                            Margin="0,0,0,20">
                                            <Border
                                                Background="#0E1A2A"
                                                BorderThickness="0,0,0,0"
                                                CornerRadius="10"
                                                Padding="0">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="4" />
                                                        <ColumnDefinition Width="*" />
                                                    </Grid.ColumnDefinitions>
                                                    <!-- Blue left accent border -->
                                                    <Border
                                                        Grid.Column="0"
                                                        Background="#1F7AE0"
                                                        CornerRadius="10,0,0,10" />
                                                    <!-- Card content -->
                                                    <StackPanel Grid.Column="1" Spacing="6" Padding="16,14,16,14">
                                                        <TextBlock
                                                            x:Name="LicenseSummaryTitle"
                                                            Text="License"
                                                            FontSize="11"
                                                            FontWeight="Bold"
                                                            Foreground="#1F7AE0"
                                                            CharacterSpacing="80" />
                                                        <TextBlock x:Name="LicenseOrgNameText" FontSize="14" FontWeight="SemiBold" Foreground="#EAF2FF" TextWrapping="WrapWholeWords" />
                                                        <TextBlock x:Name="LicenseCodeText" FontSize="12" Foreground="#AAB8CA" TextWrapping="WrapWholeWords" />
                                                        <TextBlock x:Name="LicenseStatusText" FontSize="12" Foreground="#2ABD8F" TextWrapping="WrapWholeWords" />
                                                        <TextBlock x:Name="LicenseExpiryText" FontSize="12" Foreground="#AAB8CA" TextWrapping="WrapWholeWords" />
                                                        <TextBlock x:Name="LicenseLimitsText" FontSize="12" Foreground="#7B8DA8" TextWrapping="WrapWholeWords" />
                                                    </StackPanel>
                                                </Grid>
                                            </Border>
                                        </StackPanel>

                                        <!-- Invited user section -->
                                        <Border
                                            Background="#0D1520"
                                            BorderBrush="#2A3D58"
                                            BorderThickness="1"
                                            CornerRadius="10"
                                            Padding="16,14"
                                            Margin="0,0,0,20">
                                            <StackPanel Spacing="4">
                                                <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,0,0,4">
                                                    <FontIcon Glyph="&#xE8F8;" FontSize="13" Foreground="#7B8DA8" VerticalAlignment="Center" />
                                                    <TextBlock
                                                        Text="Invited user or existing admin?"
                                                        FontSize="12"
                                                        FontWeight="SemiBold"
                                                        Foreground="#AAB8CA"
                                                        VerticalAlignment="Center" />
                                                </StackPanel>
                                                <TextBlock
                                                    Text="Enter your invited email and temporary password. If setup is already completed on another PC, use your current admin password."
                                                    TextWrapping="WrapWholeWords"
                                                    Foreground="#7B8DA8"
                                                    FontSize="12"
                                                    LineHeight="18" />
                                            </StackPanel>
                                        </Border>

                                        <TextBlock Text="EMAIL ADDRESS" Style="{StaticResource FieldLabelStyle}" />
                                        <TextBox
                                            x:Name="InviteLoginEmailBox"
                                            PlaceholderText="your@email.com"
                                            Style="{StaticResource DarkInputStyle}"
                                            Margin="0,0,0,16" />

                                        <TextBlock Text="PASSWORD" Style="{StaticResource FieldLabelStyle}" />
                                        <PasswordBox
                                            x:Name="InviteLoginPasswordBox"
                                            PlaceholderText="Enter password"
                                            Style="{StaticResource DarkPasswordStyle}"
                                            Margin="0,0,0,0" />
                                    </StackPanel>

                                    <!-- ========================= -->
                                    <!-- STEP 2: Database          -->
                                    <!-- ========================= -->
                                    <StackPanel x:Name="Step2Panel" Spacing="0" Visibility="Collapsed">

                                        <TextBlock Text="DATABASE MODE" Style="{StaticResource FieldLabelStyle}" />

                                        <RadioButtons
                                            x:Name="DatabaseModeButtons"
                                            SelectedIndex="0"
                                            SelectionChanged="OnDatabaseModeChanged"
                                            Margin="0,0,0,20">
                                            <RadioButtons.Items>
                                                <RadioButton Content="Default (Managed)" Foreground="#EAF2FF" />
                                                <RadioButton Content="Custom MongoDB" Foreground="#EAF2FF" />
                                            </RadioButtons.Items>
                                        </RadioButtons>

                                        <!-- Default mode info card -->
                                        <Border
                                            Background="#0D1520"
                                            BorderBrush="#2A3D58"
                                            BorderThickness="1"
                                            CornerRadius="10"
                                            Padding="16,14"
                                            Margin="0,0,0,20">
                                            <StackPanel Orientation="Horizontal" Spacing="12">
                                                <FontIcon Glyph="&#xE946;" FontSize="18" Foreground="#1F7AE0" VerticalAlignment="Top" Margin="0,2,0,0" />
                                                <StackPanel Spacing="4">
                                                    <TextBlock Text="Managed Database" FontSize="13" FontWeight="SemiBold" Foreground="#EAF2FF" />
                                                    <TextBlock Text="PartFinder will use the default managed database. No configuration needed." FontSize="12" Foreground="#7B8DA8" TextWrapping="WrapWholeWords" LineHeight="18" />
                                                </StackPanel>
                                            </StackPanel>
                                        </Border>

                                        <!-- Custom DB panel -->
                                        <StackPanel x:Name="CustomDbPanel" Spacing="0" Visibility="Collapsed">
                                            <TextBlock Text="MONGODB CONNECTION URI" Style="{StaticResource FieldLabelStyle}" />
                                            <TextBox
                                                x:Name="MongoUriBox"
                                                PlaceholderText="mongodb+srv://user:pass@cluster.mongodb.net/db"
                                                Style="{StaticResource DarkInputStyle}"
                                                Margin="0,0,0,12" />
                                            <Button
                                                x:Name="TestConnectionButton"
                                                Content="Test Connection"
                                                Click="OnTestConnectionClicked"
                                                Style="{StaticResource GhostButtonStyle}"
                                                HorizontalAlignment="Left"
                                                Width="180"
                                                Margin="0,0,0,10" />
                                            <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,0,0,0">
                                                <FontIcon
                                                    Glyph="&#xE73E;"
                                                    FontSize="14"
                                                    Foreground="#2ABD8F"
                                                    VerticalAlignment="Center" />
                                                <TextBlock
                                                    x:Name="ConnectionSuccessText"
                                                    Visibility="Collapsed"
                                                    Foreground="#2ABD8F"
                                                    FontSize="13"
                                                    FontWeight="SemiBold"
                                                    Text="Connection successful"
                                                    VerticalAlignment="Center" />
                                            </StackPanel>
                                        </StackPanel>
                                    </StackPanel>

                                    <!-- ========================= -->
                                    <!-- STEP 3: Security          -->
                                    <!-- ========================= -->
                                    <StackPanel x:Name="Step3Panel" Spacing="0" Visibility="Collapsed">

                                        <!-- Account info banner -->
                                        <Border
                                            Background="#0D1520"
                                            BorderBrush="#2A3D58"
                                            BorderThickness="1"
                                            CornerRadius="10"
                                            Padding="16,14"
                                            Margin="0,0,0,24">
                                            <StackPanel Orientation="Horizontal" Spacing="12">
                                                <Border
                                                    Width="36" Height="36"
                                                    CornerRadius="18"
                                                    Background="#172334">
                                                    <FontIcon Glyph="&#xE77B;" FontSize="16" Foreground="#1F7AE0" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                </Border>
                                                <StackPanel VerticalAlignment="Center" Spacing="2">
                                                    <TextBlock Text="Admin Account" FontSize="12" Foreground="#7B8DA8" />
                                                    <TextBlock x:Name="Step3EmailText" FontSize="14" FontWeight="SemiBold" Foreground="#EAF2FF" />
                                                </StackPanel>
                                            </StackPanel>
                                        </Border>

                                        <TextBlock Text="CURRENT TEMPORARY PASSWORD" Style="{StaticResource FieldLabelStyle}" />
                                        <PasswordBox
                                            x:Name="CurrentPasswordBox"
                                            PlaceholderText="Enter temporary password"
                                            Style="{StaticResource DarkPasswordStyle}"
                                            Margin="0,0,0,16" />

                                        <TextBlock Text="NEW PASSWORD" Style="{StaticResource FieldLabelStyle}" />
                                        <PasswordBox
                                            x:Name="NewPasswordBox"
                                            PlaceholderText="Create a strong password"
                                            PasswordChanged="OnAdminPasswordChanged"
                                            Style="{StaticResource DarkPasswordStyle}"
                                            Margin="0,0,0,16" />

                                        <TextBlock Text="CONFIRM NEW PASSWORD" Style="{StaticResource FieldLabelStyle}" />
                                        <PasswordBox
                                            x:Name="ConfirmPasswordBox"
                                            PlaceholderText="Repeat new password"
                                            Style="{StaticResource DarkPasswordStyle}"
                                            Margin="0,0,0,12" />

                                        <!-- Password hint -->
                                        <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,0,0,0">
                                            <FontIcon Glyph="&#xE946;" FontSize="12" Foreground="#7B8DA8" VerticalAlignment="Top" Margin="0,2,0,0" />
                                            <TextBlock
                                                x:Name="PasswordHintText"
                                                Foreground="#7B8DA8"
                                                FontSize="12"
                                                LineHeight="18"
                                                TextWrapping="WrapWholeWords"
                                                Text="New password must be at least 8 characters and include upper, lower, and a number." />
                                        </StackPanel>
                                    </StackPanel>

                                    <!-- ========================= -->
                                    <!-- STEP 4: Ready / Success   -->
                                    <!-- ========================= -->
                                    <StackPanel x:Name="Step4Panel" Spacing="0" Visibility="Collapsed" HorizontalAlignment="Center">

                                        <!-- Decorative confetti dots -->
                                        <Canvas Width="320" Height="60" HorizontalAlignment="Center" Margin="0,0,0,8" IsHitTestVisible="False">
                                            <Ellipse Canvas.Left="20" Canvas.Top="10" Width="8" Height="8" Fill="#1F7AE0" Opacity="0.7" />
                                            <Ellipse Canvas.Left="60" Canvas.Top="5" Width="5" Height="5" Fill="#2ABD8F" Opacity="0.8" />
                                            <Ellipse Canvas.Left="100" Canvas.Top="20" Width="6" Height="6" Fill="#FFB781" Opacity="0.6" />
                                            <Ellipse Canvas.Left="150" Canvas.Top="8" Width="10" Height="10" Fill="#1F7AE0" Opacity="0.5" />
                                            <Ellipse Canvas.Left="200" Canvas.Top="15" Width="5" Height="5" Fill="#2ABD8F" Opacity="0.7" />
                                            <Ellipse Canvas.Left="240" Canvas.Top="6" Width="7" Height="7" Fill="#A4C9FF" Opacity="0.6" />
                                            <Ellipse Canvas.Left="280" Canvas.Top="18" Width="6" Height="6" Fill="#FFB781" Opacity="0.5" />
                                            <Ellipse Canvas.Left="40" Canvas.Top="40" Width="4" Height="4" Fill="#2ABD8F" Opacity="0.4" />
                                            <Ellipse Canvas.Left="130" Canvas.Top="45" Width="5" Height="5" Fill="#1F7AE0" Opacity="0.4" />
                                            <Ellipse Canvas.Left="260" Canvas.Top="42" Width="4" Height="4" Fill="#A4C9FF" Opacity="0.5" />
                                        </Canvas>

                                        <!-- Success icon -->
                                        <Border
                                            Width="80" Height="80"
                                            CornerRadius="40"
                                            HorizontalAlignment="Center"
                                            Margin="0,0,0,24">
                                            <Border.Background>
                                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                    <GradientStop Color="#1A3D2E" Offset="0" />
                                                    <GradientStop Color="#0E2A1E" Offset="1" />
                                                </LinearGradientBrush>
                                            </Border.Background>
                                            <FontIcon
                                                Glyph="&#xE73E;"
                                                FontSize="36"
                                                Foreground="#2ABD8F"
                                                HorizontalAlignment="Center"
                                                VerticalAlignment="Center" />
                                        </Border>

                                        <TextBlock
                                            Text="You're all set!"
                                            FontSize="28"
                                            FontWeight="Bold"
                                            Foreground="#EAF2FF"
                                            HorizontalAlignment="Center"
                                            Margin="0,0,0,10" />

                                        <TextBlock
                                            Text="PartFinder is ready to use."
                                            FontSize="15"
                                            Foreground="#AAB8CA"
                                            HorizontalAlignment="Center"
                                            Margin="0,0,0,36" />

                                        <!-- Launch button -->
                                        <Button
                                            Content="Launch PartFinder  →"
                                            Click="OnLetsGoClicked"
                                            Style="{StaticResource PrimaryButtonStyle}"
                                            Width="280"
                                            HorizontalAlignment="Center" />
                                    </StackPanel>

                                    <!-- ========================= -->
                                    <!-- VALIDATION TEXT           -->
                                    <!-- ========================= -->
                                    <TextBlock
                                        x:Name="ValidationText"
                                        Foreground="#FFB4AB"
                                        FontSize="13"
                                        TextWrapping="WrapWholeWords"
                                        Margin="0,16,0,0" />

                                    <!-- ========================= -->
                                    <!-- NAVIGATION ROW            -->
                                    <!-- ========================= -->
                                    <StackPanel
                                        x:Name="NavigationRow"
                                        Orientation="Horizontal"
                                        HorizontalAlignment="Right"
                                        Spacing="12"
                                        Margin="0,28,0,0">
                                        <Button
                                            x:Name="BackButton"
                                            Content="Back"
                                            Click="OnBackClicked"
                                            Style="{StaticResource GhostButtonStyle}"
                                            Width="120" />
                                        <Button
                                            x:Name="NextButton"
                                            Content="Continue"
                                            Click="OnNextClicked"
                                            Style="{StaticResource PrimaryButtonStyle}"
                                            Width="160" />
                                    </StackPanel>

                                </StackPanel>
                            </Grid>
                        </ScrollViewer>
                    </Grid>
                </Border>

            </Grid>
        </Border>

    </Grid>
</Window>
