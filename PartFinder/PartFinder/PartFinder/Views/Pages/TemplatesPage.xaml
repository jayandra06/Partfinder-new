<Page
    x:Class="PartFinder.Views.Pages.TemplatesPage"
    x:Name="TemplatesPageRoot"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:components="using:PartFinder.Views.Components"
    xmlns:converters="using:PartFinder.Converters"
    xmlns:viewmodels="using:PartFinder.ViewModels"
    xmlns:models="using:PartFinder.Models"
    KeyDown="OnTemplatesPageKeyDown">
    <Page.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter" />
        <converters:InvertedBoolToVisibilityConverter x:Key="InvertedBoolToVisibilityConverter" />
        <converters:TemplateFieldTypeToSampleValueConverter x:Key="TemplateFieldTypeToSampleValueConverter" />
        <LinearGradientBrush x:Key="MacPageBackgroundBrush" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#0A1220" Offset="0" />
            <GradientStop Color="#0D1526" Offset="0.55" />
            <GradientStop Color="#111B2F" Offset="1" />
        </LinearGradientBrush>
        <SolidColorBrush x:Key="MacGlassBackgroundBrush" Color="#CC1B2A3D" />
        <SolidColorBrush x:Key="MacGlassHighlightBrush" Color="#66A4C9FF" />
        <Style x:Key="MacGlassPanelStyle" TargetType="Border" BasedOn="{StaticResource ElevatedCardStyle}">
            <Setter Property="Background" Value="{StaticResource MacGlassBackgroundBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource MacGlassHighlightBrush}" />
            <Setter Property="CornerRadius" Value="18" />
            <Setter Property="Padding" Value="16" />
        </Style>
        <Style x:Key="MacTopActionButtonStyle" TargetType="Button" BasedOn="{StaticResource PrimaryButtonStyle}">
            <Setter Property="CornerRadius" Value="18" />
            <Setter Property="Padding" Value="16,8" />
            <Setter Property="MinHeight" Value="36" />
        </Style>
        <Style x:Key="MacCircleIconButtonStyle" TargetType="Button" BasedOn="{StaticResource OutlinedButtonStyle}">
            <Setter Property="Width" Value="34" />
            <Setter Property="Height" Value="34" />
            <Setter Property="MinHeight" Value="34" />
            <Setter Property="CornerRadius" Value="17" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Background" Value="#66223752" />
            <Setter Property="BorderBrush" Value="#88A4C9FF" />
        </Style>
        <Style x:Key="MacSubtleButtonStyle" TargetType="Button" BasedOn="{StaticResource GhostButtonStyle}">
            <Setter Property="CornerRadius" Value="14" />
            <Setter Property="Padding" Value="12,6" />
            <Setter Property="Foreground" Value="#D9EAFD" />
            <Setter Property="Background" Value="#3322384F" />
            <Setter Property="BorderBrush" Value="#55A4C9FF" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>
        <Style x:Key="MacSegmentedNavHostStyle" TargetType="Border">
            <Setter Property="CornerRadius" Value="16" />
            <Setter Property="Padding" Value="4" />
            <Setter Property="Background" Value="#55324663" />
            <Setter Property="BorderBrush" Value="#77A4C9FF" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>
        <Style x:Key="MacSegmentButtonStyle" TargetType="Button" BasedOn="{StaticResource GhostButtonStyle}">
            <Setter Property="Width" Value="30" />
            <Setter Property="Height" Value="28" />
            <Setter Property="MinHeight" Value="28" />
            <Setter Property="CornerRadius" Value="12" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Background" Value="#66304A6B" />
            <Setter Property="BorderBrush" Value="#66A4C9FF" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="#EAF2FF" />
        </Style>
        <Style x:Key="CarouselNavButtonStyle" TargetType="Button" BasedOn="{StaticResource OutlinedButtonStyle}">
            <Setter Property="MinWidth" Value="88" />
            <Setter Property="Height" Value="38" />
            <Setter Property="CornerRadius" Value="19" />
            <Setter Property="Padding" Value="14,6" />
            <Setter Property="Background" Value="#440A1322" />
            <Setter Property="BorderBrush" Value="#99D8E6FF" />
            <Setter Property="BorderThickness" Value="1.2" />
            <Setter Property="Foreground" Value="#EAF2FF" />
        </Style>
    </Page.Resources>

    <Grid Padding="22" ColumnSpacing="18" Background="{StaticResource MacPageBackgroundBrush}">
        <Grid.Transitions>
            <TransitionCollection>
                <EntranceThemeTransition />
                <RepositionThemeTransition />
            </TransitionCollection>
        </Grid.Transitions>
        <ScrollViewer
            VerticalScrollBarVisibility="Disabled"
            VerticalScrollMode="Disabled"
            HorizontalScrollBarVisibility="Disabled"
            HorizontalScrollMode="Disabled"
            ZoomMode="Disabled"
            Background="Transparent">
            <StackPanel Spacing="0" Padding="20,16,20,24" HorizontalAlignment="Stretch">

                <!-- =========================================== -->
                <!-- HEADER                                     -->
                <!-- =========================================== -->
                <Grid Margin="0,0,0,14">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Spacing="4">
                        <TextBlock Text="TEMPLATES" FontSize="10" Foreground="#8FB7EC" CharacterSpacing="80" FontWeight="SemiBold" />
                        <TextBlock Text="Design and manage data schemas for your parts. Define columns, data types, and validation rules to structure your inventory." FontSize="12" Foreground="#B8CAE1" TextWrapping="WrapWholeWords" MaxWidth="720" />
                    </StackPanel>
                    <Button
                        Grid.Column="1"
                        VerticalAlignment="Top"
                        Style="{StaticResource MacTopActionButtonStyle}"
                        FontSize="12"
                        Content="+ New Template"
                        Command="{Binding StartNewCustomTemplateCommand}"
                        IsEnabled="{Binding CanAddAnotherTemplate}" />
                </Grid>

                <!-- DB Missing Banner -->
                <Border
                    Margin="0,0,0,14"
                    Padding="10,8"
                    CornerRadius="8"
                    Background="#2A1A1A"
                    BorderBrush="{StaticResource DangerBrush}"
                    BorderThickness="1"
                    Visibility="{Binding ShowDbMissingBanner, Converter={StaticResource BoolToVisibilityConverter}}">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon Glyph="&#xE7BA;" FontSize="13" Foreground="{StaticResource DangerBrush}" VerticalAlignment="Center" />
                        <TextBlock
                            Text="No tenant database configured. Complete setup with a valid organization and database connection."
                            FontSize="12"
                            Foreground="{StaticResource DangerBrush}"
                            TextWrapping="WrapWholeWords"
                            VerticalAlignment="Center" />
                    </StackPanel>
                </Border>

                <!-- =========================================== -->
                <!-- TEMPLATE EDITOR (New/Edit Template)        -->
                <!-- =========================================== -->
                <Grid Visibility="{Binding ShowTemplateEditor, Converter={StaticResource BoolToVisibilityConverter}}">
                    <Border Style="{StaticResource MacGlassPanelStyle}" Padding="18">
                        <Border.Shadow>
                            <ThemeShadow />
                        </Border.Shadow>
                        <StackPanel Spacing="16">
                            <TextBlock Text="NEW TEMPLATE CANVAS" FontSize="10" Foreground="{StaticResource AccentPrimaryBrush}" CharacterSpacing="80" FontWeight="SemiBold" />
                            <TextBox
                                Style="{StaticResource StandardTextBoxStyle}"
                                IsReadOnly="{Binding IsTemplateNameReadOnly}"
                                PlaceholderText="Template name..."
                                FontSize="20"
                                FontWeight="SemiBold"
                                Text="{Binding NewTemplateName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                            <Border Background="#401F2F46" BorderBrush="{StaticResource BorderDefaultBrush}" BorderThickness="1" CornerRadius="16" Padding="14" MinHeight="260">
                                <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
                                    <StackPanel Orientation="Horizontal" Spacing="10" HorizontalAlignment="Center">
                                        <ItemsControl ItemsSource="{Binding ColumnLabels}">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <StackPanel Orientation="Horizontal" Spacing="10" />
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="160" />
                                                            <ColumnDefinition Width="Auto" />
                                                        </Grid.ColumnDefinitions>
                                                        <Border Grid.Column="0" Background="{StaticResource CardBackgroundBrush}" BorderBrush="{StaticResource BorderDefaultBrush}" BorderThickness="1" CornerRadius="12" Padding="10">
                                                            <StackPanel Spacing="8">
                                                                <TextBox
                                                                    PlaceholderText="Column name"
                                                                    Text="{Binding Label, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                                                <ComboBox
                                                                    DisplayMemberPath="Label"
                                                                    ItemsSource="{Binding DataContext.FieldTypeOptions, ElementName=TemplatesPageRoot}"
                                                                    SelectedValue="{Binding FieldType, Mode=TwoWay}"
                                                                    SelectedValuePath="Value" />
                                                                <Button
                                                                    Style="{StaticResource GhostButtonStyle}"
                                                                    HorizontalAlignment="Right"
                                                                    Click="OnRemoveColumnClick"
                                                                    Content="Remove"
                                                                    FontSize="11" />
                                                            </StackPanel>
                                                        </Border>
                                                        <Button
                                                            Grid.Column="1"
                                                            Width="28"
                                                            Height="28"
                                                            Margin="8,0,0,0"
                                                            VerticalAlignment="Center"
                                                            Style="{StaticResource MacCircleIconButtonStyle}"
                                                            Click="OnInsertDraftColumnClick"
                                                            Opacity="0.35"
                                                            PointerEntered="OnAffordancePointerEntered"
                                                            PointerExited="OnAffordancePointerExited"
                                                            Content="+"
                                                            ToolTipService.ToolTip="Add next column" />
                                                    </Grid>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                        <Button
                                            Width="34"
                                            Height="34"
                                            VerticalAlignment="Center"
                                            Style="{StaticResource MacCircleIconButtonStyle}"
                                            Command="{Binding AddColumnCommand}"
                                            Content="+"
                                            ToolTipService.ToolTip="Add column" />
                                    </StackPanel>
                                </ScrollViewer>
                            </Border>

                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <Button Style="{StaticResource MacSubtleButtonStyle}" Command="{Binding CancelCreateCommand}" Content="Cancel" FontSize="12" />
                                <Button Style="{StaticResource PrimaryButtonStyle}" Command="{Binding SaveTemplateCommand}" Content="Save Template" FontSize="12" />
                            </StackPanel>
                            <TextBlock
                                Foreground="{StaticResource DangerBrush}"
                                Text="{Binding FormError}"
                                FontSize="12"
                                TextWrapping="WrapWholeWords" />
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- =========================================== -->
                <!-- TEMPLATE PREVIEW (Selected Template View)  -->
                <!-- =========================================== -->
                <StackPanel Visibility="{Binding ShowTemplatePreviewPanel, Converter={StaticResource BoolToVisibilityConverter}}" Spacing="18">
                    <Grid HorizontalAlignment="Stretch">
                        <Border
                            Background="#0A0D13"
                            CornerRadius="20"
                            BorderBrush="#1C2B44"
                            BorderThickness="1"
                            Padding="14"
                            MinHeight="430"
                            HorizontalAlignment="Stretch">
                            <Border.Shadow><ThemeShadow /></Border.Shadow>
                            <Viewbox Stretch="Uniform" StretchDirection="DownOnly" HorizontalAlignment="Center" VerticalAlignment="Center">
                                <Grid Width="1160" Height="360" HorizontalAlignment="Center">
                                    <Border
                                    x:Name="LeftFarCarouselCard"
                                    Width="170"
                                    Height="260"
                                    CornerRadius="20"
                                    Background="#201E2E45"
                                    BorderBrush="#4B6E99"
                                    BorderThickness="1"
                                    Opacity="0.25"
                                    HorizontalAlignment="Left"
                                    VerticalAlignment="Center"
                                    Margin="56,0,0,0"
                                    Visibility="{Binding ShowFarCarouselNeighbors, Converter={StaticResource BoolToVisibilityConverter}}">
                                    <Border.RenderTransform><RotateTransform Angle="-16" /></Border.RenderTransform>
                                    <StackPanel Margin="12,10,12,10" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding LeftFarCarouselNumber}" FontSize="34" FontWeight="SemiBold" Foreground="#8FA8C7" HorizontalAlignment="Center" />
                                    </StackPanel>
                                </Border>

                                    <Border
                                    x:Name="LeftCarouselCard"
                                    Width="230"
                                    Height="320"
                                    CornerRadius="24"
                                    Background="#1E2236"
                                    BorderBrush="#4A84D7"
                                    BorderThickness="1.2"
                                    Opacity="0.78"
                                    HorizontalAlignment="Left"
                                    VerticalAlignment="Center"
                                    Margin="188,0,0,0"
                                    Tapped="OnLeftCarouselCardTapped"
                                    Visibility="{Binding ShowCarouselNeighbors, Converter={StaticResource BoolToVisibilityConverter}}">
                                    <Border.RenderTransform><RotateTransform Angle="-10" /></Border.RenderTransform>
                                    <StackPanel Margin="16,14,16,14" VerticalAlignment="Center" Spacing="8">
                                        <TextBlock Text="{Binding LeftCarouselTemplate.Name, TargetNullValue='Template'}" FontSize="14" Foreground="#AFC0D9" TextAlignment="Center" />
                                        <TextBlock Text="{Binding LeftCarouselNumber}" FontSize="56" FontWeight="SemiBold" Foreground="#61A5FF" HorizontalAlignment="Center" />
                                    </StackPanel>
                                </Border>

                                    <Border
                                    x:Name="CenterCarouselCard"
                                    Width="300"
                                    Height="360"
                                    CornerRadius="26"
                                    Background="#141C2A"
                                    BorderBrush="#2EE89D"
                                    BorderThickness="1.5"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    Canvas.ZIndex="20">
                                    <Border.Shadow><ThemeShadow /></Border.Shadow>
                                    <Grid Margin="18,16,18,16">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="*" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>
                                        <TextBlock Text="Master Template" FontSize="13" Foreground="#8FEBC7" HorizontalAlignment="Center" />
                                        <StackPanel Grid.Row="1" VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="10">
                                            <Border Width="114" Height="114" CornerRadius="57" BorderBrush="#2EE89D" BorderThickness="2.2">
                                                <Viewbox Stretch="Uniform">
                                                    <TextBlock Text="{Binding SelectedCarouselNumber}" FontWeight="SemiBold" Foreground="#2EE89D" />
                                                </Viewbox>
                                            </Border>
                                            <TextBlock Text="{Binding SelectedTemplate.Name}" FontSize="15" FontWeight="SemiBold" Foreground="#EAF2FF" TextAlignment="Center" TextWrapping="WrapWholeWords" MaxWidth="240" />
                                        </StackPanel>
                                        <TextBlock Grid.Row="2" Text="Animate anything" FontSize="11" Foreground="#78A3D6" HorizontalAlignment="Center" />
                                    </Grid>
                                </Border>

                                    <Border
                                    x:Name="RightCarouselCard"
                                    Width="230"
                                    Height="320"
                                    CornerRadius="24"
                                    Background="#2A2231"
                                    BorderBrush="#C28CFF"
                                    BorderThickness="1.2"
                                    Opacity="0.78"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Center"
                                    Margin="0,0,188,0"
                                    Tapped="OnRightCarouselCardTapped"
                                    Visibility="{Binding ShowCarouselNeighbors, Converter={StaticResource BoolToVisibilityConverter}}">
                                    <Border.RenderTransform><RotateTransform Angle="10" /></Border.RenderTransform>
                                    <StackPanel Margin="16,14,16,14" VerticalAlignment="Center" Spacing="8">
                                        <TextBlock Text="{Binding RightCarouselTemplate.Name, TargetNullValue='Template'}" FontSize="14" Foreground="#D9C7ED" TextAlignment="Center" />
                                        <TextBlock Text="{Binding RightCarouselNumber}" FontSize="56" FontWeight="SemiBold" Foreground="#E6A5FF" HorizontalAlignment="Center" />
                                    </StackPanel>
                                </Border>

                                    <Border
                                    x:Name="RightFarCarouselCard"
                                    Width="170"
                                    Height="260"
                                    CornerRadius="20"
                                    Background="#201E2E45"
                                    BorderBrush="#4B6E99"
                                    BorderThickness="1"
                                    Opacity="0.25"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Center"
                                    Margin="0,0,56,0"
                                    Visibility="{Binding ShowFarCarouselNeighbors, Converter={StaticResource BoolToVisibilityConverter}}">
                                    <Border.RenderTransform><RotateTransform Angle="16" /></Border.RenderTransform>
                                    <StackPanel Margin="12,10,12,10" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding RightFarCarouselNumber}" FontSize="34" FontWeight="SemiBold" Foreground="#8FA8C7" HorizontalAlignment="Center" />
                                    </StackPanel>
                                    </Border>
                                </Grid>
                            </Viewbox>
                        </Border>
                    </Grid>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="12">
                        <Button Style="{StaticResource CarouselNavButtonStyle}" Content="Prev" Click="OnPreviousTemplateClick" />
                        <Button Style="{StaticResource CarouselNavButtonStyle}" Content="Next" Click="OnNextTemplateClick" />
                    </StackPanel>

                    <StackPanel x:Name="TemplateChipRowPanel" Visibility="Collapsed" />
                </StackPanel>

                <!-- =========================================== -->
                <!-- SELECT TEMPLATE PROMPT                     -->
                <!-- =========================================== -->
                <StackPanel Visibility="{Binding ShowSelectTemplatePromptPanel, Converter={StaticResource BoolToVisibilityConverter}}">
                    <components:PageHeader Subtitle="Select a template on the left to preview its columns." Title="Templates" />
                </StackPanel>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>



