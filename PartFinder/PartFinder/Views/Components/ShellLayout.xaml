<UserControl
    x:Class="PartFinder.Views.Components.ShellLayout"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converters="using:PartFinder.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:viewModels="using:PartFinder.ViewModels"
    mc:Ignorable="d">

    <UserControl.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter" />
        <converters:InvertedBoolToVisibilityConverter x:Key="InvertedBoolToVisibilityConverter" />
    </UserControl.Resources>
    <Grid Background="{ThemeResource AppBackgroundBrush}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition x:Name="SidebarColumn" Width="240" MinWidth="56" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="60" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.RowSpan="2" Grid.Column="0"
                Background="{ThemeResource AppSidebarBrush}"
                BorderBrush="{ThemeResource AppBorderBrush}"
                BorderThickness="0,0,1,0">
            <StackPanel x:Name="SidebarRoot" Padding="12,12,12,16" Spacing="4">

                <!-- Logo row + toggle button -->
                <Grid MinHeight="40">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <!-- Logo — hidden when collapsed -->
                    <StackPanel
                        Grid.Column="0"
                        Spacing="1"
                        VerticalAlignment="Center"
                        Visibility="{Binding IsSidebarCollapsed, Converter={StaticResource InvertedBoolToVisibilityConverter}}">
                        <TextBlock
                            Text="PartFinder"
                            FontSize="15"
                            FontWeight="Bold"
                            TextTrimming="CharacterEllipsis" />
                        <TextBlock
                            Text="{Binding CurrentTenant}"
                            FontSize="11"
                            Foreground="{ThemeResource AppSubtleTextBrush}"
                            TextTrimming="CharacterEllipsis" />
                    </StackPanel>

                    <!-- Toggle button — always visible -->
                    <Button
                        Grid.Column="1"
                        Width="32" Height="32"
                        Padding="0"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center"
                        AutomationProperties.Name="Collapse or expand navigation"
                        Command="{Binding ToggleSidebarCommand}"
                        Content="{Binding SidebarToggleGlyph}"
                        FontFamily="{ThemeResource SymbolThemeFontFamily}"
                        FontSize="14"
                        Style="{StaticResource GhostButtonStyle}" />
                </Grid>

                <!-- User card — hidden when collapsed -->
                <Border
                    Margin="0,4,0,4"
                    Padding="10"
                    CornerRadius="10"
                    Background="{StaticResource ElevatedCardBackgroundBrush}"
                    BorderBrush="{StaticResource BorderDefaultBrush}"
                    BorderThickness="1"
                    Visibility="{Binding IsSidebarCollapsed, Converter={StaticResource InvertedBoolToVisibilityConverter}}">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <!-- Avatar: circle via CornerRadius + overflow hidden -->
                        <Border Width="28" Height="28" CornerRadius="14"
                                Background="{StaticResource AccentPrimaryBrush}">
                            <Image Source="{Binding CurrentUserAvatarSource}" Stretch="UniformToFill"
                                   Width="28" Height="28" />
                        </Border>
                        <StackPanel Spacing="1" VerticalAlignment="Center">
                            <TextBlock
                                Text="{Binding CurrentUserName}"
                                FontSize="12"
                                FontWeight="SemiBold"
                                TextTrimming="CharacterEllipsis"
                                MaxWidth="140" />
                            <TextBlock
                                Text="{Binding CurrentUserDepartment}"
                                FontSize="10"
                                Foreground="{ThemeResource AppSubtleTextBrush}"
                                TextTrimming="CharacterEllipsis"
                                MaxWidth="140" />
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Nav label — hidden when collapsed -->
                <TextBlock
                    Margin="4,4,0,2"
                    Text="Navigation"
                    FontSize="10"
                    Foreground="{ThemeResource AppSubtleTextBrush}"
                    Visibility="{Binding IsSidebarCollapsed, Converter={StaticResource InvertedBoolToVisibilityConverter}}" />

                <!-- Nav items -->
                <ListView
                    x:Name="NavListView"
                    Margin="0,2,0,0"
                    ItemsSource="{Binding NavigationItems}"
                    SelectedItem="{Binding SelectedNavigationItem, Mode=TwoWay}"
                    SelectionMode="Single">
                    <ListView.ItemContainerStyle>
                        <Style TargetType="ListViewItem">
                            <Setter Property="Padding" Value="0" />
                            <Setter Property="Margin" Value="0,1,0,1" />
                            <Setter Property="MinHeight" Value="36" />
                            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                        </Style>
                    </ListView.ItemContainerStyle>
                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="viewModels:NavItemViewModel">
                            <StackPanel
                                Padding="8,6"
                                Orientation="Horizontal"
                                Spacing="10"
                                ToolTipService.ToolTip="{x:Bind Label}">
                                <FontIcon
                                    Glyph="{x:Bind IconGlyph}"
                                    FontSize="15"
                                    VerticalAlignment="Center"
                                    Width="20"
                                    HorizontalAlignment="Center" />
                                <TextBlock
                                    VerticalAlignment="Center"
                                    Text="{x:Bind Label}"
                                    FontSize="13"
                                    TextTrimming="CharacterEllipsis"
                                    Visibility="{x:Bind ShowNavLabel, Converter={StaticResource BoolToVisibilityConverter}, Mode=OneWay}" />
                            </StackPanel>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>

                <!-- New Part button — hidden when collapsed -->
                <Button
                    Margin="0,8,0,0"
                    HorizontalAlignment="Stretch"
                    Style="{StaticResource PrimaryButtonStyle}"
                    Content="+ New Part"
                    FontSize="13"
                    Visibility="{Binding IsSidebarCollapsed, Converter={StaticResource InvertedBoolToVisibilityConverter}}" />

            </StackPanel>
        </Border>

        <Border Grid.Column="1" Background="{ThemeResource AppSurfaceBrush}" BorderBrush="{ThemeResource AppBorderBrush}" BorderThickness="0,0,0,1">
            <Grid Padding="16,0" ColumnSpacing="12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!-- Search Bar — classic look -->
                <Border
                    Grid.Column="0"
                    VerticalAlignment="Center"
                    MaxWidth="420"
                    HorizontalAlignment="Left"
                    CornerRadius="8"
                    Background="{StaticResource CardBackgroundBrush}"
                    BorderBrush="{StaticResource BorderDefaultBrush}"
                    BorderThickness="1"
                    Padding="10,0">
                    <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                        <FontIcon Glyph="&#xE721;" FontSize="13" Foreground="{ThemeResource AppSubtleTextBrush}" VerticalAlignment="Center" />
                        <TextBox
                            BorderThickness="0"
                            Background="Transparent"
                            PlaceholderText="Search templates, parts, reports..."
                            FontSize="13"
                            MinWidth="240"
                            MaxWidth="360"
                            VerticalAlignment="Center"
                            Text="{Binding SearchText, Mode=TwoWay}" />
                    </StackPanel>
                </Border>

                <!-- Right icons -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="2" VerticalAlignment="Center">
                    <Button
                        Width="36" Height="36"
                        Padding="0"
                        Style="{StaticResource GhostButtonStyle}"
                        ToolTipService.ToolTip="Notifications">
                        <FontIcon Glyph="&#xE7F4;" FontSize="15" />
                    </Button>
                    <Button
                        Width="36" Height="36"
                        Padding="0"
                        Style="{StaticResource GhostButtonStyle}"
                        ToolTipService.ToolTip="Account settings"
                        Click="OnAccountSettingsMenuClicked">
                        <FontIcon Glyph="&#xE713;" FontSize="15" />
                    </Button>
                    <Button
                        Padding="8,4"
                        ToolTipService.ToolTip="Profile menu"
                        x:Name="ProfileMenuButton">
                        <Button.Content>
                            <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center"
                                        DataContext="{Binding ElementName=ProfileMenuButton, Path=DataContext}">
                                <!-- Avatar: circle via CornerRadius -->
                                <Border Width="28" Height="28" CornerRadius="14"
                                        Background="{StaticResource AccentPrimaryBrush}">
                                    <Image Source="{Binding CurrentUserAvatarSource}" Stretch="UniformToFill"
                                           Width="28" Height="28" />
                                </Border>
                                <TextBlock
                                    VerticalAlignment="Center"
                                    FontSize="13"
                                    Text="{Binding CurrentUserName}"
                                    TextTrimming="CharacterEllipsis"
                                    MaxWidth="90" />
                                <FontIcon VerticalAlignment="Center" Glyph="&#xE70D;" FontSize="11" />
                            </StackPanel>
                        </Button.Content>
                        <Button.Flyout>
                            <MenuFlyout>
                                <MenuFlyoutItem Text="Account Settings" Click="OnAccountSettingsMenuClicked" />
                                <MenuFlyoutSeparator />
                                <MenuFlyoutItem Text="Log out" Click="OnProfileLogoutMenuClicked" />
                            </MenuFlyout>
                        </Button.Flyout>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <Frame x:Name="ContentFrame" Grid.Row="1" Grid.Column="1" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" />
    </Grid>
</UserControl>
