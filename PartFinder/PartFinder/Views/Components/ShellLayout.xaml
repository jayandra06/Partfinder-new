<UserControl
    x:Class="PartFinder.Views.Components.ShellLayout"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converters="using:PartFinder.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:viewModels="using:PartFinder.ViewModels"
    mc:Ignorable="d">

    <UserControl.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter" />
        <converters:InvertedBoolToVisibilityConverter x:Key="InvertedBoolToVisibilityConverter" />
        <Style x:Key="TopNavIconButtonStyle" TargetType="Button" BasedOn="{StaticResource GhostButtonStyle}">
            <Setter Property="Width" Value="44" />
            <Setter Property="Height" Value="44" />
            <Setter Property="MinHeight" Value="44" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="CornerRadius" Value="12" />
        </Style>
        <Style x:Key="HeaderActionButtonStyle" TargetType="Button" BasedOn="{StaticResource TopNavIconButtonStyle}">
            <Setter Property="Width" Value="36" />
            <Setter Property="Height" Value="36" />
            <Setter Property="MinHeight" Value="36" />
        </Style>
        <Storyboard x:Key="AmbientDriftStoryboard" RepeatBehavior="Forever" AutoReverse="True">
            <DoubleAnimation Storyboard.TargetName="AmbientBlueTransform" Storyboard.TargetProperty="X" From="0" To="48" Duration="0:0:8">
                <DoubleAnimation.EasingFunction>
                    <SineEase EasingMode="EaseInOut" />
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="AmbientBlueTransform" Storyboard.TargetProperty="Y" From="0" To="20" Duration="0:0:8">
                <DoubleAnimation.EasingFunction>
                    <SineEase EasingMode="EaseInOut" />
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="AmbientPurpleTransform" Storyboard.TargetProperty="X" From="0" To="-42" Duration="0:0:9">
                <DoubleAnimation.EasingFunction>
                    <SineEase EasingMode="EaseInOut" />
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="AmbientPurpleTransform" Storyboard.TargetProperty="Y" From="0" To="-28" Duration="0:0:9">
                <DoubleAnimation.EasingFunction>
                    <SineEase EasingMode="EaseInOut" />
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="AmbientPinkTransform" Storyboard.TargetProperty="X" From="0" To="-20" Duration="0:0:10">
                <DoubleAnimation.EasingFunction>
                    <SineEase EasingMode="EaseInOut" />
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="AmbientPinkTransform" Storyboard.TargetProperty="Y" From="0" To="24" Duration="0:0:10">
                <DoubleAnimation.EasingFunction>
                    <SineEase EasingMode="EaseInOut" />
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>
    </UserControl.Resources>

    <Grid x:Name="RootGrid" Background="Transparent">
        <Grid.RowDefinitions>
            <RowDefinition Height="32" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid Grid.RowSpan="3" IsHitTestVisible="False">
            <Ellipse Width="540" Height="540" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="-180,-160,0,0" Opacity="0.9">
                <Ellipse.Fill>
                    <RadialGradientBrush>
                        <GradientStop Color="{ThemeResource AmbientBlueColor}" Offset="0" />
                        <GradientStop Color="#00000000" Offset="1" />
                    </RadialGradientBrush>
                </Ellipse.Fill>
                <Ellipse.RenderTransform>
                    <TranslateTransform x:Name="AmbientBlueTransform" />
                </Ellipse.RenderTransform>
            </Ellipse>
            <Ellipse Width="460" Height="460" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,-110,-120,0" Opacity="0.85">
                <Ellipse.Fill>
                    <RadialGradientBrush>
                        <GradientStop Color="{ThemeResource AmbientPurpleColor}" Offset="0" />
                        <GradientStop Color="#00000000" Offset="1" />
                    </RadialGradientBrush>
                </Ellipse.Fill>
                <Ellipse.RenderTransform>
                    <TranslateTransform x:Name="AmbientPurpleTransform" />
                </Ellipse.RenderTransform>
            </Ellipse>
            <Ellipse Width="420" Height="420" HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,-120,-120" Opacity="0.65">
                <Ellipse.Fill>
                    <RadialGradientBrush>
                        <GradientStop Color="{ThemeResource AmbientPinkColor}" Offset="0" />
                        <GradientStop Color="#00000000" Offset="1" />
                    </RadialGradientBrush>
                </Ellipse.Fill>
                <Ellipse.RenderTransform>
                    <TranslateTransform x:Name="AmbientPinkTransform" />
                </Ellipse.RenderTransform>
            </Ellipse>
        </Grid>

        <Border
                x:Name="TitleBarDragStrip"
                Grid.Row="0"
                Background="#08000000"
                BorderBrush="Transparent"
                BorderThickness="0"
                CornerRadius="0" />

        <Border x:Name="AppTitleBar"
                Grid.Row="1"
                Margin="0"
                Background="#08000000"
                BorderBrush="Transparent"
                BorderThickness="0"
                CornerRadius="0">
            <Grid x:Name="AppTitleBarLayout" Height="56">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition x:Name="TitleBarLeftInsetColumn" Width="0" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition x:Name="TitleBarRightInsetColumn" Width="0" />
                </Grid.ColumnDefinitions>

                <Border
                    Grid.ColumnSpan="6"
                    Height="1"
                    VerticalAlignment="Bottom"
                    Background="{StaticResource GlassHighlightBrush}"
                    Opacity="0.6" />

                <StackPanel
                    Grid.Column="1"
                    Orientation="Horizontal"
                    Spacing="10"
                    VerticalAlignment="Center"
                    Margin="12,0,0,0">
                    <Image
                        Source="ms-appx:///Assets/logo.png"
                        Width="24"
                        Height="24"
                        Stretch="Uniform" />
                    <TextBlock
                        Text="PartFinder"
                        FontSize="15"
                        FontWeight="SemiBold"
                        Foreground="{StaticResource TextPrimaryBrush}"
                        VerticalAlignment="Center" />
                </StackPanel>

                <Grid x:Name="TopNavInteractiveRegion" Grid.Column="2" Margin="10,0,10,0" VerticalAlignment="Center">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <ScrollViewer
                        x:Name="TopNavScrollViewer"
                        Grid.Column="0"
                        HorizontalScrollMode="Auto"
                        HorizontalScrollBarVisibility="Hidden"
                        VerticalScrollBarVisibility="Disabled"
                        VerticalScrollMode="Disabled"
                        ZoomMode="Disabled">
                        <ItemsRepeater
                            x:Name="TopNavRepeater"
                            ItemsSource="{Binding NavigationItems}">
                            <ItemsRepeater.Layout>
                                <StackLayout Orientation="Horizontal" Spacing="4" />
                            </ItemsRepeater.Layout>
                            <ItemsRepeater.ItemTemplate>
                                <DataTemplate x:DataType="viewModels:NavItemViewModel">
                                    <Grid Width="48" Height="44">
                                        <Border
                                            Height="2"
                                            Margin="10,0"
                                            VerticalAlignment="Bottom"
                                            Background="{StaticResource AccentPrimaryBrush}"
                                            Visibility="{x:Bind IsSelected, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}" />
                                        <Button
                                            Style="{StaticResource TopNavIconButtonStyle}"
                                            Click="OnTopNavItemClicked"
                                            DataContext="{x:Bind}"
                                            ToolTipService.ToolTip="{x:Bind Label}">
                                            <Grid>
                                                <FontIcon
                                                    Glyph="{x:Bind IconGlyph}"
                                                    FontSize="18"
                                                    Foreground="{StaticResource TextSecondaryBrush}"
                                                    Opacity="0.92"
                                                    Visibility="{x:Bind IsSelected, Mode=OneWay, Converter={StaticResource InvertedBoolToVisibilityConverter}}" />
                                                <FontIcon
                                                    Glyph="{x:Bind IconGlyph}"
                                                    FontSize="18"
                                                    Foreground="{StaticResource AccentPrimaryBrush}"
                                                    Visibility="{x:Bind IsSelected, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}" />
                                            </Grid>
                                        </Button>
                                    </Grid>
                                </DataTemplate>
                            </ItemsRepeater.ItemTemplate>
                        </ItemsRepeater>
                    </ScrollViewer>

                    <Border
                        Grid.Column="1"
                        Width="24"
                        Background="Transparent" />
                </Grid>

                <Border
                    x:Name="TopNavSearchRegion"
                    Grid.Column="3"
                    Width="280"
                    MaxWidth="320"
                    Margin="0,0,8,0"
                    VerticalAlignment="Center"
                    CornerRadius="18"
                    Background="{StaticResource InputBackgroundBrush}"
                    BorderBrush="Transparent"
                    BorderThickness="0"
                    Padding="10,0">
                    <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                        <FontIcon
                            Glyph="&#xE721;"
                            FontSize="13"
                            Foreground="{ThemeResource AppSubtleTextBrush}"
                            VerticalAlignment="Center" />
                        <TextBox
                            BorderThickness="0"
                            Background="Transparent"
                            PlaceholderText="Search templates, parts, reports..."
                            FontSize="13"
                            MinWidth="180"
                            MaxWidth="260"
                            VerticalAlignment="Center"
                            Text="{Binding SearchText, Mode=TwoWay}" />
                    </StackPanel>
                </Border>

                <StackPanel
                    x:Name="TopNavActionsRegion"
                    Grid.Column="4"
                    Orientation="Horizontal"
                    Spacing="6"
                    VerticalAlignment="Center"
                    Margin="0,0,8,0">
                    <Grid>
                        <Button
                            Width="36"
                            Height="36"
                            Padding="0"
                            Style="{StaticResource HeaderActionButtonStyle}"
                            ToolTipService.ToolTip="Alerts"
                            Click="OnBellClicked">
                            <FontIcon Glyph="&#xEA8F;" FontSize="18" />
                        </Button>
                        <Border
                            Width="8"
                            Height="8"
                            CornerRadius="4"
                            Background="#E05252"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Top"
                            Margin="0,4,4,0"
                            IsHitTestVisible="False"
                            Visibility="{Binding HasUnreadAlerts, Converter={StaticResource BoolToVisibilityConverter}}" />
                    </Grid>
                    <Button
                        x:Name="ProfileMenuButton"
                        Padding="4,0"
                        Background="Transparent"
                        BorderBrush="Transparent"
                        BorderThickness="0"
                        Foreground="{StaticResource TextPrimaryBrush}"
                        ToolTipService.ToolTip="Profile menu">
                        <Button.Content>
                            <StackPanel
                                Orientation="Horizontal"
                                Spacing="6"
                                VerticalAlignment="Center"
                                DataContext="{Binding ElementName=ProfileMenuButton, Path=DataContext}">
                                <Border
                                    Width="28"
                                    Height="28"
                                    CornerRadius="14"
                                    Background="Transparent">
                                    <Image
                                        Source="{Binding CurrentUserAvatarSource}"
                                        Stretch="UniformToFill"
                                        Width="28"
                                        Height="28" />
                                </Border>
                                <TextBlock
                                    VerticalAlignment="Center"
                                    FontSize="13"
                                    Text="{Binding CurrentUserName}"
                                    TextTrimming="CharacterEllipsis"
                                    MaxWidth="90" />
                                <FontIcon
                                    VerticalAlignment="Center"
                                    Glyph="&#xE70D;"
                                    FontSize="11" />
                            </StackPanel>
                        </Button.Content>
                        <Button.Flyout>
                            <MenuFlyout>
                                <MenuFlyoutItem Text="Account Settings" Click="OnAccountSettingsMenuClicked" />
                                <MenuFlyoutSeparator />
                                <MenuFlyoutItem Text="Log out" Click="OnProfileLogoutMenuClicked" />
                            </MenuFlyout>
                        </Button.Flyout>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="2"
                Margin="12,8,12,12"
                CornerRadius="28"
                Background="#08000000"
                BorderBrush="{StaticResource GlassHighlightBrush}"
                BorderThickness="1">
            <Frame x:Name="ContentFrame"
                   Background="Transparent"
                   HorizontalAlignment="Stretch"
                   VerticalAlignment="Stretch" />
        </Border>
    </Grid>
</UserControl>
