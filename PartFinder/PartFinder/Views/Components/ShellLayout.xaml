<UserControl
    x:Class="PartFinder.Views.Components.ShellLayout"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converters="using:PartFinder.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:viewModels="using:PartFinder.ViewModels"
    mc:Ignorable="d">

    <UserControl.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter" />
        <converters:InvertedBoolToVisibilityConverter x:Key="InvertedBoolToVisibilityConverter" />
    </UserControl.Resources>

    <!-- Root grid -->
    <Grid x:Name="RootGrid" Background="{ThemeResource AppBackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="56" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- ═══════════════════════════════════════════════════ -->
        <!-- HEADER BAR (contains logo, brand, nav, bell, profile) -->
        <!-- ═══════════════════════════════════════════════════ -->
        <Border x:Name="ShellTitleBarRoot"
                Grid.Row="0"
                Background="#0A0E15"
                BorderBrush="{ThemeResource AppBorderBrush}"
                BorderThickness="0,0,0,1"
                Padding="12,0,16,0">
            <Grid ColumnSpacing="12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!-- LEFT: Logo + brand — sole title-bar drag region so nav/profile stay clickable -->
                <Grid x:Name="ShellTitleBarDragRegion"
                      Grid.Column="0"
                      VerticalAlignment="Stretch"
                      HorizontalAlignment="Stretch">
                    <StackPanel Orientation="Horizontal" Spacing="14" VerticalAlignment="Center">
                        <Border Width="50" Height="50" CornerRadius="20"
                                Background="{StaticResource ElevatedCardBackgroundBrush}">
                            <Image Source="ms-appx:///Assets/logo.png" Stretch="Uniform" Margin="5" />
                        </Border>
                        <StackPanel Spacing="2" VerticalAlignment="Center">
                            <TextBlock Text="PartFinder"
                                       FontSize="17" FontWeight="Bold"
                                       Foreground="{StaticResource TextPrimaryBrush}" />
                            <TextBlock Text="Inventory Management"
                                       FontSize="11"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       CharacterSpacing="12"
                                       TextWrapping="NoWrap" />
                        </StackPanel>
                    </StackPanel>
                </Grid>

                <!-- CENTER: Primary nav + More overflow -->
                <StackPanel
                    Grid.Column="1"
                    Orientation="Horizontal"
                    Spacing="12"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center">
                    <ItemsRepeater
                        x:Name="NavListView"
                        ItemsSource="{Binding PrimaryNavigationItems}"
                        VerticalAlignment="Center">
                        <ItemsRepeater.Layout>
                            <StackLayout Orientation="Horizontal" Spacing="16" />
                        </ItemsRepeater.Layout>
                        <ItemsRepeater.ItemTemplate>
                            <DataTemplate x:DataType="viewModels:NavItemViewModel">
                                <Grid Width="40" Height="40"
                                      CornerRadius="8"
                                      PointerEntered="OnNavItemPointerEntered"
                                      PointerExited="OnNavItemPointerExited"
                                      Tapped="OnNavItemTapped"
                                      Tag="{x:Bind Label}">
                                    <FontIcon
                                        Glyph="{x:Bind IconGlyph}"
                                        FontSize="20"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center" />
                                </Grid>
                            </DataTemplate>
                        </ItemsRepeater.ItemTemplate>
                    </ItemsRepeater>
                    <Button
                        x:Name="MoreNavButton"
                        Width="40"
                        Height="40"
                        Padding="0"
                        CornerRadius="8"
                        Background="Transparent"
                        BorderBrush="{StaticResource BorderDefaultBrush}"
                        BorderThickness="1"
                        ToolTipService.ToolTip="More"
                        Visibility="{Binding HasOverflowNavigation, Converter={StaticResource BoolToVisibilityConverter}}"
                        Click="OnMoreNavButtonClick">
                        <FontIcon Glyph="&#xE712;" FontSize="16" Foreground="{StaticResource TextSecondaryBrush}" />
                    </Button>
                </StackPanel>

                <!-- RIGHT: Profile only -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="2" VerticalAlignment="Center">
                    <Button Padding="8,4"
                            ToolTipService.ToolTip="Profile menu"
                            x:Name="ProfileMenuButton">
                        <Button.Content>
                            <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center"
                                        DataContext="{Binding ElementName=ProfileMenuButton, Path=DataContext}">
                                <Border Width="28" Height="28" CornerRadius="14"
                                        Background="{StaticResource AccentPrimaryBrush}">
                                    <Image Source="{Binding CurrentUserAvatarSource}"
                                           Stretch="UniformToFill" Width="28" Height="28" />
                                </Border>
                                <TextBlock VerticalAlignment="Center" FontSize="13"
                                           Text="{Binding CurrentUserName}"
                                           TextTrimming="CharacterEllipsis" MaxWidth="90" />
                                <FontIcon VerticalAlignment="Center" Glyph="&#xE70D;" FontSize="11" />
                            </StackPanel>
                        </Button.Content>
                        <Button.Flyout>
                            <MenuFlyout>
                                <MenuFlyoutItem Text="Account Settings" Click="OnAccountSettingsMenuClicked" />
                                <MenuFlyoutSeparator />
                                <MenuFlyoutItem Text="Log out" Click="OnProfileLogoutMenuClicked" />
                            </MenuFlyout>
                        </Button.Flyout>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ═══════════════════════════════════════════════════ -->
        <!-- CONTENT FRAME — full width now                      -->
        <!-- ═══════════════════════════════════════════════════ -->
        <Frame x:Name="ContentFrame"
               Grid.Row="1"
               HorizontalAlignment="Stretch"
               VerticalAlignment="Stretch" />

        <!-- ═══════════════════════════════════════════════════ -->
        <!-- TOOLTIP OVERLAY — shows below nav icons on hover    -->
        <!-- ═══════════════════════════════════════════════════ -->
        <Border x:Name="NavTooltipOverlay"
                Grid.RowSpan="2"
                IsHitTestVisible="False"
                Visibility="Collapsed"
                Canvas.ZIndex="999">
            <Canvas>
                <Border x:Name="NavTooltipBox"
                        Background="#1E2D45"
                        BorderBrush="#2A3D58"
                        BorderThickness="1"
                        CornerRadius="7"
                        Padding="12,7"
                        IsHitTestVisible="False">
                    <TextBlock x:Name="NavTooltipLabel"
                               FontSize="13"
                               FontWeight="SemiBold"
                               Foreground="#EAF2FF" />
                </Border>
            </Canvas>
        </Border>

    </Grid>
</UserControl>
