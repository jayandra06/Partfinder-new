<UserControl
    x:Class="PartFinder.Views.Components.KpiCard"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Border Style="{ThemeResource AppCardBorderStyle}">
        <StackPanel Spacing="6">
            <TextBlock Text="{x:Bind Label, Mode=OneWay}" Foreground="{ThemeResource AppSubtleTextBrush}" />
            <TextBlock Text="{x:Bind Value, Mode=OneWay}" Style="{ThemeResource AppSectionTextStyle}" />
            <TextBlock Text="{x:Bind Delta, Mode=OneWay}" Foreground="{ThemeResource AppSuccessBrush}" />
        </StackPanel>
    </Border>
</UserControl>
