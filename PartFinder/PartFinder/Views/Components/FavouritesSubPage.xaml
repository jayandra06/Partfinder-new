<UserControl
    x:Class="PartFinder.Views.Components.FavouritesSubPage"
    x:Name="FavouritesSubPageRoot"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converters="using:PartFinder.Converters"
    Background="{StaticResource PageBackgroundBrush}"
    Loaded="OnLoaded"
    Unloaded="OnUnloaded"
    KeyDown="OnKeyDown">

    <UserControl.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter" />
        <converters:InvertedBoolToVisibilityConverter x:Key="InvertedBoolToVisibilityConverter" />

        <!-- Entrance animation -->
        <Storyboard x:Key="EntranceSb">
            <DoubleAnimation
                Storyboard.TargetName="CarouselRoot"
                Storyboard.TargetProperty="Opacity"
                From="0" To="1" Duration="0:0:0.5">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseOut" />
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation
                Storyboard.TargetName="RootSlideTransform"
                Storyboard.TargetProperty="Y"
                From="20" To="0" Duration="0:0:0.5">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseOut" />
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>

        <!-- Exit animation -->
        <Storyboard x:Key="ExitSb">
            <DoubleAnimation
                Storyboard.TargetName="CarouselRoot"
                Storyboard.TargetProperty="Opacity"
                From="1" To="0" Duration="0:0:0.3">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseIn" />
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>
    </UserControl.Resources>

    <Grid x:Name="CarouselRoot" Opacity="0">
        <Grid.RenderTransform>
            <TranslateTransform x:Name="RootSlideTransform" Y="20"/>
        </Grid.RenderTransform>

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- ── Header: Buttons ── -->
        <Grid Grid.Row="0" Margin="24,20,24,0" Visibility="Collapsed">
            <!-- Back to Templates Button -->
            <Button HorizontalAlignment="Left"
                    Padding="16,10"
                    CornerRadius="10"
                    BorderBrush="{StaticResource BorderDefaultBrush}"
                    BorderThickness="1"
                    Background="{StaticResource CardBackgroundBrush}"
                    Click="OnBackToTemplatesClick"
                    AutomationProperties.Name="Back to Templates">
                <Button.Resources>
                    <SolidColorBrush x:Key="ButtonBackgroundPointerOver" Color="{StaticResource ElevatedCardBackgroundColor}" />
                    <SolidColorBrush x:Key="ButtonBorderBrushPointerOver" Color="{StaticResource TextPrimaryColor}" />
                </Button.Resources>
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <FontIcon Glyph="&#xE72B;" FontSize="14" Foreground="{StaticResource TextSecondaryBrush}" />
                    <TextBlock Text="Back to Templates" FontSize="14" Foreground="{StaticResource TextPrimaryBrush}" FontWeight="Medium" />
                </StackPanel>
            </Button>
            
            <!-- New Template Button -->
            <Button HorizontalAlignment="Right"
                    Padding="16,10"
                    CornerRadius="10"
                    BorderBrush="{StaticResource BorderDefaultBrush}"
                    BorderThickness="1"
                    Background="{StaticResource CardBackgroundBrush}"
                    Click="OnNewTemplateClick"
                    AutomationProperties.Name="New Template">
                <Button.Resources>
                    <SolidColorBrush x:Key="ButtonBackgroundPointerOver" Color="{StaticResource ElevatedCardBackgroundColor}" />
                    <SolidColorBrush x:Key="ButtonBorderBrushPointerOver" Color="{StaticResource AccentPrimaryColor}" />
                </Button.Resources>
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <FontIcon Glyph="&#xE710;" FontSize="14" Foreground="{StaticResource AccentPrimaryBrush}" />
                    <TextBlock Text="New Template" FontSize="14" Foreground="{StaticResource TextPrimaryBrush}" FontWeight="Medium" />
                </StackPanel>
            </Button>
        </Grid>

        <!-- ── Empty State ── -->
        <StackPanel
            Grid.Row="1"
            Spacing="24"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            Visibility="{Binding IsEmpty, Converter={StaticResource BoolToVisibilityConverter}}">

            <!-- Animated icon circle -->
            <Border Width="120" Height="120" CornerRadius="60"
                    Background="{StaticResource CardBackgroundBrush}"
                    BorderBrush="{StaticResource BorderDefaultBrush}" BorderThickness="2"
                    HorizontalAlignment="Center">
                <Border.Shadow>
                    <ThemeShadow/>
                </Border.Shadow>
                <FontIcon Glyph="&#xE735;" FontSize="48" Foreground="{StaticResource AccentPrimaryBrush}" />
            </Border>

            <StackPanel Spacing="12" HorizontalAlignment="Center">
                <TextBlock Text="Your favourites empty" FontSize="28" FontWeight="SemiBold" 
                          HorizontalAlignment="Center" Foreground="{StaticResource TextPrimaryBrush}" />
                <TextBlock Text="Star your favorite templates to see them here."
                           FontSize="15" Foreground="{StaticResource TextTertiaryBrush}"
                           HorizontalAlignment="Center" TextAlignment="Center"
                           MaxWidth="400" TextWrapping="WrapWholeWords" />
            </StackPanel>
        </StackPanel>

        <!-- ── Horizontal Carousel ── -->
        <Canvas
            x:Name="CarouselCanvas"
            Grid.Row="1"
            HorizontalAlignment="Stretch"
            VerticalAlignment="Center"
            Height="460"
            Visibility="{Binding IsEmpty, Converter={StaticResource InvertedBoolToVisibilityConverter}}">
            <!-- Cards will be positioned absolutely here -->
        </Canvas>

        <!-- ── Bottom Navigation ── -->
        <StackPanel Grid.Row="2"
                   Spacing="20"
                   HorizontalAlignment="Center"
                   Margin="0,0,0,40"
                   Visibility="{Binding IsEmpty, Converter={StaticResource InvertedBoolToVisibilityConverter}}">

            <!-- Counter -->
            <TextBlock Text="{Binding IndexLabel}"
                      FontSize="14"
                      Foreground="{StaticResource TextTertiaryBrush}"
                      HorizontalAlignment="Center"
                      FontWeight="Medium" />

            <!-- Navigation Buttons -->
            <StackPanel Orientation="Horizontal" Spacing="16" HorizontalAlignment="Center">
                <!-- Prev Button -->
                <Button x:Name="PrevButton"
                        Width="100" Height="44"
                        Background="{StaticResource CardBackgroundBrush}"
                        BorderBrush="{StaticResource BorderDefaultBrush}"
                        BorderThickness="1.5"
                        CornerRadius="22"
                        IsEnabled="{Binding CanGoPrevious}"
                        Click="OnPreviousClick"
                        AutomationProperties.Name="Previous template">
                    <Button.Resources>
                        <SolidColorBrush x:Key="ButtonBackgroundPointerOver" Color="{StaticResource ElevatedCardBackgroundColor}" />
                        <SolidColorBrush x:Key="ButtonBorderBrushPointerOver" Color="{StaticResource AccentPrimaryColor}" />
                    </Button.Resources>
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <FontIcon Glyph="&#xE76B;" FontSize="12" Foreground="{StaticResource TextPrimaryBrush}" />
                        <TextBlock Text="Prev" FontSize="15" Foreground="{StaticResource TextPrimaryBrush}" FontWeight="Medium" />
                    </StackPanel>
                </Button>

                <!-- Next Button -->
                <Button x:Name="NextButton"
                        Width="100" Height="44"
                        Background="{StaticResource CardBackgroundBrush}"
                        BorderBrush="{StaticResource BorderDefaultBrush}"
                        BorderThickness="1.5"
                        CornerRadius="22"
                        IsEnabled="{Binding CanGoNext}"
                        Click="OnNextClick"
                        AutomationProperties.Name="Next template">
                    <Button.Resources>
                        <SolidColorBrush x:Key="ButtonBackgroundPointerOver" Color="{StaticResource ElevatedCardBackgroundColor}" />
                        <SolidColorBrush x:Key="ButtonBorderBrushPointerOver" Color="{StaticResource AccentPrimaryColor}" />
                    </Button.Resources>
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <TextBlock Text="Next" FontSize="15" Foreground="{StaticResource TextPrimaryBrush}" FontWeight="Medium" />
                        <FontIcon Glyph="&#xE76C;" FontSize="12" Foreground="{StaticResource TextPrimaryBrush}" />
                    </StackPanel>
                </Button>
            </StackPanel>

        </StackPanel>

    </Grid>
</UserControl>
