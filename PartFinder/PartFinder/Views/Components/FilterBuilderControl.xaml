<UserControl
    x:Class="PartFinder.Views.Components.FilterBuilderControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Border Style="{ThemeResource AppCardBorderStyle}">
        <StackPanel Spacing="10">
            <TextBlock Text="Advanced Filters" Style="{ThemeResource AppSectionTextStyle}" />
            <Grid ColumnSpacing="8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*" />
                    <ColumnDefinition Width="2*" />
                    <ColumnDefinition Width="3*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <ComboBox PlaceholderText="Field" />
                <ComboBox Grid.Column="1" PlaceholderText="Condition" />
                <TextBox Grid.Column="2" PlaceholderText="Value" />
                <Button Grid.Column="3" Content="Add" />
            </Grid>
            <TextBlock Text="Tip: Use AND/OR groups for multi-condition searches." Foreground="{ThemeResource AppSubtleTextBrush}" />
        </StackPanel>
    </Border>
</UserControl>
