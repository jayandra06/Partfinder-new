<Page
    x:Class="PartFinder.Views.Pages.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converters="using:PartFinder.Converters"
    xmlns:viewmodels="using:PartFinder.ViewModels"
    xmlns:models="using:PartFinder.Models">
    <Page.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter" />
        <converters:InvertedBoolToVisibilityConverter x:Key="InvertedBoolToVisibilityConverter" />
        <converters:StringToVisibilityConverter x:Key="StringToVisibilityConverter" />

        <!-- ========================================== -->
        <!-- LUXURY MINIMAL DESIGN SYSTEM FOR SETTINGS   -->
        <!-- ========================================== -->
        
        <Style x:Key="SectionTitleStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="28" />
            <Setter Property="FontWeight" Value="Light" />
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
            <Setter Property="CharacterSpacing" Value="20" />
            <Setter Property="Margin" Value="0,0,0,8" />
        </Style>

        <Style x:Key="SectionDescriptionStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}" />
            <Setter Property="LineHeight" Value="20" />
            <Setter Property="Margin" Value="0,0,0,32" />
        </Style>

        <Style x:Key="SettingRowBorderStyle" TargetType="Border">
            <Setter Property="BorderBrush" Value="{StaticResource BorderDefaultBrush}" />
            <Setter Property="BorderThickness" Value="0,0,0,1" />
            <Setter Property="Padding" Value="0,20,0,20" />
        </Style>

        <Style x:Key="SettingLabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
            <Setter Property="Margin" Value="0,0,0,4" />
        </Style>

        <Style x:Key="SettingHintStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Foreground" Value="{StaticResource TextTertiaryBrush}" />
            <Setter Property="TextWrapping" Value="WrapWholeWords" />
        </Style>

        <Style x:Key="NavButtonStyle" TargetType="Button">
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="16,12" />
            <Setter Property="CornerRadius" Value="6" />
        </Style>
    </Page.Resources>

    <Grid Background="{StaticResource PageBackgroundBrush}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- TOAST POPUP (Preserved x:Names) -->
        <Border
            x:Name="ToastPopup"
            Grid.ColumnSpan="2"
            HorizontalAlignment="Right"
            VerticalAlignment="Bottom"
            Margin="0,0,32,32"
            Padding="20,16"
            CornerRadius="8"
            Background="{StaticResource ElevatedCardBackgroundBrush}"
            BorderBrush="{StaticResource BorderDefaultBrush}"
            BorderThickness="1"
            Opacity="0"
            IsHitTestVisible="False"
            Canvas.ZIndex="99">
            <Border.Shadow><ThemeShadow/></Border.Shadow>
            <StackPanel Orientation="Horizontal" Spacing="16">
                <Border Width="32" Height="32" CornerRadius="16" Background="#102ABD8F" BorderBrush="#302ABD8F" BorderThickness="1">
                    <FontIcon Glyph="&#xE73E;" FontSize="14" Foreground="{StaticResource SuccessBrush}" />
                </Border>
                <StackPanel Spacing="2" VerticalAlignment="Center">
                    <TextBlock x:Name="ToastTitle" Text="Saved successfully" FontSize="13" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}" />
                    <TextBlock x:Name="ToastMessage" Text="Your changes have been applied." FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" />
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- LEFT SIDEBAR: Editorial Navigation -->
        <Border Grid.Column="0" Background="{StaticResource CardBackgroundBrush}" 
                BorderBrush="{StaticResource BorderDefaultBrush}" BorderThickness="0,0,1,0" 
                Padding="0,32" Translation="0,0,32">
            <Grid>
                <Grid RowSpacing="32">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                        <StackPanel x:Name="NavItemsStack" Spacing="4" Padding="12,0" HorizontalAlignment="Stretch">
                            <!-- Profile -->
                            <Border x:Name="NavProfileItem" CornerRadius="6" Background="{StaticResource NavItemSelectedBrush}">
                                <Button Style="{StaticResource NavButtonStyle}" Click="OnNavProfileClick">
                                    <StackPanel Orientation="Horizontal" Spacing="16">
                                        <FontIcon Glyph="&#xE77B;" FontSize="18" Foreground="{StaticResource AccentPrimaryBrush}" VerticalAlignment="Center" />
                                        <TextBlock Text="Profile" FontSize="14" VerticalAlignment="Center" Foreground="{StaticResource TextPrimaryBrush}" />
                                    </StackPanel>
                                </Button>
                            </Border>

                            <!-- Security & 2FA -->
                            <Border x:Name="NavSecurityItem" CornerRadius="6" Background="Transparent">
                                <Button Style="{StaticResource NavButtonStyle}" Click="OnNavSecurityClick">
                                    <StackPanel Orientation="Horizontal" Spacing="16">
                                        <FontIcon Glyph="&#xE72E;" FontSize="18" Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center" />
                                        <TextBlock Text="Security &amp; 2FA" FontSize="14" VerticalAlignment="Center" Foreground="{StaticResource TextSecondaryBrush}" />
                                    </StackPanel>
                                </Button>
                            </Border>

                            <!-- Change Password -->
                            <Border x:Name="NavPasswordItem" CornerRadius="6" Background="Transparent">
                                <Button Style="{StaticResource NavButtonStyle}" Click="OnNavPasswordClick">
                                    <StackPanel Orientation="Horizontal" Spacing="16">
                                        <FontIcon Glyph="&#xE8D7;" FontSize="18" Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center" />
                                        <TextBlock Text="Password" FontSize="14" VerticalAlignment="Center" Foreground="{StaticResource TextSecondaryBrush}" />
                                    </StackPanel>
                                </Button>
                            </Border>

                            <!-- App Lock -->
                            <Border x:Name="NavAppLockItem" CornerRadius="6" Background="Transparent">
                                <Button Style="{StaticResource NavButtonStyle}" Click="OnNavAppLockClick">
                                    <StackPanel Orientation="Horizontal" Spacing="16">
                                        <FontIcon Glyph="&#xE72E;" FontSize="18" Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center" />
                                        <TextBlock Text="App Lock" FontSize="14" VerticalAlignment="Center" Foreground="{StaticResource TextSecondaryBrush}" />
                                    </StackPanel>
                                </Button>
                            </Border>

                            <!-- Login Device Management -->
                            <Border x:Name="NavLoginDeviceItem" CornerRadius="6" Background="Transparent">
                                <Button Style="{StaticResource NavButtonStyle}" Click="OnNavLoginDeviceClick">
                                    <StackPanel Orientation="Horizontal" Spacing="16">
                                        <FontIcon Glyph="&#xE770;" FontSize="18" Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center" />
                                        <TextBlock Text="Login Device Management" FontSize="14" VerticalAlignment="Center" Foreground="{StaticResource TextSecondaryBrush}" />
                                    </StackPanel>
                                </Button>
                            </Border>

                            <!-- Logout -->
                            <Border CornerRadius="6" Background="Transparent" Margin="0,8,0,0">
                                <Button Style="{StaticResource NavButtonStyle}" Click="OnLogoutClick">
                                    <StackPanel Orientation="Horizontal" Spacing="16">
                                        <FontIcon Glyph="&#xF3B1;" FontSize="18" Foreground="#E05555" VerticalAlignment="Center" />
                                        <TextBlock Text="Logout" FontSize="14" VerticalAlignment="Center" Foreground="#E05555" />
                                    </StackPanel>
                                </Button>
                            </Border>

                            <!-- Organization section — directly below logout, no border -->
                            <StackPanel x:Name="OrgInfoPanel" Spacing="10" Padding="12,12,12,0" Margin="0,8,0,0">
                                <!-- Divider -->
                                <Border Height="1" Background="{StaticResource BorderDefaultBrush}" Margin="0,0,0,2" />
                                <!-- Section label -->
                                <TextBlock Text="ORGANIZATION"
                                           FontSize="10"
                                           FontWeight="Bold"
                                           CharacterSpacing="80"
                                           Foreground="{StaticResource TextTertiaryBrush}" />

                                <!-- Org Name -->
                                <StackPanel Spacing="2">
                                    <TextBlock Text="Name"
                                               FontSize="11"
                                               Foreground="{StaticResource TextTertiaryBrush}" />
                                    <TextBlock Text="{Binding OrgDisplayName}"
                                               FontSize="13"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource TextPrimaryBrush}"
                                               TextTrimming="CharacterEllipsis" />
                                </StackPanel>

                                <!-- Org Code -->
                                <StackPanel Spacing="2">
                                    <TextBlock Text="Org Code"
                                               FontSize="11"
                                               Foreground="{StaticResource TextTertiaryBrush}" />
                                    <TextBlock Text="{Binding OrgCode}"
                                               FontSize="13"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource TextPrimaryBrush}"
                                               TextTrimming="CharacterEllipsis" />
                                </StackPanel>

                                <!-- Org Plan -->
                                <StackPanel Spacing="2">
                                    <TextBlock Text="Plan"
                                               FontSize="11"
                                               Foreground="{StaticResource TextTertiaryBrush}" />
                                    <Border Background="#101F7AE0"
                                            BorderBrush="#301F7AE0"
                                            BorderThickness="1"
                                            CornerRadius="4"
                                            Padding="8,3"
                                            HorizontalAlignment="Left">
                                        <TextBlock Text="{Binding OrgPlanDisplay}"
                                                   FontSize="11"
                                                   FontWeight="SemiBold"
                                                   Foreground="{StaticResource AccentPrimaryBrush}" />
                                    </Border>
                                </StackPanel>
                            </StackPanel>

                            <!-- Hidden bindings -->
                            <Border x:Name="NavTwoFactorItem" Visibility="Collapsed" />
                            <Border x:Name="NavAppearanceItem" Visibility="Collapsed" />
                            <Border x:Name="NavNotificationsItem" Visibility="Collapsed" />
                        </StackPanel>
                    </ScrollViewer>

                    <!-- Row 1: empty — org panel moved into nav stack above -->
                    <Border Grid.Row="1" />
                </Grid>
            </Grid>
        </Border>

        <!-- RIGHT CONTENT AREA -->
        <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <!-- Constrain width for readability, but allow it to stretch nicely -->
            <StackPanel HorizontalAlignment="Stretch" Padding="0,48,48,80">

                <!-- Header moved to content area to stay undisturbed -->
                <StackPanel Spacing="4" Margin="48,0,0,40">
                    <TextBlock Text="PREFERENCES" FontSize="10" Foreground="{StaticResource TextTertiaryBrush}" CharacterSpacing="100" FontWeight="Bold" />
                    <TextBlock Text="Settings" FontSize="32" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}" />
                </StackPanel>

                <StackPanel x:Name="ProfileSection" Visibility="Visible" Margin="48,0,0,0">
                    <TextBlock Text="PROFILE &amp; IDENTITY" Style="{StaticResource SectionTitleStyle}" />
                    <TextBlock Text="Manage your identity, personal information, and how you appear to others within the organization. Changes are reflected across the entire workspace." Style="{StaticResource SectionDescriptionStyle}" />

                    <!-- Avatar Row -->
                    <Border Style="{StaticResource SettingRowBorderStyle}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="2*" />
                                <ColumnDefinition Width="3*" />
                            </Grid.ColumnDefinitions>
                            
                            <StackPanel Spacing="8">
                                <TextBlock Text="Avatar &amp; Role" Style="{StaticResource SettingLabelStyle}" />
                                <TextBlock Text="Your profile picture and system privileges." Style="{StaticResource SettingHintStyle}" />
                            </StackPanel>

                            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="24">
                                <!-- Avatar circle: photo if set, else initials -->
                                <Grid Width="72" Height="72">
                                    <Border CornerRadius="36" Background="{StaticResource AccentPrimaryBrush}"
                                            Visibility="{Binding HasAvatarPhoto, Converter={StaticResource InvertedBoolToVisibilityConverter}}">
                                        <TextBlock Text="{Binding AvatarInitial}" FontSize="20" FontWeight="SemiBold" Foreground="White"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center" />
                                    </Border>
                                    <Border CornerRadius="36"
                                            Visibility="{Binding HasAvatarPhoto, Converter={StaticResource BoolToVisibilityConverter}}">
                                        <Border.Background>
                                            <ImageBrush ImageSource="{Binding AvatarImageSource}" Stretch="UniformToFill" />
                                        </Border.Background>
                                    </Border>
                                </Grid>
                                <StackPanel VerticalAlignment="Center" Spacing="8">
                                    <StackPanel Orientation="Horizontal" Spacing="12">
                                        <Button Style="{StaticResource GhostButtonStyle}" Content="Change photo" Click="OnChangePhotoClick" />
                                        <Button Style="{StaticResource GhostButtonStyle}" Content="Use email profile" Click="OnUseEmailProfileClick" />
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <Border Background="#101F7AE0" BorderBrush="#301F7AE0" BorderThickness="1" CornerRadius="4" Padding="8,2">
                                            <TextBlock Text="Administrator" FontSize="10" FontWeight="SemiBold" Foreground="{StaticResource AccentPrimaryBrush}" />
                                        </Border>
                                        <Border Background="#102ABD8F" BorderBrush="#302ABD8F" BorderThickness="1" CornerRadius="4" Padding="8,2">
                                            <TextBlock Text="Verified User" FontSize="10" FontWeight="SemiBold" Foreground="{StaticResource SuccessBrush}" />
                                        </Border>
                                    </StackPanel>
                                </StackPanel>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- Personal Info Row -->
                    <Border Style="{StaticResource SettingRowBorderStyle}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="2*" />
                                <ColumnDefinition Width="3*" />
                            </Grid.ColumnDefinitions>
                            
                            <StackPanel Spacing="8">
                                <TextBlock Text="Personal Details" Style="{StaticResource SettingLabelStyle}" />
                                <TextBlock Text="Core identification details used for auditing and communication." Style="{StaticResource SettingHintStyle}" />
                            </StackPanel>

                            <Grid Grid.Column="1" RowSpacing="20" ColumnSpacing="16">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Row="0" Grid.Column="0" Spacing="6">
                                    <TextBlock Text="Display Name" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" />
                                    <TextBox Style="{StaticResource StandardTextBoxStyle}" Text="{Binding ProfileName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                </StackPanel>

                                <StackPanel Grid.Row="0" Grid.Column="1" Spacing="6">
                                    <TextBlock Text="Email Address (Read-only)" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" />
                                    <TextBox Style="{StaticResource StandardTextBoxStyle}" IsReadOnly="True" Text="{Binding SessionEmailDisplay}" />
                                </StackPanel>

                                <StackPanel Grid.Row="1" Grid.Column="0" Spacing="6">
                                    <TextBlock Text="Designation" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" />
                                    <TextBox Style="{StaticResource StandardTextBoxStyle}" PlaceholderText="e.g. Lead Engineer" />
                                </StackPanel>

                                <StackPanel Grid.Row="1" Grid.Column="1" Spacing="6">
                                    <TextBlock Text="Department" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" />
                                    <TextBox Style="{StaticResource StandardTextBoxStyle}" PlaceholderText="e.g. Operations" Text="{Binding ProfileDepartment, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                </StackPanel>
                            </Grid>
                        </Grid>
                    </Border>


                    <!-- Bio Row -->
                    <Border Style="{StaticResource SettingRowBorderStyle}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="2*" />
                                <ColumnDefinition Width="3*" />
                            </Grid.ColumnDefinitions>
                            
                            <StackPanel Spacing="8">
                                <TextBlock Text="Professional Bio" Style="{StaticResource SettingLabelStyle}" />
                                <TextBlock Text="A brief description of your responsibilities. Visible to other workspace members." Style="{StaticResource SettingHintStyle}" />
                            </StackPanel>

                            <StackPanel Grid.Column="1" Spacing="20">
                                <TextBox Style="{StaticResource StandardTextBoxStyle}" AcceptsReturn="True" TextWrapping="Wrap" MinHeight="100" />
                                
                                <Grid ColumnSpacing="24">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <ToggleSwitch Grid.Column="0" Header="Public Explorer Visibility" IsOn="True" />
                                    <ToggleSwitch Grid.Column="1" Header="Show Online Status" IsOn="True" />
                                </Grid>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- Last Login Session Row -->
                    <Border Style="{StaticResource SettingRowBorderStyle}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="2*" />
                                <ColumnDefinition Width="3*" />
                            </Grid.ColumnDefinitions>
                            
                            <StackPanel Spacing="8">
                                <TextBlock Text="Last Login Session" Style="{StaticResource SettingLabelStyle}" />
                                <TextBlock Text="Details of your current or most recent successful login." Style="{StaticResource SettingHintStyle}" />
                            </StackPanel>

                            <Border Grid.Column="1" Background="{StaticResource CardBackgroundBrush}" 
                                    BorderBrush="{StaticResource BorderDefaultBrush}" 
                                    BorderThickness="1" CornerRadius="12" Padding="20">
                                <StackPanel Spacing="16">
                                    <StackPanel Orientation="Horizontal" Spacing="12">
                                        <Border Width="40" Height="40" CornerRadius="20" Background="#102ABD8F" BorderBrush="#302ABD8F" BorderThickness="1">
                                            <FontIcon Glyph="&#xE770;" FontSize="18" Foreground="{StaticResource SuccessBrush}" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                        </Border>
                                        <StackPanel VerticalAlignment="Center">
                                            <TextBlock Text="{Binding LastLoginDeviceName}" FontSize="15" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}" />
                                            <TextBlock Text="{Binding LastLoginTime}" FontSize="11" Foreground="{StaticResource TextTertiaryBrush}" />
                                        </StackPanel>
                                    </StackPanel>

                                    <Grid ColumnSpacing="24" RowSpacing="12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>

                                        <StackPanel Grid.Row="0" Grid.Column="0" Spacing="2">
                                            <TextBlock Text="IP ADDRESS" FontSize="9" FontWeight="Bold" Foreground="{StaticResource TextTertiaryBrush}" CharacterSpacing="50" />
                                            <TextBlock Text="{Binding LastLoginIp}" FontSize="13" FontWeight="Medium" />
                                        </StackPanel>
                                        <StackPanel Grid.Row="0" Grid.Column="1" Spacing="2">
                                            <TextBlock Text="LOCATION" FontSize="9" FontWeight="Bold" Foreground="{StaticResource TextTertiaryBrush}" CharacterSpacing="50" />
                                            <TextBlock Text="{Binding LastLoginLocation}" FontSize="13" FontWeight="Medium" />
                                        </StackPanel>
                                        <StackPanel Grid.Row="1" Grid.Column="0" Spacing="2">
                                            <TextBlock Text="BROWSER" FontSize="9" FontWeight="Bold" Foreground="{StaticResource TextTertiaryBrush}" CharacterSpacing="50" />
                                            <TextBlock Text="{Binding LastLoginBrowser}" FontSize="13" FontWeight="Medium" />
                                        </StackPanel>
                                        <StackPanel Grid.Row="1" Grid.Column="1" Spacing="2">
                                            <TextBlock Text="OS VERSION" FontSize="9" FontWeight="Bold" Foreground="{StaticResource TextTertiaryBrush}" CharacterSpacing="50" />
                                            <TextBlock Text="{Binding LastLoginOsVersion}" FontSize="13" FontWeight="Medium" />
                                        </StackPanel>
                                    </Grid>
                                    
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <FontIcon Glyph="&#xE81D;" FontSize="12" Foreground="{StaticResource SuccessBrush}" VerticalAlignment="Center" />
                                        <TextBlock Text="{Binding LastLoginCoordinates}" FontSize="11" Foreground="{StaticResource SuccessBrush}" VerticalAlignment="Center" />
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </Border>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="12" Margin="0,32,0,0">
                        <TextBlock Text="{Binding ProfileMessage}" Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center" Margin="0,0,16,0" />
                        <Button Style="{StaticResource GhostButtonStyle}" Content="Discard" />
                        <Button Style="{StaticResource PrimaryButtonStyle}" Content="Save Changes" Command="{Binding SaveProfileCommand}" Padding="24,8" />
                    </StackPanel>
                </StackPanel>

                <!-- â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â• -->
                <!-- SECURITY SECTION                                   -->
                <!-- â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â• -->

                <!-- ── LOGIN DEVICE MANAGEMENT SECTION ────────────── -->
                <StackPanel x:Name="LoginDeviceSection" Visibility="Collapsed" Margin="48,0,0,0">
                    <Grid Margin="0,0,0,32">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Spacing="8">
                            <TextBlock Text="LOGIN DEVICE MANAGEMENT" Style="{StaticResource SectionTitleStyle}" />
                            <TextBlock Text="Manage active sessions and authorized devices currently accessing your account. You can revoke access for any suspicious device." Style="{StaticResource SectionDescriptionStyle}" Margin="0" />
                        </StackPanel>
                        <Button Grid.Column="1" Style="{StaticResource OutlinedButtonStyle}" 
                                Content="Logout All Other Sessions" 
                                Foreground="{StaticResource DangerBrush}"
                                Command="{Binding LogoutAllSessionsCommand}"
                                VerticalAlignment="Top" Margin="0,8,0,0" />
                    </Grid>

                    <!-- Active Sessions List -->
                    <TextBlock Text="Active Sessions" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,16" />
                    <ListView ItemsSource="{Binding ActiveSessions}" SelectionMode="None" Margin="0,0,0,48">
                        <ListView.ItemContainerStyle>
                            <Style TargetType="ListViewItem">
                                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                <Setter Property="Padding" Value="0" />
                                <Setter Property="Margin" Value="0,0,0,16" />
                            </Style>
                        </ListView.ItemContainerStyle>
                        <ListView.ItemTemplate>
                            <DataTemplate x:DataType="viewmodels:SessionUIWrapper">
                                <Border Background="{StaticResource CardBackgroundBrush}" 
                                        BorderBrush="{StaticResource BorderDefaultBrush}" 
                                        BorderThickness="1" CornerRadius="12" Padding="24">
                                    <Grid ColumnSpacing="24">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>

                                        <!-- Device Icon -->
                                        <Border Width="56" Height="56" CornerRadius="28" Background="#101F7AE0" BorderBrush="#201F7AE0" BorderThickness="1" VerticalAlignment="Top">
                                            <FontIcon Glyph="&#xE770;" FontSize="24" Foreground="{StaticResource AccentPrimaryBrush}" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                        </Border>

                                        <!-- Device Details -->
                                        <StackPanel Grid.Column="1" Spacing="16">
                                            <StackPanel Orientation="Horizontal" Spacing="12">
                                                <TextBlock FontSize="18" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}">
                                                    <Run Text="{x:Bind Session.DeviceName}" />
                                                    <Run Text=" · " />
                                                    <Run Text="{x:Bind Session.OperatingSystem}" />
                                                </TextBlock>
                                                <Border Visibility="{x:Bind CurrentBadgeVisibility}" Background="#102ABD8F" BorderBrush="#302ABD8F" BorderThickness="1" CornerRadius="4" Padding="8,2" VerticalAlignment="Center">
                                                    <TextBlock Text="This Device" FontSize="10" FontWeight="Bold" Foreground="{StaticResource SuccessBrush}" />
                                                </Border>
                                                <Border Visibility="{x:Bind NonCurrentBadgeVisibility}" Background="#101F7AE0" BorderBrush="#201F7AE0" BorderThickness="1" CornerRadius="4" Padding="8,2" VerticalAlignment="Center">
                                                    <TextBlock Text="Active Now" FontSize="10" FontWeight="Bold" Foreground="{StaticResource AccentPrimaryBrush}" />
                                                </Border>
                                            </StackPanel>

                                            <Grid ColumnSpacing="40" RowSpacing="16">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="Auto" />
                                                </Grid.RowDefinitions>

                                                <StackPanel Grid.Row="0" Grid.Column="0" Spacing="2">
                                                    <TextBlock Text="BROWSER" FontSize="9" FontWeight="Bold" Foreground="{StaticResource TextTertiaryBrush}" CharacterSpacing="50" />
                                                    <TextBlock Text="{x:Bind Session.Browser}" FontSize="14" FontWeight="Medium" />
                                                </StackPanel>
                                                <StackPanel Grid.Row="0" Grid.Column="1" Spacing="2">
                                                    <TextBlock Text="IP ADDRESS" FontSize="9" FontWeight="Bold" Foreground="{StaticResource TextTertiaryBrush}" CharacterSpacing="50" />
                                                    <TextBlock Text="{x:Bind Session.IpAddress}" FontSize="14" FontWeight="Medium" />
                                                </StackPanel>
                                                <StackPanel Grid.Row="0" Grid.Column="2" Spacing="2">
                                                    <TextBlock Text="LOCATION" FontSize="9" FontWeight="Bold" Foreground="{StaticResource TextTertiaryBrush}" CharacterSpacing="50" />
                                                    <TextBlock Text="{x:Bind Session.City}" FontSize="14" FontWeight="Medium" />
                                                </StackPanel>

                                                <StackPanel Grid.Row="1" Grid.Column="0" Spacing="2">
                                                    <TextBlock Text="COORDINATES" FontSize="9" FontWeight="Bold" Foreground="{StaticResource TextTertiaryBrush}" CharacterSpacing="50" />
                                                    <TextBlock FontSize="14" FontWeight="Medium">
                                                        <Run Text="{x:Bind Session.Latitude}" />
                                                        <Run Text=", " />
                                                        <Run Text="{x:Bind Session.Longitude}" />
                                                    </TextBlock>
                                                </StackPanel>
                                                <StackPanel Grid.Row="1" Grid.Column="1" Spacing="2">
                                                    <TextBlock Text="LOGIN TIME" FontSize="9" FontWeight="Bold" Foreground="{StaticResource TextTertiaryBrush}" CharacterSpacing="50" />
                                                    <TextBlock Text="{x:Bind DisplayTime}" FontSize="14" FontWeight="Medium" />
                                                </StackPanel>
                                                <StackPanel Grid.Row="1" Grid.Column="2" Spacing="2">
                                                    <TextBlock Text="LAST ACTIVE" FontSize="9" FontWeight="Bold" Foreground="{StaticResource TextTertiaryBrush}" CharacterSpacing="50" />
                                                    <TextBlock Text="{x:Bind DisplayLastActive}" FontSize="14" FontWeight="Medium" />
                                                </StackPanel>
                                            </Grid>
                                        </StackPanel>

                                        <!-- Action -->
                                        <StackPanel Grid.Column="2" VerticalAlignment="Center" Spacing="12">
                                            <Button Visibility="{x:Bind RevokeButtonVisibility}" 
                                                    Style="{StaticResource GhostButtonStyle}" 
                                                    Content="Log out device" 
                                                    Foreground="{StaticResource DangerBrush}"
                                                    Command="{Binding DataContext.LogoutSessionCommand, ElementName=LoginDeviceSection}"
                                                    CommandParameter="{x:Bind Session.Id}" />
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>

                    <!-- Login History Audit -->
                    <StackPanel Spacing="16">
                        <TextBlock Text="Login History Audit" FontSize="18" FontWeight="SemiBold" />
                        <TextBlock Text="A full log of all successful and attempted logins to your account." FontSize="13" Foreground="{StaticResource TextSecondaryBrush}" />
                        <Border Background="{StaticResource CardBackgroundBrush}" BorderBrush="{StaticResource BorderDefaultBrush}" BorderThickness="1" CornerRadius="8">
                            <Grid>
                                <!-- History List -->
                                <ListView ItemsSource="{Binding LoginHistoryItems}" SelectionMode="None" Padding="0"
                                          Visibility="{Binding HasLoginHistory, Converter={StaticResource BoolToVisibilityConverter}}">
                                    <ListView.Header>
                                        <Grid Padding="16,12" Background="{StaticResource ElevatedCardBackgroundBrush}">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="140" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="120" />
                                                <ColumnDefinition Width="100" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="TIME" FontSize="10" FontWeight="Bold" Foreground="{StaticResource TextTertiaryBrush}" />
                                            <TextBlock Grid.Column="1" Text="DETAILS" FontSize="10" FontWeight="Bold" Foreground="{StaticResource TextTertiaryBrush}" />
                                            <TextBlock Grid.Column="2" Text="IP" FontSize="10" FontWeight="Bold" Foreground="{StaticResource TextTertiaryBrush}" />
                                            <TextBlock Grid.Column="3" Text="STATUS" FontSize="10" FontWeight="Bold" Foreground="{StaticResource TextTertiaryBrush}" HorizontalAlignment="Right" />
                                        </Grid>
                                    </ListView.Header>
                                    <ListView.ItemTemplate>
                                        <DataTemplate x:DataType="models:LoginHistory">
                                            <Grid Padding="16,12" BorderBrush="{StaticResource BorderDefaultBrush}" BorderThickness="0,1,0,0">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="140" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="120" />
                                                    <ColumnDefinition Width="100" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Text="{x:Bind Time}" FontSize="12" VerticalAlignment="Center" />
                                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                    <TextBlock Text="{x:Bind Details}" FontSize="13" FontWeight="SemiBold" />
                                                </StackPanel>
                                                <TextBlock Grid.Column="2" Text="{x:Bind IP}" FontSize="12" VerticalAlignment="Center" Foreground="{StaticResource TextSecondaryBrush}" />
                                                <Border Grid.Column="3" HorizontalAlignment="Right" Padding="8,2" CornerRadius="4" VerticalAlignment="Center" Background="#102ABD8F" BorderBrush="#302ABD8F" BorderThickness="1">
                                                    <TextBlock Text="{x:Bind Status}" FontSize="9" FontWeight="Bold" Foreground="{StaticResource SuccessBrush}" />
                                                </Border>
                                            </Grid>
                                        </DataTemplate>
                                    </ListView.ItemTemplate>
                                </ListView>

                                <!-- Empty State Fallback -->
                                <StackPanel Visibility="{Binding HasLoginHistory, Converter={StaticResource InvertedBoolToVisibilityConverter}}"
                                            Padding="32" Spacing="16" HorizontalAlignment="Center">
                                    <Border Width="48" Height="48" CornerRadius="24" Background="{StaticResource ElevatedCardBackgroundBrush}">
                                        <FontIcon Glyph="&#xE9CE;" FontSize="18" Foreground="{StaticResource TextTertiaryBrush}" />
                                    </Border>
                                    <TextBlock Text="No Login History Available" FontSize="14" Foreground="{StaticResource TextSecondaryBrush}" HorizontalAlignment="Center" />
                                </StackPanel>
                            </Grid>
                        </Border>
                    </StackPanel>
                </StackPanel>
                <StackPanel x:Name="SecuritySection" Visibility="Collapsed" Margin="48,0,0,0">
                    <TextBlock Text="SECURITY &amp; 2FA" Style="{StaticResource SectionTitleStyle}" />
                    <TextBlock Text="Protect your account with two-factor authentication. Once enabled, a 6-digit code from your authenticator app is required for sensitive operations." Style="{StaticResource SectionDescriptionStyle}" />

                    <!-- ── STATUS CARD ─────────────────────────────────── -->
                    <Border Style="{StaticResource SettingRowBorderStyle}">
                        <Grid ColumnSpacing="32">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="2*" />
                                <ColumnDefinition Width="3*" />
                            </Grid.ColumnDefinitions>

                            <StackPanel Spacing="6">
                                <TextBlock Text="Authenticator Status" Style="{StaticResource SettingLabelStyle}" />
                                <TextBlock Text="Shows whether 2FA is active on this device." Style="{StaticResource SettingHintStyle}" />
                            </StackPanel>

                            <!-- STATUS: OFF -->
                            <Border Grid.Column="1"
                                    Visibility="{Binding ShowTwoFactorOffPanel, Converter={StaticResource BoolToVisibilityConverter}}"
                                    Background="{StaticResource CardBackgroundBrush}"
                                    BorderBrush="{StaticResource BorderDefaultBrush}"
                                    BorderThickness="1" CornerRadius="10" Padding="20,16">
                                <Grid ColumnSpacing="16">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <Border Width="40" Height="40" CornerRadius="20"
                                            Background="#18E87040" BorderBrush="#30E87040" BorderThickness="1">
                                        <FontIcon Glyph="&#xE72E;" FontSize="16" Foreground="#E87040" />
                                    </Border>
                                    <StackPanel Grid.Column="1" Spacing="2" VerticalAlignment="Center">
                                        <TextBlock Text="Not Protected" FontSize="13" FontWeight="SemiBold"
                                                   Foreground="{StaticResource TextPrimaryBrush}" />
                                        <TextBlock Text="Your account has no second factor. Enable 2FA to secure it."
                                                   FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"
                                                   TextWrapping="WrapWholeWords" />
                                    </StackPanel>
                                    <Button Grid.Column="2" Style="{StaticResource PrimaryButtonStyle}"
                                            Content="Enable 2FA" VerticalAlignment="Center"
                                            Command="{Binding StartTwoFactorSetupCommand}" />
                                </Grid>
                            </Border>

                            <!-- STATUS: ENABLED -->
                            <Border Grid.Column="1"
                                    Visibility="{Binding ShowTwoFactorEnabledPanel, Converter={StaticResource BoolToVisibilityConverter}}"
                                    Background="#0A2ABD8F"
                                    BorderBrush="#252ABD8F"
                                    BorderThickness="1" CornerRadius="10" Padding="20,16">
                                <Grid ColumnSpacing="16">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <Border Width="40" Height="40" CornerRadius="20"
                                            Background="#182ABD8F" BorderBrush="#302ABD8F" BorderThickness="1">
                                        <FontIcon Glyph="&#xE73E;" FontSize="16" Foreground="{StaticResource SuccessBrush}" />
                                    </Border>
                                    <StackPanel Grid.Column="1" Spacing="2" VerticalAlignment="Center">
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <TextBlock Text="Protected" FontSize="13" FontWeight="SemiBold"
                                                       Foreground="{StaticResource SuccessBrush}" />
                                            <Border Background="#182ABD8F" BorderBrush="#302ABD8F" BorderThickness="1"
                                                    CornerRadius="4" Padding="6,2">
                                                <TextBlock Text="2FA ON" FontSize="9" FontWeight="Bold"
                                                           Foreground="{StaticResource SuccessBrush}" CharacterSpacing="50" />
                                            </Border>
                                        </StackPanel>
                                        <TextBlock Text="Two-factor authentication is active on this device."
                                                   FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" />
                                    </StackPanel>
                                    <Button Grid.Column="2" Style="{StaticResource GhostButtonStyle}"
                                            Content="Manage" VerticalAlignment="Center"
                                            Click="OnOpenTwoFactorEditorClick" />
                                </Grid>
                            </Border>
                        </Grid>
                    </Border>

                    <!-- ── SETUP PANEL (visible only during setup) ────── -->
                    <Border Style="{StaticResource SettingRowBorderStyle}"
                            Visibility="{Binding ShowTwoFactorSetupPanel, Converter={StaticResource BoolToVisibilityConverter}}">
                        <StackPanel Spacing="24">

                            <StackPanel Spacing="4">
                                <TextBlock Text="Set Up Authenticator App" Style="{StaticResource SettingLabelStyle}" />
                                <TextBlock Text="Scan the QR code with Google Authenticator, Microsoft Authenticator, or Authy. Then enter the 6-digit code to confirm." Style="{StaticResource SettingHintStyle}" />
                            </StackPanel>

                            <!-- QR + Key side by side -->
                            <Grid ColumnSpacing="32">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <Border Width="160" Height="160" Background="White"
                                        CornerRadius="12" Padding="10"
                                        BorderBrush="{StaticResource BorderDefaultBrush}" BorderThickness="1">
                                    <Image Source="{Binding TwoFactorQrImage}" Stretch="Uniform" />
                                </Border>

                                <StackPanel Grid.Column="1" Spacing="20" VerticalAlignment="Center">
                                    <StackPanel Spacing="6">
                                        <TextBlock Text="MANUAL ENTRY KEY" FontSize="10" FontWeight="Bold"
                                                   Foreground="{StaticResource TextTertiaryBrush}" CharacterSpacing="60" />
                                        <Grid ColumnSpacing="8">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <Border Background="{StaticResource CardBackgroundBrush}"
                                                    BorderBrush="{StaticResource BorderDefaultBrush}"
                                                    BorderThickness="1" CornerRadius="6" Padding="12,10">
                                                <TextBlock Text="{Binding TwoFactorSecretDisplay}"
                                                           FontFamily="Consolas" FontSize="13"
                                                           Foreground="{StaticResource AccentPrimaryBrush}"
                                                           TextWrapping="Wrap" />
                                            </Border>
                                            <Button Grid.Column="1" Style="{StaticResource GhostButtonStyle}"
                                                    Width="40" Height="40" Padding="0"
                                                    ToolTipService.ToolTip="Copy key"
                                                    Click="OnCopyTwoFactorKeyClick">
                                                <FontIcon Glyph="&#xE8C8;" FontSize="14" />
                                            </Button>
                                        </Grid>
                                    </StackPanel>

                                    <StackPanel Spacing="6">
                                        <TextBlock Text="VERIFICATION CODE" FontSize="10" FontWeight="Bold"
                                                   Foreground="{StaticResource TextTertiaryBrush}" CharacterSpacing="60" />
                                        <TextBox Style="{StaticResource StandardTextBoxStyle}"
                                                 MaxLength="6" PlaceholderText="000 000"
                                                 Text="{Binding TwoFactorConfirmCode, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                 FontFamily="Consolas" FontSize="22"
                                                 CharacterSpacing="12" TextAlignment="Center" />
                                    </StackPanel>
                                </StackPanel>
                            </Grid>

                            <!-- Message box -->
                            <Border Visibility="{Binding TwoFactorMessage, Converter={StaticResource StringToVisibilityConverter}}"
                                    Background="{StaticResource CardBackgroundBrush}"
                                    BorderBrush="{StaticResource BorderDefaultBrush}"
                                    BorderThickness="1" CornerRadius="6" Padding="12,10">
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <FontIcon Glyph="&#xE946;" FontSize="13"
                                              Foreground="{StaticResource AccentPrimaryBrush}"
                                              VerticalAlignment="Top" Margin="0,1,0,0" />
                                    <TextBlock Text="{Binding TwoFactorMessage}"
                                               FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"
                                               TextWrapping="WrapWholeWords" />
                                </StackPanel>
                            </Border>

                            <!-- Action buttons -->
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="12">
                                <Button Style="{StaticResource GhostButtonStyle}" Content="Cancel"
                                        Command="{Binding CancelTwoFactorSetupCommand}" />
                                <Button Style="{StaticResource PrimaryButtonStyle}"
                                        Content="Verify &amp; Activate"
                                        Command="{Binding ConfirmTwoFactorSetupCommand}"
                                        Padding="24,8" />
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- ── MANAGE / DISABLE PANEL ────────────────────── -->
                    <Border Style="{StaticResource SettingRowBorderStyle}"
                            Visibility="{Binding ShowTwoFactorEditor, Converter={StaticResource BoolToVisibilityConverter}}">
                        <StackPanel Spacing="20">

                            <StackPanel Spacing="4">
                                <TextBlock Text="Disable Two-Factor Authentication" Style="{StaticResource SettingLabelStyle}" />
                                <TextBlock Text="Enter the current 6-digit code from your authenticator app to turn off 2FA. This will reduce your account security."
                                           Style="{StaticResource SettingHintStyle}" />
                            </StackPanel>

                            <Grid ColumnSpacing="12" MaxWidth="380" HorizontalAlignment="Left">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBox Style="{StaticResource StandardTextBoxStyle}"
                                         MaxLength="6" PlaceholderText="000 000"
                                         Text="{Binding TwoFactorDisableCode, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                         FontFamily="Consolas" FontSize="18" CharacterSpacing="10"
                                         TextAlignment="Center" />
                                <Button Grid.Column="1" Style="{StaticResource OutlinedButtonStyle}"
                                        Content="Disable 2FA"
                                        Foreground="{StaticResource DangerBrush}"
                                        Click="OnDisableTwoFactorClick" />
                            </Grid>

                            <Border Visibility="{Binding TwoFactorMessage, Converter={StaticResource StringToVisibilityConverter}}"
                                    Background="{StaticResource CardBackgroundBrush}"
                                    BorderBrush="{StaticResource BorderDefaultBrush}"
                                    BorderThickness="1" CornerRadius="6" Padding="12,10">
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <FontIcon Glyph="&#xE946;" FontSize="13"
                                              Foreground="{StaticResource AccentPrimaryBrush}"
                                              VerticalAlignment="Top" Margin="0,1,0,0" />
                                    <TextBlock Text="{Binding TwoFactorMessage}"
                                               FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"
                                               TextWrapping="WrapWholeWords" />
                                </StackPanel>
                            </Border>

                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                <Button Style="{StaticResource GhostButtonStyle}" Content="Close"
                                        Click="OnCloseTwoFactorEditorClick" />
                            </StackPanel>
                        </StackPanel>
                    </Border>

                </StackPanel>

                <!-- â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â• -->
                <!-- PASSWORD SECTION                                   -->
                <!-- â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â• -->
                <StackPanel x:Name="PasswordSection" Visibility="Collapsed" Margin="48,0,0,0">
                    <TextBlock Text="PASSWORD MANAGEMENT" Style="{StaticResource SectionTitleStyle}" />
                    <TextBlock Text="Change your account password. Enter your current password to verify identity, then set a new strong password." Style="{StaticResource SectionDescriptionStyle}" />

                    <!-- Card wrapper -->
                    <Border Background="{StaticResource CardBackgroundBrush}"
                            BorderBrush="{StaticResource BorderDefaultBrush}"
                            BorderThickness="1" CornerRadius="12" Padding="32,28">
                        <StackPanel Spacing="24">

                            <!-- CURRENT PASSWORD -->
                            <StackPanel Spacing="8">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <Border Width="32" Height="32" CornerRadius="8"
                                            Background="#101F7AE0" BorderBrush="#201F7AE0" BorderThickness="1">
                                        <FontIcon Glyph="&#xE8D7;" FontSize="14" Foreground="{StaticResource AccentPrimaryBrush}" />
                                    </Border>
                                    <TextBlock Text="Current Password" FontSize="15" FontWeight="SemiBold"
                                               Foreground="{StaticResource TextPrimaryBrush}" VerticalAlignment="Center" />
                                </StackPanel>
                                <Grid>
                                    <PasswordBox x:Name="CurrentPasswordBox"
                                                 PlaceholderText="Enter your current password"
                                                 PasswordChanged="OnCurrentPasswordChanged"
                                                 PasswordRevealMode="Hidden"
                                                 Padding="12,10,44,10" />
                                    <Button x:Name="CurrentPasswordRevealButton"
                                            Click="OnCurrentPasswordRevealClick"
                                            Style="{StaticResource GhostButtonStyle}"
                                            BorderThickness="0"
                                            Background="Transparent"
                                            Width="36" Height="36"
                                            HorizontalAlignment="Right"
                                            VerticalAlignment="Center"
                                            Margin="0,0,4,0"
                                            Padding="0">
                                        <FontIcon x:Name="CurrentPasswordRevealIcon" Glyph="&#xE890;" FontSize="14" Foreground="{StaticResource TextSecondaryBrush}" />
                                    </Button>
                                </Grid>
                                <Border x:Name="CurrentPasswordErrorBorder" Visibility="Collapsed"
                                        Background="#18E05252" BorderBrush="#30E05252"
                                        BorderThickness="1" CornerRadius="6" Padding="10,8">
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <FontIcon Glyph="&#xE783;" FontSize="12" Foreground="#E05252" VerticalAlignment="Center" />
                                        <TextBlock x:Name="CurrentPasswordErrorText"
                                                   Text="Current password is incorrect."
                                                   FontSize="12" Foreground="#E05252" TextWrapping="WrapWholeWords" />
                                    </StackPanel>
                                </Border>
                            </StackPanel>

                            <!-- Divider -->
                            <Border Height="1" Background="{StaticResource BorderDefaultBrush}" />

                            <!-- NEW PASSWORD -->
                            <StackPanel Spacing="8">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <Border Width="32" Height="32" CornerRadius="8"
                                            Background="#102ABD8F" BorderBrush="#202ABD8F" BorderThickness="1">
                                        <FontIcon Glyph="&#xE72E;" FontSize="14" Foreground="{StaticResource SuccessBrush}" />
                                    </Border>
                                    <TextBlock Text="New Password" FontSize="15" FontWeight="SemiBold"
                                               Foreground="{StaticResource TextPrimaryBrush}" VerticalAlignment="Center" />
                                </StackPanel>

                                <!-- Auto-generate row -->
                                <Border Background="{StaticResource ElevatedCardBackgroundBrush}"
                                        BorderBrush="{StaticResource BorderDefaultBrush}"
                                        BorderThickness="1" CornerRadius="8" Padding="16,12">
                                    <Grid ColumnSpacing="12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Spacing="2" VerticalAlignment="Center">
                                            <TextBlock Text="Auto-generate a strong password"
                                                       FontSize="13" FontWeight="SemiBold"
                                                       Foreground="{StaticResource TextPrimaryBrush}" />
                                            <TextBlock Text="16 chars · upper · lower · digits · symbols"
                                                       FontSize="11" Foreground="{StaticResource TextTertiaryBrush}" />
                                        </StackPanel>
                                        <Button Grid.Column="1"
                                                Style="{StaticResource PrimaryButtonStyle}"
                                                Padding="16,8" FontSize="13"
                                                Click="OnGeneratePasswordClick">
                                            <StackPanel Orientation="Horizontal" Spacing="8">
                                                <FontIcon Glyph="&#xE72C;" FontSize="12" />
                                                <TextBlock Text="Generate" />
                                            </StackPanel>
                                        </Button>
                                        <Button Grid.Column="2" Style="{StaticResource GhostButtonStyle}"
                                                Width="36" Height="36" Padding="0"
                                                ToolTipService.ToolTip="Copy generated password"
                                                Click="OnCopyGeneratedPasswordClick">
                                            <FontIcon Glyph="&#xE8C8;" FontSize="13" />
                                        </Button>
                                    </Grid>
                                </Border>

                                <!-- New password input + strength -->
                                <Grid>
                                    <PasswordBox x:Name="NewPasswordBox"
                                                 PlaceholderText="Enter or paste new password"
                                                 PasswordChanged="OnNewPasswordChanged"
                                                 PasswordRevealMode="Hidden"
                                                 Padding="12,10,44,10" />
                                    <Button x:Name="NewPasswordRevealButton"
                                            Click="OnNewPasswordRevealClick"
                                            Style="{StaticResource GhostButtonStyle}"
                                            BorderThickness="0"
                                            Background="Transparent"
                                            Width="36" Height="36"
                                            HorizontalAlignment="Right"
                                            VerticalAlignment="Center"
                                            Margin="0,0,4,0"
                                            Padding="0">
                                        <FontIcon x:Name="NewPasswordRevealIcon" Glyph="&#xE890;" FontSize="14" Foreground="{StaticResource TextSecondaryBrush}" />
                                    </Button>
                                </Grid>
                                <Grid ColumnSpacing="4">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Rectangle Grid.Column="0" Height="3" RadiusX="2" RadiusY="2" x:Name="StrengthBar1" Fill="{StaticResource BorderDefaultBrush}" />
                                    <Rectangle Grid.Column="1" Height="3" RadiusX="2" RadiusY="2" x:Name="StrengthBar2" Fill="{StaticResource BorderDefaultBrush}" />
                                    <Rectangle Grid.Column="2" Height="3" RadiusX="2" RadiusY="2" x:Name="StrengthBar3" Fill="{StaticResource BorderDefaultBrush}" />
                                    <Rectangle Grid.Column="3" Height="3" RadiusX="2" RadiusY="2" x:Name="StrengthBar4" Fill="{StaticResource BorderDefaultBrush}" />
                                </Grid>
                                <TextBlock x:Name="StrengthLabel" Text="" FontSize="11"
                                           Foreground="{StaticResource TextTertiaryBrush}"
                                           HorizontalAlignment="Right" />
                            </StackPanel>

                            <!-- Divider -->
                            <Border Height="1" Background="{StaticResource BorderDefaultBrush}" />

                            <!-- CONFIRM PASSWORD -->
                            <StackPanel Spacing="8">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <Border Width="32" Height="32" CornerRadius="8"
                                            Background="#10E8A040" BorderBrush="#20E8A040" BorderThickness="1">
                                        <FontIcon Glyph="&#xE73E;" FontSize="14" Foreground="#E8A040" />
                                    </Border>
                                    <TextBlock Text="Confirm New Password" FontSize="15" FontWeight="SemiBold"
                                               Foreground="{StaticResource TextPrimaryBrush}" VerticalAlignment="Center" />
                                </StackPanel>
                                <Grid>
                                    <PasswordBox x:Name="ConfirmPasswordBox"
                                                 PlaceholderText="Re-enter new password"
                                                 PasswordChanged="OnConfirmPasswordChanged"
                                                 PasswordRevealMode="Hidden"
                                                 Padding="12,10,44,10" />
                                    <Button x:Name="ConfirmPasswordRevealButton"
                                            Click="OnConfirmPasswordRevealClick"
                                            Style="{StaticResource GhostButtonStyle}"
                                            BorderThickness="0"
                                            Background="Transparent"
                                            Width="36" Height="36"
                                            HorizontalAlignment="Right"
                                            VerticalAlignment="Center"
                                            Margin="0,0,4,0"
                                            Padding="0">
                                        <FontIcon x:Name="ConfirmPasswordRevealIcon" Glyph="&#xE890;" FontSize="14" Foreground="{StaticResource TextSecondaryBrush}" />
                                    </Button>
                                </Grid>
                            </StackPanel>

                            <!-- Requirements hint -->
                            <Border Background="{StaticResource ElevatedCardBackgroundBrush}"
                                    BorderBrush="{StaticResource BorderDefaultBrush}"
                                    BorderThickness="1" CornerRadius="8" Padding="16,12">
                                <StackPanel Orientation="Horizontal" Spacing="16">
                                    <FontIcon Glyph="&#xE946;" FontSize="13" Foreground="{StaticResource TextTertiaryBrush}" VerticalAlignment="Center" />
                                    <StackPanel Spacing="3">
                                        <TextBlock Text="Password Requirements" FontSize="12" FontWeight="SemiBold"
                                                   Foreground="{StaticResource TextSecondaryBrush}" />
                                        <StackPanel Orientation="Horizontal" Spacing="16">
                                            <TextBlock Text="• Min 8 characters" FontSize="11" Foreground="{StaticResource TextTertiaryBrush}" />
                                            <TextBlock Text="• Uppercase &amp; lowercase" FontSize="11" Foreground="{StaticResource TextTertiaryBrush}" />
                                            <TextBlock Text="• At least one number" FontSize="11" Foreground="{StaticResource TextTertiaryBrush}" />
                                            <TextBlock Text="• Special character recommended" FontSize="11" Foreground="{StaticResource TextTertiaryBrush}" />
                                        </StackPanel>
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                            <!-- Message -->
                            <Border x:Name="PasswordMessageBorder" Visibility="Collapsed"
                                    BorderThickness="1" CornerRadius="6" Padding="12,10">
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <FontIcon x:Name="PasswordMessageIcon" Glyph="&#xE946;"
                                              FontSize="13" VerticalAlignment="Top" Margin="0,1,0,0" />
                                    <TextBlock x:Name="PasswordMessageText"
                                               FontSize="12" TextWrapping="WrapWholeWords" />
                                </StackPanel>
                            </Border>

                            <!-- Actions -->
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="12">
                                <Button Style="{StaticResource GhostButtonStyle}" Content="Clear"
                                        Click="OnClearPasswordFieldsClick" Padding="20,10" />
                                <Button Style="{StaticResource PrimaryButtonStyle}"
                                        Content="Update Password"
                                        Command="{Binding ChangePasswordCommand}"
                                        Padding="24,10" />
                            </StackPanel>

                        </StackPanel>
                    </Border>
                </StackPanel>
                <!-- APP LOCK SECTION -->
                <StackPanel x:Name="AppLockSection" Visibility="Collapsed" Margin="48,0,0,0">
                    <TextBlock Text="APPLICATION LOCK" Style="{StaticResource SectionTitleStyle}" />
                    <TextBlock Text="When enabled, Windows Hello (fingerprint, face, or device PIN) is required every time the app opens." Style="{StaticResource SectionDescriptionStyle}" />

                    <!-- Toggle row -->
                    <Border Style="{StaticResource SettingRowBorderStyle}">
                        <Grid ColumnSpacing="32">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="2*" />
                                <ColumnDefinition Width="3*" />
                            </Grid.ColumnDefinitions>

                            <StackPanel Spacing="6">
                                <TextBlock Text="Windows Hello Lock" Style="{StaticResource SettingLabelStyle}" />
                                <TextBlock Text="Uses your device's built-in biometric or PIN — no separate app password needed." Style="{StaticResource SettingHintStyle}" />
                            </StackPanel>

                            <!-- OFF state -->
                            <Border Grid.Column="1"
                                    Visibility="{Binding AppLockEnabled, Converter={StaticResource InvertedBoolToVisibilityConverter}}"
                                    Background="{StaticResource CardBackgroundBrush}"
                                    BorderBrush="{StaticResource BorderDefaultBrush}"
                                    BorderThickness="1" CornerRadius="10" Padding="20,16">
                                <Grid ColumnSpacing="16">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <Border Width="40" Height="40" CornerRadius="20"
                                            Background="#18E87040" BorderBrush="#30E87040" BorderThickness="1">
                                        <FontIcon Glyph="&#xE785;" FontSize="16" Foreground="#E87040" />
                                    </Border>
                                    <StackPanel Grid.Column="1" Spacing="2" VerticalAlignment="Center">
                                        <TextBlock Text="Not Protected" FontSize="13" FontWeight="SemiBold"
                                                   Foreground="{StaticResource TextPrimaryBrush}" />
                                        <TextBlock Text="App opens without any identity check."
                                                   FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" />
                                    </StackPanel>
                                    <Button Grid.Column="2" Style="{StaticResource PrimaryButtonStyle}"
                                            Content="Enable" VerticalAlignment="Center" Padding="20,8"
                                            Click="OnAppLockToggleClick" />
                                </Grid>
                            </Border>

                            <!-- ON state -->
                            <Border Grid.Column="1"
                                    Visibility="{Binding AppLockEnabled, Converter={StaticResource BoolToVisibilityConverter}}"
                                    Background="#0A1F7AE0" BorderBrush="#251F7AE0"
                                    BorderThickness="1" CornerRadius="10" Padding="20,16">
                                <Grid ColumnSpacing="16">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <Border Width="40" Height="40" CornerRadius="20"
                                            Background="#181F7AE0" BorderBrush="#301F7AE0" BorderThickness="1">
                                        <FontIcon Glyph="&#xE72E;" FontSize="16"
                                                  Foreground="{StaticResource AccentPrimaryBrush}" />
                                    </Border>
                                    <StackPanel Grid.Column="1" Spacing="2" VerticalAlignment="Center">
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <TextBlock Text="Protected" FontSize="13" FontWeight="SemiBold"
                                                       Foreground="{StaticResource AccentPrimaryBrush}" />
                                            <Border Background="#181F7AE0" BorderBrush="#301F7AE0"
                                                    BorderThickness="1" CornerRadius="4" Padding="6,2">
                                                <TextBlock Text="WINDOWS HELLO" FontSize="9" FontWeight="Bold"
                                                           Foreground="{StaticResource AccentPrimaryBrush}"
                                                           CharacterSpacing="40" />
                                            </Border>
                                        </StackPanel>
                                        <TextBlock Text="Windows Hello verification required on startup."
                                                   FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" />
                                    </StackPanel>
                                    <Button Grid.Column="2" Style="{StaticResource OutlinedButtonStyle}"
                                            Content="Disable" VerticalAlignment="Center" Padding="20,8"
                                            Foreground="{StaticResource DangerBrush}"
                                            Click="OnAppLockToggleClick" />
                                </Grid>
                            </Border>
                        </Grid>
                    </Border>

                    <!-- Info row -->
                    <Border Style="{StaticResource SettingRowBorderStyle}">
                        <Grid ColumnSpacing="32">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="2*" />
                                <ColumnDefinition Width="3*" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Spacing="6">
                                <TextBlock Text="How it works" Style="{StaticResource SettingLabelStyle}" />
                                <TextBlock Text="Uses the Windows Security API — no data is stored in PartFinder." Style="{StaticResource SettingHintStyle}" />
                            </StackPanel>
                            <StackPanel Grid.Column="1" Spacing="12">
                                <StackPanel Orientation="Horizontal" Spacing="12">
                                    <Border Width="32" Height="32" CornerRadius="16"
                                            Background="#181F7AE0" BorderBrush="#301F7AE0" BorderThickness="1">
                                        <FontIcon Glyph="&#xED39;" FontSize="14"
                                                  Foreground="{StaticResource AccentPrimaryBrush}" />
                                    </Border>
                                    <StackPanel Spacing="2" VerticalAlignment="Center">
                                        <TextBlock Text="Fingerprint / Face ID" FontSize="13" FontWeight="SemiBold"
                                                   Foreground="{StaticResource TextPrimaryBrush}" />
                                        <TextBlock Text="If your device supports biometrics"
                                                   FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" />
                                    </StackPanel>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Spacing="12">
                                    <Border Width="32" Height="32" CornerRadius="16"
                                            Background="#181F7AE0" BorderBrush="#301F7AE0" BorderThickness="1">
                                        <FontIcon Glyph="&#xE8D7;" FontSize="14"
                                                  Foreground="{StaticResource AccentPrimaryBrush}" />
                                    </Border>
                                    <StackPanel Spacing="2" VerticalAlignment="Center">
                                        <TextBlock Text="Windows PIN / Password" FontSize="13" FontWeight="SemiBold"
                                                   Foreground="{StaticResource TextPrimaryBrush}" />
                                        <TextBlock Text="Falls back to your Windows account credentials"
                                                   FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" />
                                    </StackPanel>
                                </StackPanel>
                            </StackPanel>
                        </Grid>
                    </Border>
                </StackPanel>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
