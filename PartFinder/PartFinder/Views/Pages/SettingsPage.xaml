<Page
    x:Class="PartFinder.Views.Pages.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:components="using:PartFinder.Views.Components"
    xmlns:converters="using:PartFinder.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">
    <Page.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter" />
    </Page.Resources>
    <ScrollViewer x:Name="SettingsScrollViewer" Background="{StaticResource PageBackgroundBrush}">
        <Grid Padding="20" ColumnSpacing="16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource CardStyle}" Background="{StaticResource NavBackgroundBrush}">
                <StackPanel Spacing="6">
                    <TextBlock Text="Profile Settings" Style="{StaticResource CardTitleStyle}" Margin="4,0,0,6" />
                    <Border
                        Padding="12"
                        Margin="0,0,0,8"
                        CornerRadius="12"
                        Background="{StaticResource CardBackgroundBrush}"
                        BorderBrush="{StaticResource BorderDefaultBrush}"
                        BorderThickness="1">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <Border Width="34" Height="34" CornerRadius="17" Background="{StaticResource AccentPrimaryBrush}">
                                <TextBlock Text="JD" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="SemiBold" />
                            </Border>
                            <StackPanel>
                                <TextBlock Text="{Binding SessionEmailDisplay}" FontWeight="SemiBold" />
                                <TextBlock Text="Enterprise Tier" Style="{StaticResource CaptionStyle}" />
                            </StackPanel>
                        </StackPanel>
                    </Border>
                    <Button Padding="12,10" HorizontalContentAlignment="Stretch" Click="OnSecurityNavClick">
                        <Button.Content>
                            <Border Padding="10,8" Background="{StaticResource NavItemSelectedBrush}" CornerRadius="10">
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <FontIcon Glyph="&#xE713;" />
                                    <TextBlock Text="Security &amp; Authentication" Style="{StaticResource BodyStyle}" />
                                </StackPanel>
                            </Border>
                        </Button.Content>
                    </Button>
                    <Button Padding="12,10" HorizontalContentAlignment="Stretch" Click="OnProfileNavClick">
                        <Button.Content>
                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <FontIcon Glyph="&#xE77B;" />
                                <TextBlock Text="Profile" Style="{StaticResource CaptionStyle}" />
                            </StackPanel>
                        </Button.Content>
                    </Button>
                    <Button Padding="12,10" HorizontalContentAlignment="Stretch" Click="OnAppearanceNavClick">
                        <Button.Content>
                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <FontIcon Glyph="&#xE706;" />
                                <TextBlock Text="Appearance" Style="{StaticResource CaptionStyle}" />
                            </StackPanel>
                        </Button.Content>
                    </Button>
                    <Button Padding="12,10" HorizontalContentAlignment="Stretch" Click="OnNotificationsNavClick">
                        <Button.Content>
                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <FontIcon Glyph="&#xE7F4;" />
                                <TextBlock Text="Notifications" Style="{StaticResource CaptionStyle}" />
                            </StackPanel>
                        </Button.Content>
                    </Button>
                    <Button Margin="0,12,0,0" Style="{StaticResource PrimaryButtonStyle}" Content="+ New Part" />
                </StackPanel>
            </Border>

            <StackPanel Grid.Column="1" Spacing="16" MaxWidth="960">
                <StackPanel Spacing="4">
                        <TextBlock Text="Settings / Security" Style="{StaticResource CaptionStyle}" Foreground="{StaticResource TextSecondaryBrush}" />
                        <TextBlock Text="Profile Settings" Style="{StaticResource PageTitleStyle}" />
                    <TextBlock
                            Text="Manage personal information, security, and interface preferences."
                        Foreground="{StaticResource TextSecondaryBrush}"
                        TextWrapping="WrapWholeWords" />
                </StackPanel>

                <Grid ColumnSpacing="16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*" />
                        <ColumnDefinition Width="1.35*" />
                    </Grid.ColumnDefinitions>

                    <Border x:Name="SecuritySectionCard" Grid.Column="0" Style="{StaticResource ElevatedCardStyle}" Padding="20">
                        <StackPanel Spacing="14">
                            <TextBlock Text="Change Password" Style="{StaticResource CardTitleStyle}" />

                            <TextBlock Text="CURRENT PASSWORD" Style="{StaticResource CaptionStyle}" Foreground="{StaticResource TextSecondaryBrush}" />
                            <TextBox
                                PlaceholderText="Enter current password"
                                Text="{Binding ChangeCurrentPassword, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                            <TextBlock Text="NEW PASSWORD" Style="{StaticResource CaptionStyle}" Foreground="{StaticResource TextSecondaryBrush}" />
                            <TextBox
                                PlaceholderText="Enter new password"
                                Text="{Binding ChangeNewPassword, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                            <StackPanel Spacing="6">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="SECURITY STRENGTH" Style="{StaticResource CaptionStyle}" Foreground="{StaticResource TextSecondaryBrush}" />
                                    <TextBlock Grid.Column="1" Text="FAIR" Style="{StaticResource CaptionStyle}" Foreground="{StaticResource WarningBrush}" />
                                </Grid>
                                <Grid ColumnSpacing="6">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.Column="0" Height="3" CornerRadius="3" Background="{StaticResource DangerBrush}" />
                                    <Border Grid.Column="1" Height="3" CornerRadius="3" Background="{StaticResource WarningBrush}" />
                                    <Border Grid.Column="2" Height="3" CornerRadius="3" Background="{StaticResource BorderDefaultBrush}" />
                                </Grid>
                            </StackPanel>

                            <TextBlock Text="CONFIRM PASSWORD" Style="{StaticResource CaptionStyle}" Foreground="{StaticResource TextSecondaryBrush}" />
                            <TextBox
                                PlaceholderText="Repeat new password"
                                Text="{Binding ChangeConfirmPassword, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                            <Grid Margin="0,8,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock
                                    VerticalAlignment="Center"
                                    Text="Last changed 30 days ago"
                                    Foreground="{StaticResource TextSecondaryBrush}" />
                                <Button
                                    Grid.Column="1"
                                    Style="{StaticResource PrimaryButtonStyle}"
                                    Content="Save password"
                                    Command="{Binding ChangePasswordCommand}" />
                            </Grid>
                            <TextBlock Text="{Binding ChangePasswordMessage}" Foreground="{StaticResource TextSecondaryBrush}" TextWrapping="WrapWholeWords" />
                        </StackPanel>
                    </Border>

                    <StackPanel Grid.Column="1" Spacing="16">
                        <Border x:Name="ProfileSectionCard" Style="{StaticResource ElevatedCardStyle}" Padding="16">
                            <StackPanel Spacing="12">
                                <TextBlock Text="ARCHITECTURAL RULES" Style="{StaticResource CaptionStyle}" Foreground="{StaticResource AccentPrimaryBrush}" />
                                <TextBlock
                                    Text="To ensure industrial-grade security, your password must adhere to the following PartFinder precision standards."
                                    Foreground="{StaticResource TextSecondaryBrush}"
                                    TextWrapping="WrapWholeWords" />

                                <Border Style="{StaticResource CardStyle}" Padding="12">
                                    <StackPanel Orientation="Horizontal" Spacing="10">
                                        <TextBlock Text="✔" Foreground="{StaticResource SuccessBrush}" />
                                        <TextBlock Text="Minimum 8 characters long" />
                                    </StackPanel>
                                </Border>
                                <Border Style="{StaticResource CardStyle}" Padding="12">
                                    <StackPanel Orientation="Horizontal" Spacing="10">
                                        <TextBlock Text="✔" Foreground="{StaticResource SuccessBrush}" />
                                        <TextBlock Text="At least one uppercase letter" />
                                    </StackPanel>
                                </Border>
                                <Border Style="{StaticResource CardStyle}" Padding="12">
                                    <StackPanel Orientation="Horizontal" Spacing="10">
                                        <TextBlock Text="✔" Foreground="{StaticResource SuccessBrush}" />
                                        <TextBlock Text="At least one numerical digit" />
                                    </StackPanel>
                                </Border>
                                <Border Style="{StaticResource CardStyle}" Padding="12">
                                    <StackPanel Orientation="Horizontal" Spacing="10">
                                        <TextBlock Text="✖" Foreground="{StaticResource DangerBrush}" />
                                        <TextBlock Text="Includes a special character (@$%+?)" />
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource ElevatedCardStyle}" Padding="16">
                            <StackPanel Spacing="10">
                                <TextBlock Text="Architect's Tip" Style="{StaticResource CardTitleStyle}" />
                                <TextBlock
                                    Text="Use a unique phrase or sequence of words that is easy for you to remember but hard to predict."
                                    Foreground="{StaticResource TextSecondaryBrush}"
                                    TextWrapping="WrapWholeWords" />
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource ElevatedCardStyle}" Padding="16">
                            <StackPanel Spacing="12">
                                <TextBlock Text="Two-Factor Authentication" Style="{StaticResource CardTitleStyle}" />
                                <TextBlock Text="{Binding TwoFactorStatusDetail}" Foreground="{StaticResource TextSecondaryBrush}" />
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <Button Style="{StaticResource OutlinedButtonStyle}" Content="Enable 2FA" Command="{Binding StartTwoFactorSetupCommand}" />
                                    <Button Style="{StaticResource OutlinedButtonStyle}" Content="Disable 2FA" Click="OnDisableTwoFactorClick" />
                                </StackPanel>
                                <TextBox
                                    MaxLength="6"
                                    PlaceholderText="Authenticator code to disable 2FA"
                                    Text="{Binding TwoFactorDisableCode, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                <TextBlock Text="{Binding TwoFactorMessage}" Foreground="{StaticResource TextSecondaryBrush}" TextWrapping="WrapWholeWords" />
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource ElevatedCardStyle}" Padding="16">
                            <StackPanel Spacing="10">
                                <TextBlock Text="Profile" Style="{StaticResource CardTitleStyle}" />
                                <TextBlock
                                    Text="Set display name shown in the top-right profile menu."
                                    Foreground="{StaticResource TextSecondaryBrush}"
                                    TextWrapping="WrapWholeWords" />
                                <TextBox
                                    MaxLength="80"
                                    PlaceholderText="Display name"
                                    Text="{Binding ProfileName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <Button Style="{StaticResource PrimaryButtonStyle}" Content="Save profile" Command="{Binding SaveProfileCommand}" />
                                    <Button Style="{StaticResource OutlinedButtonStyle}" Content="Use email instead" Click="OnUseEmailProfileClick" />
                                </StackPanel>
                                <TextBlock Text="{Binding ProfileMessage}" Foreground="{StaticResource TextSecondaryBrush}" TextWrapping="WrapWholeWords" />
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource ElevatedCardStyle}" Padding="16">
                            <StackPanel Spacing="10">
                                <TextBlock Text="App Lock" Style="{StaticResource CardTitleStyle}" />
                                <TextBlock Text="{Binding PasscodeStatusText}" Foreground="{StaticResource TextSecondaryBrush}" />
                                <Button
                                    Style="{StaticResource OutlinedButtonStyle}"
                                    Content="{Binding PasscodePrimaryActionText}"
                                    Click="OnOpenAppLockEditorClick"
                                    HorizontalAlignment="Left" />

                                <Border
                                    Padding="12"
                                    Background="{StaticResource ElevatedCardBackgroundBrush}"
                                    BorderBrush="{StaticResource BorderDefaultBrush}"
                                    BorderThickness="1"
                                    CornerRadius="8"
                                    Visibility="{Binding ShowAppLockEditor, Converter={StaticResource BoolToVisibilityConverter}}">
                                    <StackPanel Spacing="10">
                                        <StackPanel Visibility="{Binding ShowPasscodeCurrentField, Converter={StaticResource BoolToVisibilityConverter}}">
                                            <TextBlock Text="Current passcode" />
                                            <PasswordBox
                                                x:Name="PasscodeCurrentBox"
                                                MaxLength="6"
                                                PasswordRevealMode="Hidden"
                                                PasswordChanged="OnPasscodeFieldChanged" />
                                        </StackPanel>
                                        <TextBlock Text="New passcode (6 digits)" />
                                        <PasswordBox
                                            x:Name="PasscodeNewBox"
                                            MaxLength="6"
                                            PasswordRevealMode="Hidden"
                                            PasswordChanged="OnPasscodeFieldChanged" />
                                        <TextBlock Text="Confirm new passcode" />
                                        <PasswordBox
                                            x:Name="PasscodeConfirmBox"
                                            MaxLength="6"
                                            PasswordRevealMode="Hidden"
                                            PasswordChanged="OnPasscodeFieldChanged" />
                                        <StackPanel Visibility="{Binding ShowPasscodeRemoveTotpField, Converter={StaticResource BoolToVisibilityConverter}}">
                                            <TextBlock Text="Authenticator code (required to remove passcode while 2FA is enabled)" TextWrapping="Wrap" Foreground="{StaticResource TextSecondaryBrush}" />
                                            <TextBox Text="{Binding PasscodeRemoveTotpCode, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" MaxLength="6" />
                                        </StackPanel>
                                        <TextBlock Text="{Binding PasscodeMessage}" Foreground="{StaticResource TextSecondaryBrush}" TextWrapping="WrapWholeWords" />
                                        <StackPanel Orientation="Horizontal" Spacing="10">
                                            <Button Style="{StaticResource PrimaryButtonStyle}" Content="{Binding PasscodePrimaryActionText}" Click="OnSavePasscodeClick" />
                                            <Button
                                                Style="{StaticResource OutlinedButtonStyle}"
                                                Content="Remove passcode"
                                                Click="OnRemovePasscodeClick"
                                                Visibility="{Binding ShowPasscodeRemoveAction, Converter={StaticResource BoolToVisibilityConverter}}" />
                                            <Button Style="{StaticResource OutlinedButtonStyle}" Content="Cancel" Click="OnCloseAppLockEditorClick" />
                                        </StackPanel>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource ElevatedCardStyle}" Padding="16">
                            <StackPanel Spacing="12">
                                <TextBlock Text="Recovery" Style="{StaticResource CardTitleStyle}" />
                                <Expander Header="Recover app passcode (with authenticator)">
                                    <StackPanel Spacing="8" Margin="0,10,0,0">
                                        <TextBlock Text="Authenticator code" />
                                        <TextBox Text="{Binding ResetPasscodeTotp, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" MaxLength="6" />
                                        <TextBlock Text="New passcode" />
                                        <TextBox Text="{Binding ResetPasscodeNew, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" MaxLength="6" />
                                        <TextBlock Text="Confirm new passcode" />
                                        <TextBox Text="{Binding ResetPasscodeConfirm, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" MaxLength="6" />
                                        <Button Style="{StaticResource OutlinedButtonStyle}" Content="Reset passcode" Command="{Binding ResetPasscodeWithTwoFactorCommand}" HorizontalAlignment="Left" />
                                        <TextBlock Text="{Binding PasscodeRecoveryMessage}" Foreground="{StaticResource TextSecondaryBrush}" TextWrapping="WrapWholeWords" />
                                    </StackPanel>
                                </Expander>
                            </StackPanel>
                        </Border>

                        <Border x:Name="AppearanceSectionCard" Style="{StaticResource ElevatedCardStyle}" Padding="16">
                            <StackPanel Spacing="10">
                                <TextBlock Text="Appearance" Style="{StaticResource CardTitleStyle}" />
                                <TextBlock
                                    Text="Choose application theme behavior."
                                    Foreground="{StaticResource TextSecondaryBrush}"
                                    TextWrapping="WrapWholeWords" />
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <Button Style="{StaticResource OutlinedButtonStyle}" Content="System" Click="OnThemeSystemClick" />
                                    <Button Style="{StaticResource OutlinedButtonStyle}" Content="Light" Click="OnThemeLightClick" />
                                    <Button Style="{StaticResource OutlinedButtonStyle}" Content="Dark" Click="OnThemeDarkClick" />
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <Border x:Name="NotificationsSectionCard" Style="{StaticResource ElevatedCardStyle}" Padding="16">
                            <StackPanel Spacing="10">
                                <TextBlock Text="Notifications" Style="{StaticResource CardTitleStyle}" />
                                <TextBlock
                                    Text="Manage local app notification preferences."
                                    Foreground="{StaticResource TextSecondaryBrush}"
                                    TextWrapping="WrapWholeWords" />
                                <ToggleSwitch Header="Security alerts" IsOn="True" />
                                <ToggleSwitch Header="Product updates" IsOn="False" />
                                <ToggleSwitch Header="Sync status" IsOn="True" />
                            </StackPanel>
                        </Border>

                        <Grid ColumnSpacing="10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" Style="{StaticResource CardStyle}" Padding="12">
                                <StackPanel>
                                    <TextBlock Text="Last Login" Style="{StaticResource CaptionStyle}" />
                                    <TextBlock Text="2 hours ago" />
                                </StackPanel>
                            </Border>
                            <Border Grid.Column="1" Style="{StaticResource CardStyle}" Padding="12">
                                <StackPanel>
                                    <TextBlock Text="Session ID" Style="{StaticResource CaptionStyle}" />
                                    <TextBlock Text="PF-882" />
                                </StackPanel>
                            </Border>
                            <Border Grid.Column="2" Style="{StaticResource CardStyle}" Padding="12">
                                <StackPanel>
                                    <TextBlock Text="Parts Managed" Style="{StaticResource CaptionStyle}" />
                                    <TextBlock Text="1,402" />
                                </StackPanel>
                            </Border>
                            <Border Grid.Column="3" Style="{StaticResource CardStyle}" Padding="12">
                                <StackPanel>
                                    <TextBlock Text="Active Status" Style="{StaticResource CaptionStyle}" />
                                    <TextBlock Text="Online" />
                                </StackPanel>
                            </Border>
                        </Grid>
                    </StackPanel>
                </Grid>
            </StackPanel>
        </Grid>
    </ScrollViewer>
</Page>
