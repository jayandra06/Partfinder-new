<Page
    x:Class="PartFinder.Views.Pages.PartsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:components="using:PartFinder.Views.Components">
    <StackPanel Padding="20" Spacing="12">
        <components:PageHeader Title="Parts Explorer" Subtitle="Browse template rows. Right-click any cell or use row actions (...) to open linked views like suppliers/prices/delivery.">
            <components:PageHeader.Actions>
                <Button Content="Refresh" Command="{Binding RefreshCommand}" />
            </components:PageHeader.Actions>
        </components:PageHeader>

        <Grid ColumnSpacing="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="300" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <ComboBox
                ItemsSource="{Binding Templates}"
                SelectedItem="{Binding SelectedTemplate, Mode=TwoWay}"
                DisplayMemberPath="Name"
                PlaceholderText="Select template" />
            <Button
                Grid.Column="1"
                HorizontalAlignment="Left"
                Content="Load More"
                Command="{Binding LoadMoreCommand}" />
        </Grid>

        <Border Style="{ThemeResource AppCardBorderStyle}">
            <StackPanel Spacing="8">
                <TextBlock Text="Column Search" Style="{ThemeResource AppSectionTextStyle}" />
                <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
                    <StackPanel x:Name="ColumnFiltersPanel" Orientation="Horizontal" Spacing="8" />
                </ScrollViewer>
            </StackPanel>
        </Border>

        <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto" MinHeight="420">
            <StackPanel>
                <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled" Margin="0,0,0,8">
                    <StackPanel x:Name="ColumnsHeaderPanel" Orientation="Horizontal" Spacing="0" />
                </ScrollViewer>
                <ListView
                    x:Name="PartsListView"
                    ItemsSource="{Binding FilteredRecords}"
                    ContainerContentChanging="OnContainerContentChanging">
                    <ListView.ItemsPanel>
                        <ItemsPanelTemplate>
                            <ItemsStackPanel />
                        </ItemsPanelTemplate>
                    </ListView.ItemsPanel>
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <Grid />
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
                <StackPanel Margin="0,8,0,0" Orientation="Horizontal" Spacing="8">
                    <ProgressRing Width="16" Height="16" IsActive="{Binding IsLoading}" />
                    <TextBlock Foreground="{ThemeResource AppSubtleTextBrush}" Text="Tip: use right-click on a cell or the ... button at row end for actions." />
                </StackPanel>
            </StackPanel>
        </ScrollViewer>
    </StackPanel>
</Page>
