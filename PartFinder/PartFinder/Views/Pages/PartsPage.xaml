<Page
    x:Class="PartFinder.Views.Pages.PartsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:components="using:PartFinder.Views.Components">
    <StackPanel Padding="20" Spacing="12">
        <components:PageHeader Title="Parts" Subtitle="Template-driven dynamic table with async incremental loading">
            <components:PageHeader.Actions>
                <Button Content="Refresh" Command="{Binding RefreshCommand}" />
            </components:PageHeader.Actions>
        </components:PageHeader>

        <Grid ColumnSpacing="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="300" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <ComboBox
                ItemsSource="{Binding Templates}"
                SelectedItem="{Binding SelectedTemplate, Mode=TwoWay}"
                DisplayMemberPath="Name"
                PlaceholderText="Select template" />
            <Button
                Grid.Column="1"
                HorizontalAlignment="Left"
                Content="Load More"
                Command="{Binding LoadMoreCommand}" />
        </Grid>

        <components:FilterBuilderControl />

        <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto" MinHeight="420">
            <StackPanel>
                <ItemsControl x:Name="ColumnsHeader" Margin="0,0,0,8" />
                <ListView
                    x:Name="PartsListView"
                    ItemsSource="{Binding Records}"
                    ContainerContentChanging="OnContainerContentChanging">
                    <ListView.ItemsPanel>
                        <ItemsPanelTemplate>
                            <ItemsStackPanel />
                        </ItemsPanelTemplate>
                    </ListView.ItemsPanel>
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <ItemsControl Loaded="OnRowLoaded" />
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
                <StackPanel Margin="0,8,0,0" Orientation="Horizontal" Spacing="8">
                    <ProgressRing Width="16" Height="16" IsActive="{Binding IsLoading}" />
                    <TextBlock Foreground="{ThemeResource AppSubtleTextBrush}" Text="Infinite loading active for large datasets." />
                </StackPanel>
            </StackPanel>
        </ScrollViewer>
    </StackPanel>
</Page>
