<Page
    x:Class="PartFinder.Views.Pages.PartsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:components="using:PartFinder.Views.Components">
    <Page.Resources>
        <Style x:Key="ExplorerListItemStyle" TargetType="ListViewItem">
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="UseSystemFocusVisuals" Value="False" />
            <Setter Property="CornerRadius" Value="0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListViewItem">
                        <Grid>
                            <VisualStateManager.VisualStateGroups>
                                <VisualStateGroup x:Name="CommonStates">
                                    <VisualState x:Name="Normal" />
                                    <VisualState x:Name="PointerOver">
                                        <Storyboard>
                                            <ObjectAnimationUsingKeyFrames Storyboard.TargetName="RootBorder" Storyboard.TargetProperty="Background">
                                                <DiscreteObjectKeyFrame KeyTime="0" Value="{StaticResource RowHoverBackgroundBrush}" />
                                            </ObjectAnimationUsingKeyFrames>
                                        </Storyboard>
                                    </VisualState>
                                </VisualStateGroup>
                                <VisualStateGroup x:Name="SelectionStates">
                                    <VisualState x:Name="Unselected">
                                        <Storyboard>
                                            <ObjectAnimationUsingKeyFrames Storyboard.TargetName="SelectionBar" Storyboard.TargetProperty="Visibility">
                                                <DiscreteObjectKeyFrame KeyTime="0" Value="Collapsed" />
                                            </ObjectAnimationUsingKeyFrames>
                                        </Storyboard>
                                    </VisualState>
                                    <VisualState x:Name="Selected">
                                        <Storyboard>
                                            <ObjectAnimationUsingKeyFrames Storyboard.TargetName="RootBorder" Storyboard.TargetProperty="Background">
                                                <DiscreteObjectKeyFrame KeyTime="0" Value="{StaticResource RowSelectedBackgroundBrush}" />
                                            </ObjectAnimationUsingKeyFrames>
                                            <ObjectAnimationUsingKeyFrames Storyboard.TargetName="SelectionBar" Storyboard.TargetProperty="Visibility">
                                                <DiscreteObjectKeyFrame KeyTime="0" Value="Visible" />
                                            </ObjectAnimationUsingKeyFrames>
                                        </Storyboard>
                                    </VisualState>
                                </VisualStateGroup>
                            </VisualStateManager.VisualStateGroups>
                            <Border
                                x:Name="SelectionBar"
                                Width="2"
                                HorizontalAlignment="Left"
                                Background="{StaticResource RowSelectedBorderBrush}"
                                Visibility="Collapsed" />
                            <Border
                                x:Name="RootBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{StaticResource BorderDefaultBrush}"
                                BorderThickness="0,0,0,1"
                                Padding="{TemplateBinding Padding}">
                                <ContentPresenter />
                            </Border>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Page.Resources>
    <Grid Background="{StaticResource PageBackgroundBrush}">
        <StackPanel Padding="20" Spacing="12">
            <components:PageHeader Title="Explorer" Subtitle="Browse template rows. Right-click any cell or use row actions (...) to open linked views like suppliers/prices/delivery.">
            <components:PageHeader.Actions>
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <Button Style="{StaticResource OutlinedButtonStyle}" Content="Refresh" Command="{Binding RefreshCommand}" />
                </StackPanel>
            </components:PageHeader.Actions>
            </components:PageHeader>

            <Grid ColumnSpacing="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="300" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <ComboBox
                Style="{StaticResource StandardTextBoxStyle}"
                ItemsSource="{Binding Templates}"
                SelectedItem="{Binding SelectedTemplate, Mode=TwoWay}"
                DisplayMemberPath="Name"
                PlaceholderText="Select template" />
            <Button
                Grid.Column="1"
                HorizontalAlignment="Left"
                Content="Load More"
                Visibility="Collapsed"
                Command="{Binding LoadMoreCommand}" />
            </Grid>

            <Border Style="{StaticResource CardStyle}">
            <StackPanel Spacing="8">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <Button Style="{StaticResource OutlinedButtonStyle}" Content="Clear all filters" Command="{Binding ClearAllFiltersCommand}" />
                    <TextBlock VerticalAlignment="Center" Foreground="{StaticResource TextSecondaryBrush}">
                        <Run Text="Showing " />
                        <Run Text="{Binding FilteredRecordsCount}" />
                        <Run Text=" rows" />
                    </TextBlock>
                    <TextBlock VerticalAlignment="Center" Foreground="{StaticResource TextSecondaryBrush}">
                        <Run Text="of " />
                        <Run Text="{Binding TotalRecordsCount}" />
                        <Run Text=" loaded" />
                    </TextBlock>
                </StackPanel>
                <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
                    <StackPanel x:Name="ColumnFiltersPanel" Orientation="Horizontal" Spacing="0" />
                </ScrollViewer>
            </StackPanel>
            </Border>

            <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto" MinHeight="420">
                <StackPanel>
                    <ListView
                        x:Name="PartsListView"
                        ItemContainerStyle="{StaticResource ExplorerListItemStyle}"
                        ItemsSource="{Binding FilteredRecords}"
                        SelectionChanged="OnPartsSelectionChanged"
                        ContainerContentChanging="OnContainerContentChanging">
                        <ListView.ItemsPanel>
                            <ItemsPanelTemplate>
                                <ItemsStackPanel />
                            </ItemsPanelTemplate>
                        </ListView.ItemsPanel>
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Grid />
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                    <StackPanel Margin="0,8,0,0" Orientation="Horizontal" Spacing="8" Visibility="Collapsed">
                        <ProgressRing Width="16" Height="16" IsActive="{Binding IsLoading}" />
                        <TextBlock Foreground="{ThemeResource AppSubtleTextBrush}" Text="Tip: use right-click on a cell or the ... button at row end for actions." />
                    </StackPanel>

                    <Border
                        Margin="0,10,0,0"
                        Padding="10"
                        BorderThickness="1"
                        BorderBrush="{ThemeResource AppBorderBrush}"
                        Visibility="Collapsed">
                        <StackPanel Spacing="8">
                            <TextBlock Text="Actions" Style="{ThemeResource AppSectionTextStyle}" />
                            <StackPanel x:Name="RowActionsPanel" Orientation="Horizontal" Spacing="8" />
                            <TextBlock
                                x:Name="RowActionsHintText"
                                Foreground="{ThemeResource AppSubtleTextBrush}"
                                Text="Select a row to see available actions." />
                            <Button
                                x:Name="ClearSelectedRowButton"
                                HorizontalAlignment="Left"
                                Content="Clear selected row"
                                Visibility="Collapsed"
                                Click="OnClearSelectedRowClick" />
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>
        </StackPanel>

        <Border
            x:Name="ActionResultsOverlay"
            Background="#66000000"
            Visibility="Collapsed"
            Tapped="OnActionOverlayTapped" />

        <Border
            x:Name="ActionResultsPanel"
            Width="320"
            HorizontalAlignment="Right"
            VerticalAlignment="Stretch"
            Background="{ThemeResource AppSurfaceBrush}"
            BorderBrush="{ThemeResource AppBorderBrush}"
            BorderThickness="1,0,0,0"
            Visibility="Collapsed">
            <Border.RenderTransform>
                <TranslateTransform x:Name="ActionResultsTransform" X="320" />
            </Border.RenderTransform>
            <Grid RowSpacing="8" Padding="14">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <StackPanel Spacing="4">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock x:Name="ActionTitleText" Text="Details" Style="{ThemeResource AppSectionTextStyle}" />
                        <Button Grid.Column="1" Content="Close" Click="OnCloseActionPanelClick" />
                    </Grid>
                    <TextBlock x:Name="ActionCountText" Foreground="{ThemeResource AppSubtleTextBrush}" />
                </StackPanel>

                <ListView x:Name="ActionRowsListView" Grid.Row="1">
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Spacing="4" Margin="0,4,0,8">
                                <TextBlock Text="{Binding Title}" FontWeight="SemiBold" />
                                <ItemsControl ItemsSource="{Binding Lines}" />
                            </StackPanel>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </Grid>
        </Border>
    </Grid>
</Page>
