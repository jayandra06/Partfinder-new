<Page
    x:Class="PartFinder.Views.Pages.WorksheetRelationsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:components="using:PartFinder.Views.Components"
    xmlns:converters="using:PartFinder.Converters"
    xmlns:viewmodels="using:PartFinder.ViewModels">

    <Page.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter" />

        <!-- ═══════════════════════════════════════════════════════════════
             PAGE ENTRANCE  — fade + slide up (macOS-style, 300ms)
        ════════════════════════════════════════════════════════════════ -->
        <Storyboard x:Name="PageEntranceStoryboard">
            <DoubleAnimation
                Storyboard.TargetName="PageRoot"
                Storyboard.TargetProperty="Opacity"
                From="0" To="1" Duration="0:0:0.30">
                <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation
                Storyboard.TargetName="PageSlideTransform"
                Storyboard.TargetProperty="Y"
                From="14" To="0" Duration="0:0:0.30">
                <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>

        <!-- ═══════════════════════════════════════════════════════════════
             CONNECTOR PULSE  — subtle scale loop (2 s, macOS-style)
        ════════════════════════════════════════════════════════════════ -->
        <Storyboard x:Name="ConnectorPulseStoryboard" RepeatBehavior="Forever" AutoReverse="True">
            <DoubleAnimation
                Storyboard.TargetName="ConnectorTransform"
                Storyboard.TargetProperty="ScaleX"
                From="1.0" To="1.08" Duration="0:0:1.0">
                <DoubleAnimation.EasingFunction><SineEase EasingMode="EaseInOut"/></DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation
                Storyboard.TargetName="ConnectorTransform"
                Storyboard.TargetProperty="ScaleY"
                From="1.0" To="1.08" Duration="0:0:1.0">
                <DoubleAnimation.EasingFunction><SineEase EasingMode="EaseInOut"/></DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>

        <!-- ═══════════════════════════════════════════════════════════════
             CHIP STRIP FADE IN
        ════════════════════════════════════════════════════════════════ -->
        <Storyboard x:Name="ChipStripFadeStoryboard">
            <DoubleAnimation
                Storyboard.TargetName="ChipStrip"
                Storyboard.TargetProperty="Opacity"
                From="0" To="1" Duration="0:0:0.20">
                <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>

        <!-- ═══════════════════════════════════════════════════════════════
             COLUMN ROW ITEM STYLE  — hover state
        ════════════════════════════════════════════════════════════════ -->
        <Style x:Key="ColumnRowBorderStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource GridRowAltBackgroundBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource GlassStrokeBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="14" />
            <Setter Property="Padding" Value="12,0" />
            <Setter Property="MinHeight" Value="44" />
            <Setter Property="Margin" Value="0,0,0,4" />
        </Style>

        <!-- Badge styles -->
        <Style x:Key="KeyBadgeStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource AccentPrimaryBrush}" />
            <Setter Property="CornerRadius" Value="10" />
            <Setter Property="Padding" Value="7,3" />
            <Setter Property="Margin" Value="4,0,0,0" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <Style x:Key="DisplayBadgeStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource SuccessBrush}" />
            <Setter Property="CornerRadius" Value="10" />
            <Setter Property="Padding" Value="7,3" />
            <Setter Property="Margin" Value="4,0,0,0" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <Style x:Key="BadgeLabelStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="White" />
            <Setter Property="FontSize" Value="9" />
            <Setter Property="CharacterSpacing" Value="60" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <!-- Chip button style for relations strip -->
        <Style x:Key="RelationChipStyle" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource CardBackgroundBrush}" />
            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource GlassStrokeBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="20" />
            <Setter Property="Padding" Value="14,6" />
            <Setter Property="MinHeight" Value="32" />
            <Setter Property="FontSize" Value="12" />
        </Style>

        <Style x:Key="RelationChipActiveStyle" TargetType="Button" BasedOn="{StaticResource RelationChipStyle}">
            <Setter Property="BorderBrush" Value="{StaticResource AccentPrimaryBrush}" />
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
        </Style>
    </Page.Resources>

    <!-- ═══════════════════════════════════════════════════════════════════
         PAGE ROOT  — opacity + translate for entrance animation
    ════════════════════════════════════════════════════════════════════ -->
    <Grid
        x:Name="PageRoot"
        Opacity="0"
        Padding="24"
        RowSpacing="14"
        Background="Transparent"
        Transitions="{StaticResource LuxuryPanelTransitions}">
        <Grid.RenderTransform>
            <TranslateTransform x:Name="PageSlideTransform" Y="14" />
        </Grid.RenderTransform>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- ═══════════════════════════════════════════════════════════════
             ROW 0 — HEADER
        ════════════════════════════════════════════════════════════════ -->
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel Spacing="3">
                <TextBlock
                    Text="LINK TEMPLATES"
                    FontSize="10"
                    Foreground="{StaticResource AccentPrimaryBrush}"
                    CharacterSpacing="120"
                    FontWeight="SemiBold" />
                <TextBlock
                    Text="Template Relationships"
                    FontSize="22"
                    FontWeight="SemiBold"
                    Foreground="{StaticResource TextPrimaryBrush}" />
                <TextBlock
                    Text="Connect columns between templates to enable cross-template lookups and data enrichment in your inventory explorer."
                    FontSize="12"
                    Foreground="{StaticResource TextSecondaryBrush}"
                    TextWrapping="WrapWholeWords" />
            </StackPanel>

            <!-- Saved relations count badge (NEW) -->
            <Border
                Grid.Column="1"
                VerticalAlignment="Top"
                Visibility="{Binding HasRelations, Converter={StaticResource BoolToVisibilityConverter}}"
                Background="{StaticResource NavItemSelectedBrush}"
                BorderBrush="{StaticResource AccentPrimaryBrush}"
                BorderThickness="1"
                CornerRadius="12"
                Padding="10,4">
                <StackPanel Orientation="Horizontal" Spacing="5">
                    <FontIcon Glyph="&#xE71B;" FontSize="11" Foreground="{StaticResource AccentPrimaryBrush}" VerticalAlignment="Center" />
                    <TextBlock
                        FontSize="11"
                        FontWeight="SemiBold"
                        Foreground="{StaticResource AccentPrimaryBrush}"
                        VerticalAlignment="Center">
                        <Run Text="{Binding RelationCount}" /><Run Text=" saved" />
                    </TextBlock>
                </StackPanel>
            </Border>
        </Grid>

        <!-- ═══════════════════════════════════════════════════════════════
             ROW 1 — RELATIONS CHIP STRIP (NEW)
             Horizontal scrollable list of saved relations
        ════════════════════════════════════════════════════════════════ -->
        <Border
            x:Name="ChipStrip"
            Grid.Row="1"
            Opacity="0"
            Visibility="{Binding HasRelations, Converter={StaticResource BoolToVisibilityConverter}}"
            Background="{StaticResource CardBackgroundBrush}"
            BorderBrush="{StaticResource BorderDefaultBrush}"
            BorderThickness="1"
            CornerRadius="10"
            Padding="12,10"
            Translation="0,0,16">
            <Border.Shadow><ThemeShadow/></Border.Shadow>
            <StackPanel Spacing="10">
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <FontIcon Glyph="&#xE8FD;" FontSize="11" Foreground="{StaticResource TextTertiaryBrush}" VerticalAlignment="Center" />
                    <TextBlock
                        Text="SAVED RELATIONS"
                        FontSize="9"
                        CharacterSpacing="80"
                        FontWeight="SemiBold"
                        Foreground="{StaticResource TextTertiaryBrush}"
                        VerticalAlignment="Center" />
                    <TextBlock
                        Text="— click to load"
                        FontSize="9"
                        Foreground="{StaticResource TextTertiaryBrush}"
                        VerticalAlignment="Center" />
                </StackPanel>
                <ScrollViewer
                    HorizontalScrollMode="Auto"
                    HorizontalScrollBarVisibility="Hidden"
                    VerticalScrollMode="Disabled"
                    VerticalScrollBarVisibility="Disabled">
                    <ItemsControl ItemsSource="{Binding RelationChips}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Horizontal" Spacing="8" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="viewmodels:RelationChipItem">
                                <Button
                                    Content="{Binding Label}"
                                    Style="{StaticResource RelationChipStyle}"
                                    Command="{Binding ElementName=PageRoot, Path=DataContext.SelectRelationCommand}"
                                    CommandParameter="{Binding}" />
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </StackPanel>
        </Border>

        <!-- ═══════════════════════════════════════════════════════════════
             ROW 2 — TWO-PANEL LINKER
        ════════════════════════════════════════════════════════════════ -->
        <Grid Grid.Row="2" ColumnSpacing="14">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- ── PRIMARY TEMPLATE CARD ─────────────────────────────── -->
            <Border
                Background="{StaticResource ElevatedCardBackgroundBrush}"
                BorderBrush="{StaticResource BorderDefaultBrush}"
                BorderThickness="1"
                CornerRadius="10"
                Padding="20"
                Translation="0,0,32">
                <Border.Shadow><ThemeShadow/></Border.Shadow>
                <StackPanel Spacing="12">

                    <!-- Card header -->
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Border
                            Width="28" Height="28"
                            CornerRadius="8"
                            Background="{StaticResource NavItemSelectedBrush}">
                            <FontIcon
                                Glyph="&#xE80A;"
                                FontSize="13"
                                Foreground="{StaticResource AccentPrimaryBrush}"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center" />
                        </Border>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock
                                Text="Primary Template"
                                FontSize="13"
                                FontWeight="SemiBold"
                                Foreground="{StaticResource TextPrimaryBrush}" />
                            <TextBlock
                                Text="Source of match keys"
                                FontSize="10"
                                Foreground="{StaticResource TextTertiaryBrush}" />
                        </StackPanel>
                    </StackPanel>

                    <!-- Divider -->
                    <Border Height="1" Background="{StaticResource BorderDefaultBrush}" />

                    <!-- Template selector -->
                    <ComboBox
                        HorizontalAlignment="Stretch"
                        FontSize="13"
                        MinHeight="40"
                        DisplayMemberPath="Name"
                        ItemsSource="{Binding Templates}"
                        SelectedItem="{Binding PrimaryTemplate, Mode=TwoWay}" />

                    <!-- KEY indicator hint -->
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <Border Width="8" Height="8" CornerRadius="4" Background="{StaticResource AccentPrimaryBrush}" VerticalAlignment="Center" />
                        <TextBlock
                            Text="Check columns to use as match keys"
                            FontSize="10"
                            Foreground="{StaticResource TextTertiaryBrush}"
                            VerticalAlignment="Center" />
                    </StackPanel>

                    <!-- Column list -->
                    <ScrollViewer
                        MaxHeight="300"
                        VerticalScrollMode="Auto"
                        VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                            <!-- Empty state -->
                            <StackPanel
                                Spacing="6"
                                HorizontalAlignment="Center"
                                Margin="0,24"
                                Visibility="{Binding DataContext.HasNoPrimaryColumns, ElementName=PageRoot, Converter={StaticResource BoolToVisibilityConverter}}">
                                <FontIcon Glyph="&#xE8D2;" FontSize="28" Foreground="{StaticResource TextTertiaryBrush}" HorizontalAlignment="Center" />
                                <TextBlock
                                    Text="No columns"
                                    FontSize="12"
                                    Foreground="{StaticResource TextTertiaryBrush}"
                                    HorizontalAlignment="Center" />
                            </StackPanel>

                            <ItemsControl ItemsSource="{Binding PrimaryColumns}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Style="{StaticResource ColumnRowBorderStyle}">
                                            <Grid MinHeight="44">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <CheckBox
                                                    IsChecked="{Binding IsChecked, Mode=TwoWay}"
                                                    VerticalAlignment="Center"
                                                    MinWidth="0"
                                                    Margin="0,0,4,0" />
                                                <TextBlock
                                                    Grid.Column="1"
                                                    Text="{Binding ColumnName}"
                                                    VerticalAlignment="Center"
                                                    FontSize="13"
                                                    Foreground="{StaticResource TextPrimaryBrush}" />
                                                <Border Grid.Column="2" Style="{StaticResource KeyBadgeStyle}">
                                                    <TextBlock Text="KEY" Style="{StaticResource BadgeLabelStyle}" />
                                                </Border>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </ScrollViewer>
                </StackPanel>
            </Border>

            <!-- ── CENTER CONNECTOR ──────────────────────────────────── -->
            <StackPanel
                Grid.Column="1"
                VerticalAlignment="Center"
                Spacing="8"
                HorizontalAlignment="Center">
                <Border
                    Width="44" Height="44"
                    CornerRadius="22"
                    Background="{StaticResource AccentPrimaryBrush}"
                    RenderTransformOrigin="0.5,0.5"
                    Translation="0,0,8">
                    <Border.Shadow><ThemeShadow/></Border.Shadow>
                    <Border.RenderTransform>
                        <CompositeTransform
                            x:Name="ConnectorTransform"
                            ScaleX="1.0"
                            ScaleY="1.0" />
                    </Border.RenderTransform>
                    <FontIcon Glyph="&#xE72A;" FontSize="17" Foreground="White" />
                </Border>
                <TextBlock
                    Text="MATCH"
                    FontSize="9"
                    HorizontalAlignment="Center"
                    Foreground="{StaticResource TextTertiaryBrush}"
                    CharacterSpacing="80"
                    FontWeight="SemiBold" />
            </StackPanel>

            <!-- ── LOOKUP TEMPLATE CARD ──────────────────────────────── -->
            <Border
                Grid.Column="2"
                Background="{StaticResource ElevatedCardBackgroundBrush}"
                BorderBrush="{StaticResource BorderDefaultBrush}"
                BorderThickness="1"
                CornerRadius="10"
                Padding="20"
                Translation="0,0,32">
                <Border.Shadow><ThemeShadow/></Border.Shadow>
                <StackPanel Spacing="12">

                    <!-- Card header -->
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Border
                            Width="28" Height="28"
                            CornerRadius="8"
                            Background="#1A2B3A">
                            <FontIcon
                                Glyph="&#xE721;"
                                FontSize="13"
                                Foreground="{StaticResource SuccessBrush}"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center" />
                        </Border>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock
                                Text="Lookup Template"
                                FontSize="13"
                                FontWeight="SemiBold"
                                Foreground="{StaticResource TextPrimaryBrush}" />
                            <TextBlock
                                Text="Columns to display"
                                FontSize="10"
                                Foreground="{StaticResource TextTertiaryBrush}" />
                        </StackPanel>
                    </StackPanel>

                    <!-- Divider -->
                    <Border Height="1" Background="{StaticResource BorderDefaultBrush}" />

                    <!-- Template selector -->
                    <ComboBox
                        HorizontalAlignment="Stretch"
                        FontSize="13"
                        MinHeight="40"
                        DisplayMemberPath="Name"
                        ItemsSource="{Binding Templates}"
                        SelectedItem="{Binding LookupTemplate, Mode=TwoWay}" />

                    <!-- DISPLAY indicator hint -->
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <Border Width="8" Height="8" CornerRadius="4" Background="{StaticResource SuccessBrush}" VerticalAlignment="Center" />
                        <TextBlock
                            Text="Check columns to show in results"
                            FontSize="10"
                            Foreground="{StaticResource TextTertiaryBrush}"
                            VerticalAlignment="Center" />
                    </StackPanel>

                    <!-- Column list -->
                    <ScrollViewer
                        MaxHeight="300"
                        VerticalScrollMode="Auto"
                        VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                            <!-- Empty state -->
                            <StackPanel
                                Spacing="6"
                                HorizontalAlignment="Center"
                                Margin="0,24"
                                Visibility="{Binding DataContext.HasNoLookupColumns, ElementName=PageRoot, Converter={StaticResource BoolToVisibilityConverter}}">
                                <FontIcon Glyph="&#xE8D2;" FontSize="28" Foreground="{StaticResource TextTertiaryBrush}" HorizontalAlignment="Center" />
                                <TextBlock
                                    Text="No columns"
                                    FontSize="12"
                                    Foreground="{StaticResource TextTertiaryBrush}"
                                    HorizontalAlignment="Center" />
                            </StackPanel>

                            <ItemsControl ItemsSource="{Binding LookupColumns}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Style="{StaticResource ColumnRowBorderStyle}">
                                            <Grid MinHeight="44">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <CheckBox
                                                    IsChecked="{Binding IsChecked, Mode=TwoWay}"
                                                    IsEnabled="{Binding IsSelectable}"
                                                    VerticalAlignment="Center"
                                                    MinWidth="0"
                                                    Margin="0,0,4,0" />
                                                <TextBlock
                                                    Grid.Column="1"
                                                    Text="{Binding ColumnName}"
                                                    VerticalAlignment="Center"
                                                    FontSize="13"
                                                    Foreground="{StaticResource TextPrimaryBrush}" />
                                                <Border
                                                    Grid.Column="2"
                                                    Style="{StaticResource DisplayBadgeStyle}">
                                                    <TextBlock Text="DISPLAY" Style="{StaticResource BadgeLabelStyle}" />
                                                </Border>
                                                <Border
                                                    Grid.Column="3"
                                                    Style="{StaticResource KeyBadgeStyle}"
                                                    Visibility="{Binding IsAutoMatchKey, Converter={StaticResource BoolToVisibilityConverter}}">
                                                    <TextBlock Text="KEY" Style="{StaticResource BadgeLabelStyle}" />
                                                </Border>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </ScrollViewer>
                </StackPanel>
            </Border>
        </Grid>

        <!-- ROW 3 — legend removed, moved into card footers below -->

        <!-- ═══════════════════════════════════════════════════════════════
             ROW 3 — ACTION BAR
        ════════════════════════════════════════════════════════════════ -->
        <Border
            Grid.Row="3"
            Background="{StaticResource CardBackgroundBrush}"
            BorderBrush="{StaticResource BorderDefaultBrush}"
            BorderThickness="1"
            CornerRadius="8"
            Padding="14,10"
            Translation="0,0,16">
            <Border.Shadow><ThemeShadow/></Border.Shadow>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!-- Status / error messages -->
                <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                    <ProgressRing
                        Width="16" Height="16"
                        IsActive="{Binding IsLoading}"
                        Foreground="{StaticResource AccentPrimaryBrush}" />
                    <TextBlock
                        Text="{Binding StatusMessage}"
                        FontSize="12"
                        Foreground="{StaticResource SuccessBrush}"
                        VerticalAlignment="Center" />
                    <TextBlock
                        Text="{Binding ErrorMessage}"
                        FontSize="12"
                        Foreground="{StaticResource DangerBrush}"
                        VerticalAlignment="Center"
                        TextWrapping="WrapWholeWords" />
                </StackPanel>

                <!-- Action buttons -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
                    <!-- Delete button — only visible when a relation is loaded (NEW) -->
                    <Button
                        Style="{StaticResource DangerOutlinedButtonStyle}"
                        Content="Delete"
                        FontSize="12"
                        MinHeight="40"
                        Padding="16,8"
                        Visibility="{Binding HasLoadedRelation, Converter={StaticResource BoolToVisibilityConverter}}"
                        Command="{Binding DeleteCommand}" />

                    <Button
                        Style="{StaticResource GhostButtonStyle}"
                        Content="Reset"
                        FontSize="12"
                        MinHeight="40"
                        Padding="16,8"
                        Command="{Binding ResetCommand}" />

                    <Button
                        Style="{StaticResource PrimaryButtonStyle}"
                        Content="Save Link"
                        FontSize="12"
                        MinHeight="40"
                        MinWidth="120"
                        Padding="16,8"
                        Command="{Binding SaveCommand}" />
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Page>
