ÔĽŅ<Page
    x:Class="PartFinder.Views.Pages.InventoryPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:components="using:PartFinder.Views.Components"
    xmlns:converters="using:PartFinder.Converters"
    xmlns:viewmodels="using:PartFinder.ViewModels">
    <Page.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter" />
    </Page.Resources>

    <Grid Background="{StaticResource PageBackgroundBrush}">
        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <StackPanel Padding="24,20,24,32" Spacing="18" HorizontalAlignment="Stretch">
                <StackPanel.ChildrenTransitions>
                    <TransitionCollection>
                        <EntranceThemeTransition IsStaggeringEnabled="True" FromVerticalOffset="50" />
                    </TransitionCollection>
                </StackPanel.ChildrenTransitions>

                <!-- √Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź -->
                <!-- HEADER                                     -->
                <!-- √Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź -->
                <Grid ColumnSpacing="12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Spacing="2">
                        <TextBlock Text="INVENTORY" FontSize="10" Foreground="{StaticResource AccentPrimaryBrush}" CharacterSpacing="100" FontWeight="SemiBold" />
                        <TextBlock Text="Inventory Management" FontSize="32" FontWeight="Light" CharacterSpacing="20" />
                        <TextBlock Text="Track stock levels, monitor part availability, and manage inventory across your organization." FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" />
                    </StackPanel>
                    <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                        <Button Style="{StaticResource OutlinedButtonStyle}" FontSize="12">
                            <StackPanel Orientation="Horizontal" Spacing="5">
                                <FontIcon Glyph="&#xE74E;" FontSize="13" />
                                <TextBlock Text="Export" FontSize="12" />
                            </StackPanel>
                        </Button>
                        <Button Style="{StaticResource PrimaryButtonStyle}" FontSize="12" Click="OnAddStockClick">
                            <StackPanel Orientation="Horizontal" Spacing="5">
                                <FontIcon Glyph="&#xE710;" FontSize="13" />
                                <TextBlock Text="Add Stock" FontSize="12" />
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Grid>

                <!-- √Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź -->
                <!-- KPI CARDS ROW                              -->
                <!-- √Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź -->
                <Grid ColumnSpacing="14">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <!-- Total Parts -->
                    <Border Grid.Column="0" Background="{StaticResource CardBackgroundBrush}" BorderBrush="{StaticResource BorderDefaultBrush}" BorderThickness="1" CornerRadius="4" Padding="16,14" Translation="0,0,32">
                            <Border.Shadow><ThemeShadow/></Border.Shadow>
                            <StackPanel Spacing="8">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Spacing="2">
                                    <TextBlock Text="TOTAL PARTS" FontSize="9" Foreground="{StaticResource TextTertiaryBrush}" CharacterSpacing="60" FontWeight="SemiBold" />
                                    <TextBlock Text="{x:Bind ViewModel.TotalItems, Mode=OneWay}" FontSize="32" FontWeight="Light" CharacterSpacing="20" />
                                </StackPanel>
                                <Border Grid.Column="1" Width="48" Height="48" CornerRadius="4" Background="#101F7AE0" VerticalAlignment="Top">
                                    <FontIcon Glyph="&#xE80A;" FontSize="20" Foreground="{StaticResource AccentPrimaryBrush}" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                </Border>
                            </Grid>
                            <TextBlock Text="√Ę‚Ä†‚Äė 12% from last month" FontSize="10" Foreground="{StaticResource SuccessBrush}" />
                        </StackPanel>
                    </Border>

                    <!-- Low Stock Alert -->
                    <Border Grid.Column="1" Background="{StaticResource CardBackgroundBrush}" BorderBrush="{StaticResource BorderDefaultBrush}" BorderThickness="1" CornerRadius="4" Padding="16,14" Translation="0,0,32">
                            <Border.Shadow><ThemeShadow/></Border.Shadow>
                            <StackPanel Spacing="8">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Spacing="2">
                                    <TextBlock Text="LOW STOCK" FontSize="9" Foreground="{StaticResource TextTertiaryBrush}" CharacterSpacing="60" FontWeight="SemiBold" />
                                    <TextBlock Text="{x:Bind ViewModel.LowStockItems, Mode=OneWay}" FontSize="32" FontWeight="Light" CharacterSpacing="20" Foreground="{StaticResource WarningBrush}" />
                                </StackPanel>
                                <Border Grid.Column="1" Width="48" Height="48" CornerRadius="4" Background="#10FEBC2E" VerticalAlignment="Top">
                                    <FontIcon Glyph="&#xE7BA;" FontSize="20" Foreground="{StaticResource WarningBrush}" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                </Border>
                            </Grid>
                            <TextBlock Text="Requires attention" FontSize="10" Foreground="{StaticResource WarningBrush}" />
                        </StackPanel>
                    </Border>

                    <!-- Out of Stock -->
                    <Border Grid.Column="2" Background="{StaticResource CardBackgroundBrush}" BorderBrush="{StaticResource BorderDefaultBrush}" BorderThickness="1" CornerRadius="4" Padding="16,14" Translation="0,0,32">
                            <Border.Shadow><ThemeShadow/></Border.Shadow>
                            <StackPanel Spacing="8">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Spacing="2">
                                    <TextBlock Text="OUT OF STOCK" FontSize="9" Foreground="{StaticResource TextTertiaryBrush}" CharacterSpacing="60" FontWeight="SemiBold" />
                                    <TextBlock Text="{x:Bind ViewModel.OutOfStockItems, Mode=OneWay}" FontSize="32" FontWeight="Light" CharacterSpacing="20" Foreground="{StaticResource DangerBrush}" />
                                </StackPanel>
                                <Border Grid.Column="1" Width="48" Height="48" CornerRadius="4" Background="#10FF5F57" VerticalAlignment="Top">
                                    <FontIcon Glyph="&#xE7BA;" FontSize="20" Foreground="{StaticResource DangerBrush}" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                </Border>
                            </Grid>
                            <TextBlock Text="Critical" FontSize="10" Foreground="{StaticResource DangerBrush}" />
                        </StackPanel>
                    </Border>

                    <!-- Inventory Value -->
                    <Border Grid.Column="3" Background="{StaticResource CardBackgroundBrush}" BorderBrush="{StaticResource BorderDefaultBrush}" BorderThickness="1" CornerRadius="4" Padding="16,14" Translation="0,0,32">
                            <Border.Shadow><ThemeShadow/></Border.Shadow>
                            <StackPanel Spacing="8">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Spacing="2">
                                    <TextBlock Text="TOTAL VALUE" FontSize="9" Foreground="{StaticResource TextTertiaryBrush}" CharacterSpacing="60" FontWeight="SemiBold" />
                                    <TextBlock Text="{x:Bind ViewModel.TotalValueFormatted, Mode=OneWay}" FontSize="32" FontWeight="Light" CharacterSpacing="20" />
                                </StackPanel>
                                <Border Grid.Column="1" Width="48" Height="48" CornerRadius="4" Background="#102ABD8F" VerticalAlignment="Top">
                                    <FontIcon Glyph="&#xE8B5;" FontSize="20" Foreground="{StaticResource SuccessBrush}" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                </Border>
                            </Grid>
                            <TextBlock Text="Across all parts" FontSize="10" Foreground="{StaticResource TextSecondaryBrush}" />
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- √Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź -->
                <!-- FILTERS & SEARCH                           -->
                <!-- √Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź -->
                <Border Background="{StaticResource CardBackgroundBrush}" BorderBrush="{StaticResource BorderDefaultBrush}" BorderThickness="1" CornerRadius="4" Padding="14,10" Translation="0,0,32">
                            <Border.Shadow><ThemeShadow/></Border.Shadow>
                            <Grid ColumnSpacing="10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon Glyph="&#xE721;" FontSize="12" Foreground="{StaticResource TextTertiaryBrush}" VerticalAlignment="Center" />
                            <TextBox
                                BorderThickness="0"
                                Background="Transparent"
                                PlaceholderText="Search parts by name or ID..."
                                FontSize="12"
                                MinWidth="240"
                                VerticalAlignment="Center" />
                        </StackPanel>

                        <ComboBox Grid.Column="1" MinWidth="140" FontSize="11" PlaceholderText="Category" />
                        <ComboBox Grid.Column="2" MinWidth="140" FontSize="11" PlaceholderText="Status" />
                        <Button Grid.Column="3" Style="{StaticResource GhostButtonStyle}" Content="Clear Filters" FontSize="11" />
                    </Grid>
                </Border>

                <!-- √Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź -->
                <!-- INVENTORY TABLE                            -->
                <!-- √Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź -->
                <Border Background="{StaticResource CardBackgroundBrush}" BorderBrush="{StaticResource BorderDefaultBrush}" BorderThickness="1" CornerRadius="4" Padding="0" Translation="0,0,32">
                            <Border.Shadow><ThemeShadow/></Border.Shadow>
                            <StackPanel>
                        <!-- Table header -->
                        <Grid Padding="14,10" Background="{StaticResource GridHeaderBackgroundBrush}" ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="1.5*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <CheckBox Grid.Column="0" VerticalAlignment="Center" />
                            <TextBlock Grid.Column="1" Text="PART NAME" FontSize="9" Foreground="{StaticResource TextTertiaryBrush}" CharacterSpacing="60" FontWeight="SemiBold" VerticalAlignment="Center" />
                            <TextBlock Grid.Column="2" Text="PART ID" FontSize="9" Foreground="{StaticResource TextTertiaryBrush}" CharacterSpacing="60" FontWeight="SemiBold" VerticalAlignment="Center" />
                            <TextBlock Grid.Column="3" Text="QUANTITY" FontSize="9" Foreground="{StaticResource TextTertiaryBrush}" CharacterSpacing="60" FontWeight="SemiBold" VerticalAlignment="Center" />
                            <TextBlock Grid.Column="4" Text="CATEGORY" FontSize="9" Foreground="{StaticResource TextTertiaryBrush}" CharacterSpacing="60" FontWeight="SemiBold" VerticalAlignment="Center" />
                            <TextBlock Grid.Column="5" Text="STATUS" FontSize="9" Foreground="{StaticResource TextTertiaryBrush}" CharacterSpacing="60" FontWeight="SemiBold" VerticalAlignment="Center" />
                            <TextBlock Grid.Column="6" Text="ACTION" FontSize="9" Foreground="{StaticResource TextTertiaryBrush}" CharacterSpacing="60" FontWeight="SemiBold" VerticalAlignment="Center" MinWidth="60" />
                        </Grid>

                        <!-- Sample rows -->
                        <ProgressRing IsActive="{x:Bind ViewModel.IsLoading, Mode=OneWay}"
                                      Visibility="{x:Bind ViewModel.IsLoading, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}"
                                      Width="32" Height="32" HorizontalAlignment="Center" Margin="0,12,0,12"/>

                        <ListView ItemsSource="{x:Bind ViewModel.InventoryItems, Mode=OneWay}"
                                  SelectionMode="None">
                            <ListView.ItemContainerStyle>
                                <Style TargetType="ListViewItem">
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                    <Setter Property="Padding" Value="0"/>
                                </Style>
                            </ListView.ItemContainerStyle>
                            <ListView.ItemTemplate>
                                <DataTemplate x:DataType="viewmodels:InventoryItem">
                                    <Grid Padding="14,10" ColumnSpacing="12" MinHeight="44"
                                          BorderBrush="{StaticResource BorderDefaultBrush}" BorderThickness="0,0,0,1">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="1.5*"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <CheckBox Grid.Column="0" VerticalAlignment="Center"/>
                                        <StackPanel Grid.Column="1" Spacing="2" VerticalAlignment="Center">
                                            <TextBlock Text="{x:Bind PartName}" FontSize="12" FontWeight="SemiBold"/>
                                            <TextBlock Text="{x:Bind Category}" FontSize="10" Foreground="{StaticResource TextTertiaryBrush}"/>
                                        </StackPanel>
                                        <TextBlock Grid.Column="2" Text="{x:Bind Id}" FontSize="11" VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="3" Text="{x:Bind Quantity}" FontSize="11" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="4" Text="{x:Bind Category}" FontSize="11" VerticalAlignment="Center"/>
                                        <Border Grid.Column="5" CornerRadius="6" Padding="8,4" VerticalAlignment="Center" HorizontalAlignment="Left">
                                            <TextBlock Text="{x:Bind Status}" FontSize="9" FontWeight="SemiBold"/>
                                        </Border>
                                        <Button Grid.Column="6" Style="{StaticResource GhostButtonStyle}" FontSize="10" Padding="6,2">
                                            <StackPanel Orientation="Horizontal" Spacing="3">
                                                <FontIcon Glyph="&#xE70F;" FontSize="10"/>
