<Page
    x:Class="PartFinder.Views.Pages.AuditPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converters="using:PartFinder.Converters"
    xmlns:viewmodels="using:PartFinder.ViewModels">
    <Page.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter" />
    </Page.Resources>
    <Grid Background="{StaticResource PageBackgroundBrush}">
        <VisualStateManager.VisualStateGroups>
            <VisualStateGroup x:Name="AdaptiveStates">
                <VisualState x:Name="WideState">
                    <VisualState.StateTriggers>
                        <AdaptiveTrigger MinWindowWidth="1024" />
                    </VisualState.StateTriggers>
                </VisualState>
                <VisualState x:Name="NarrowState">
                    <VisualState.StateTriggers>
                        <AdaptiveTrigger MinWindowWidth="0" />
                    </VisualState.StateTriggers>
                    <VisualState.Setters>
                        <Setter Target="KpiGridDef2.Height" Value="Auto" />
                        <Setter Target="KpiGridDef3.Height" Value="Auto" />
                        <Setter Target="KpiGridDef4.Height" Value="Auto" />
                        <Setter Target="KpiCol1.Width" Value="*" />
                        <Setter Target="KpiCol2.Width" Value="0" />
                        <Setter Target="KpiCol3.Width" Value="0" />
                        <Setter Target="KpiCol4.Width" Value="0" />
                        <Setter Target="Kpi1.(Grid.Row)" Value="0" />
                        <Setter Target="Kpi1.(Grid.Column)" Value="0" />
                        <Setter Target="Kpi2.(Grid.Row)" Value="1" />
                        <Setter Target="Kpi2.(Grid.Column)" Value="0" />
                        <Setter Target="Kpi3.(Grid.Row)" Value="2" />
                        <Setter Target="Kpi3.(Grid.Column)" Value="0" />
                        <Setter Target="Kpi4.(Grid.Row)" Value="3" />
                        <Setter Target="Kpi4.(Grid.Column)" Value="0" />
                        <Setter Target="KpiGrid.RowSpacing" Value="12" />
                        
                        <Setter Target="FilterGridDef2.Height" Value="Auto" />
                        <Setter Target="FilterGridDef3.Height" Value="Auto" />
                        <Setter Target="FilterGridDef4.Height" Value="Auto" />
                        <Setter Target="FilterCol1.Width" Value="*" />
                        <Setter Target="FilterCol2.Width" Value="0" />
                        <Setter Target="FilterCol3.Width" Value="0" />
                        <Setter Target="FilterCol4.Width" Value="0" />
                        <Setter Target="FilterSearch.(Grid.Row)" Value="0" />
                        <Setter Target="FilterSearch.(Grid.Column)" Value="0" />
                        <Setter Target="FilterType.(Grid.Row)" Value="1" />
                        <Setter Target="FilterType.(Grid.Column)" Value="0" />
                        <Setter Target="FilterUser.(Grid.Row)" Value="2" />
                        <Setter Target="FilterUser.(Grid.Column)" Value="0" />
                        <Setter Target="FilterDate.(Grid.Row)" Value="3" />
                        <Setter Target="FilterDate.(Grid.Column)" Value="0" />
                        <Setter Target="FilterGrid.RowSpacing" Value="10" />
                    </VisualState.Setters>
                </VisualState>
            </VisualStateGroup>
        </VisualStateManager.VisualStateGroups>
        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
            <StackPanel Padding="24,20,24,32" Spacing="18" HorizontalAlignment="Stretch">
                <StackPanel.ChildrenTransitions>
                    <TransitionCollection>
                        <EntranceThemeTransition IsStaggeringEnabled="True" FromVerticalOffset="50" />
                    </TransitionCollection>
                </StackPanel.ChildrenTransitions>

                <!-- HEADER -->
                <Grid ColumnSpacing="12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Spacing="2">
                        <TextBlock Text="AUDIT" FontSize="10" Foreground="{StaticResource AccentPrimaryBrush}" CharacterSpacing="100" FontWeight="SemiBold" />
                        <TextBlock Text="Audit &amp; History" FontSize="32" FontWeight="Light" CharacterSpacing="20" />
                        <TextBlock Text="Complete audit trail of all inventory changes, user actions, and system events for compliance and traceability." FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" />
                    </StackPanel>
                    <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                        <Button Style="{StaticResource GhostButtonStyle}" FontSize="12" Click="OnFilterClick">
                            <StackPanel Orientation="Horizontal" Spacing="5">
                                <FontIcon Glyph="&#xE71C;" FontSize="13" />
                                <TextBlock Text="Filter" FontSize="12" />
                            </StackPanel>
                        </Button>
                        <Button Style="{StaticResource OutlinedButtonStyle}" FontSize="12" Click="OnExportAuditClick">
                            <StackPanel Orientation="Horizontal" Spacing="5">
                                <FontIcon Glyph="&#xE74E;" FontSize="13" />
                                <TextBlock Text="Export Log" FontSize="12" />
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Grid>

                <!-- KPI CARDS -->
                <Grid x:Name="KpiGrid" ColumnSpacing="14">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition x:Name="KpiGridDef2" Height="0" />
                        <RowDefinition x:Name="KpiGridDef3" Height="0" />
                        <RowDefinition x:Name="KpiGridDef4" Height="0" />
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition x:Name="KpiCol1" Width="*" />
                        <ColumnDefinition x:Name="KpiCol2" Width="*" />
                        <ColumnDefinition x:Name="KpiCol3" Width="*" />
                        <ColumnDefinition x:Name="KpiCol4" Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border x:Name="Kpi1" Grid.Column="0" Background="{StaticResource CardBackgroundBrush}" BorderBrush="{StaticResource BorderDefaultBrush}" BorderThickness="1" CornerRadius="4" Padding="16,14" Translation="0,0,32">
                            <Border.Shadow><ThemeShadow/></Border.Shadow>
                            <StackPanel Spacing="8">
                            <Grid>
                                <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                                <StackPanel Spacing="2">
                                    <TextBlock Text="EVENTS TODAY" FontSize="9" Foreground="{StaticResource TextTertiaryBrush}" CharacterSpacing="60" FontWeight="SemiBold" />
                                    <TextBlock Text="{x:Bind ViewModel.TotalEvents, Mode=OneWay}" FontSize="28" FontWeight="Bold" />
                                </StackPanel>
                                <Border Grid.Column="1" Width="44" Height="44" CornerRadius="4" Background="#101F7AE0" VerticalAlignment="Top">
                                    <FontIcon Glyph="&#xE823;" FontSize="20" Foreground="{StaticResource AccentPrimaryBrush}" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                </Border>
                            </Grid>
                            <TextBlock Text="All system events" FontSize="10" Foreground="{StaticResource TextSecondaryBrush}" />
                        </StackPanel>
                    </Border>

                    <Border x:Name="Kpi2" Grid.Column="1" Background="{StaticResource CardBackgroundBrush}" BorderBrush="{StaticResource BorderDefaultBrush}" BorderThickness="1" CornerRadius="4" Padding="16,14" Translation="0,0,32">
                            <Border.Shadow><ThemeShadow/></Border.Shadow>
                            <StackPanel Spacing="8">
                            <Grid>
                                <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                                <StackPanel Spacing="2">
                                    <TextBlock Text="STOCK CHANGES" FontSize="9" Foreground="{StaticResource TextTertiaryBrush}" CharacterSpacing="60" FontWeight="SemiBold" />
                                    <TextBlock Text="{x:Bind ViewModel.StockChangeCount, Mode=OneWay}" FontSize="28" FontWeight="Bold" Foreground="{StaticResource SuccessBrush}" />
                                </StackPanel>
                                <Border Grid.Column="1" Width="44" Height="44" CornerRadius="4" Background="#102ABD8F" VerticalAlignment="Top">
                                    <FontIcon Glyph="&#xE80A;" FontSize="20" Foreground="{StaticResource SuccessBrush}" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                </Border>
                            </Grid>
                            <TextBlock Text="Inventory updates" FontSize="10" Foreground="{StaticResource SuccessBrush}" />
                        </StackPanel>
                    </Border>

                    <Border x:Name="Kpi3" Grid.Column="2" Background="{StaticResource CardBackgroundBrush}" BorderBrush="{StaticResource BorderDefaultBrush}" BorderThickness="1" CornerRadius="4" Padding="16,14" Translation="0,0,32">
                            <Border.Shadow><ThemeShadow/></Border.Shadow>
                            <StackPanel Spacing="8">
                            <Grid>
                                <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                                <StackPanel Spacing="2">
                                    <TextBlock Text="USER ACTIONS" FontSize="9" Foreground="{StaticResource TextTertiaryBrush}" CharacterSpacing="60" FontWeight="SemiBold" />
                                    <TextBlock Text="{x:Bind ViewModel.UserActionCount, Mode=OneWay}" FontSize="28" FontWeight="Bold" Foreground="{StaticResource WarningBrush}" />
                                </StackPanel>
                                <Border Grid.Column="1" Width="44" Height="44" CornerRadius="4" Background="#10FEBC2E" VerticalAlignment="Top">
                                    <FontIcon Glyph="&#xE77B;" FontSize="20" Foreground="{StaticResource WarningBrush}" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                </Border>
                            </Grid>
                            <TextBlock Text="Login, edits, exports" FontSize="10" Foreground="{StaticResource WarningBrush}" />
                        </StackPanel>
                    </Border>

                    <Border x:Name="Kpi4" Grid.Column="3" Background="{StaticResource CardBackgroundBrush}" BorderBrush="{StaticResource BorderDefaultBrush}" BorderThickness="1" CornerRadius="4" Padding="16,14" Translation="0,0,32">
                            <Border.Shadow><ThemeShadow/></Border.Shadow>
                            <StackPanel Spacing="8">
                            <Grid>
                                <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                                <StackPanel Spacing="2">
                                    <TextBlock Text="SYSTEM EVENTS" FontSize="9" Foreground="{StaticResource TextTertiaryBrush}" CharacterSpacing="60" FontWeight="SemiBold" />
                                    <TextBlock Text="{x:Bind ViewModel.SystemEventCount, Mode=OneWay}" FontSize="28" FontWeight="Bold" />
                                </StackPanel>
                                <Border Grid.Column="1" Width="44" Height="44" CornerRadius="4" Background="#108B5CF6" VerticalAlignment="Top">
                                    <FontIcon Glyph="&#xE9D9;" FontSize="20" Foreground="#8B5CF6" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                </Border>
                            </Grid>
                            <TextBlock Text="Sync, imports, exports" FontSize="10" Foreground="{StaticResource TextSecondaryBrush}" />
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- SEARCH & DATE FILTER -->
                <Border Background="{StaticResource CardBackgroundBrush}" BorderBrush="{StaticResource BorderDefaultBrush}" BorderThickness="1" CornerRadius="4" Padding="14,10" Translation="0,0,32">
                            <Border.Shadow><ThemeShadow/></Border.Shadow>
                            <Grid x:Name="FilterGrid" ColumnSpacing="10">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition x:Name="FilterGridDef2" Height="0" />
                            <RowDefinition x:Name="FilterGridDef3" Height="0" />
                            <RowDefinition x:Name="FilterGridDef4" Height="0" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition x:Name="FilterCol1" Width="*" />
                            <ColumnDefinition x:Name="FilterCol2" Width="Auto" />
                            <ColumnDefinition x:Name="FilterCol3" Width="Auto" />
                            <ColumnDefinition x:Name="FilterCol4" Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel x:Name="FilterSearch" Orientation="Horizontal" Spacing="8">
                            <FontIcon Glyph="&#xE721;" FontSize="12" Foreground="{StaticResource TextTertiaryBrush}" VerticalAlignment="Center" />
                            <TextBox BorderThickness="0" Background="Transparent" PlaceholderText="Search by user, action, or part..." FontSize="12" MinWidth="240" VerticalAlignment="Center" Text="{x:Bind ViewModel.SearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                        </StackPanel>
                        <ComboBox x:Name="FilterType" Grid.Column="1" MinWidth="130" FontSize="11" PlaceholderText="Event Type" HorizontalAlignment="Stretch" SelectedValue="{x:Bind ViewModel.SelectedEventType, Mode=TwoWay}" SelectedValuePath="Content">
                            <ComboBoxItem Content="All Events" />
                            <ComboBoxItem Content="Stock Changes" />
                            <ComboBoxItem Content="User Actions" />
                            <ComboBoxItem Content="System Events" />
                            <ComboBoxItem Content="Templates" />
                            <ComboBoxItem Content="Alerts" />
                        </ComboBox>
                        <ComboBox x:Name="FilterUser" Grid.Column="2" MinWidth="130" FontSize="11" PlaceholderText="User" HorizontalAlignment="Stretch" ItemsSource="{x:Bind ViewModel.AvailableUsers, Mode=OneWay}" SelectedItem="{x:Bind ViewModel.SelectedUser, Mode=TwoWay}">
                        </ComboBox>
                        <ComboBox x:Name="FilterDate" Grid.Column="3" MinWidth="130" FontSize="11" PlaceholderText="Date Range" HorizontalAlignment="Stretch" SelectedValue="{x:Bind ViewModel.SelectedDateRange, Mode=TwoWay}" SelectedValuePath="Content">
                            <ComboBoxItem Content="Today" />
                            <ComboBoxItem Content="Last 7 days" />
                            <ComboBoxItem Content="Last 30 days" />
                            <ComboBoxItem Content="All time" />
                        </ComboBox>
                    </Grid>
                </Border>

                <!-- AUDIT LOG TABLE -->
                <Border Background="{StaticResource CardBackgroundBrush}" BorderBrush="{StaticResource BorderDefaultBrush}" BorderThickness="1" CornerRadius="4" Padding="0" Translation="0,0,32">
                            <Border.Shadow><ThemeShadow/></Border.Shadow>
                            <StackPanel>
                        <!-- COLUMN HEADERS -->
                        <Grid Padding="14,10" Background="{StaticResource GridHeaderBackgroundBrush}" ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="1.5*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="120" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="TYPE" FontSize="9" Foreground="{StaticResource TextTertiaryBrush}" CharacterSpacing="60" FontWeight="SemiBold" MinWidth="90" />
                            <TextBlock Grid.Column="1" Text="ACTION" FontSize="9" Foreground="{StaticResource TextTertiaryBrush}" CharacterSpacing="60" FontWeight="SemiBold" />
                            <TextBlock Grid.Column="2" Text="DETAILS" FontSize="9" Foreground="{StaticResource TextTertiaryBrush}" CharacterSpacing="60" FontWeight="SemiBold" />
                            <TextBlock Grid.Column="3" Text="USER" FontSize="9" Foreground="{StaticResource TextTertiaryBrush}" CharacterSpacing="60" FontWeight="SemiBold" />
                            <TextBlock Grid.Column="4" Text="WHEN" FontSize="9" Foreground="{StaticResource TextTertiaryBrush}" CharacterSpacing="60" FontWeight="SemiBold" />
                            <TextBlock Grid.Column="5" Text="" FontSize="9" Foreground="{StaticResource TextTertiaryBrush}" CharacterSpacing="60" FontWeight="SemiBold" MinWidth="32" />
                        </Grid>

                        <ProgressRing IsActive="{x:Bind ViewModel.IsLoading, Mode=OneWay}"
                                      Visibility="{x:Bind ViewModel.IsLoading, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}"
                                      Width="32" Height="32" HorizontalAlignment="Center" Margin="0,12,0,12"/>

                        <ListView ItemsSource="{x:Bind ViewModel.AuditLogs, Mode=OneWay}"
                                  SelectionMode="None"
                                  MaxHeight="560">
                            <ListView.ItemContainerStyle>
                                <Style TargetType="ListViewItem">
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                    <Setter Property="Padding" Value="0"/>
                                </Style>
                            </ListView.ItemContainerStyle>
                            <ListView.ItemTemplate>
                                <DataTemplate x:DataType="viewmodels:AuditLogEntry">
                                    <Grid Padding="14,10" ColumnSpacing="12"
                                          BorderBrush="{StaticResource BorderDefaultBrush}" BorderThickness="0,1,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="1.5*"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="120"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <!-- Event Type Badge -->
                                        <Border CornerRadius="4" Padding="7,3" VerticalAlignment="Center" MinWidth="90"
                                                Background="{x:Bind EventTypeColor}">
                                            <StackPanel Orientation="Horizontal" Spacing="4" HorizontalAlignment="Center">
                                                <FontIcon Glyph="{x:Bind EventTypeIcon}" FontSize="9"
                                                          Foreground="{x:Bind EventTypeForeground}" VerticalAlignment="Center"/>
                                                <TextBlock Text="{x:Bind EventType}" FontSize="9" FontWeight="SemiBold"
                                                           Foreground="{x:Bind EventTypeForeground}" VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </Border>

                                        <!-- Action -->
                                        <TextBlock Grid.Column="1" Text="{x:Bind Action}" FontSize="12"
                                                   FontWeight="SemiBold" VerticalAlignment="Center"/>

                                        <!-- Details -->
                                        <TextBlock Grid.Column="2" Text="{x:Bind Details}" FontSize="11"
                                                   Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center"
                                                   TextWrapping="NoWrap" TextTrimming="CharacterEllipsis"/>

                                        <!-- User -->
                                        <StackPanel Grid.Column="3" Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                                            <Border Width="22" Height="22" CornerRadius="11"
                                                    Background="#101F7AE0">
                                                <TextBlock Text="{x:Bind UserInitial}" FontSize="9" FontWeight="Bold"
                                                           HorizontalAlignment="Center" VerticalAlignment="Center"
                                                           Foreground="{StaticResource AccentPrimaryBrush}"/>
                                            </Border>
                                            <TextBlock Text="{x:Bind User}" FontSize="11" VerticalAlignment="Center"
                                                       TextTrimming="CharacterEllipsis"/>
                                        </StackPanel>

                                        <!-- Timestamp: date + time stacked -->
                                        <StackPanel Grid.Column="4" Spacing="1" VerticalAlignment="Center">
                                            <TextBlock Text="{x:Bind FormattedDate}" FontSize="11"
                                                       Foreground="{StaticResource TextPrimaryBrush}"/>
                                            <TextBlock Text="{x:Bind FormattedTime}" FontSize="10"
                                                       Foreground="{StaticResource TextTertiaryBrush}"/>
                                        </StackPanel>

                                        <!-- Detail button -->
                                        <Button Grid.Column="5" Style="{StaticResource GhostButtonStyle}"
                                                Padding="6,4" Click="OnViewDetailClick">
                                            <FontIcon Glyph="&#xE946;" FontSize="12"/>
                                        </Button>
                                    </Grid>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                            </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>


