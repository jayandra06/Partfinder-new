<Page
    x:Class="PartFinder.Views.Pages.UserManagementPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:components="using:PartFinder.Views.Components"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Page.Resources>
        <!-- Row hover style -->
        <Style x:Key="UserRowItemStyle" TargetType="ListViewItem">
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="MinHeight" Value="0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListViewItem">
                        <Grid>
                            <VisualStateManager.VisualStateGroups>
                                <VisualStateGroup x:Name="CommonStates">
                                    <VisualState x:Name="Normal" />
                                    <VisualState x:Name="PointerOver">
                                        <Storyboard>
                                            <ObjectAnimationUsingKeyFrames Storyboard.TargetName="RowBg" Storyboard.TargetProperty="Background">
                                                <DiscreteObjectKeyFrame KeyTime="0" Value="{StaticResource RowHoverBackgroundBrush}" />
                                            </ObjectAnimationUsingKeyFrames>
                                        </Storyboard>
                                    </VisualState>
                                    <VisualState x:Name="Pressed">
                                        <Storyboard>
                                            <ObjectAnimationUsingKeyFrames Storyboard.TargetName="RowBg" Storyboard.TargetProperty="Background">
                                                <DiscreteObjectKeyFrame KeyTime="0" Value="{StaticResource RowSelectedBackgroundBrush}" />
                                            </ObjectAnimationUsingKeyFrames>
                                        </Storyboard>
                                    </VisualState>
                                </VisualStateGroup>
                            </VisualStateManager.VisualStateGroups>
                            <Border x:Name="RowBg" Background="Transparent">
                                <ContentPresenter />
                            </Border>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Page.Resources>

    <Grid Background="{StaticResource PageBackgroundBrush}">
        <VisualStateManager.VisualStateGroups>
            <VisualStateGroup x:Name="AdaptiveStates">
                <VisualState x:Name="WideState">
                    <VisualState.StateTriggers>
                        <AdaptiveTrigger MinWindowWidth="1024" />
                    </VisualState.StateTriggers>
                </VisualState>
                <VisualState x:Name="NarrowState">
                    <VisualState.StateTriggers>
                        <AdaptiveTrigger MinWindowWidth="0" />
                    </VisualState.StateTriggers>
                    <VisualState.Setters>
                        <Setter Target="KpiGridDef2.Height" Value="Auto" />
                        <Setter Target="KpiGridDef3.Height" Value="Auto" />
                        <Setter Target="KpiGridDef4.Height" Value="Auto" />
                        <Setter Target="KpiCol1.Width" Value="*" />
                        <Setter Target="KpiCol2.Width" Value="0" />
                        <Setter Target="KpiCol3.Width" Value="0" />
                        <Setter Target="KpiCol4.Width" Value="0" />
                        <Setter Target="Kpi1.(Grid.Row)" Value="0" />
                        <Setter Target="Kpi1.(Grid.Column)" Value="0" />
                        <Setter Target="Kpi2.(Grid.Row)" Value="1" />
                        <Setter Target="Kpi2.(Grid.Column)" Value="0" />
                        <Setter Target="Kpi3.(Grid.Row)" Value="2" />
                        <Setter Target="Kpi3.(Grid.Column)" Value="0" />
                        <Setter Target="Kpi4.(Grid.Row)" Value="3" />
                        <Setter Target="Kpi4.(Grid.Column)" Value="0" />
                        <Setter Target="KpiGrid.RowSpacing" Value="10" />
                        
                        <Setter Target="FilterGridDef2.Height" Value="Auto" />
                        <Setter Target="FilterGridDef3.Height" Value="Auto" />
                        <Setter Target="FilterCol1.Width" Value="*" />
                        <Setter Target="FilterCol2.Width" Value="0" />
                        <Setter Target="FilterCol3.Width" Value="0" />
                        <Setter Target="FilterSearch.(Grid.Row)" Value="0" />
                        <Setter Target="FilterSearch.(Grid.Column)" Value="0" />
                        <Setter Target="FilterRole.(Grid.Row)" Value="1" />
                        <Setter Target="FilterRole.(Grid.Column)" Value="0" />
                        <Setter Target="FilterStatus.(Grid.Row)" Value="2" />
                        <Setter Target="FilterStatus.(Grid.Column)" Value="0" />
                        <Setter Target="FilterGrid.RowSpacing" Value="10" />
                    </VisualState.Setters>
                </VisualState>
            </VisualStateGroup>
        </VisualStateManager.VisualStateGroups>

        <!-- â”€â”€ Toast Popup â”€â”€ slide-up notification â”€â”€ -->
        <Border
            x:Name="ToastPopup"
            HorizontalAlignment="Right"
            VerticalAlignment="Bottom"
            Margin="0,0,20,20"
            Padding="14,10"
            CornerRadius="4"
            Background="#172334"
            BorderBrush="#1F7AE0"
            BorderThickness="1"
            Opacity="0"
            IsHitTestVisible="False"
            Canvas.ZIndex="99">
            <Border.RenderTransform>
                <TranslateTransform x:Name="ToastTranslate" Y="20" />
            </Border.RenderTransform>
            <StackPanel Orientation="Horizontal" Spacing="10">
                <Border Width="28" Height="28" CornerRadius="14" Background="#1A3A5C">
                    <FontIcon Glyph="&#xE73E;" FontSize="13" Foreground="#2ABD8F" />
                </Border>
                <StackPanel Spacing="1" VerticalAlignment="Center">
                    <TextBlock x:Name="ToastTitle" Text="Invite sent" FontSize="12" FontWeight="SemiBold" Foreground="#EAF2FF" />
                    <TextBlock x:Name="ToastMessage" Text="User has been invited successfully." FontSize="11" Foreground="#AAB8CA" />
                </StackPanel>
            </StackPanel>
        </Border>

        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
            <StackPanel Padding="24,20,24,32" Spacing="20" HorizontalAlignment="Stretch">
                <StackPanel.ChildrenTransitions>
                    <TransitionCollection>
                        <EntranceThemeTransition IsStaggeringEnabled="True" FromVerticalOffset="50" />
                    </TransitionCollection>
                </StackPanel.ChildrenTransitions>

                <!-- â”€â”€ Header Row â”€â”€ -->
                <Grid ColumnSpacing="12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Spacing="2">
                        <TextBlock Text="USERS" FontSize="11" Foreground="{StaticResource TextTertiaryBrush}" CharacterSpacing="80" FontWeight="SemiBold" />
                        <TextBlock Text="Team Management" FontSize="22" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}" />
                        <TextBlock
                            Text="Invite team members, assign roles and control which templates each user can access for inventory management."
                            FontSize="12"
                            Foreground="{StaticResource TextSecondaryBrush}" />
                    </StackPanel>

                    <Button
                        Grid.Column="1"
                        VerticalAlignment="Center"
                        Style="{StaticResource PrimaryButtonStyle}"
                        Click="OnInviteClicked">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <FontIcon Glyph="&#xE8FA;" FontSize="13" />
                            <TextBlock Text="Invite User" FontSize="12" />
                        </StackPanel>
                    </Button>
                </Grid>

                <!-- â”€â”€ KPI Summary Cards â”€â”€ -->
                <Grid x:Name="KpiGrid" ColumnSpacing="14">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition x:Name="KpiGridDef2" Height="0" />
                        <RowDefinition x:Name="KpiGridDef3" Height="0" />
                        <RowDefinition x:Name="KpiGridDef4" Height="0" />
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition x:Name="KpiCol1" Width="*" />
                        <ColumnDefinition x:Name="KpiCol2" Width="*" />
                        <ColumnDefinition x:Name="KpiCol3" Width="*" />
                        <ColumnDefinition x:Name="KpiCol4" Width="*" />
                    </Grid.ColumnDefinitions>

                    <!-- Total users -->
                    <Border x:Name="Kpi1" Grid.Column="0" Background="{StaticResource CardBackgroundBrush}" BorderBrush="{StaticResource BorderDefaultBrush}" BorderThickness="1" CornerRadius="8" Padding="14,12" Translation="0,0,32">
                            <Border.Shadow><ThemeShadow/></Border.Shadow>
                            <StackPanel Spacing="4">
                            <TextBlock Text="TOTAL USERS" FontSize="9" Foreground="{StaticResource TextTertiaryBrush}" CharacterSpacing="60" FontWeight="SemiBold" />
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <FontIcon Glyph="&#xE77B;" FontSize="16" Foreground="{StaticResource AccentPrimaryBrush}" />
                                <TextBlock Text="{Binding Users.Count}" FontSize="20" FontWeight="SemiBold" />
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- Active -->
                    <Border x:Name="Kpi2" Grid.Column="1" Background="{StaticResource CardBackgroundBrush}" BorderBrush="{StaticResource BorderDefaultBrush}" BorderThickness="1" CornerRadius="8" Padding="14,12" Translation="0,0,32">
                            <Border.Shadow><ThemeShadow/></Border.Shadow>
                            <StackPanel Spacing="4">
                            <TextBlock Text="ACTIVE" FontSize="9" Foreground="{StaticResource TextTertiaryBrush}" CharacterSpacing="60" FontWeight="SemiBold" />
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <Ellipse Width="8" Height="8" Fill="{StaticResource SuccessBrush}" VerticalAlignment="Center" />
                                <TextBlock Text="{Binding Users.Count}" FontSize="20" FontWeight="SemiBold" Foreground="{StaticResource SuccessBrush}" />
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- Admins -->
                    <Border x:Name="Kpi3" Grid.Column="2" Background="{StaticResource CardBackgroundBrush}" BorderBrush="{StaticResource BorderDefaultBrush}" BorderThickness="1" CornerRadius="8" Padding="14,12" Translation="0,0,32">
                            <Border.Shadow><ThemeShadow/></Border.Shadow>
                            <StackPanel Spacing="4">
                            <TextBlock Text="ADMINS" FontSize="9" Foreground="{StaticResource TextTertiaryBrush}" CharacterSpacing="60" FontWeight="SemiBold" />
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <FontIcon Glyph="&#xE7EF;" FontSize="16" Foreground="{StaticResource WarningBrush}" />
                                <TextBlock Text="-" FontSize="20" FontWeight="SemiBold" />
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- Pending -->
                    <Border x:Name="Kpi4" Grid.Column="3" Background="{StaticResource CardBackgroundBrush}" BorderBrush="{StaticResource BorderDefaultBrush}" BorderThickness="1" CornerRadius="8" Padding="14,12" Translation="0,0,32">
                            <Border.Shadow><ThemeShadow/></Border.Shadow>
                            <StackPanel Spacing="4">
                            <TextBlock Text="PENDING" FontSize="9" Foreground="{StaticResource TextTertiaryBrush}" CharacterSpacing="60" FontWeight="SemiBold" />
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <FontIcon Glyph="&#xE823;" FontSize="16" Foreground="{StaticResource InfoBrush}" />
                                <TextBlock Text="-" FontSize="20" FontWeight="SemiBold" />
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- â”€â”€ Search + Filters â”€â”€ -->
                <Grid x:Name="FilterGrid" ColumnSpacing="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition x:Name="FilterGridDef2" Height="0" />
                        <RowDefinition x:Name="FilterGridDef3" Height="0" />
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition x:Name="FilterCol1" Width="*" />
                        <ColumnDefinition x:Name="FilterCol2" Width="140" />
                        <ColumnDefinition x:Name="FilterCol3" Width="140" />
                    </Grid.ColumnDefinitions>

                    <Border
                        x:Name="FilterSearch"
                        Grid.Column="0"
                        CornerRadius="8"
                        Background="{StaticResource CardBackgroundBrush}"
                        BorderBrush="{StaticResource BorderDefaultBrush}"
                        BorderThickness="1"
                        Padding="8,0" Translation="0,0,32">
                            <Border.Shadow><ThemeShadow/></Border.Shadow>
                            <Grid ColumnSpacing="6" VerticalAlignment="Stretch">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <FontIcon Grid.Column="0" Glyph="&#xE721;" FontSize="12" Foreground="{StaticResource TextTertiaryBrush}" VerticalAlignment="Center" />
                                <TextBox
                                    Grid.Column="1"
                                    BorderThickness="0"
                                    Background="Transparent"
                                    PlaceholderText="Search users..."
                                    FontSize="12"
                                    VerticalAlignment="Stretch"
                                    VerticalContentAlignment="Center"
                                    HorizontalAlignment="Stretch"
                                    Text="{Binding SearchQuery, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            </Grid>
                    </Border>

                    <ComboBox x:Name="FilterRole" Grid.Column="1" HorizontalAlignment="Stretch" FontSize="12"
                              ItemsSource="{Binding RoleFilters}"
                              SelectedItem="{Binding SelectedRoleFilter, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                    <ComboBox x:Name="FilterStatus" Grid.Column="2" PlaceholderText="All Status" HorizontalAlignment="Stretch" FontSize="12">
                        <ComboBoxItem Content="Active" />
                        <ComboBoxItem Content="Pending" />
                    </ComboBox>
                </Grid>

                <!-- â”€â”€ Status + Loading â”€â”€ -->
                <TextBlock
                    Foreground="{StaticResource DangerBrush}"
                    Text="{Binding StatusMessage}"
                    FontSize="12"
                    TextWrapping="WrapWholeWords" />
                <ProgressRing
                    Width="24" Height="24"
                    HorizontalAlignment="Left"
                    IsActive="{Binding IsBusy}" />

                <!-- â”€â”€ Users Table â”€â”€ -->
                <Border
                    Background="{StaticResource CardBackgroundBrush}"
                    BorderBrush="{StaticResource BorderDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="4" Translation="0,0,32">
                            <Border.Shadow><ThemeShadow/></Border.Shadow>
                            <StackPanel>

                        <!-- Table Header -->
                        <Grid
                            Padding="14,10"
                            ColumnSpacing="10"
                            Background="{StaticResource GridHeaderBackgroundBrush}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="2*" />
                                <ColumnDefinition Width="2.5*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="2*" />
                                <ColumnDefinition Width="1.5*" />
                                <ColumnDefinition Width="100" />
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" Width="28" />
                            <TextBlock Grid.Column="1" Text="NAME" FontSize="10" FontWeight="SemiBold" Foreground="{StaticResource TextTertiaryBrush}" CharacterSpacing="60" VerticalAlignment="Center" />
                            <TextBlock Grid.Column="2" Text="EMAIL" FontSize="10" FontWeight="SemiBold" Foreground="{StaticResource TextTertiaryBrush}" CharacterSpacing="60" VerticalAlignment="Center" />
                            <TextBlock Grid.Column="3" Text="ROLE" FontSize="10" FontWeight="SemiBold" Foreground="{StaticResource TextTertiaryBrush}" CharacterSpacing="60" VerticalAlignment="Center" />
                            <TextBlock Grid.Column="4" Text="ACCESS" FontSize="10" FontWeight="SemiBold" Foreground="{StaticResource TextTertiaryBrush}" CharacterSpacing="60" VerticalAlignment="Center" />
                            <TextBlock Grid.Column="5" Text="INVITATIONS" FontSize="10" FontWeight="SemiBold" Foreground="{StaticResource TextTertiaryBrush}" CharacterSpacing="60" VerticalAlignment="Center" MinWidth="70" />
                            <TextBlock Grid.Column="6" Text="ACTIONS" FontSize="10" FontWeight="SemiBold" Foreground="{StaticResource TextTertiaryBrush}" CharacterSpacing="60" VerticalAlignment="Center" Margin="10,0,0,0" />
                        </Grid>

                        <!-- Table Rows -->
                        <ListView
                            ItemsSource="{Binding Users}"
                            SelectionMode="None"
                            ItemContainerStyle="{StaticResource UserRowItemStyle}">
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <Grid
                                        Padding="14,10"
                                        ColumnSpacing="10"
                                        MinHeight="48"
                                        BorderBrush="{StaticResource BorderDefaultBrush}"
                                        BorderThickness="0,0,0,1">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="2*" />
                                            <ColumnDefinition Width="2.5*" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="2*" />
                                            <ColumnDefinition Width="1.5*" />
                                            <ColumnDefinition Width="100" />
                                        </Grid.ColumnDefinitions>

                                        <!-- Avatar -->
                                        <Border
                                            Grid.Column="0"
                                            Width="28" Height="28"
                                            CornerRadius="14"
                                            Background="{StaticResource AccentPrimaryBrush}"
                                            VerticalAlignment="Center">
                                            <TextBlock
                                                HorizontalAlignment="Center"
                                                VerticalAlignment="Center"
                                                FontSize="11"
                                                FontWeight="SemiBold"
                                                Foreground="White"
                                                Text="{Binding Name}" />
                                        </Border>

                                        <!-- Name -->
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="1">
                                            <TextBlock
                                                Text="{Binding Name}"
                                                FontSize="12"
                                                FontWeight="SemiBold"
                                                Foreground="{StaticResource TextPrimaryBrush}"
                                                TextTrimming="CharacterEllipsis" />
                                        </StackPanel>

                                        <!-- Email -->
                                        <TextBlock
                                            Grid.Column="2"
                                            Text="{Binding Email}"
                                            FontSize="11"
                                            Foreground="{StaticResource TextSecondaryBrush}"
                                            VerticalAlignment="Center"
                                            TextTrimming="CharacterEllipsis" />

                                        <!-- Role Badge -->
                                        <Border
                                            Grid.Column="3"
                                            VerticalAlignment="Center"
                                            HorizontalAlignment="Left"
                                            CornerRadius="6"
                                            Padding="6,2"
                                            Background="#1A2B43">
                                            <TextBlock
                                                Text="{Binding Role}"
                                                FontSize="10"
                                                FontWeight="SemiBold"
                                                Foreground="{StaticResource AccentPrimaryBrush}" />
                                        </Border>

                                        <!-- Access -->
                                        <TextBlock
                                            Grid.Column="4"
                                            Text="{Binding PartsScopeDisplay}"
                                            FontSize="11"
                                            Foreground="{StaticResource TextSecondaryBrush}"
                                            VerticalAlignment="Center"
                                            TextWrapping="WrapWholeWords" />

                                        <!-- Invited date -->
                                        <TextBlock
                                            Grid.Column="5"
                                            Text="{Binding InvitedAtUtc}"
                                            FontSize="10"
                                            Foreground="{StaticResource TextTertiaryBrush}"
                                            VerticalAlignment="Center"
                                            MinWidth="70" />

                                        <!-- Actions -->
                                        <StackPanel Grid.Column="6" Orientation="Horizontal" Spacing="4" VerticalAlignment="Center" Margin="10,0,0,0">
                                            <Button Style="{StaticResource GhostButtonStyle}" Padding="6" CornerRadius="4" Click="OnEditUserClicked" ToolTipService.ToolTip="Edit User">
                                                <FontIcon Glyph="&#xE70F;" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" />
                                            </Button>
                                            <Button Style="{StaticResource GhostButtonStyle}" Padding="6" CornerRadius="4" Click="OnDeleteUserClicked" ToolTipService.ToolTip="Delete User">
                                                <FontIcon Glyph="&#xE74D;" FontSize="12" Foreground="{StaticResource DangerBrush}" />
                                            </Button>
                                        </StackPanel>
                                    </Grid>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>

                        <!-- Empty state -->
                        <Border Padding="20" Visibility="{Binding IsBusy}">
                            <StackPanel HorizontalAlignment="Center" Spacing="6">
                                <ProgressRing Width="20" Height="20" IsActive="True" />
                                <TextBlock
                                    Text="Loading users..."
                                    FontSize="12"
                                    Foreground="{StaticResource TextSecondaryBrush}"
                                    HorizontalAlignment="Center" />
                            </StackPanel>
                        </Border>

                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>



