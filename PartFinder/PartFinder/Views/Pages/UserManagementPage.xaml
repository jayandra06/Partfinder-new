<Page
    x:Class="PartFinder.Views.Pages.UserManagementPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:components="using:PartFinder.Views.Components"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">
    <ScrollViewer Background="{StaticResource PageBackgroundBrush}">
        <StackPanel Padding="20" Spacing="16">
            <Grid ColumnSpacing="12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <components:PageHeader
                    Grid.Column="0"
                    Title="User management"
                    Subtitle="Invite admins (full access) or employees (Parts only, with template scope you define)." />
                <Button
                    Grid.Column="1"
                    VerticalAlignment="Center"
                    Style="{StaticResource PrimaryButtonStyle}"
                    Content="+ Invite user"
                    Click="OnInviteClicked" />
            </Grid>

            <Grid ColumnSpacing="10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <TextBox Grid.Column="0" Style="{StaticResource SearchTextBoxStyle}" PlaceholderText="Search users..." />
                <ComboBox Grid.Column="1" PlaceholderText="Role" />
                <ComboBox Grid.Column="2" PlaceholderText="Status" />
            </Grid>

            <TextBlock
                Foreground="{StaticResource DangerBrush}"
                Text="{Binding StatusMessage}"
                TextWrapping="WrapWholeWords" />

            <ProgressRing
                Width="32"
                Height="32"
                HorizontalAlignment="Left"
                IsActive="{Binding IsBusy}" />

            <Border Style="{StaticResource CardStyle}">
                <StackPanel>
                    <Grid Padding="12,12" ColumnSpacing="12" Background="{StaticResource GridHeaderBackgroundBrush}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2*" />
                            <ColumnDefinition Width="2*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="2*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Name" Style="{StaticResource ColumnHeaderStyle}" />
                        <TextBlock Grid.Column="1" Text="Email" Style="{StaticResource ColumnHeaderStyle}" />
                        <TextBlock Grid.Column="2" Text="Role" Style="{StaticResource ColumnHeaderStyle}" />
                        <TextBlock Grid.Column="3" Text="Access" Style="{StaticResource ColumnHeaderStyle}" />
                    </Grid>
                    <ListView ItemsSource="{Binding Users}">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Grid Padding="12,10" ColumnSpacing="12" MinHeight="56">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="2*" />
                                        <ColumnDefinition Width="2*" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="2*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="{Binding Name}" Style="{StaticResource BodyStyle}" TextWrapping="WrapWholeWords" />
                                    <TextBlock Grid.Column="1" Text="{Binding Email}" Style="{StaticResource CaptionStyle}" TextWrapping="WrapWholeWords" />
                                    <Border Grid.Column="2" Style="{StaticResource GrayBadgeStyle}" HorizontalAlignment="Left">
                                        <TextBlock Text="{Binding Role}" Style="{StaticResource BadgeTextStyle}" />
                                    </Border>
                                    <TextBlock
                                        Grid.Column="3"
                                        Text="{Binding PartsScopeDisplay}"
                                        Style="{StaticResource CaptionStyle}"
                                        TextWrapping="WrapWholeWords" />
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>
