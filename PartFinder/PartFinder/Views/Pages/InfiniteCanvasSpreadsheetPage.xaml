<Page
    x:Class="PartFinder.Views.Pages.InfiniteCanvasSpreadsheetPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:components="using:PartFinder.Views.Components"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">
    <Grid x:Name="RootGrid" Background="{StaticResource PageBackgroundBrush}">
        <Grid
            x:Name="Viewport"
            Background="Transparent"
            PointerPressed="OnViewportPointerPressed"
            PointerMoved="OnViewportPointerMoved"
            PointerReleased="OnViewportPointerReleased"
            PointerWheelChanged="OnViewportPointerWheelChanged">
            <Canvas x:Name="WorldCanvas" Width="20000" Height="20000">
                <Canvas.RenderTransform>
                    <TransformGroup>
                        <ScaleTransform x:Name="WorldScaleTransform" ScaleX="1" ScaleY="1" />
                        <TranslateTransform x:Name="WorldTranslateTransform" X="-9200" Y="-3500" />
                    </TransformGroup>
                </Canvas.RenderTransform>
            </Canvas>
        </Grid>

        <Border
            x:Name="TemplatePickerHost"
            HorizontalAlignment="Center"
            VerticalAlignment="Top"
            Margin="0,8,0,0"
            Padding="10,8"
            CornerRadius="14"
            Background="{StaticResource ElevatedCardBackgroundBrush}"
            BorderBrush="{StaticResource BorderDefaultBrush}"
            BorderThickness="1"
            Canvas.ZIndex="20">
            <StackPanel Orientation="Horizontal" Spacing="8">
                <AutoSuggestBox
                    x:Name="TemplateSuggestBox"
                    Width="360"
                    HorizontalAlignment="Center"
                    PlaceholderText="Type template name..."
                    QueryIcon="Find"
                    QuerySubmitted="OnTemplateQuerySubmitted"
                    SuggestionChosen="OnTemplateSuggestionChosen"
                    TextChanged="OnTemplateSuggestTextChanged" />
                <Button
                    x:Name="SaveTemplateButton"
                    MinWidth="92"
                    Content="Save"
                    Click="OnSaveTemplateClicked" />
                <Button
                    x:Name="GroupColumnsButton"
                    MinWidth="92"
                    Content="Group"
                    Click="OnGroupColumnsClicked" />
            </StackPanel>
        </Border>

        <Border
            x:Name="HintPill"
            HorizontalAlignment="Center"
            VerticalAlignment="Top"
            Margin="0,64,0,0"
            Padding="16,8"
            CornerRadius="18"
            Background="{StaticResource ElevatedCardBackgroundBrush}"
            BorderBrush="{StaticResource BorderDefaultBrush}"
            BorderThickness="1"
            Opacity="0.92">
            <TextBlock
                Text="Hover a cell edge → click + to add · Drag empty canvas to move · Ctrl+Scroll to zoom"
                Foreground="{StaticResource TextSecondaryBrush}" />
        </Border>

        <TextBlock
            x:Name="TemplateStatusText"
            HorizontalAlignment="Center"
            VerticalAlignment="Top"
            Margin="0,116,0,0"
            Foreground="{StaticResource TextSecondaryBrush}"
            Visibility="Collapsed" />

        <Border
            x:Name="SelectionInfoHost"
            HorizontalAlignment="Center"
            VerticalAlignment="Top"
            Margin="0,148,0,0"
            Padding="10,6"
            CornerRadius="12"
            Background="{StaticResource ElevatedCardBackgroundBrush}"
            BorderBrush="{StaticResource BorderDefaultBrush}"
            BorderThickness="1"
            Visibility="Collapsed"
            Canvas.ZIndex="20">
            <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                <TextBlock
                    x:Name="SelectionSummaryText"
                    VerticalAlignment="Center"
                    Foreground="{StaticResource TextPrimaryBrush}"
                    Text="No columns selected" />
                <Button
                    x:Name="GroupSelectedButton"
                    MinWidth="92"
                    Content="Group Selected"
                    Click="OnGroupColumnsClicked" />
                <Button
                    x:Name="ClearSelectionButton"
                    MinWidth="72"
                    Content="Clear"
                    Click="OnClearSelectionClicked" />
            </StackPanel>
        </Border>

        <Border
            HorizontalAlignment="Right"
            VerticalAlignment="Bottom"
            Margin="0,0,24,20"
            Padding="10"
            CornerRadius="20"
            BorderBrush="{StaticResource BorderDefaultBrush}"
            BorderThickness="1">
            <Border.Background>
                <SolidColorBrush Color="{StaticResource ElevatedCardBackgroundColor}" />
            </Border.Background>
            <Border.Shadow>
                <ThemeShadow />
            </Border.Shadow>
            <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                <Button Width="56" Height="42" CornerRadius="12" Content="−" Click="OnZoomOutClicked" />
                <TextBlock x:Name="ZoomText" Width="58" VerticalAlignment="Center" TextAlignment="Center" Text="100%" />
                <Button Width="56" Height="42" CornerRadius="12" Content="+" Click="OnZoomInClicked" />
                <Button Width="72" Height="42" CornerRadius="12" Content="Reset" Click="OnZoomResetClicked" />
            </StackPanel>
        </Border>
    </Grid>
</Page>
