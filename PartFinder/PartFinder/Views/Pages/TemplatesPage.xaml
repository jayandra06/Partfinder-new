<Page
    x:Class="PartFinder.Views.Pages.TemplatesPage"
    x:Name="TemplatesPageRoot"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:components="using:PartFinder.Views.Components"
    xmlns:converters="using:PartFinder.Converters"
    xmlns:viewmodels="using:PartFinder.ViewModels"
    xmlns:models="using:PartFinder.Models">
    <Page.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter" />
        <converters:InvertedBoolToVisibilityConverter x:Key="InvertedBoolToVisibilityConverter" />
        <converters:BoolToStarGlyphConverter x:Key="BoolToStarGlyphConverter" />
        <converters:BoolToStarColorConverter x:Key="BoolToStarColorConverter" />
        <converters:StringToVisibilityConverter x:Key="StringToVisibilityConverter" />
        
        <!-- Custom Styles for Modern UI -->
        <Style x:Key="ModernCardStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource ElevatedCardBackgroundBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderDefaultBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="12" />
            <Setter Property="Padding" Value="20" />
        </Style>
        
        <Style x:Key="GlowButtonStyle" TargetType="Button" BasedOn="{StaticResource PrimaryButtonStyle}">
            <Setter Property="Background" Value="#13096e" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>
        
        <Style x:Key="ModernOutlineButtonStyle" TargetType="Button" BasedOn="{StaticResource OutlinedButtonStyle}">
            <Setter Property="BorderBrush" Value="#13096e" />
            <Setter Property="Foreground" Value="#AAB8CA" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="FontWeight" Value="Normal" />
        </Style>
    </Page.Resources>

    <Grid Padding="32" ColumnSpacing="24" Background="Transparent">
        <Grid.Transitions>
            <TransitionCollection>
                <EntranceThemeTransition IsStaggeringEnabled="True" FromVerticalOffset="30" />
            </TransitionCollection>
        </Grid.Transitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="320" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- LEFT SIDEBAR - Redesigned -->
        <Border Style="{StaticResource ModernCardStyle}" Translation="0,0,32" VerticalAlignment="Stretch">
            <Border.Shadow><ThemeShadow/></Border.Shadow>
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- Header Section -->
                <StackPanel Grid.Row="0" Spacing="16" Margin="0,0,0,24">
                    <!-- Modern Header Badge -->
                    <Border Background="#13096e" CornerRadius="12" Padding="16,12">
                        <StackPanel Orientation="Horizontal" Spacing="12">
                            <Border Width="36" Height="36" CornerRadius="10" Background="White" Opacity="0.2">
                                <FontIcon Glyph="&#xE8A5;" FontSize="16" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                            <StackPanel Spacing="2">
                                <TextBlock Text="Template Studio" FontSize="14" FontWeight="Bold" Foreground="White" />
                                <TextBlock Text="Schema Builder v2.4" FontSize="10" Foreground="White" Opacity="0.8" />
                            </StackPanel>
                        </StackPanel>
                    </Border>
                    
                    <!-- Action Buttons -->
                    <StackPanel Spacing="12">
                        <Button
                            Style="{StaticResource GlowButtonStyle}"
                            HorizontalAlignment="Stretch"
                            Height="44"
                            Command="{Binding StartNewCustomTemplateCommand}"
                            IsEnabled="{Binding CanAddAnotherTemplate}"
                            Visibility="{Binding CanAddAnotherTemplate, Converter={StaticResource BoolToVisibilityConverter}}">
                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <FontIcon Glyph="&#xE710;" FontSize="14" />
                                <TextBlock Text="Create New Template" FontSize="13" />
                            </StackPanel>
                        </Button>

                        <Grid ColumnSpacing="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            
                            <Button
                                Grid.Column="0"
                                Style="{StaticResource ModernOutlineButtonStyle}"
                                HorizontalAlignment="Stretch"
                                Height="36"
                                FontSize="11"
                                Content="Import From CSV"
                                Click="OnImportCsvClick"
                                IsEnabled="{Binding ShowTemplatePreviewPanel}" />

                            <Button
                                x:Name="ViewFavouritesButton"
                                Grid.Column="1"
                                Style="{StaticResource ModernOutlineButtonStyle}"
                                HorizontalAlignment="Stretch"
                                Height="36"
                                FontSize="11"
                                Command="{Binding ShowFavouritesCommand}"
                                PointerEntered="OnFavouritesButtonPointerEntered"
                                PointerExited="OnFavouritesButtonPointerExited">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <FontIcon Glyph="&#xE735;" FontSize="11" />
                                    <TextBlock Text="Favorites" FontSize="11" />
                                </StackPanel>
                            </Button>
                        </Grid>
                    </StackPanel>
                </StackPanel>

                <!-- Templates List -->
                <Grid Grid.Row="3" RowSpacing="12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="Your All Templates" FontSize="11" Foreground="#ffffff" FontWeight="Bold" CharacterSpacing="60" />

                    <ListView
                        Grid.Row="1"
                        x:Name="TemplatesList"
                        ItemsSource="{Binding Templates}"
                        SelectedItem="{Binding SelectedTemplate, Mode=TwoWay}"
                        Visibility="{Binding ShowTemplateList, Converter={StaticResource BoolToVisibilityConverter}}"
                        SelectionMode="Single"
                        Background="Transparent"
                        ContainerContentChanging="OnListViewContainerContentChanging">
                        <ListView.ItemContainerStyle>
                            <Style TargetType="ListViewItem">
                                <Setter Property="Padding" Value="0" />
                                <Setter Property="Margin" Value="0,2" />
                                <Setter Property="MinHeight" Value="0" />
                                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ListViewItem">
                                            <Border x:Name="Root" Background="Transparent" CornerRadius="8">
                                                <VisualStateManager.VisualStateGroups>
                                                    <VisualStateGroup x:Name="CommonStates">
                                                        <VisualState x:Name="Normal" />
                                                        <VisualState x:Name="PointerOver">
                                                            <Storyboard>
                                                                <ObjectAnimationUsingKeyFrames Storyboard.TargetName="Root" Storyboard.TargetProperty="Background">
                                                                    <DiscreteObjectKeyFrame KeyTime="0" Value="{StaticResource RowHoverBackgroundBrush}" />
                                                                </ObjectAnimationUsingKeyFrames>
                                                            </Storyboard>
                                                        </VisualState>
                                                        <VisualState x:Name="Selected">
                                                            <Storyboard>
                                                                <ObjectAnimationUsingKeyFrames Storyboard.TargetName="Root" Storyboard.TargetProperty="Background">
                                                                    <DiscreteObjectKeyFrame KeyTime="0" Value="{StaticResource RowSelectedBackgroundBrush}" />
                                                                </ObjectAnimationUsingKeyFrames>
                                                            </Storyboard>
                                                        </VisualState>
                                                    </VisualStateGroup>
                                                </VisualStateManager.VisualStateGroups>
                                                <ContentPresenter x:Name="ContentPresenter" Padding="12,10" />
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ListView.ItemContainerStyle>
                        <ListView.ItemTemplate>
                            <DataTemplate x:DataType="models:PartTemplateDefinition">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" Spacing="4">
                                        <TextBlock Text="{Binding Name}" FontSize="13" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <TextBlock Text="{Binding Fields.Count}" FontSize="10" Foreground="#1F7AE0" FontWeight="SemiBold" />
                                            <TextBlock Text="fields" FontSize="10" Foreground="{StaticResource TextTertiaryBrush}" />
                                            <TextBlock Text="•" FontSize="10" Foreground="{StaticResource TextTertiaryBrush}" />
                                            <TextBlock Text="Active" FontSize="10" Foreground="{StaticResource SuccessBrush}" />
                                        </StackPanel>
                                    </StackPanel>
                                    <Button
                                        Grid.Column="1"
                                        Style="{StaticResource GhostButtonStyle}"
                                        Width="32"
                                        Height="32"
                                        Padding="0"
                                        VerticalAlignment="Center"
                                        AutomationProperties.Name="{Binding Name}"
                                        Click="OnStarButtonClick">
                                        <FontIcon
                                            x:Name="StarIcon"
                                            FontSize="14"
                                            Glyph="&#xE734;"
                                            Foreground="{StaticResource TextSecondaryBrush}" />
                                    </Button>
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </Grid>

                <!-- Footer -->
                <StackPanel Grid.Row="4" Spacing="8" Margin="0,16,0,0">
                    <!-- Import Status Panel -->
                    <Border x:Name="ImportStatusPanel" Visibility="Collapsed" Background="{StaticResource CardBackgroundBrush}" CornerRadius="8" Padding="12" BorderBrush="#2A3D58" BorderThickness="1">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <ProgressRing x:Name="ImportProgressRing" Width="16" Height="16" IsActive="True" />
                            <StackPanel Spacing="2">
                                <TextBlock x:Name="ImportStatusText" Text="Import in progress..." FontSize="12" FontWeight="SemiBold" />
                                <TextBlock
                                    x:Name="ImportStatusDetailText"
                                    Foreground="{StaticResource TextSecondaryBrush}"
                                    FontSize="10"
                                    TextWrapping="WrapWholeWords" />
                            </StackPanel>
                        </StackPanel>
                    </Border>
                    
                    <Border Height="1" Background="{StaticResource BorderDefaultBrush}" Opacity="0.3" />
                    <StackPanel Orientation="Horizontal" Spacing="16">
                        <TextBlock Text="Support" FontSize="10" Foreground="#ffffff" />
                        <TextBlock Text="Documentation" FontSize="10" Foreground="#ffffff" />
                    </StackPanel>
                </StackPanel>
            </Grid>
        </Border>

        <!-- â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â• -->
        <!-- RIGHT CONTENT AREA                                     -->
        <!-- â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â• -->
        <!-- Favourites sub-page -->
        <components:FavouritesSubPage
            x:Name="FavouritesSubPageControl"
            Grid.Column="1"
            Padding="24"
            Visibility="{Binding ShowFavouritesSubPage, Converter={StaticResource BoolToVisibilityConverter}}" />

        <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto" Background="{StaticResource PageBackgroundBrush}"
                      Visibility="{Binding ShowFavouritesSubPage, Converter={StaticResource InvertedBoolToVisibilityConverter}}">
            <StackPanel Spacing="0" Padding="20,16,20,24" HorizontalAlignment="Stretch">

                <!-- â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â• -->
                <!-- HEADER                                     -->
                <!-- â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â• -->
                <StackPanel Spacing="2" Margin="0,0,0,14">
                    <TextBlock Text="TEMPLATES" FontSize="10" Foreground="{StaticResource AccentPrimaryBrush}" CharacterSpacing="100" FontWeight="SemiBold" />
                    <TextBlock Text="Schema Builder" FontSize="32" FontWeight="Light" CharacterSpacing="20" />
                    <TextBlock Text="Design and manage data schemas for your parts. Define columns, data types, and validation rules to structure your inventory." FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" TextWrapping="WrapWholeWords" />
                </StackPanel>

                <!-- â”€â”€ DB Missing Banner â”€â”€ -->
                <Border
                    Margin="0,0,0,14"
                    Padding="10,8"
                    CornerRadius="8"
                    Background="#16142e"
                    BorderBrush="{StaticResource DangerBrush}"
                    BorderThickness="1"
                    Visibility="{Binding ShowDbMissingBanner, Converter={StaticResource BoolToVisibilityConverter}}">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon Glyph="&#xE7BA;" FontSize="13" Foreground="{StaticResource DangerBrush}" VerticalAlignment="Center" />
                        <TextBlock
                            Text="No tenant database configured. Complete setup with a valid organization and database connection."
                            FontSize="12"
                            Foreground="{StaticResource DangerBrush}"
                            TextWrapping="WrapWholeWords"
                            VerticalAlignment="Center" />
                    </StackPanel>
                </Border>

                <!-- â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â• -->
                <!-- TEMPLATE EDITOR (New/Edit Template) - Redesigned -->
                <Grid Visibility="{Binding ShowTemplateEditor, Converter={StaticResource BoolToVisibilityConverter}}" ColumnSpacing="20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1.3*" />
                        <ColumnDefinition Width="1*" />
                    </Grid.ColumnDefinitions>

                    <!-- LEFT: Schema Editor Card -->
                    <Border Grid.Column="0"
                            Background="{StaticResource ElevatedCardBackgroundBrush}"
                            BorderBrush="{StaticResource BorderDefaultBrush}"
                            BorderThickness="1" CornerRadius="16" Padding="0" Translation="0,0,24">
                        <Border.Shadow><ThemeShadow/></Border.Shadow>
                        <StackPanel Spacing="0">
                            <Border Height="4" CornerRadius="16,16,0,0" Background="#1F7AE0" />
                            <StackPanel Spacing="0" Padding="24,20,24,24">

                                <!-- Header -->
                                <Grid Margin="0,0,0,16">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Spacing="4" Margin="0,0,12,0">
                                        <TextBlock Text="{Binding EditorHeaderTitle}" FontSize="11" FontWeight="Bold" Foreground="#1F7AE0" CharacterSpacing="80" />
                                        <TextBox Style="{StaticResource StandardTextBoxStyle}"
                                                 IsReadOnly="{Binding IsTemplateNameReadOnly}"
                                                 PlaceholderText="Enter Template name"
                                                 FontSize="16" FontWeight="SemiBold"
                                                 Background="Transparent" BorderThickness="0,0,0,2"
                                                 BorderBrush="#2A3D58" Padding="0,4,0,6"
                                                 Text="{Binding NewTemplateName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                    </StackPanel>
                                    <Border Grid.Column="1" Background="#0D1E33" BorderBrush="#1F7AE0" BorderThickness="1" CornerRadius="16" Padding="10,5" VerticalAlignment="Bottom">
                                        <StackPanel Orientation="Horizontal" Spacing="5">
                                            <FontIcon Glyph="&#xE80A;" FontSize="10" Foreground="#1F7AE0" />
                                            <TextBlock FontSize="11" Foreground="#1F7AE0" FontWeight="SemiBold">
                                                <Run Text="{Binding ColumnLabels.Count}" /><Run Text=" cols" />
                                            </TextBlock>
                                        </StackPanel>
                                    </Border>
                                </Grid>

                                <!-- Column Table Header -->
                                <Border Background="#0D1E33" CornerRadius="8,8,0,0" Padding="12,9">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="26" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="120" />
                                            <ColumnDefinition Width="68" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="#" FontSize="10" Foreground="#1F7AE0" FontWeight="Bold" VerticalAlignment="Center" />
                                        <TextBlock Grid.Column="1" Text="tbl Name" FontSize="10" Foreground="#1F7AE0" FontWeight="Bold" CharacterSpacing="60" VerticalAlignment="Center" Margin="8,0,0,0" />
                                        <TextBlock Grid.Column="2" Text="Data Type" FontSize="10" Foreground="#1F7AE0" FontWeight="Bold" CharacterSpacing="60" VerticalAlignment="Center" />
                                        <TextBlock Grid.Column="3" Text="ACT." FontSize="10" Foreground="#1F7AE0" FontWeight="Bold" CharacterSpacing="60" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                    </Grid>
                                </Border>

                                <!-- Column Rows -->
                                <Border Background="{StaticResource CardBackgroundBrush}" BorderBrush="#2A3D58" BorderThickness="1,0,1,1" CornerRadius="0,0,8,8" Margin="0,0,0,12">
                                    <ItemsControl ItemsSource="{Binding ColumnLabels}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border BorderBrush="#1A2A3E" BorderThickness="0,0,0,1" Padding="12,0">
                                                    <Grid MinHeight="46">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="26" />
                                                            <ColumnDefinition Width="*" />
                                                            <ColumnDefinition Width="120" />
                                                            <ColumnDefinition Width="34" />
                                                            <ColumnDefinition Width="34" />
                                                        </Grid.ColumnDefinitions>

                                                        <!-- Row index badge -->
                                                        <Border Grid.Column="0" Width="20" Height="20" CornerRadius="5" Background="#0D1E33" VerticalAlignment="Center">
                                                            <FontIcon Glyph="&#xE80A;" FontSize="9" Foreground="#4A6080" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                        </Border>

                                                        <!-- Column Name -->
                                                        <TextBox Grid.Column="1"
                                                                 FontSize="12" PlaceholderText="Tbl Name"
                                                                 Background="Transparent" BorderThickness="0"
                                                                 Padding="8,0" VerticalAlignment="Center"
                                                                 Text="{Binding Label, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                                                        <!-- Type ComboBox -->
                                                        <ComboBox Grid.Column="2"
                                                                  FontSize="11"
                                                                  Background="#0D1E33" BorderBrush="#2A3D58" BorderThickness="1" CornerRadius="6"
                                                                  Padding="6,3" HorizontalAlignment="Stretch" VerticalAlignment="Center"
                                                                  DisplayMemberPath="Label"
                                                                  ItemsSource="{Binding DataContext.FieldTypeOptions, ElementName=TemplatesPageRoot}"
                                                                  SelectedValue="{Binding FieldType, Mode=TwoWay}"
                                                                  SelectedValuePath="Value" />

                                                        <!-- Delete -->
                                                        <Button Grid.Column="3"
                                                                Style="{StaticResource GhostButtonStyle}"
                                                                Width="30" Height="30" Padding="0" VerticalAlignment="Center"
                                                                Click="OnRemoveColumnClick"
                                                                ToolTipService.ToolTip="Remove column">
                                                            <FontIcon Glyph="&#xE74D;" FontSize="12" Foreground="{StaticResource DangerBrush}" />
                                                        </Button>

                                                        <!-- Insert below -->
                                                        <Button Grid.Column="4"
                                                                Style="{StaticResource GhostButtonStyle}"
                                                                Width="30" Height="30" Padding="0" VerticalAlignment="Center"
                                                                Click="OnInsertDraftColumnClick" Opacity="0.45"
                                                                PointerEntered="OnAffordancePointerEntered"
                                                                PointerExited="OnAffordancePointerExited"
                                                                ToolTipService.ToolTip="Insert column below">
                                                            <FontIcon Glyph="&#xE710;" FontSize="11" Foreground="#ffffffff" />
                                                        </Button>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </Border>

                                <!-- Add Column Button -->
                                <Button Style="{StaticResource GhostButtonStyle}" HorizontalAlignment="Stretch" Command="{Binding AddColumnCommand}" Margin="0,0,0,16" Height="40">
                                    <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Center">
                                        <FontIcon Glyph="&#xE710;" FontSize="13" Foreground="#ffffffff" />
                                        <TextBlock Text="Add New Column" FontSize="12" Foreground="#ffffffff" FontWeight="SemiBold" />
                                    </StackPanel>
                                </Button>

                                <Border Height="1" Background="#200a9cff" Margin="0,0,0,20" />

                                <!-- Error -->
                                <Border Background="#1A0A0A" BorderBrush="{StaticResource DangerBrush}" BorderThickness="1" CornerRadius="8"
                                        Padding="14,10" Margin="0,0,0,16"
                                        Visibility="{Binding FormError, Converter={StaticResource StringToVisibilityConverter}}">
                                    <StackPanel Orientation="Horizontal" Spacing="10">
                                        <FontIcon Glyph="&#xE783;" FontSize="14" Foreground="{StaticResource DangerBrush}" VerticalAlignment="Center" />
                                        <TextBlock Foreground="{StaticResource DangerBrush}" Text="{Binding FormError}" FontSize="12" TextWrapping="WrapWholeWords" VerticalAlignment="Center" />
                                    </StackPanel>
                                </Border>

                                <!-- Action Buttons -->
                                <Grid ColumnSpacing="12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="1.6*" />
                                    </Grid.ColumnDefinitions>
                                    <Button Grid.Column="0" Style="{StaticResource GhostButtonStyle}"
                                            Command="{Binding CancelCreateCommand}" HorizontalAlignment="Stretch"
                                            Height="44" BorderBrush="#2A3D58" BorderThickness="1" CornerRadius="10">
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <FontIcon Glyph="&#xE711;" FontSize="13" Foreground="#AAB8CA" />
                                            <TextBlock Text="Cancel" FontSize="13" Foreground="#AAB8CA" />
                                        </StackPanel>
                                    </Button>
                                    <Button Grid.Column="1" Command="{Binding SaveTemplateCommand}"
                                            HorizontalAlignment="Stretch" Height="44"
                                            Background="#1F7AE0" Foreground="White"
                                            BorderThickness="0" CornerRadius="10" FontWeight="SemiBold">
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <FontIcon Glyph="&#xE74E;" FontSize="14" Foreground="White" />
                                            <TextBlock Text="Save Template" FontSize="13" FontWeight="SemiBold" />
                                        </StackPanel>
                                    </Button>
                                </Grid>

                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- RIGHT: Live Preview + Tips -->
                    <StackPanel Grid.Column="1" Spacing="16">

                        <!-- Live Preview Card -->
                        <Border Background="{StaticResource ElevatedCardBackgroundBrush}"
                                BorderBrush="{StaticResource BorderDefaultBrush}"
                                BorderThickness="1" CornerRadius="16" Padding="0" Translation="0,0,16">
                            <Border.Shadow><ThemeShadow/></Border.Shadow>
                            <StackPanel Spacing="0">
                                <Border Height="4" CornerRadius="16,16,0,0" Background="#2ABD8F" />
                                <StackPanel Spacing="16" Padding="20,16,20,20">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Spacing="2">
                                            <TextBlock Text="LIVE PREVIEW" FontSize="10" Foreground="#2ABD8F" FontWeight="Bold" CharacterSpacing="80" />
                                            <TextBlock Text="Schema Visualization" FontSize="15" FontWeight="SemiBold" />
                                        </StackPanel>
                                        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="5" VerticalAlignment="Center">
                                            <Ellipse Width="7" Height="7" Fill="#FF5F57" />
                                            <Ellipse Width="7" Height="7" Fill="#FEBC2E" />
                                            <Ellipse Width="7" Height="7" Fill="#28C840" />
                                        </StackPanel>
                                    </Grid>
                                    <Border CornerRadius="10" BorderBrush="#2A3D58" BorderThickness="1">
                                        <StackPanel>
                                            <Border Background="#1F7AE0" Padding="12,10">
                                                <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
                                                    <ItemsControl ItemsSource="{Binding ColumnLabels}">
                                                        <ItemsControl.ItemsPanel>
                                                            <ItemsPanelTemplate>
                                                                <StackPanel Orientation="Horizontal" Spacing="20" />
                                                            </ItemsPanelTemplate>
                                                        </ItemsControl.ItemsPanel>
                                                        <ItemsControl.ItemTemplate>
                                                            <DataTemplate>
                                                                <TextBlock Text="{Binding Label}" FontSize="11" FontWeight="Bold" Foreground="White" MinWidth="90" />
                                                            </DataTemplate>
                                                        </ItemsControl.ItemTemplate>
                                                    </ItemsControl>
                                                </ScrollViewer>
                                            </Border>
                                            <Border Background="{StaticResource CardBackgroundBrush}" Padding="12,10">
                                                <ItemsControl ItemsSource="{Binding ColumnLabels}">
                                                    <ItemsControl.ItemsPanel>
                                                        <ItemsPanelTemplate>
                                                            <StackPanel Orientation="Horizontal" Spacing="20" />
                                                        </ItemsPanelTemplate>
                                                    </ItemsControl.ItemsPanel>
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <TextBlock Text="{Binding SampleValue1}" FontSize="11" Foreground="{StaticResource TextTertiaryBrush}" MinWidth="90" />
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </Border>
                                            <Border Background="#0E1623" Padding="12,10">
                                                <ItemsControl ItemsSource="{Binding ColumnLabels}">
                                                    <ItemsControl.ItemsPanel>
                                                        <ItemsPanelTemplate>
                                                            <StackPanel Orientation="Horizontal" Spacing="20" />
                                                        </ItemsPanelTemplate>
                                                    </ItemsControl.ItemsPanel>
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <TextBlock Text="{Binding SampleValue2}" FontSize="11" Foreground="{StaticResource TextTertiaryBrush}" MinWidth="90" />
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </Border>
                                        </StackPanel>
                                    </Border>
                                    <Border Background="#0D1E33" CornerRadius="8" Padding="12,8">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Orientation="Horizontal" Spacing="16">
                                                <StackPanel Orientation="Horizontal" Spacing="4">
                                                    <TextBlock Text="COLS:" FontSize="10" Foreground="#7B8DA8" />
                                                    <TextBlock Text="{Binding ColumnLabels.Count}" FontSize="10" Foreground="#1F7AE0" FontWeight="Bold" />
                                                </StackPanel>
                                                <TextBlock Text="TYPE: DYNAMIC" FontSize="10" Foreground="#7B8DA8" />
                                            </StackPanel>
                                            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="5">
                                                <Ellipse Width="6" Height="6" Fill="#2ABD8F" VerticalAlignment="Center" />
                                                <TextBlock Text="LIVE" FontSize="10" Foreground="#2ABD8F" FontWeight="Bold" />
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- Tips Card -->
                        <Border Background="{StaticResource ElevatedCardBackgroundBrush}"
                                BorderBrush="{StaticResource BorderDefaultBrush}"
                                BorderThickness="1" CornerRadius="16" Padding="0">
                            <StackPanel Spacing="0">
                                <Border Height="4" CornerRadius="16,16,0,0" Background="#FFB781" />
                                <StackPanel Spacing="14" Padding="20,16,20,20">
                                    <StackPanel Orientation="Horizontal" Spacing="12">
                                        <Border Width="36" Height="36" CornerRadius="10" Background="#1A1200">
                                            <FontIcon Glyph="&#xE946;" FontSize="16" Foreground="#FFB781" />
                                        </Border>
                                        <StackPanel Spacing="2" VerticalAlignment="Center">
                                            <TextBlock Text="DESIGN TIPS" FontSize="10" Foreground="#FFB781" FontWeight="Bold" CharacterSpacing="60" />
                                            <TextBlock Text="Schema best practices" FontSize="13" FontWeight="SemiBold" />
                                        </StackPanel>
                                    </StackPanel>
                                    <StackPanel Spacing="10">
                                        <StackPanel Orientation="Horizontal" Spacing="10">
                                            <Border Width="6" Height="6" CornerRadius="3" Background="#1F7AE0" VerticalAlignment="Center" />
                                            <TextBlock Text="Use Number types for quantities to enable alerts" FontSize="12" Foreground="#AAB8CA" TextWrapping="WrapWholeWords" />
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal" Spacing="10">
                                            <Border Width="6" Height="6" CornerRadius="3" Background="#1F7AE0" VerticalAlignment="Center" />
                                            <TextBlock Text="Dropdown fields improve data consistency" FontSize="12" Foreground="#AAB8CA" TextWrapping="WrapWholeWords" />
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal" Spacing="10">
                                            <Border Width="6" Height="6" CornerRadius="3" Background="#1F7AE0" VerticalAlignment="Center" />
                                            <TextBlock Text="RecordLink connects data across templates" FontSize="12" Foreground="#AAB8CA" TextWrapping="WrapWholeWords" />
                                        </StackPanel>
                                    </StackPanel>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                    </StackPanel>
                </Grid>

                <!-- â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â• -->
                <!-- TEMPLATE PREVIEW (Selected Template View)  -->
                <!-- â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â• -->
                <StackPanel Visibility="{Binding ShowTemplatePreviewPanel, Converter={StaticResource BoolToVisibilityConverter}}" Spacing="14">

                    <!-- Configuration Mode header -->
                    <StackPanel Spacing="2">
                        <TextBlock Text="CONFIGURATION MODE" FontSize="10" Foreground="{StaticResource AccentPrimaryBrush}" CharacterSpacing="80" FontWeight="SemiBold" />
                        <TextBlock Text="Select and edit your template schema â€” columns, types and cell actions." FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" />
                    </StackPanel>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="{Binding SelectedTemplate.Name}" FontSize="22" FontWeight="SemiBold" />
                        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
                            <Button Style="{StaticResource GhostButtonStyle}" Content="Discard" FontSize="12" />
                            <Button Style="{StaticResource PrimaryButtonStyle}" Command="{Binding BeginEditSelectedTemplateCommand}" Content="Save Changes" FontSize="12" />
                        </StackPanel>
                    </Grid>

                    <!-- Data Schema Columns section -->
                    <StackPanel Spacing="8">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <FontIcon Glyph="&#xE80A;" FontSize="13" Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center" />
                                <TextBlock Text="Data Schema Columns" FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center" />
                            </StackPanel>
                            <Border Grid.Column="2" Style="{StaticResource GrayBadgeStyle}" Padding="6,2">
                                <TextBlock FontSize="9" Foreground="{StaticResource TextSecondaryBrush}" CharacterSpacing="60">
                                    <Run Text="{Binding SelectedTemplate.Fields.Count}" /><Run Text=" FIELDS DEFINED" />
                                </TextBlock>
                            </Border>
                        </Grid>

                        <!-- Schema chip row -->
                        <ScrollViewer HorizontalScrollBarVisibility="Auto" HorizontalScrollMode="Enabled" VerticalScrollBarVisibility="Disabled" VerticalScrollMode="Disabled" MinHeight="48">
                            <StackPanel
                                x:Name="TemplateChipRowPanel"
                                Orientation="Horizontal"
                                Spacing="4"
                                VerticalAlignment="Center"
                                Margin="0,4,0,4" />
                        </ScrollViewer>
                    </StackPanel>

                    <!-- Cell Actions section -->
                    <Border Background="{StaticResource ElevatedCardBackgroundBrush}" BorderBrush="{StaticResource BorderDefaultBrush}" BorderThickness="1" CornerRadius="4" Padding="14" Visibility="{Binding ShowContextActionsEditor, Converter={StaticResource BoolToVisibilityConverter}}">
                        <StackPanel Spacing="10">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <FontIcon Glyph="&#xE945;" FontSize="14" Foreground="{StaticResource AccentPrimaryBrush}" />
                                <TextBlock Text="Cell Actions" FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center" />
                            </StackPanel>
                            <TextBlock
                                Foreground="{StaticResource TextSecondaryBrush}"
                                FontSize="11"
                                Text="Define right-click actions for specific cell types in Explorer."
                                TextWrapping="WrapWholeWords" />

                            <!-- Action cards grid -->
                            <ListView
                                MaxHeight="200"
                                SelectedItem="{Binding SelectedContextAction, Mode=TwoWay}"
                                ItemsSource="{Binding ContextActionRows}"
                                SelectionMode="Single">
                                <ListView.ItemContainerStyle>
                                    <Style TargetType="ListViewItem">
                                        <Setter Property="Padding" Value="0" />
                                        <Setter Property="Margin" Value="0,0,8,8" />
                                        <Setter Property="MinHeight" Value="0" />
                                    </Style>
                                </ListView.ItemContainerStyle>
                                <ListView.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <ItemsWrapGrid Orientation="Horizontal" ItemWidth="200" />
                                    </ItemsPanelTemplate>
                                </ListView.ItemsPanel>
                                <ListView.ItemTemplate>
                                    <DataTemplate x:DataType="viewmodels:ContextActionListRow">
                                        <Border Background="{StaticResource CardBackgroundBrush}" BorderBrush="{StaticResource BorderDefaultBrush}" BorderThickness="1" CornerRadius="8" Padding="12" Translation="0,0,32">
                            <Border.Shadow><ThemeShadow/></Border.Shadow>
                            <StackPanel Spacing="6">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto" />
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>
                                                    <Border Width="28" Height="28" CornerRadius="6" Background="{StaticResource GridHeaderBackgroundBrush}">
                                                        <FontIcon Glyph="&#xE8A5;" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" />
                                                    </Border>
                                                    <FontIcon Grid.Column="2" Glyph="&#xE74D;" FontSize="12" Foreground="{StaticResource TextTertiaryBrush}" />
                                                </Grid>
                                                <TextBlock Text="{x:Bind Action.MenuLabel}" FontSize="12" FontWeight="SemiBold" />
                                                <TextBlock FontSize="10" Foreground="{StaticResource TextSecondaryBrush}" TextTrimming="CharacterEllipsis">
                                                    <Run Text="â†’ " /><Run Text="{x:Bind TargetTemplateName}" />
                                                </TextBlock>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>



                            <!-- Add cell action (dashed) -->
                            <Border
                                Padding="14,10"
                                CornerRadius="8"
                                BorderBrush="{StaticResource BorderDefaultBrush}"
                                BorderThickness="1"
                                HorizontalAlignment="Left">
                                <Button Style="{StaticResource GhostButtonStyle}" Click="OnAddContextActionClick" FontSize="12">
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                        <FontIcon Glyph="&#xE710;" FontSize="12" />
                                        <TextBlock Text="ADD CELL ACTION" FontSize="10" CharacterSpacing="60" VerticalAlignment="Center" />
                                    </StackPanel>
                                </Button>
                            </Border>

                            <Button Style="{StaticResource GhostButtonStyle}" Command="{Binding DeleteContextActionCommand}" Content="Remove selected" FontSize="11" HorizontalAlignment="Left" />
                        </StackPanel>
                    </Border>

                    <!-- Template Usage Analysis + Help -->
                    <Grid ColumnSpacing="14">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2*" />
                            <ColumnDefinition Width="1*" />
                        </Grid.ColumnDefinitions>

                        <!-- Usage Analysis -->
                        <Border Grid.Column="0" Background="{StaticResource ElevatedCardBackgroundBrush}" BorderBrush="{StaticResource BorderDefaultBrush}" BorderThickness="1" CornerRadius="4" Padding="14">
                            <StackPanel Spacing="10">
                                <TextBlock Text="Template Usage Analysis" FontSize="14" FontWeight="SemiBold" />
                                <Grid ColumnSpacing="10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.Column="0" Background="{StaticResource CardBackgroundBrush}" BorderBrush="{StaticResource BorderDefaultBrush}" BorderThickness="1" CornerRadius="4" Padding="12,10">
                                        <StackPanel Spacing="4">
                                            <TextBlock Text="ACTIVE PROJECTS" FontSize="9" Foreground="{StaticResource TextTertiaryBrush}" CharacterSpacing="60" />
                                            <TextBlock Text="14" FontSize="20" FontWeight="SemiBold" />
                                        </StackPanel>
                                    </Border>
                                    <Border Grid.Column="1" Background="{StaticResource CardBackgroundBrush}" BorderBrush="{StaticResource BorderDefaultBrush}" BorderThickness="1" CornerRadius="4" Padding="12,10">
                                        <StackPanel Spacing="4">
                                            <TextBlock Text="DATA DENSITY" FontSize="9" Foreground="{StaticResource TextTertiaryBrush}" CharacterSpacing="60" />
                                            <TextBlock Text="82%" FontSize="20" FontWeight="SemiBold" />
                                        </StackPanel>
                                    </Border>
                                    <Border Grid.Column="2" Background="{StaticResource CardBackgroundBrush}" BorderBrush="{StaticResource BorderDefaultBrush}" BorderThickness="1" CornerRadius="4" Padding="12,10">
                                        <StackPanel Spacing="4">
                                            <TextBlock Text="INTEGRITY SCORE" FontSize="9" Foreground="{StaticResource TextTertiaryBrush}" CharacterSpacing="60" />
                                            <TextBlock Text="9.8" FontSize="20" FontWeight="SemiBold" />
                                        </StackPanel>
                                    </Border>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- Template Integrity panel -->
                        <Border Grid.Column="1" Background="{StaticResource ElevatedCardBackgroundBrush}" BorderBrush="{StaticResource BorderDefaultBrush}" BorderThickness="1" CornerRadius="4" Padding="14">
                            <StackPanel Spacing="8">
                                <TextBlock Text="TEMPLATE INTEGRITY" FontSize="10" Foreground="{StaticResource TextSecondaryBrush}" CharacterSpacing="60" FontWeight="SemiBold" />
                                <StackPanel Spacing="4">
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                        <Ellipse Width="6" Height="6" Fill="{StaticResource SuccessBrush}" VerticalAlignment="Center" />
                                        <TextBlock Text="Schema validation passed" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" />
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                        <Ellipse Width="6" Height="6" Fill="{StaticResource SuccessBrush}" VerticalAlignment="Center" />
                                        <TextBlock Text="Actions compatible with Fluent UI" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" />
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                        <Ellipse Width="6" Height="6" Fill="{StaticResource WarningBrush}" VerticalAlignment="Center" />
                                        <TextBlock Text="Review linked templates" FontSize="11" Foreground="{StaticResource WarningBrush}" />
                                    </StackPanel>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </Grid>
                </StackPanel>

                <!-- â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â• -->
                <!-- SELECT TEMPLATE PROMPT                     -->
                <!-- â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â• -->
                <StackPanel Visibility="{Binding ShowSelectTemplatePromptPanel, Converter={StaticResource BoolToVisibilityConverter}}">
                    <components:PageHeader Subtitle="Select a template on the left to preview its columns." Title="Templates" />
                </StackPanel>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>