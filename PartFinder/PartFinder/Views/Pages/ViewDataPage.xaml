<Page
    x:Class="PartFinder.Views.Pages.ViewDataPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:components="using:PartFinder.Views.Components"
    xmlns:converters="using:PartFinder.Converters"
    xmlns:viewModels="using:PartFinder.ViewModels">
    <Page.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter" />
    </Page.Resources>

    <Grid Padding="20" ColumnSpacing="12">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="280" />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <components:PageHeader
            Grid.ColumnSpan="2"
            Title="View Data"
            Subtitle="Enriched row view with linked vendor details." />

        <Grid Grid.Row="1" Grid.Column="0">
            <StackPanel Spacing="12">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <ComboBox
                        Width="320"
                        DisplayMemberPath="Name"
                        ItemsSource="{Binding Templates}"
                        SelectedItem="{Binding SelectedTemplate, Mode=TwoWay}"
                        PlaceholderText="Select template to view" />
                    <Button Command="{Binding LoadViewDataCommand}" Content="Refresh" />
                </StackPanel>

                <TextBlock Foreground="IndianRed" Text="{Binding ErrorMessage}" TextWrapping="WrapWholeWords" />

                <Border Style="{ThemeResource AppCardBorderStyle}">
                    <Grid>
                        <ListView
                            x:Name="RowsListView"
                            MinHeight="420"
                            ItemsSource="{Binding Rows}"
                            SelectionMode="Single"
                            SelectedItem="{Binding HoveredRow, Mode=TwoWay}">
                            <ListView.ItemTemplate>
                                <DataTemplate x:DataType="viewModels:ViewDataRowItem">
                                    <Border
                                        Tag="{x:Bind}"
                                        PointerEntered="OnRowPointerEntered"
                                        PointerExited="OnRowPointerExited"
                                        Margin="0,0,0,1"
                                        Padding="10"
                                        BorderThickness="0,0,0,1"
                                        BorderBrush="{ThemeResource AppBorderBrush}">
                                        <StackPanel Spacing="6">
                                        <TextBlock Text="{x:Bind Row.RowId}" FontWeight="SemiBold" />
                                        <TextBlock
                                            Foreground="{ThemeResource AppSubtleTextBrush}"
                                            Text="{x:Bind PrimaryPreview, Mode=OneWay}"
                                            TextTrimming="CharacterEllipsis" />
                                        <StackPanel Orientation="Horizontal" Spacing="6">
                                            <Ellipse Width="8" Height="8" Fill="{StaticResource SuccessBrush}" />
                                            <TextBlock
                                                Foreground="{ThemeResource AppSubtleTextBrush}"
                                                Text="{x:Bind MatchedRelations, Mode=OneWay}" />
                                            <TextBlock
                                                Foreground="{ThemeResource AppSubtleTextBrush}"
                                                Text="/" />
                                            <Ellipse Width="8" Height="8" Fill="{StaticResource TextTertiaryBrush}" />
                                            <TextBlock
                                                Foreground="{ThemeResource AppSubtleTextBrush}"
                                                Text="{x:Bind TotalRelations, Mode=OneWay}" />
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal" Spacing="6">
                                            <TextBlock Foreground="{ThemeResource AppSubtleTextBrush}" Text="Vendor Info" />
                                            <Ellipse Width="8" Height="8" Fill="{StaticResource SuccessBrush}" />
                                        </StackPanel>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                        <ProgressRing
                            Width="40"
                            Height="40"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            IsActive="{Binding IsLoading}" />
                    </Grid>
                </Border>
            </StackPanel>
        </Grid>

        <Border
            x:Name="DetailsPanel"
            Grid.Row="1"
            Grid.Column="1"
            PointerEntered="OnDetailsPanelPointerEntered"
            PointerExited="OnDetailsPanelPointerExited"
            Background="White"
            BorderBrush="{ThemeResource AppBorderBrush}"
            BorderThickness="1,0,0,0"
            Padding="12"
            Visibility="{Binding IsFlyoutOpen, Converter={StaticResource BoolToVisibilityConverter}}">
            <Border.RenderTransform>
                <TranslateTransform x:Name="DetailsPanelTransform" X="24" />
            </Border.RenderTransform>
            <ScrollViewer>
                <StackPanel Spacing="10">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Stretch">
                        <TextBlock Text="PART DETAILS" Style="{ThemeResource AppSectionTextStyle}" />
                        <Button Content="Close" HorizontalAlignment="Right" Command="{Binding CloseFlyoutCommand}" />
                    </StackPanel>
                    <ItemsControl ItemsSource="{Binding HoveredRowPrimaryDetails}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding DisplayText}" TextWrapping="WrapWholeWords" />
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <TextBlock Text="VENDOR INFORMATION" Style="{ThemeResource AppSectionTextStyle}" Margin="0,8,0,0" />
                    <Border
                        Background="{StaticResource GridHeaderBackgroundBrush}"
                        Padding="10"
                        CornerRadius="8"
                        BorderBrush="{ThemeResource AppBorderBrush}"
                        BorderThickness="1">
                        <ItemsControl ItemsSource="{Binding HoveredRowLinkedDetails}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding DisplayText}" TextWrapping="WrapWholeWords" />
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Border>

                    <TextBlock Text="All Relation Status" Style="{ThemeResource AppSectionTextStyle}" Margin="0,8,0,0" />
                    <ItemsControl ItemsSource="{Binding HoveredRelationSections}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="viewModels:RelationDetailSection">
                                <Border
                                    Margin="0,0,0,8"
                                    Padding="8"
                                    BorderBrush="{ThemeResource AppBorderBrush}"
                                    BorderThickness="1">
                                    <StackPanel Spacing="6">
                                        <StackPanel Orientation="Horizontal" Spacing="6">
                                            <Ellipse
                                                Width="8"
                                                Height="8"
                                                Fill="{StaticResource SuccessBrush}" />
                                            <TextBlock Text="{x:Bind Title}" FontWeight="SemiBold" />
                                            <TextBlock
                                                Foreground="{ThemeResource AppSubtleTextBrush}"
                                                Text="{x:Bind MatchLabel, Mode=OneWay}" />
                                        </StackPanel>
                                        <ItemsControl ItemsSource="{x:Bind Details, Mode=OneWay}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <TextBlock Text="{Binding DisplayText}" TextWrapping="WrapWholeWords" />
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </ScrollViewer>
        </Border>
    </Grid>
</Page>
