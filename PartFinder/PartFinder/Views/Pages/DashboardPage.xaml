<Page
    x:Class="PartFinder.Views.Pages.DashboardPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:components="using:PartFinder.Views.Components"
    xmlns:lvc="using:LiveChartsCore.SkiaSharpView.WinUI"
    xmlns:viewModels="using:PartFinder.ViewModels">
    <ScrollViewer>
        <StackPanel Padding="20" Spacing="16">
            <components:PageHeader Title="Dashboard" Subtitle="Operational overview for parts and templates" />

            <ItemsControl ItemsSource="{Binding Kpis}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <ItemsWrapGrid Orientation="Horizontal" ItemWidth="250" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="viewModels:KpiItem">
                        <components:KpiCard Label="{x:Bind Label}" Value="{x:Bind Value, Mode=OneWay}" Delta="{x:Bind Delta, Mode=OneWay}" />
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <Grid ColumnSpacing="16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Border Grid.Column="0" Style="{ThemeResource AppCardBorderStyle}">
                    <StackPanel Spacing="8">
                        <TextBlock Text="Parts Trend" Style="{ThemeResource AppSectionTextStyle}" />
                        <Grid>
                            <lvc:CartesianChart Height="240" Series="{Binding TrendSeries}" />
                            <ProgressRing
                                Width="30"
                                Height="30"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                IsActive="{Binding IsLoading}" />
                        </Grid>
                    </StackPanel>
                </Border>
                <Border Grid.Column="1" Style="{ThemeResource AppCardBorderStyle}">
                    <StackPanel Spacing="8">
                        <TextBlock Text="Recent Activity" Style="{ThemeResource AppSectionTextStyle}" />
                        <ItemsControl ItemsSource="{Binding RecentActivity}" />
                    </StackPanel>
                </Border>
            </Grid>
        </StackPanel>
    </ScrollViewer>
</Page>
