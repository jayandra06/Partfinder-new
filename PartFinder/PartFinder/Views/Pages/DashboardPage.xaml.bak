<Page
    x:Class="PartFinder.Views.Pages.DashboardPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:components="using:PartFinder.Views.Components"
    xmlns:lvc="using:LiveChartsCore.SkiaSharpView.WinUI"
    xmlns:viewModels="using:PartFinder.ViewModels">

    <ScrollViewer Background="{StaticResource PageBackgroundBrush}">
        <StackPanel Padding="24,20,24,32" Spacing="18" MaxWidth="1400" HorizontalAlignment="Left">

            <!-- ═══════════════════════════════════════════════ -->
            <!-- HEADER                                         -->
            <!-- ═══════════════════════════════════════════════ -->
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Spacing="2">
                    <TextBlock Text="OVERVIEW" FontSize="10" Foreground="{StaticResource TextTertiaryBrush}" CharacterSpacing="80" FontWeight="SemiBold" />
                    <TextBlock Text="Dashboard" FontSize="24" FontWeight="Bold" />
                    <TextBlock Text="Operational overview for parts and templates" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" />
                </StackPanel>

                <!-- Status badge -->
                <Border Grid.Column="1" VerticalAlignment="Center" CornerRadius="8" Padding="10,6" Background="#102ABD8F" BorderBrush="#302ABD8F" BorderThickness="1">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <Ellipse Width="8" Height="8" Fill="{StaticResource SuccessBrush}" VerticalAlignment="Center" />
                        <TextBlock Text="SYSTEM ONLINE" FontSize="9" Foreground="{StaticResource SuccessBrush}" CharacterSpacing="60" FontWeight="SemiBold" />
                    </StackPanel>
                </Border>
            </Grid>

            <!-- ═══════════════════════════════════════════════ -->
            <!-- KPI CARDS ROW                                  -->
            <!-- ═══════════════════════════════════════════════ -->
            <ItemsControl ItemsSource="{Binding Kpis}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <ItemsWrapGrid Orientation="Horizontal" ItemWidth="260" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="viewModels:KpiItem">
                        <components:KpiCard Label="{x:Bind Label}" Value="{x:Bind Value, Mode=OneWay}" Delta="{x:Bind Delta, Mode=OneWay}" />
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <!-- ═══════════════════════════════════════════════ -->
            <!-- ROW 1: Trend Chart + Distribution Pie          -->
            <!-- ═══════════════════════════════════════════════ -->
            <Grid ColumnSpacing="16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2.2*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <!-- Parts Trend Chart -->
                <Border Grid.Column="0" Background="{StaticResource CardBackgroundBrush}" BorderBrush="{StaticResource BorderDefaultBrush}" BorderThickness="1" CornerRadius="10" Padding="18,14">
                    <StackPanel Spacing="12">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Spacing="2">
                                <TextBlock Text="Parts Trend" FontSize="15" FontWeight="SemiBold" />
                                <TextBlock Text="Parts created over time with average baseline" FontSize="11" Foreground="{StaticResource TextTertiaryBrush}" />
                            </StackPanel>
                            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                <Border CornerRadius="6" Padding="8,3" Background="#101F7AE0">
                                    <TextBlock Text="LAST 30 DAYS" FontSize="8" Foreground="{StaticResource AccentPrimaryBrush}" CharacterSpacing="60" FontWeight="SemiBold" />
                                </Border>
                                <Border CornerRadius="6" Padding="8,3" Background="#10FFFFFF">
                                    <TextBlock Text="LIVE" FontSize="8" Foreground="{StaticResource TextTertiaryBrush}" CharacterSpacing="60" FontWeight="SemiBold" />
                                </Border>
                            </StackPanel>
                        </Grid>
                        <Grid>
                            <lvc:CartesianChart
                                Height="260"
                                Series="{Binding TrendSeries}"
                                AnimationsSpeed="00:00:00.6"
                                EasingFunction="{x:Null}">
                            </lvc:CartesianChart>
                            <ProgressRing
                                Width="24"
                                Height="24"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                IsActive="{Binding IsLoading}" />
                        </Grid>
                        <!-- Legend -->
                        <StackPanel Orientation="Horizontal" Spacing="16">
                            <StackPanel Orientation="Horizontal" Spacing="5">
                                <Border Width="16" Height="3" CornerRadius="2" Background="#1F7AE0" VerticalAlignment="Center" />
                                <TextBlock Text="Trend" FontSize="10" Foreground="{StaticResource TextTertiaryBrush}" />
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Spacing="5">
                                <Border Width="16" Height="1" CornerRadius="1" Background="#64647880" VerticalAlignment="Center" />
                                <TextBlock Text="Average" FontSize="10" Foreground="{StaticResource TextTertiaryBrush}" />
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Template Distribution Pie -->
                <Border Grid.Column="1" Background="{StaticResource CardBackgroundBrush}" BorderBrush="{StaticResource BorderDefaultBrush}" BorderThickness="1" CornerRadius="10" Padding="18,14">
                    <StackPanel Spacing="10">
                        <TextBlock Text="Template Distribution" FontSize="15" FontWeight="SemiBold" />
                        <TextBlock Text="Parts per schema category" FontSize="11" Foreground="{StaticResource TextTertiaryBrush}" />
                        <lvc:PieChart
                            Height="200"
                            Series="{Binding DistributionSeries}"
                            AnimationsSpeed="00:00:00.8"
                            InitialRotation="-90" />
                        <!-- Pie legend -->
                        <StackPanel Spacing="4">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <Ellipse Width="8" Height="8" Fill="#1F7AE0" VerticalAlignment="Center" />
                                <TextBlock Text="Turbocharger" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" />
                                <TextBlock Text="42%" FontSize="11" FontWeight="SemiBold" />
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <Ellipse Width="8" Height="8" Fill="#2ABD8F" VerticalAlignment="Center" />
                                <TextBlock Text="Fuel Injector" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" />
                                <TextBlock Text="28%" FontSize="11" FontWeight="SemiBold" />
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <Ellipse Width="8" Height="8" Fill="#FEBC2E" VerticalAlignment="Center" />
                                <TextBlock Text="Valve Assembly" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" />
                                <TextBlock Text="18%" FontSize="11" FontWeight="SemiBold" />
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <Ellipse Width="8" Height="8" Fill="#8B5CF6" VerticalAlignment="Center" />
                                <TextBlock Text="Shaft Log" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" />
                                <TextBlock Text="12%" FontSize="11" FontWeight="SemiBold" />
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- ═══════════════════════════════════════════════ -->
            <!-- ROW 2: Health Gauge + Activity + Quick Actions  -->
            <!-- ═══════════════════════════════════════════════ -->
            <Grid ColumnSpacing="16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="1.4*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <!-- System Health Gauge -->
                <Border Grid.Column="0" Background="{StaticResource CardBackgroundBrush}" BorderBrush="{StaticResource BorderDefaultBrush}" BorderThickness="1" CornerRadius="10" Padding="18,14">
                    <StackPanel Spacing="10">
                        <TextBlock Text="System Health" FontSize="15" FontWeight="SemiBold" />
                        <TextBlock Text="Import pipeline reliability" FontSize="11" Foreground="{StaticResource TextTertiaryBrush}" />
                        <Grid>
                            <lvc:PieChart
                                Height="160"
                                Series="{Binding HealthGaugeSeries}"
                                AnimationsSpeed="00:00:01.0"
                                InitialRotation="225"
                                MaxAngle="270" />
                            <!-- Center label overlay -->
                            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="0">
                                <TextBlock Text="{Binding Kpis[3].Value, Mode=OneWay}" FontSize="22" FontWeight="Bold" HorizontalAlignment="Center" />
                                <TextBlock Text="Success" FontSize="10" Foreground="{StaticResource TextTertiaryBrush}" HorizontalAlignment="Center" />
                            </StackPanel>
                        </Grid>
                        <!-- Health indicators -->
                        <StackPanel Spacing="4">
                            <StackPanel Orientation="Horizontal" Spacing="5">
                                <Ellipse Width="6" Height="6" Fill="{StaticResource SuccessBrush}" VerticalAlignment="Center" />
                                <TextBlock Text="Schema validation" FontSize="10" Foreground="{StaticResource TextSecondaryBrush}" />
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Spacing="5">
                                <Ellipse Width="6" Height="6" Fill="{StaticResource SuccessBrush}" VerticalAlignment="Center" />
                                <TextBlock Text="API connectivity" FontSize="10" Foreground="{StaticResource TextSecondaryBrush}" />
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Spacing="5">
                                <Ellipse Width="6" Height="6" Fill="{StaticResource SuccessBrush}" VerticalAlignment="Center" />
                                <TextBlock Text="Database sync" FontSize="10" Foreground="{StaticResource TextSecondaryBrush}" />
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Recent Activity -->
                <Border Grid.Column="1" Background="{StaticResource CardBackgroundBrush}" BorderBrush="{StaticResource BorderDefaultBrush}" BorderThickness="1" CornerRadius="10" Padding="18,14">
                    <StackPanel Spacing="10">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Spacing="2">
                                <TextBlock Text="Recent Activity" FontSize="15" FontWeight="SemiBold" />
                                <TextBlock Text="Latest operations and system events" FontSize="11" Foreground="{StaticResource TextTertiaryBrush}" />
                            </StackPanel>
                            <Border Grid.Column="1" CornerRadius="6" Padding="8,3" Background="#10FFFFFF" VerticalAlignment="Top">
                                <TextBlock Text="AUTO-REFRESH 60S" FontSize="8" Foreground="{StaticResource TextTertiaryBrush}" CharacterSpacing="60" FontWeight="SemiBold" />
                            </Border>
                        </Grid>
                        <Border Background="{StaticResource ElevatedCardBackgroundBrush}" CornerRadius="8" Padding="10" BorderBrush="{StaticResource BorderDefaultBrush}" BorderThickness="1" MinHeight="200">
                            <ItemsControl ItemsSource="{Binding RecentActivity}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Padding="8,6" Margin="0,0,0,2" CornerRadius="4">
                                            <StackPanel Orientation="Horizontal" Spacing="8">
                                                <Border Width="4" Height="4" CornerRadius="2" Background="{StaticResource AccentPrimaryBrush}" VerticalAlignment="Center" />
                                                <TextBlock Text="{Binding}" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" TextTrimming="CharacterEllipsis" />
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </Border>
                    </StackPanel>
                </Border>

                <!-- Quick Actions -->
                <Border Grid.Column="2" Background="{StaticResource CardBackgroundBrush}" BorderBrush="{StaticResource BorderDefaultBrush}" BorderThickness="1" CornerRadius="10" Padding="18,14">
                    <StackPanel Spacing="12">
                        <TextBlock Text="Quick Actions" FontSize="15" FontWeight="SemiBold" />
                        <TextBlock Text="Common workflows at a glance" FontSize="11" Foreground="{StaticResource TextTertiaryBrush}" />
                        <StackPanel Spacing="6">
                            <!-- Action cards -->
                            <Border Background="{StaticResource ElevatedCardBackgroundBrush}" BorderBrush="{StaticResource BorderDefaultBrush}" BorderThickness="1" CornerRadius="8" Padding="10,8">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <Border Width="28" Height="28" CornerRadius="6" Background="#101F7AE0">
                                        <FontIcon Glyph="&#xE710;" FontSize="12" Foreground="{StaticResource AccentPrimaryBrush}" />
                                    </Border>
                                    <StackPanel Spacing="1" VerticalAlignment="Center">
                                        <TextBlock Text="New Template" FontSize="12" FontWeight="SemiBold" />
                                        <TextBlock Text="Create schema" FontSize="9" Foreground="{StaticResource TextTertiaryBrush}" />
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                            <Border Background="{StaticResource ElevatedCardBackgroundBrush}" BorderBrush="{StaticResource BorderDefaultBrush}" BorderThickness="1" CornerRadius="8" Padding="10,8">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <Border Width="28" Height="28" CornerRadius="6" Background="#102ABD8F">
                                        <FontIcon Glyph="&#xE8B5;" FontSize="12" Foreground="{StaticResource SuccessBrush}" />
                                    </Border>
                                    <StackPanel Spacing="1" VerticalAlignment="Center">
                                        <TextBlock Text="Import Data" FontSize="12" FontWeight="SemiBold" />
                                        <TextBlock Text="CSV or Excel" FontSize="9" Foreground="{StaticResource TextTertiaryBrush}" />
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                            <Border Background="{StaticResource ElevatedCardBackgroundBrush}" BorderBrush="{StaticResource BorderDefaultBrush}" BorderThickness="1" CornerRadius="8" Padding="10,8">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <Border Width="28" Height="28" CornerRadius="6" Background="#10FEBC2E">
                                        <FontIcon Glyph="&#xE8FA;" FontSize="12" Foreground="{StaticResource WarningBrush}" />
                                    </Border>
                                    <StackPanel Spacing="1" VerticalAlignment="Center">
                                        <TextBlock Text="Invite Member" FontSize="12" FontWeight="SemiBold" />
                                        <TextBlock Text="Team access" FontSize="9" Foreground="{StaticResource TextTertiaryBrush}" />
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                            <Border Background="{StaticResource ElevatedCardBackgroundBrush}" BorderBrush="{StaticResource BorderDefaultBrush}" BorderThickness="1" CornerRadius="8" Padding="10,8">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <Border Width="28" Height="28" CornerRadius="6" Background="#108B5CF6">
                                        <FontIcon Glyph="&#xEDE1;" FontSize="12" Foreground="#8B5CF6" />
                                    </Border>
                                    <StackPanel Spacing="1" VerticalAlignment="Center">
                                        <TextBlock Text="Export Report" FontSize="12" FontWeight="SemiBold" />
                                        <TextBlock Text="Excel download" FontSize="9" Foreground="{StaticResource TextTertiaryBrush}" />
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </Grid>

        </StackPanel>
    </ScrollViewer>
</Page>
