<Page
    x:Class="PartFinder.Views.Pages.MasterDataPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:components="using:PartFinder.Views.Components"
    xmlns:converters="using:PartFinder.Converters">
    <Page.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter" />
        <converters:InvertedBoolToVisibilityConverter x:Key="InvertedBoolToVisibilityConverter" />
        <converters:StringToVisibilityConverter x:Key="StringToVisibilityConverter" />
        <Style x:Key="ToolbarSegmentButtonStyle" TargetType="Button" BasedOn="{StaticResource GhostButtonStyle}">
            <Setter Property="Width" Value="40" />
            <Setter Property="Height" Value="40" />
            <Setter Property="MinHeight" Value="40" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}" />
        </Style>
        <Style x:Key="ToolbarConfirmButtonStyle" TargetType="Button" BasedOn="{StaticResource ToolbarSegmentButtonStyle}">
            <Setter Property="Width" Value="44" />
            <Setter Property="Background" Value="{StaticResource SuccessBrush}" />
            <Setter Property="Foreground" Value="{StaticResource TextOnAccentBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource SuccessBrush}" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>
    </Page.Resources>

    <Grid x:Name="RootGrid" Padding="20" Background="Transparent" Transitions="{StaticResource LuxuryPanelTransitions}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="320" />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border
            Grid.Row="0"
            Grid.Column="0"
            HorizontalAlignment="Left"
            Margin="0,0,0,8"
            Padding="10,8"
            Background="{StaticResource ElevatedCardBackgroundBrush}"
            BorderBrush="{StaticResource GlassStrokeBrush}"
            BorderThickness="1"
            CornerRadius="16"
            Visibility="{Binding ShowTemplatePicker, Converter={StaticResource BoolToVisibilityConverter}}">
            <ComboBox
                MinWidth="260"
                HorizontalAlignment="Left"
                FontSize="12"
                DisplayMemberPath="Name"
                ItemsSource="{Binding DataTemplates}"
                PlaceholderText="Choose templateâ€¦"
                SelectedItem="{Binding SelectedDataTemplate, Mode=TwoWay}" />
        </Border>

        <Border
            Grid.Row="0"
            Grid.Column="1"
            HorizontalAlignment="Right"
            Margin="0,0,0,8"
            Padding="0"
            Background="Transparent"
            BorderBrush="Transparent"
            BorderThickness="0"
            Visibility="{Binding IsEditMode, Converter={StaticResource InvertedBoolToVisibilityConverter}}">
            <StackPanel Orientation="Horizontal" Spacing="6">
                <Button
                    Style="{StaticResource ToolbarSegmentButtonStyle}"
                    Foreground="{StaticResource AccentPrimaryBrush}"
                    IsEnabled="{Binding CanEditMasterData}"
                    Click="OnToggleEditModeClicked"
                    ToolTipService.ToolTip="Edit master data">
                    <SymbolIcon Symbol="Edit" />
                </Button>

                <Button
                    Style="{StaticResource ToolbarSegmentButtonStyle}"
                    Click="OnExportTemplateClicked"
                    ToolTipService.ToolTip="Export Excel">
                    <SymbolIcon Symbol="Upload" />
                </Button>

                <Button
                    Style="{StaticResource ToolbarSegmentButtonStyle}"
                    Click="OnImportExcelClicked"
                    IsEnabled="{Binding CanAddMasterData}"
                    ToolTipService.ToolTip="Import Excel">
                    <SymbolIcon Symbol="Download" />
                </Button>
            </StackPanel>
        </Border>

        <Border
            Grid.Row="0"
            Grid.Column="1"
            HorizontalAlignment="Right"
            Margin="0,0,0,8"
            Padding="0"
            Background="Transparent"
            BorderBrush="Transparent"
            BorderThickness="0"
            Visibility="{Binding IsEditMode, Converter={StaticResource BoolToVisibilityConverter}}">
            <StackPanel Orientation="Horizontal" Spacing="6">
                <Button
                    Style="{StaticResource ToolbarConfirmButtonStyle}"
                    Click="OnSaveGridClicked"
                    ToolTipService.ToolTip="Save changes">
                    <SymbolIcon Symbol="Accept" />
                </Button>

                <Button
                    Style="{StaticResource ToolbarSegmentButtonStyle}"
                    Click="OnCancelEditClicked"
                    ToolTipService.ToolTip="Cancel editing">
                    <SymbolIcon Symbol="Cancel" />
                </Button>
            </StackPanel>
        </Border>

        <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,0,0,6" Spacing="6">
            <!-- Status messages -->
            <StackPanel Spacing="4">
                <TextBlock
                    Foreground="{StaticResource TextSecondaryBrush}"
                    FontSize="11"
                    Text="Loading..."
                    Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibilityConverter}}" />
                <TextBlock
                    Foreground="{StaticResource TextSecondaryBrush}"
                    Text="{Binding StatusMessage}"
                    FontSize="11"
                    TextWrapping="Wrap"
                    Visibility="{Binding StatusMessage, Converter={StaticResource StringToVisibilityConverter}}" />
                <TextBlock
                    Foreground="{StaticResource TextSecondaryBrush}"
                    FontSize="11"
                    Text="Choose a template from the header. Edit, export and import from the right."
                    Visibility="{Binding IsEditMode, Converter={StaticResource InvertedBoolToVisibilityConverter}}" />
                <TextBlock
                    Foreground="{StaticResource TextSecondaryBrush}"
                    FontSize="11"
                    Text="Edit mode enabled. Use the top-right tick to save or the cancel button to discard."
                    Visibility="{Binding IsEditMode, Converter={StaticResource BoolToVisibilityConverter}}" />
                <TextBlock
                    Foreground="{StaticResource TextSecondaryBrush}"
                    FontSize="11"
                    Text="Create and save a Master Data template under Templates to see columns here."
                    TextWrapping="Wrap"
                    Visibility="{Binding ShowNoTemplateHint, Converter={StaticResource BoolToVisibilityConverter}}" />
                <TextBlock
                    Foreground="{StaticResource TextSecondaryBrush}"
                    FontSize="11"
                    Text="No tenant database is configured. Complete setup with a valid organization and database connection."
                    TextWrapping="Wrap"
                    Visibility="{Binding ShowNoDatabaseHint, Converter={StaticResource BoolToVisibilityConverter}}" />
            </StackPanel>
        </StackPanel>

        <!-- Spreadsheet host -->
        <ContentControl
            x:Name="SpreadsheetHost"
            Grid.Row="2"
            Grid.Column="0"
            Margin="0,4,0,0"
            HorizontalContentAlignment="Stretch"
            VerticalContentAlignment="Stretch" />

        <!-- Action overlay -->
        <Rectangle
            x:Name="ActionResultsOverlay"
            Grid.Column="0"
            Grid.RowSpan="3"
            Fill="Black"
            Opacity="0.3"
            Visibility="Collapsed"
            Tapped="OnActionOverlayTapped" />

        <!-- Action results slide panel -->
        <Border
            x:Name="ActionResultsPanel"
            Grid.Column="1"
            Grid.RowSpan="3"
            Width="320"
            Padding="14"
            Visibility="Collapsed"
            CornerRadius="20"
            Background="{StaticResource ElevatedCardBackgroundBrush}"
            BorderBrush="{StaticResource GlassStrongStrokeBrush}"
            BorderThickness="1">
            <Border.RenderTransform>
                <TranslateTransform x:Name="ActionResultsTransform" X="320" />
            </Border.RenderTransform>
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock
                    x:Name="ActionTitleText"
                    Grid.Row="0"
                    Grid.Column="0"
                    FontSize="14"
                    FontWeight="SemiBold" />
                <Button
                    Grid.Row="0"
                    Grid.Column="1"
                    Style="{StaticResource GhostButtonStyle}"
                    Content="âœ•"
                    FontSize="12"
                    Click="OnCloseActionPanelClick" />

                <TextBlock
                    x:Name="ActionCountText"
                    Grid.Row="1"
                    Grid.ColumnSpan="2"
                    Margin="0,4,0,10"
                    FontSize="11"
                    Foreground="{StaticResource TextSecondaryBrush}" />

                <ListView x:Name="ActionRowsListView" Grid.Row="2">
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <Border
                                Margin="0,0,0,6"
                                Padding="10"
                                Background="{StaticResource CardBackgroundBrush}"
                                BorderBrush="{StaticResource BorderDefaultBrush}"
                                BorderThickness="1"
                                CornerRadius="8" Translation="0,0,32">
                            <Border.Shadow><ThemeShadow/></Border.Shadow>
                            <StackPanel Spacing="3">
                                    <TextBlock
                                        Text="{Binding Title}"
                                        FontSize="12"
                                        FontWeight="SemiBold"
                                        TextWrapping="WrapWholeWords" />
                                    <ItemsControl ItemsSource="{Binding Lines}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding}" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" TextWrapping="WrapWholeWords" />
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </Grid>
        </Border>
    </Grid>
</Page>



