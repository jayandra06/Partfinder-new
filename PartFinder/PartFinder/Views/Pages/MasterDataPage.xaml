<Page
    x:Class="PartFinder.Views.Pages.MasterDataPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:components="using:PartFinder.Views.Components"
    xmlns:converters="using:PartFinder.Converters">
    <Page.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter" />
        <converters:InvertedBoolToVisibilityConverter x:Key="InvertedBoolToVisibilityConverter" />
        <converters:StringToVisibilityConverter x:Key="StringToVisibilityConverter" />
    </Page.Resources>
    <Grid x:Name="RootGrid" Padding="20" Background="{StaticResource PageBackgroundBrush}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="320" />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <components:PageHeader
            Grid.Row="0"
            Grid.Column="0"
            Title="Master Data"
            Subtitle="Select a template and review data. Switch to edit mode to update rows." />
        <Border Grid.Row="1" Grid.Column="0" Margin="0,12,0,0" Padding="12" Style="{StaticResource CardStyle}">
            <Grid RowSpacing="10" ColumnSpacing="12">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <ComboBox
                    Grid.Row="0"
                    MinWidth="280"
                    HorizontalAlignment="Left"
                    Style="{StaticResource StandardTextBoxStyle}"
                    DisplayMemberPath="Name"
                    ItemsSource="{Binding DataTemplates}"
                    PlaceholderText="Choose template…"
                    SelectedItem="{Binding SelectedDataTemplate, Mode=TwoWay}"
                    Visibility="{Binding ShowTemplatePicker, Converter={StaticResource BoolToVisibilityConverter}}" />
                <Button
                    Grid.Row="0"
                    Grid.Column="1"
                    Style="{StaticResource OutlinedButtonStyle}"
                    Visibility="{Binding IsEditMode, Converter={StaticResource InvertedBoolToVisibilityConverter}}"
                    Click="OnToggleEditModeClicked">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <FontIcon Glyph="&#xE70F;" />
                        <TextBlock Text="Edit" />
                    </StackPanel>
                </Button>
                <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="10">
                    <Button
                        Click="OnSaveGridClicked"
                        Style="{StaticResource PrimaryButtonStyle}"
                        Content="Save"
                        Visibility="{Binding IsEditMode, Converter={StaticResource BoolToVisibilityConverter}}" />
                    <Button
                        Click="OnCancelEditClicked"
                        Style="{StaticResource OutlinedButtonStyle}"
                        Content="Cancel"
                        Visibility="{Binding IsEditMode, Converter={StaticResource BoolToVisibilityConverter}}" />
                    <TextBlock
                        VerticalAlignment="Center"
                        Foreground="{StaticResource TextSecondaryBrush}"
                        Text="Loading..."
                        Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibilityConverter}}" />
                </StackPanel>
                <StackPanel Grid.Row="1" Grid.Column="1" Orientation="Horizontal" Spacing="8">
                    <Button Style="{StaticResource OutlinedButtonStyle}" Click="OnExportTemplateClicked" Content="Export Excel template" />
                    <Button Style="{StaticResource OutlinedButtonStyle}" Click="OnImportExcelClicked" Content="Import Excel data" />
                </StackPanel>
            </Grid>
        </Border>
        <StackPanel Grid.Row="2" Grid.Column="0" Margin="0,8,0,8" Spacing="6">
            <TextBlock
                Foreground="{StaticResource TextSecondaryBrush}"
                Text="{Binding StatusMessage}"
                TextWrapping="Wrap"
                Visibility="{Binding StatusMessage, Converter={StaticResource StringToVisibilityConverter}}" />
            <TextBlock
                Foreground="{StaticResource TextSecondaryBrush}"
                Text="Create and save a Master Data template under Templates to see columns here."
                TextWrapping="Wrap"
                Visibility="{Binding ShowNoTemplateHint, Converter={StaticResource BoolToVisibilityConverter}}" />
            <TextBlock
                Foreground="{StaticResource TextSecondaryBrush}"
                Text="No tenant database is configured. Complete setup with a valid organization and database connection."
                TextWrapping="Wrap"
                Visibility="{Binding ShowNoDatabaseHint, Converter={StaticResource BoolToVisibilityConverter}}" />
        </StackPanel>
        <ContentControl
            x:Name="SpreadsheetHost"
            Grid.Row="3"
            Grid.Column="0"
            Margin="0,8,0,0"
            HorizontalContentAlignment="Stretch"
            VerticalContentAlignment="Stretch" />
        <Rectangle
            x:Name="ActionResultsOverlay"
            Grid.Column="0"
            Grid.RowSpan="5"
            Fill="Black"
            Opacity="0.3"
            Visibility="Collapsed"
            Tapped="OnActionOverlayTapped" />
        <Border
            x:Name="ActionResultsPanel"
            Grid.Column="1"
            Grid.RowSpan="5"
            Width="320"
            Padding="16"
            Visibility="Collapsed"
            Style="{StaticResource ElevatedCardStyle}">
            <Border.RenderTransform>
                <TranslateTransform x:Name="ActionResultsTransform" X="320" />
            </Border.RenderTransform>
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock
                    x:Name="ActionTitleText"
                    Grid.Row="0"
                    Grid.Column="0"
                    Style="{StaticResource CardTitleStyle}" />
                <Button
                    Grid.Row="0"
                    Grid.Column="1"
                    Style="{StaticResource GhostButtonStyle}"
                    Content="✕"
                    Click="OnCloseActionPanelClick" />

                <TextBlock
                    x:Name="ActionCountText"
                    Grid.Row="1"
                    Grid.ColumnSpan="2"
                    Margin="0,6,0,12"
                    Style="{StaticResource CaptionStyle}" />

                <ListView x:Name="ActionRowsListView" Grid.Row="2">
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <Border
                                Margin="0,0,0,8"
                                Padding="10"
                                Style="{StaticResource CardStyle}">
                                <StackPanel Spacing="4">
                                    <TextBlock
                                        Text="{Binding Title}"
                                        FontWeight="SemiBold"
                                        TextWrapping="WrapWholeWords" />
                                    <ItemsControl ItemsSource="{Binding Lines}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding}" Style="{StaticResource CaptionStyle}" TextWrapping="WrapWholeWords" />
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </Grid>
        </Border>
    </Grid>
</Page>
