<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Style x:Key="AppCardBorderStyle" TargetType="Border">
        <Setter Property="Background" Value="{ThemeResource AppSurfaceBrush}" />
        <Setter Property="BorderBrush" Value="{ThemeResource AppBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="12" />
        <Setter Property="Padding" Value="{StaticResource CardPadding}" />
    </Style>

    <Style TargetType="Button">
        <Setter Property="CornerRadius" Value="10" />
        <Setter Property="Padding" Value="12,8" />
    </Style>

    <Style TargetType="TextBox">
        <Setter Property="CornerRadius" Value="10" />
    </Style>

    <Style TargetType="ComboBox">
        <Setter Property="CornerRadius" Value="10" />
    </Style>
</ResourceDictionary>
