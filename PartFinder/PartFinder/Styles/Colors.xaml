<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <ResourceDictionary.ThemeDictionaries>
        <ResourceDictionary x:Key="Default">
            <!-- Backgrounds -->
            <Color x:Key="PageBackgroundColor">#0A0E15</Color>
            <Color x:Key="CardBackgroundColor">#111A26</Color>
            <Color x:Key="ElevatedCardBackgroundColor">#172334</Color>
            <Color x:Key="InputBackgroundColor">#0B1320</Color>
            <Color x:Key="GridHeaderBackgroundColor">#1C2A3E</Color>
            <Color x:Key="GridRowAltBackgroundColor">#0E1623</Color>

            <!-- Interactive states -->
            <Color x:Key="RowHoverBackgroundColor">#1A2738</Color>
            <Color x:Key="RowSelectedBackgroundColor">#1E3858</Color>
            <Color x:Key="RowSelectedBorderColor">#2F7FD2</Color>

            <!-- Accent -->
            <Color x:Key="AccentPrimaryColor">#1F7AE0</Color>
            <Color x:Key="AccentHoverColor">#2D88ED</Color>
            <Color x:Key="AccentPressedColor">#155DAF</Color>

            <!-- Text -->
            <Color x:Key="TextPrimaryColor">#EAF2FF</Color>
            <Color x:Key="TextSecondaryColor">#AAB8CA</Color>
            <Color x:Key="TextTertiaryColor">#7B8DA8</Color>
            <Color x:Key="TextOnAccentColor">#FFFFFF</Color>

            <!-- Borders -->
            <Color x:Key="BorderDefaultColor">#2A3D58</Color>
            <Color x:Key="BorderHoverColor">#3D567A</Color>
            <Color x:Key="BorderFocusColor">#A4C9FF</Color>

            <!-- Semantic -->
            <Color x:Key="SuccessColor">#2ABD8F</Color>
            <Color x:Key="WarningColor">#FFB781</Color>
            <Color x:Key="DangerColor">#FFB4AB</Color>
            <Color x:Key="InfoColor">#A4C9FF</Color>

            <!-- Navigation -->
            <Color x:Key="NavBackgroundColor">#0B111B</Color>
            <Color x:Key="NavItemHoverColor">#162234</Color>
            <Color x:Key="NavItemSelectedColor">#1A2B43</Color>
            <Color x:Key="NavItemSelectedBorderColor">#2F7FD2</Color>

            <!-- Backward-compatible aliases -->
            <Color x:Key="AppPrimaryColor">#185FA5</Color>
            <Color x:Key="AppBackgroundColor">#131313</Color>
            <Color x:Key="AppSurfaceColor">#201F1F</Color>
            <Color x:Key="AppTextColor">#E5E2E1</Color>
            <Color x:Key="AppBorderColor">#424751</Color>
            <Color x:Key="AppSkeletonColor">#26262626</Color>
            <Color x:Key="AppSubtleTextColor">#C2C6D2</Color>
        </ResourceDictionary>

        <ResourceDictionary x:Key="Light">
            <!-- Backgrounds -->
            <Color x:Key="PageBackgroundColor">#F3F4F6</Color>
            <Color x:Key="CardBackgroundColor">#FFFFFF</Color>
            <Color x:Key="ElevatedCardBackgroundColor">#F9FAFB</Color>
            <Color x:Key="InputBackgroundColor">#FFFFFF</Color>
            <Color x:Key="GridHeaderBackgroundColor">#E5E7EB</Color>
            <Color x:Key="GridRowAltBackgroundColor">#F9FAFB</Color>

            <!-- Interactive states -->
            <Color x:Key="RowHoverBackgroundColor">#E5E7EB</Color>
            <Color x:Key="RowSelectedBackgroundColor">#E0F2FE</Color>
            <Color x:Key="RowSelectedBorderColor">#1F7AE0</Color>

            <!-- Accent -->
            <Color x:Key="AccentPrimaryColor">#1F7AE0</Color>
            <Color x:Key="AccentHoverColor">#155DAF</Color>
            <Color x:Key="AccentPressedColor">#0E3F78</Color>

            <!-- Text -->
            <Color x:Key="TextPrimaryColor">#1F2937</Color>
            <Color x:Key="TextSecondaryColor">#4B5563</Color>
            <Color x:Key="TextTertiaryColor">#9CA3AF</Color>
            <Color x:Key="TextOnAccentColor">#FFFFFF</Color>

            <!-- Borders -->
            <Color x:Key="BorderDefaultColor">#D1D5DB</Color>
            <Color x:Key="BorderHoverColor">#9CA3AF</Color>
            <Color x:Key="BorderFocusColor">#1F7AE0</Color>

            <!-- Semantic -->
            <Color x:Key="SuccessColor">#10B981</Color>
            <Color x:Key="WarningColor">#F59E0B</Color>
            <Color x:Key="DangerColor">#EF4444</Color>
            <Color x:Key="InfoColor">#3B82F6</Color>

            <!-- Navigation -->
            <Color x:Key="NavBackgroundColor">#F9FAFB</Color>
            <Color x:Key="NavItemHoverColor">#E5E7EB</Color>
            <Color x:Key="NavItemSelectedColor">#E0F2FE</Color>
            <Color x:Key="NavItemSelectedBorderColor">#1F7AE0</Color>

            <!-- Backward-compatible aliases -->
            <Color x:Key="AppPrimaryColor">#1F7AE0</Color>
            <Color x:Key="AppBackgroundColor">#F3F4F6</Color>
            <Color x:Key="AppSurfaceColor">#FFFFFF</Color>
            <Color x:Key="AppTextColor">#1F2937</Color>
            <Color x:Key="AppBorderColor">#D1D5DB</Color>
            <Color x:Key="AppSkeletonColor">#E5E7EB</Color>
            <Color x:Key="AppSubtleTextColor">#4B5563</Color>
        </ResourceDictionary>
    </ResourceDictionary.ThemeDictionaries>

    <!-- Global Brushes referencing ThemeResources -->
    <SolidColorBrush x:Key="PageBackgroundBrush" Color="{ThemeResource PageBackgroundColor}" />
    <SolidColorBrush x:Key="CardBackgroundBrush" Color="{ThemeResource CardBackgroundColor}" />
    <SolidColorBrush x:Key="ElevatedCardBackgroundBrush" Color="{ThemeResource ElevatedCardBackgroundColor}" />
    <SolidColorBrush x:Key="InputBackgroundBrush" Color="{ThemeResource InputBackgroundColor}" />
    <SolidColorBrush x:Key="GridHeaderBackgroundBrush" Color="{ThemeResource GridHeaderBackgroundColor}" />
    <SolidColorBrush x:Key="GridRowAltBackgroundBrush" Color="{ThemeResource GridRowAltBackgroundColor}" />
    <SolidColorBrush x:Key="RowHoverBackgroundBrush" Color="{ThemeResource RowHoverBackgroundColor}" />
    <SolidColorBrush x:Key="RowSelectedBackgroundBrush" Color="{ThemeResource RowSelectedBackgroundColor}" />
    <SolidColorBrush x:Key="RowSelectedBorderBrush" Color="{ThemeResource RowSelectedBorderColor}" />
    <SolidColorBrush x:Key="AccentPrimaryBrush" Color="{ThemeResource AccentPrimaryColor}" />
    <SolidColorBrush x:Key="AccentHoverBrush" Color="{ThemeResource AccentHoverColor}" />
    <SolidColorBrush x:Key="AccentPressedBrush" Color="{ThemeResource AccentPressedColor}" />
    <SolidColorBrush x:Key="TextPrimaryBrush" Color="{ThemeResource TextPrimaryColor}" />
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="{ThemeResource TextSecondaryColor}" />
    <SolidColorBrush x:Key="TextTertiaryBrush" Color="{ThemeResource TextTertiaryColor}" />
    <SolidColorBrush x:Key="TextOnAccentBrush" Color="{ThemeResource TextOnAccentColor}" />
    <SolidColorBrush x:Key="BorderDefaultBrush" Color="{ThemeResource BorderDefaultColor}" />
    <SolidColorBrush x:Key="BorderHoverBrush" Color="{ThemeResource BorderHoverColor}" />
    <SolidColorBrush x:Key="BorderFocusBrush" Color="{ThemeResource BorderFocusColor}" />
    <SolidColorBrush x:Key="SuccessBrush" Color="{ThemeResource SuccessColor}" />
    <SolidColorBrush x:Key="WarningBrush" Color="{ThemeResource WarningColor}" />
    <SolidColorBrush x:Key="DangerBrush" Color="{ThemeResource DangerColor}" />
    <SolidColorBrush x:Key="InfoBrush" Color="{ThemeResource InfoColor}" />
    <SolidColorBrush x:Key="NavBackgroundBrush" Color="{ThemeResource NavBackgroundColor}" />
    <SolidColorBrush x:Key="NavItemHoverBrush" Color="{ThemeResource NavItemHoverColor}" />
    <SolidColorBrush x:Key="NavItemSelectedBrush" Color="{ThemeResource NavItemSelectedColor}" />
    <SolidColorBrush x:Key="NavItemSelectedBorderBrush" Color="{ThemeResource NavItemSelectedBorderColor}" />

    <!-- Backward-compatible aliases -->
    <SolidColorBrush x:Key="AppBackgroundBrush" Color="{ThemeResource AppBackgroundColor}" />
    <SolidColorBrush x:Key="AppSidebarBrush" Color="{ThemeResource NavBackgroundColor}" />
    <SolidColorBrush x:Key="AppSurfaceBrush" Color="{ThemeResource AppSurfaceColor}" />
    <SolidColorBrush x:Key="AppBorderBrush" Color="{ThemeResource AppBorderColor}" />
    <SolidColorBrush x:Key="AppSubtleTextBrush" Color="{ThemeResource AppSubtleTextColor}" />
    <SolidColorBrush x:Key="AppSuccessBrush" Color="{ThemeResource SuccessColor}" />
    <SolidColorBrush x:Key="AppSkeletonBrush" Color="{ThemeResource AppSkeletonColor}" />
</ResourceDictionary>
