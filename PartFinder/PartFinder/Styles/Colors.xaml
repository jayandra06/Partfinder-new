<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!-- Backgrounds -->
    <Color x:Key="PageBackgroundColor">#0A0E15</Color>
    <Color x:Key="CardBackgroundColor">#111A26</Color>
    <Color x:Key="ElevatedCardBackgroundColor">#172334</Color>
    <Color x:Key="InputBackgroundColor">#0B1320</Color>
    <Color x:Key="GridHeaderBackgroundColor">#1C2A3E</Color>
    <Color x:Key="GridRowAltBackgroundColor">#0E1623</Color>

    <!-- Interactive states -->
    <Color x:Key="RowHoverBackgroundColor">#1A2738</Color>
    <Color x:Key="RowSelectedBackgroundColor">#1E3858</Color>
    <Color x:Key="RowSelectedBorderColor">#2F7FD2</Color>

    <!-- Accent -->
    <Color x:Key="AccentPrimaryColor">#1F7AE0</Color>
    <Color x:Key="AccentHoverColor">#2D88ED</Color>
    <Color x:Key="AccentPressedColor">#155DAF</Color>

    <!-- Text -->
    <Color x:Key="TextPrimaryColor">#EAF2FF</Color>
    <Color x:Key="TextSecondaryColor">#AAB8CA</Color>
    <Color x:Key="TextTertiaryColor">#7B8DA8</Color>
    <Color x:Key="TextOnAccentColor">#FFFFFF</Color>

    <!-- Borders -->
    <Color x:Key="BorderDefaultColor">#2A3D58</Color>
    <Color x:Key="BorderHoverColor">#3D567A</Color>
    <Color x:Key="BorderFocusColor">#A4C9FF</Color>

    <!-- Semantic -->
    <Color x:Key="SuccessColor">#2ABD8F</Color>
    <Color x:Key="WarningColor">#FFB781</Color>
    <Color x:Key="DangerColor">#FFB4AB</Color>
    <Color x:Key="InfoColor">#A4C9FF</Color>

    <!-- Navigation -->
    <Color x:Key="NavBackgroundColor">#0B111B</Color>
    <Color x:Key="NavItemHoverColor">#162234</Color>
    <Color x:Key="NavItemSelectedColor">#1A2B43</Color>
    <Color x:Key="NavItemSelectedBorderColor">#2F7FD2</Color>

    <SolidColorBrush x:Key="PageBackgroundBrush" Color="{StaticResource PageBackgroundColor}" />
    <SolidColorBrush x:Key="CardBackgroundBrush" Color="{StaticResource CardBackgroundColor}" />
    <SolidColorBrush x:Key="ElevatedCardBackgroundBrush" Color="{StaticResource ElevatedCardBackgroundColor}" />
    <SolidColorBrush x:Key="InputBackgroundBrush" Color="{StaticResource InputBackgroundColor}" />
    <SolidColorBrush x:Key="GridHeaderBackgroundBrush" Color="{StaticResource GridHeaderBackgroundColor}" />
    <SolidColorBrush x:Key="GridRowAltBackgroundBrush" Color="{StaticResource GridRowAltBackgroundColor}" />
    <SolidColorBrush x:Key="RowHoverBackgroundBrush" Color="{StaticResource RowHoverBackgroundColor}" />
    <SolidColorBrush x:Key="RowSelectedBackgroundBrush" Color="{StaticResource RowSelectedBackgroundColor}" />
    <SolidColorBrush x:Key="RowSelectedBorderBrush" Color="{StaticResource RowSelectedBorderColor}" />
    <SolidColorBrush x:Key="AccentPrimaryBrush" Color="{StaticResource AccentPrimaryColor}" />
    <SolidColorBrush x:Key="AccentHoverBrush" Color="{StaticResource AccentHoverColor}" />
    <SolidColorBrush x:Key="AccentPressedBrush" Color="{StaticResource AccentPressedColor}" />
    <SolidColorBrush x:Key="TextPrimaryBrush" Color="{StaticResource TextPrimaryColor}" />
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="{StaticResource TextSecondaryColor}" />
    <SolidColorBrush x:Key="TextTertiaryBrush" Color="{StaticResource TextTertiaryColor}" />
    <SolidColorBrush x:Key="TextOnAccentBrush" Color="{StaticResource TextOnAccentColor}" />
    <SolidColorBrush x:Key="BorderDefaultBrush" Color="{StaticResource BorderDefaultColor}" />
    <SolidColorBrush x:Key="BorderHoverBrush" Color="{StaticResource BorderHoverColor}" />
    <SolidColorBrush x:Key="BorderFocusBrush" Color="{StaticResource BorderFocusColor}" />
    <SolidColorBrush x:Key="SuccessBrush" Color="{StaticResource SuccessColor}" />
    <SolidColorBrush x:Key="WarningBrush" Color="{StaticResource WarningColor}" />
    <SolidColorBrush x:Key="DangerBrush" Color="{StaticResource DangerColor}" />
    <SolidColorBrush x:Key="InfoBrush" Color="{StaticResource InfoColor}" />
    <SolidColorBrush x:Key="NavBackgroundBrush" Color="{StaticResource NavBackgroundColor}" />
    <SolidColorBrush x:Key="NavItemHoverBrush" Color="{StaticResource NavItemHoverColor}" />
    <SolidColorBrush x:Key="NavItemSelectedBrush" Color="{StaticResource NavItemSelectedColor}" />
    <SolidColorBrush x:Key="NavItemSelectedBorderBrush" Color="{StaticResource NavItemSelectedBorderColor}" />

    <!-- Backward-compatible aliases -->
    <Color x:Key="AppPrimaryColor">#185FA5</Color>
    <Color x:Key="AppBackgroundColor">#131313</Color>
    <Color x:Key="AppSurfaceColor">#201F1F</Color>
    <Color x:Key="AppTextColor">#E5E2E1</Color>
    <Color x:Key="AppBorderColor">#424751</Color>
    <Color x:Key="AppSkeletonColor">#26262626</Color>
    <Color x:Key="AppSubtleTextColor">#C2C6D2</Color>
    <SolidColorBrush x:Key="AppBackgroundBrush" Color="{StaticResource AppBackgroundColor}" />
    <SolidColorBrush x:Key="AppSidebarBrush" Color="{StaticResource NavBackgroundColor}" />
    <SolidColorBrush x:Key="AppSurfaceBrush" Color="{StaticResource AppSurfaceColor}" />
    <SolidColorBrush x:Key="AppBorderBrush" Color="{StaticResource AppBorderColor}" />
    <SolidColorBrush x:Key="AppSubtleTextBrush" Color="{StaticResource AppSubtleTextColor}" />
    <SolidColorBrush x:Key="AppSuccessBrush" Color="{StaticResource SuccessColor}" />
    <SolidColorBrush x:Key="AppSkeletonBrush" Color="{StaticResource AppSkeletonColor}" />
</ResourceDictionary>
