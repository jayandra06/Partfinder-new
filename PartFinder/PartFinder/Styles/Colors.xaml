<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ResourceDictionary.ThemeDictionaries>
        <ResourceDictionary x:Key="Default">
            <Color x:Key="AppPrimaryColor">#3B82F6</Color>
            <Color x:Key="AppBackgroundColor">#F8FAFC</Color>
            <Color x:Key="AppSurfaceColor">#FFFFFF</Color>
            <Color x:Key="AppTextColor">#0F172A</Color>
            <Color x:Key="AppBorderColor">#1F000000</Color>
            <Color x:Key="AppSkeletonColor">#16000000</Color>
            <Color x:Key="AppSubtleTextColor">#6B7280</Color>
        </ResourceDictionary>
        <ResourceDictionary x:Key="Dark">
            <Color x:Key="AppPrimaryColor">#60A5FA</Color>
            <Color x:Key="AppBackgroundColor">#0F172A</Color>
            <Color x:Key="AppSurfaceColor">#111827</Color>
            <Color x:Key="AppTextColor">#E5E7EB</Color>
            <Color x:Key="AppBorderColor">#33FFFFFF</Color>
            <Color x:Key="AppSkeletonColor">#30FFFFFF</Color>
            <Color x:Key="AppSubtleTextColor">#9CA3AF</Color>
        </ResourceDictionary>
    </ResourceDictionary.ThemeDictionaries>

    <SolidColorBrush x:Key="AppBackgroundBrush" Color="{ThemeResource AppBackgroundColor}" />
    <SolidColorBrush x:Key="AppSidebarBrush" Color="{ThemeResource AppSurfaceColor}" />
    <SolidColorBrush x:Key="AppSurfaceBrush" Color="{ThemeResource AppSurfaceColor}" />
    <SolidColorBrush x:Key="AppBorderBrush" Color="{ThemeResource AppBorderColor}" />
    <SolidColorBrush x:Key="AppSubtleTextBrush" Color="{ThemeResource AppSubtleTextColor}" />
    <SolidColorBrush x:Key="AppSuccessBrush" Color="#16A34A" />
    <SolidColorBrush x:Key="AppSkeletonBrush" Color="{ThemeResource AppSkeletonColor}" />
</ResourceDictionary>
